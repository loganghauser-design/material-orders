<% var _cur = (typeof current !== 'undefined') ? current : 'office'; %>
<div class="dash-switch">
  <span class="dsw-label">Home view</span>
  <div class="dsw-group">
    <button type="button" class="dsw <%= _cur==='office'?'on':'' %>" onclick="setDash('office')">Office</button>
    <button type="button" class="dsw <%= _cur==='permits'?'on':'' %>" onclick="setDash('permits')">Permits</button>
  </div>
</div>
<script>
function setDash(d){
  fetch('/dashboard-pref',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({dashboard:d})})
    .then(function(r){return r.json();})
    .then(function(){ location.href='/'; })
    .catch(function(){ location.href='/'; });
}
</script>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deliveries — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css?v=3">
</head>
<body>
<%- include('_nav', { active: 'deliveries' }) %>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem">
    <h1>Upcoming Deliveries</h1>
    <button type="button" class="btn btn-ghost" id="confirmTomBtn" onclick="confirmTomorrow(this)" title="Email every vendor with a delivery due tomorrow, inside their existing thread: 'confirming tomorrow's delivery — please reply to confirm.' Never sends twice for the same delivery.">✉ Confirm tomorrow's deliveries</button>
  </div>
  <script>
  async function confirmTomorrow(btn) {
    if (!confirm("Email each vendor with a delivery due tomorrow, asking them to confirm it's on track?")) return;
    btn.disabled = true; btn.textContent = '⏳ Sending…';
    try {
      const r = await fetch('/deliveries/confirm-tomorrow', { method: 'POST' });
      const d = await r.json();
      if (d.ok) btn.textContent = d.due === 0 ? '✓ Nothing due tomorrow' : '✓ ' + d.sent + ' sent · ' + d.alreadySent + ' already asked · ' + d.noThread + ' no vendor thread';
      else { alert(d.error || 'Failed'); btn.disabled = false; btn.textContent = "✉ Confirm tomorrow's deliveries"; }
    } catch (e) { alert('Failed — try again'); btn.disabled = false; btn.textContent = "✉ Confirm tomorrow's deliveries"; }
  }
  </script>

  <!-- Ferguson tracker: shipment + appliance-delivery alerts matched to projects.
       Split into what's COMING UP (scheduled dates still ahead) and recent history. -->
  <%
    var _fu = (typeof ferguson !== 'undefined' && ferguson) || [];
    // Parse "Monday, July 6th 2026 between 07:30 AM - 10:30 AM" → a Date for sorting/bucketing
    var MONTHS = { january:0, february:1, march:2, april:3, may:4, june:5, july:6, august:7, september:8, october:9, november:10, december:11 };
    function schedDate(s) {
      var m = String(s || '').match(/(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{1,2})\w*,?\s+(\d{4})/i);
      return m ? new Date(Number(m[3]), MONTHS[m[1].toLowerCase()], Number(m[2])) : null;
    }
    var _today = new Date(); _today.setHours(0, 0, 0, 0);
    // One row per ORDER: scheduled → out → delivered collapse together (matched by order number)
    var byOrder = {};
    _fu.forEach(function (f) { var k = f.order_base || ('row-' + f.id); (byOrder[k] = byOrder[k] || []).push(f); });
    var RANK = { delivered: 3, out: 2, scheduled: 1 };
    var merged = Object.keys(byOrder).map(function (k) {
      byOrder[k].forEach(function (x) { x._ekind = (x.kind === 'scheduled' && x.auto_done_at) ? 'delivered' : x.kind; });   // window passed = delivered
      var g = byOrder[k].slice().sort(function (a, b) { return (RANK[b._ekind] || 0) - (RANK[a._ekind] || 0); });
      var main = g[0];
      main._journey = g.slice(1).map(function (x) {
        var label = x.kind === 'out' ? 'out for delivery' : x.kind === 'scheduled' ? 'scheduled' : 'delivered';
        return label + ' ' + new Date(x.created_at).toLocaleDateString('en-US', { month: 'numeric', day: 'numeric' });
      });
      g.forEach(function (x) {   // borrow richer fields from siblings (the scheduled email carries the item list)
        if (!main.items && x.items) main.items = x.items;
        if (!main.applied && x.applied) main.applied = x.applied;
        if (!main.po && x.po) main.po = x.po;
      });
      return main;
    });
    var upcoming = [], history = [];
    merged.forEach(function (f) {
      f._sched = f.kind === 'scheduled' ? schedDate(f.scheduled_for) : null;
      if (f._ekind === 'scheduled' && f._sched && f._sched >= _today) upcoming.push(f); else history.push(f);
    });
    upcoming.sort(function (a, b) { return a._sched - b._sched; });   // soonest delivery first
    function fuRow(f, dim) { %>
      <div style="display:flex;align-items:baseline;gap:.55rem;flex-wrap:wrap;font-size:.87rem;<%= dim ? 'opacity:.65' : '' %>">
        <% var ek = f._ekind || f.kind;
           var tag = ek === 'delivered' ? ['DELIVERED', '#16a34a', '#fff'] : ek === 'out' ? ['OUT FOR DELIVERY', '#d97706', '#fff'] : (dim ? ['WAS SCHEDULED', '#e6e6e6', '#555'] : ['SCHEDULED', '#e0e7ff', '#3730a3']); %>
        <span style="background:<%= tag[1] %>;color:<%= tag[2] %>;font-size:.66rem;font-weight:800;padding:2px 9px;border-radius:9px;white-space:nowrap"><%= tag[0] %></span>
        <strong><%= f.project_address || f.address || 'unmatched' %></strong>
        <% if (f.po) { %><span style="color:var(--muted);font-size:.8rem"><%= f.po %></span><% } %>
        <% if (f.kind === 'scheduled' && f.scheduled_for) { %><span style="color:<%= dim ? 'var(--muted)' : '#3730a3' %>;font-size:.82rem;font-weight:600">🗓 <%= f.scheduled_for %></span><% } %>
        <% if (f.tracking) { %><a href="https://www.ups.com/track?tracknum=<%= f.tracking %>" target="_blank" rel="noopener" style="font-size:.78rem" title="Track on UPS">UPS ↗</a><% } %>
        <% if (f.applied) { %><span style="color:#16a34a;font-size:.76rem;font-weight:700">✔ <%= f.applied %></span><% } %>
        <% if (f.order_base) { %><span style="color:var(--muted);font-size:.72rem" title="Ferguson order number — links all updates for this shipment">#<%= f.order_base %></span><% } %>
        <span style="color:var(--muted);font-size:.74rem;margin-left:auto" title="When Ferguson's email arrived">✉ <%= new Date(f.created_at).toLocaleDateString('en-US', { month: 'numeric', day: 'numeric' }) %></span>
      </div>
      <% if (f._journey && f._journey.length) { %><div style="color:var(--muted);font-size:.72rem;margin:-.1rem 0 .1rem 4.2rem;<%= dim ? 'opacity:.65' : '' %>">↳ <%= f._journey.join(' · ') %></div><% } %>
      <% if (f.items) { %><div style="color:var(--muted);font-size:.74rem;margin:-.1rem 0 .15rem 4.2rem;<%= dim ? 'opacity:.65' : '' %>"><%= f.items.slice(0, 150) %><%= f.items.length > 150 ? '…' : '' %></div><% } %>
    <% } %>
  <% if (_fu.length) { %>
  <div class="card" style="max-width:none;margin-bottom:1.3rem;padding:1rem 1.3rem">
    <div style="display:flex;align-items:baseline;gap:.6rem;flex-wrap:wrap;margin-bottom:.6rem">
      <strong style="font-size:1rem">📦 Ferguson tracker</strong>
      <span style="color:var(--muted);font-size:.8rem">🗓 = when the delivery happens · ✉ = when Ferguson's email arrived</span>
    </div>
    <% if (upcoming.length) { %>
    <div style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:#3730a3;margin-bottom:.35rem">Coming up</div>
    <div style="display:flex;flex-direction:column;gap:.35rem;margin-bottom:.9rem">
      <% upcoming.forEach(function (f) { fuRow(f, false); }) %>
    </div>
    <% } %>
    <% if (history.length) { %>
    <div style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);margin-bottom:.35rem">Recent activity</div>
    <div style="display:flex;flex-direction:column;gap:.35rem">
      <% history.forEach(function (f) { fuRow(f, (f._ekind || f.kind) === 'scheduled'); }) %>
    </div>
    <% } %>
  </div>
  <% } %>

  <%
    const today = new Date(); today.setHours(0,0,0,0);
    const weekEnd = new Date(today); weekEnd.setDate(weekEnd.getDate() + 7);
    // Windows: bucket by the END of the window for overdue, the START for upcoming.
    const dStart = i => new Date(i.delivery_date);
    const dEnd = i => i.delivery_date_end ? new Date(i.delivery_date_end) : new Date(i.delivery_date);
    const overdue = items.filter(i => dEnd(i) < today);
    const thisWeek = items.filter(i => dEnd(i) >= today && dStart(i) <= weekEnd);
    const later = items.filter(i => dStart(i) > weekEnd);
  %>

  <% [['⚠ Overdue', overdue, 'var(--danger)'], ['This Week', thisWeek, 'var(--accent)'], ['Upcoming', later, 'var(--muted)']].forEach(([title, list, color]) => { %>
    <h2 style="font-size:1rem;font-weight:700;margin:1.5rem 0 .6rem;color:<%= color %>"><%= title %> (<%= list.length %>)</h2>
    <% if (!list.length) { %>
      <div style="color:var(--muted);font-size:.85rem;margin-bottom:.5rem">None.</div>
    <% } else { %>
      <div class="table-wrap" style="margin-bottom:1rem">
        <table>
          <thead><tr><th>Delivery Date</th><th>Project</th><th>Material</th><th>Status</th></tr></thead>
          <tbody>
            <% list.forEach(i => { %>
              <tr>
                <% var _s = new Date(i.delivery_date); var _e = i.delivery_date_end ? new Date(i.delivery_date_end) : null; %>
                <td><strong><%= _s.toLocaleDateString(undefined,{weekday:'short',month:'short',day:'numeric'}) %><% if (_e) { %> – <%= _e.toLocaleDateString(undefined,{month:'short',day:'numeric'}) %><% } %></strong><% if (_e) { %> <span style="color:var(--muted);font-size:.7rem">window</span><% } %></td>
                <td><a href="/projects/<%= i.project_id %>"><%= i.address %></a></td>
                <td><%= i.item_name %> <span style="color:var(--muted);font-size:.75rem">(<%= i.item_code %>)</span></td>
                <td><span class="badge badge-in_progress"><%= i.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  <% }) %>

  <% if (!items.length) { %>
    <div style="color:var(--muted);margin-top:1rem">No materials have delivery dates set yet. Add delivery dates on a project's materials to see them here.</div>
  <% } %>
</div>
</body>
</html>

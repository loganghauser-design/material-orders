<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Suppliers — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<%- include('_nav', { active: 'suppliers' }) %>

<div class="container">
  <div class="page-header"><h1>Suppliers</h1></div>
  <p style="color:var(--muted);font-size:.9rem;margin-bottom:1.5rem;max-width:720px">
    Your supplier directory. Set the contact name and email for each material once — when you click <strong>Request Quote</strong> on that material in any project, the RFQ auto-fills the right supplier from here.
    <br><strong>Multiple contacts?</strong> Put several emails separated by commas (e.g. <code>sales@vendor.com, rep@vendor.com</code>) and the RFQ goes to all of them in one email.
  </p>

  <% if (saved) { %>
    <div class="error-msg" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a">✓ Suppliers saved.</div>
  <% } %>

  <div class="card" style="max-width:900px">
    <form method="POST" action="/suppliers">
      <div class="supplier-row supplier-head">
        <div class="supplier-label">Material</div>
        <div>Supplier Name</div>
        <div>Supplier Email</div>
      </div>
      <% STAGES.forEach(stage => { %>
        <div class="supplier-stage"><%= stage.name %></div>
        <% stage.items.forEach(item => {
          const sup = suppliers[item.code] || {};
        %>
          <div class="supplier-row">
            <div class="supplier-label"><span class="supplier-code"><%= item.code %></span> <%= item.name %></div>
            <input type="text" name="name_<%= item.code %>" value="<%= sup.name || '' %>" placeholder="Supplier name">
            <input type="text" name="email_<%= item.code %>" value="<%= sup.email || '' %>" placeholder="email@vendor.com, second@vendor.com">
          </div>
        <% }) %>
      <% }) %>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save suppliers</button>
      </div>
    </form>
  </div>
</div>
</body>
</html>

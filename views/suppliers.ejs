<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Suppliers — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<%- include('_nav', { active: 'suppliers' }) %>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem">
    <h1>Suppliers</h1>
    <a href="/suppliers/finder" class="btn btn-primary" title="Search Google county-wide for lumber yards, supply houses, showrooms…">🔎 Find suppliers</a>
  </div>
  <p style="color:var(--muted);font-size:.9rem;margin-bottom:1.5rem;max-width:720px">
    Your supplier directory. Set the contact name and email for each material once — when you click <strong>Request Quote</strong> on that material in any project, the RFQ auto-fills the right supplier from here.
    <br><strong>Multiple contacts?</strong> Put several emails separated by commas (e.g. <code>sales@vendor.com, rep@vendor.com</code>) and the RFQ goes to all of them in one email.
  </p>

  <% if (saved) { %>
    <div class="error-msg" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a">✓ Suppliers saved.</div>
  <% } %>

  <div class="card" style="max-width:900px">
    <form method="POST" action="/suppliers">
      <div class="supplier-row supplier-head">
        <div class="supplier-label">Material</div>
        <div>Supplier Name</div>
        <div>Supplier Email</div>
      </div>
      <% STAGES.forEach(stage => { %>
        <div class="supplier-stage"><%= stage.name %></div>
        <% stage.items.forEach(item => {
          const sup = suppliers[item.code] || {};
        %>
          <div class="supplier-row">
            <div class="supplier-label"><span class="supplier-code"><%= item.code %></span> <%= item.name %></div>
            <input type="text" name="name_<%= item.code %>" value="<%= sup.name || '' %>" placeholder="Supplier name">
            <input type="text" name="email_<%= item.code %>" value="<%= sup.email || '' %>" placeholder="email@vendor.com, second@vendor.com">
          </div>
        <% }) %>
      <% }) %>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save suppliers</button>
      </div>
    </form>
  </div>

  <!-- Supplier Directory (candidates from the Supplier Finder) -->
  <div class="card" style="max-width:1100px;margin-top:1.5rem;padding:0;overflow:hidden">
    <div style="padding:1.2rem 1.4rem .6rem">
      <h2 style="font-size:1.1rem;font-weight:700;margin:0 0 .25rem">📇 Supplier Directory <span style="color:var(--muted);font-weight:400;font-size:.9rem">(<%= (directory || []).length %>)</span></h2>
      <p style="color:var(--muted);font-size:.85rem;margin:0 0 .6rem">Candidates found with the 🔎 Supplier Finder. Call or check the website for their email, add it here — then copy your pick into a material slot above so RFQs auto-fill.</p>
    </div>
    <% if (!(directory || []).length) { %>
      <div style="padding:0 1.4rem 1.3rem;color:var(--muted);font-size:.88rem">Nothing here yet — hit <strong>🔎 Find suppliers</strong> to search county-wide.</div>
    <% } else { %>
    <table style="width:100%;border-collapse:collapse;font-size:.86rem">
      <thead><tr>
        <th style="text-align:left;padding:.5rem .8rem;font-size:.7rem;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)">Category</th>
        <th style="text-align:left;padding:.5rem .8rem;font-size:.7rem;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)">Supplier</th>
        <th style="text-align:left;padding:.5rem .8rem;font-size:.7rem;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)">Phone</th>
        <th style="text-align:left;padding:.5rem .8rem;font-size:.7rem;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)">Email</th>
        <th style="text-align:left;padding:.5rem .8rem;font-size:.7rem;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border)">Links</th>
        <th></th>
      </tr></thead>
      <tbody>
        <% directory.forEach(d => { %>
        <tr id="dir_<%= d.id %>" style="border-bottom:1px solid var(--border)">
          <td style="padding:.55rem .8rem"><span style="background:#eef0f4;color:#555;font-size:.72rem;font-weight:700;padding:2px 9px;border-radius:9px;white-space:nowrap"><%= d.category || '—' %></span></td>
          <td style="padding:.55rem .8rem">
            <strong><%= d.name %></strong>
            <% if (d.rating) { %> <span style="color:#b45309;font-size:.78rem"><%= d.rating %></span><% } %>
            <% if (d.address) { %><div style="color:var(--muted);font-size:.76rem"><%= d.address %></div><% } %>
          </td>
          <td style="padding:.55rem .8rem;white-space:nowrap"><% if (d.phone) { %><a href="tel:<%= String(d.phone).replace(/[^0-9]/g,'') %>"><%= d.phone %></a><% } %></td>
          <td style="padding:.55rem .8rem"><input type="email" value="<%= d.email || '' %>" placeholder="add email…" onchange="dirField(<%= d.id %>, 'email', this.value)" style="width:190px;padding:4px 7px;border:1px solid var(--border);border-radius:7px;font-size:.82rem"></td>
          <td style="padding:.55rem .8rem;white-space:nowrap"><% if (d.website) { %><a href="<%= d.website %>" target="_blank" rel="noopener" title="Website">🌐</a><% } %></td>
          <td style="padding:.55rem .8rem"><button type="button" onclick="dirDelete(<%= d.id %>, '<%= (d.name||'').replace(/'/g, "\\'") %>')" style="background:none;border:none;color:#cc2222;cursor:pointer;font-size:.82rem">✕</button></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<div id="toast" class="toast"></div>
<script>
async function dirField(id, field, value) {
  try {
    const r = await fetch('/suppliers/directory/' + id + '/field', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams({ [field]: value }) });
    const d = await r.json();
    showToast(d.ok ? 'Saved' : 'Could not save', !d.ok);
  } catch (e) { showToast('Could not save', true); }
}
async function dirDelete(id, name) {
  if (!confirm('Remove "' + name + '" from the directory?')) return;
  try {
    const r = await fetch('/suppliers/directory/' + id + '/delete', { method:'POST' });
    const d = await r.json();
    if (d.ok) { const tr = document.getElementById('dir_' + id); if (tr) tr.remove(); showToast('Removed'); }
    else showToast('Could not remove', true);
  } catch (e) { showToast('Could not remove', true); }
}
function showToast(msg, err) {
  const t = document.getElementById('toast');
  if (!t) return alert(msg);
  t.textContent = msg; t.className = 'toast show' + (err ? ' error' : '');
  setTimeout(() => t.className = 'toast', 1800);
}
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Item Catalog — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .cat-table { width:100%; border-collapse:collapse; font-size:.85rem; }
    .cat-table th { text-align:left; padding:.45rem .6rem; font-size:.68rem; text-transform:uppercase; color:var(--muted); border-bottom:1px solid var(--border); position:sticky; top:0; background:var(--surface); }
    .cat-table td { padding:.42rem .6rem; border-bottom:1px solid var(--border); }
    .cat-code { font-weight:700; white-space:nowrap; }
    .cat-bucket { background:#eef0f4; color:#555; font-size:.7rem; font-weight:700; padding:2px 8px; border-radius:8px; white-space:nowrap; }
    .cat-model { font-family:monospace; font-size:.8rem; white-space:nowrap; }
    .cat-sec td { background:#15161a; color:#fff; font-size:.85rem; font-weight:800; padding:.5rem .7rem; letter-spacing:.02em; }
    .cat-sub td { background:var(--bg); color:var(--text); font-size:.76rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; padding:.4rem .7rem; }
  </style>
</head>
<body>
<%- include('_nav', { active: 'catalog' }) %>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem">
    <h1>Master Finish Schedule <span style="color:var(--muted);font-weight:400;font-size:1rem">(<%= items.length %> items)</span></h1>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
      <a class="btn btn-ghost" href="https://docs.google.com/spreadsheets/d/1wSZb3PVq1rrE3PTyraBSUHVp-tYtOHpMaeAOO2l0_40/edit" target="_blank" rel="noopener" title="Open the source Google Sheet — edits there, then sync here">📄 Open the sheet ↗</a>
      <button type="button" class="btn btn-ghost" id="catSync" onclick="catSync(this)" title="Re-read the Buildoly Master Finish Schedule sheet (read-only)">↻ Sync from sheet</button>
    </div>
  </div>
  <p style="color:var(--muted);font-size:.88rem;margin-bottom:1rem;max-width:760px">
    Every item from the <strong>Master Finish Schedule</strong>: prod code → model #, stage bucket, supplier, cost.
    Finish schedules reference these prod codes per project; Ferguson's delivery emails reference the model #s — this catalog joins them.
  </p>

  <div class="card" style="max-width:none;padding:0;overflow:hidden">
    <div style="padding:.8rem 1rem">
      <input type="search" id="catSearch" placeholder="Search prod code, model #, name, brand, supplier…" style="width:100%;max-width:460px;font:inherit;font-size:.9rem;padding:.45rem .7rem;border:1px solid var(--border);border-radius:9px" oninput="catFilter()">
    </div>
    <div style="max-height:74vh;overflow:auto">
      <table class="cat-table">
        <thead><tr><th>Prod code</th><th>Bucket</th><th>Item</th><th>Model #</th><th>Finish</th><th>Supplier</th><th>Cost</th><th>Link</th></tr></thead>
        <tbody>
          <% var curSec = null, curSub = null; %>
          <% items.forEach(function (it) { %>
            <% if (it.section !== curSec) { curSec = it.section; curSub = null; %>
              <tr class="cat-sec"><td colspan="8"><%= curSec || 'Other' %></td></tr>
            <% } %>
            <% if (it.subsection !== curSub) { curSub = it.subsection; %>
              <% if (curSub) { %><tr class="cat-sub"><td colspan="8"><%= curSub %></td></tr><% } %>
            <% } %>
          <tr data-s="<%= [it.prod_code, it.item_role, it.brand, it.product_name, it.model_no, it.supplier, it.category_code, it.section, it.subsection].filter(Boolean).join(' ').toLowerCase() %>">
            <td class="cat-code"><%= it.prod_code %></td>
            <td><span class="cat-bucket"><%= it.category_code %></span></td>
            <td><strong><%= it.item_role %></strong><div style="color:var(--muted);font-size:.76rem"><%= [it.brand, it.product_name].filter(Boolean).join(' — ').slice(0, 90) %></div></td>
            <td class="cat-model"><%= it.model_no || '—' %></td>
            <td style="font-size:.78rem;color:var(--muted)"><%= it.finish || '' %></td>
            <td style="font-size:.8rem"><%= it.supplier || '—' %></td>
            <td style="white-space:nowrap"><%= it.cost != null ? '$' + Number(it.cost).toLocaleString('en-US', { minimumFractionDigits: 2 }) : '' %></td>
            <td style="text-align:center"><% if (it.item_url) { %><a href="<%= it.item_url %>" target="_blank" rel="noopener" title="Open product page" style="text-decoration:none;font-size:.9rem">🔗</a><% } %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function catFilter() {
  const q = document.getElementById('catSearch').value.toLowerCase().trim();
  document.querySelectorAll('tr[data-s]').forEach(function (r) { r.style.display = !q || r.dataset.s.includes(q) ? '' : 'none'; });
  // Hide section/subsection dividers that have no visible items beneath them
  const all = Array.prototype.slice.call(document.querySelectorAll('.cat-table tbody tr'));
  all.forEach(function (tr, i) {
    if (!tr.classList.contains('cat-sec') && !tr.classList.contains('cat-sub')) return;
    let any = false;
    for (let j = i + 1; j < all.length; j++) {
      if (tr.classList.contains('cat-sec') && all[j].classList.contains('cat-sec')) break;
      if (tr.classList.contains('cat-sub') && (all[j].classList.contains('cat-sub') || all[j].classList.contains('cat-sec'))) break;
      if (all[j].dataset.s && all[j].style.display !== 'none') { any = true; break; }
    }
    tr.style.display = any ? '' : 'none';
  });
}
async function catSync(btn) {
  btn.disabled = true; btn.textContent = '⏳ Reading the sheet…';
  try {
    const r = await fetch('/catalog/sync', { method: 'POST' });
    const d = await r.json();
    if (d.ok) { btn.textContent = '✓ ' + d.upserted + ' items synced'; setTimeout(function () { location.reload(); }, 900); }
    else { alert(d.error || 'Sync failed'); btn.disabled = false; btn.textContent = '↻ Sync from master sheet'; }
  } catch (e) { alert('Sync failed'); btn.disabled = false; btn.textContent = '↻ Sync from master sheet'; }
}
</script>
</body>
</html>

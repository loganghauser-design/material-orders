<%
  const oQty = officeItems.reduce((s,i)=>s+(i.qty||0),0);
  const oDeliv = officeItems.reduce((s,i)=>s+(i.delivered||0),0);
  const oOffice = officeItems.reduce((s,i)=>s+(i.inOffice||0),0);
  const wHeld = warehouseItems.reduce((s,i)=>s+(i.held||0),0);
  const wDeliv = warehouseItems.reduce((s,i)=>s+(i.delivered||0),0);
  const wWare = warehouseItems.reduce((s,i)=>s+(i.inWarehouse||0),0);
%>
<% if (error) { %>
  <div class="error-msg">Couldn't read one or more schedules right now: <%= error %></div>
<% } %>
<% if (typeof sheetFails !== 'undefined' && sheetFails && sheetFails.length) { %>
  <div style="background:#fff7e6;border:1px solid #f0d9a8;color:#7a5b00;border-radius:10px;padding:.7rem .9rem;margin-bottom:1rem;font-size:.86rem">
    ⚠ <strong><%= sheetFails.length %> project schedule<%= sheetFails.length>1?'s':'' %> couldn't be read</strong>, so their stock isn't counted here. Fix the finish-schedule link/tab for:
    <ul style="margin:.4rem 0 0;padding-left:1.2rem">
      <% sheetFails.forEach(function(f){ %><li><%= f.address %> <span style="color:#a58a4a">— <%= /not be found|not found|404/i.test(f.error) ? 'link is dead or not shared' : (/parse range|Fin Sched/i.test(f.error) ? 'no “Fin Sched” tab' : f.error) %></span></li><% }) %>
    </ul>
  </div>
<% } %>

<!-- ───────────── OFFICE STOCK ───────────── -->
<div class="sec-head">
  <div>
    <h2 class="sec-title">🏢 Office Stock</h2>
    <div class="sec-sub">Jedco items &amp; range hoods — bulk stock you buy and keep in the office.</div>
  </div>
  <div class="sec-totals">
    <span>On hand <b><%= oQty %></b></span>
    <span class="col-deliv">Delivered <b id="tot-odeliv"><%= oDeliv %></b></span>
    <span class="col-office">In office <b id="tot-ooffice"><%= oOffice %></b></span>
  </div>
</div>
<div class="card" style="padding:0;overflow:hidden;max-width:none">
  <% if (!officeItems.length) { %>
    <div style="padding:1.4rem;color:var(--muted)">
      No office items yet. Click <strong>+ Add Office Item</strong> to add one (e.g. <em>S-VG01</em> or a range hood) with the qty you bought.
    </div>
  <% } else { %>
  <table class="inv-table">
    <thead>
      <tr>
        <th class="l">Item</th>
        <th class="l">Model # / Code</th>
        <th>On hand</th>
        <th>In use</th>
        <th>Available</th>
        <th class="grp-sep">Delivered</th>
        <th>In office</th>
        <th style="width:1rem"></th>
      </tr>
    </thead>
    <tbody>
      <%
        officeItems.forEach(it => {
          const cls = it.available < 0 ? 'avail-neg' : (it.available === 0 ? 'avail-low' : 'avail-pos');
          const hasAlloc = it.byProject && it.byProject.length; %>
        <tr class="item-row" data-id="<%= it.id %>">
          <td class="l">
            <span class="caret" id="car_<%= it.id %>" onclick="toggleAlloc('<%= it.id %>')"><%= hasAlloc ? '▸' : '' %></span>
            <strong class="<%= hasAlloc ? 'name-toggle' : '' %>" <% if (hasAlloc) { %>onclick="toggleAlloc('<%= it.id %>')"<% } %>><%= it.name %></strong>
          </td>
          <td class="l"><% if (it.product) { %><span class="prod-tag"><%= it.product %></span><% } else { %><span style="color:var(--muted)">—</span><% } %><% if (it.productName) { %><br><span style="color:var(--muted);font-size:.78rem"><%= it.productName %></span><% } %></td>
          <td class="num">
            <div style="display:inline-flex;align-items:center;gap:4px">
              <button class="qty-step" onclick="stepQty(this,-1)" title="Remove one">−</button>
              <input class="qty-input" type="number" min="0" value="<%= it.qty %>" data-inuse="<%= it.inUse %>" data-deliv="<%= it.delivered %>" onchange="saveQty(this)">
              <button class="qty-step" onclick="stepQty(this,1)" title="Add one">+</button>
              <span class="saved-tick">✓</span>
            </div>
          </td>
          <td class="num" style="color:var(--muted)"><%= it.inUse %></td>
          <td class="num avail-cell <%= cls %>"><%= it.available %><% if (it.available < 0) { %> ⚠<% } %></td>
          <td class="num col-deliv grp-sep deliv-cell"><%= it.delivered %></td>
          <td class="num col-office office-cell" style="<%= it.inOffice < 0 ? 'color:#cc2222' : '' %>"><%= it.inOffice %><% if (it.inOffice < 0) { %> ⚠<% } %></td>
          <td><button class="link-danger" title="Delete" onclick="deleteItem(<%= it.id %>, '<%= it.name.replace(/'/g, "\\'") %>')">✕</button></td>
        </tr>
        <% if (hasAlloc) { %>
        <tr id="det_<%= it.id %>" style="display:none">
          <td class="detail-cell" colspan="8">
            <table class="alloc">
              <thead><tr><th>Project (allocated to)</th><th>Allocated</th><th>Delivered (type a number)</th></tr></thead>
              <tbody>
                <% it.byProject.forEach(p => { %>
                  <tr>
                    <td><%= p.address %></td>
                    <td>×<%= p.qty %></td>
                    <td>
                      <button type="button" class="qstep" onclick="bumpDeliv(this,-1)">−</button>
                      <input type="number" class="deliv-qty" min="0" max="<%= p.qty %>" value="<%= p.delivered %>"
                        data-pid="<%= p.projectId %>" data-keys="<%= p.itemKeys.join('||') %>" data-max="<%= p.qty %>"
                        data-prev="<%= p.delivered %>" data-loc="office" data-itemid="<%= it.id %>"
                        onchange="saveDeliveredQty(this)">
                      <button type="button" class="qstep" onclick="bumpDeliv(this,1)">+</button>
                      <span style="color:var(--muted)">of <%= p.qty %></span>
                      <button type="button" class="mini-btn" onclick="setDeliv(this,'all')">All</button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </td>
        </tr>
        <% } %>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<p style="color:var(--muted);font-size:.78rem;margin-top:.7rem;max-width:820px">
  <strong>On hand</strong> = qty you bought · <strong>In use</strong> = allocated to projects · <strong>Available</strong> = On hand − In use ·
  <strong>Delivered</strong> = pulled out &amp; dropped at jobs · <strong>In office</strong> = On hand − Delivered (still on your shelf).
</p>

<!-- ───────────── WAREHOUSE STOCK ───────────── -->
<div class="sec-head" style="margin-top:2.2rem">
  <div>
    <h2 class="sec-title">🏭 Warehouse Stock</h2>
    <div class="sec-sub">Vanities, closets, cabinets, decking, LVP, pantry, linen… built per job and held in the warehouse until delivered. Auto-listed from your schedules.</div>
  </div>
  <div class="sec-totals">
    <span>Held <b><%= wHeld %></b></span>
    <span class="col-deliv">Delivered <b id="tot-wdeliv"><%= wDeliv %></b></span>
    <span class="col-ware">In warehouse <b id="tot-wware"><%= wWare %></b></span>
  </div>
</div>
<div class="card" style="padding:0;overflow:hidden;max-width:none">
  <% if (!warehouseItems.length) { %>
    <div style="padding:1.4rem;color:var(--muted)">No warehouse items found in your linked schedules yet.</div>
  <% } else { %>
  <table class="inv-table">
    <thead>
      <tr>
        <th class="l">Item</th>
        <th class="l">Code</th>
        <th>Held</th>
        <th class="grp-sep">Delivered</th>
        <th>In warehouse</th>
      </tr>
    </thead>
    <tbody>
      <%
        warehouseItems.forEach((it, wi) => {
          const wid = 'wh' + wi;
          const hasAlloc = it.byProject && it.byProject.length; %>
        <tr class="item-row" data-id="<%= wid %>">
          <td class="l">
            <span class="caret" id="car_<%= wid %>" onclick="toggleAlloc('<%= wid %>')"><%= hasAlloc ? '▸' : '' %></span>
            <strong class="<%= hasAlloc ? 'name-toggle' : '' %>" <% if (hasAlloc) { %>onclick="toggleAlloc('<%= wid %>')"<% } %>><%= it.name %></strong>
          </td>
          <td class="l"><% if (it.code) { %><span class="prod-tag"><%= it.code %></span><% } else { %><span style="color:var(--muted)">—</span><% } %></td>
          <td class="num"><%= it.held %></td>
          <td class="num col-deliv grp-sep deliv-cell"><%= it.delivered %></td>
          <td class="num col-ware ware-cell" style="<%= it.inWarehouse < 0 ? 'color:#cc2222' : '' %>"><%= it.inWarehouse %><% if (it.inWarehouse < 0) { %> ⚠<% } %></td>
        </tr>
        <% if (hasAlloc) { %>
        <tr id="det_<%= wid %>" style="display:none">
          <td class="detail-cell" colspan="5">
            <table class="alloc">
              <thead><tr><th>Project (allocated to)</th><th>Allocated</th><th>Delivered (type a number)</th></tr></thead>
              <tbody>
                <% it.byProject.forEach(p => { %>
                  <tr>
                    <td><%= p.address %></td>
                    <td>×<%= p.qty %></td>
                    <td>
                      <button type="button" class="qstep" onclick="bumpDeliv(this,-1)">−</button>
                      <input type="number" class="deliv-qty" min="0" max="<%= p.qty %>" value="<%= p.delivered %>"
                        data-pid="<%= p.projectId %>" data-keys="<%= p.itemKeys.join('||') %>" data-max="<%= p.qty %>"
                        data-prev="<%= p.delivered %>" data-loc="ware" data-itemid="<%= wid %>"
                        onchange="saveDeliveredQty(this)">
                      <button type="button" class="qstep" onclick="bumpDeliv(this,1)">+</button>
                      <span style="color:var(--muted)">of <%= p.qty %></span>
                      <button type="button" class="mini-btn" onclick="setDeliv(this,'all')">All</button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </td>
        </tr>
        <% } %>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<p style="color:var(--muted);font-size:.78rem;margin-top:.7rem;max-width:820px">
  <strong>Held</strong> = total allocated across jobs · <strong>Delivered</strong> = pulled from the warehouse &amp; dropped at jobs ·
  <strong>In warehouse</strong> = Held − Delivered (still sitting in the warehouse).
</p>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buildoly</title>
  <link rel="icon" href="/icon.svg">
  <meta name="theme-color" content="#000000">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      background: #000; color: #fff; padding: 1.5rem;
      -webkit-font-smoothing: antialiased;
    }
    .login-wrap { width: 100%; max-width: 360px; }
    .brand { text-align: center; margin-bottom: 2.6rem; }
    .logo {
      font-weight: 800; font-size: 3.4rem; line-height: 1; letter-spacing: -.04em; color: #fff;
    }
    .logo .dot { /* keep the wordmark tight + lowercase like the mark */ }
    .tagline {
      margin-top: .7rem; font-size: .72rem; text-transform: uppercase; letter-spacing: .32em;
      color: #777; padding-left: .32em;
    }
    form { display: flex; flex-direction: column; gap: 1.1rem; }
    .field label {
      display: block; font-size: .7rem; text-transform: uppercase; letter-spacing: .12em;
      color: #888; margin-bottom: .5rem;
    }
    .field input {
      width: 100%; padding: .9rem 1rem; font-size: 1rem;
      background: #0d0d0d; border: 1px solid #2a2a2a; border-radius: 12px; color: #fff;
      transition: border-color .15s, background .15s;
    }
    .field input::placeholder { color: #555; }
    .field input:focus { outline: none; border-color: #fff; background: #141414; }
    .signin-btn {
      margin-top: .5rem; width: 100%; padding: .95rem; font-size: 1rem; font-weight: 700;
      background: #fff; color: #000; border: none; border-radius: 12px; cursor: pointer;
      transition: opacity .15s, transform .1s; letter-spacing: .01em;
    }
    .signin-btn:hover { opacity: .88; }
    .signin-btn:active { transform: translateY(1px); }
    .error-msg {
      background: #160d0d; border: 1px solid #4a1d1d; color: #ff7a7a;
      padding: .75rem 1rem; border-radius: 11px; font-size: .88rem; margin-bottom: 1.4rem; text-align: center;
    }
    .foot { text-align: center; margin-top: 2rem; font-size: .72rem; letter-spacing: .04em; color: #555; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="brand">
      <div class="logo">buildoly</div>
      <div class="tagline">Office</div>
    </div>

    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <form method="POST" action="/login">
      <div class="field">
        <label for="username">Username or email</label>
        <input type="text" id="username" name="username" autocomplete="username" required autofocus placeholder="name or @buildoly.com email">
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
      </div>
      <button type="submit" class="signin-btn">Sign in</button>
    </form>

    <div class="foot">🔒 Secure sign-in</div>
  </div>
</body>
</html>

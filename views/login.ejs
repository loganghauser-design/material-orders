<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buildoly</title>
  <link rel="icon" href="/icon.svg">
  <meta name="theme-color" content="#f4f4f5">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      background: #f3f3f5; color: #111; padding: 1.5rem; -webkit-font-smoothing: antialiased;
    }
    .card {
      width: 100%; max-width: 380px; background: #fff; border: 1px solid #ececef;
      border-radius: 20px; box-shadow: 0 12px 40px rgba(0,0,0,.07); padding: 2.6rem 2.1rem 2.2rem;
    }
    .brand { text-align: center; margin-bottom: 2rem; }
    .badge {
      width: 56px; height: 56px; border-radius: 15px; background: #000; margin: 0 auto .9rem;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 800; font-size: 1.9rem; letter-spacing: -.04em;
    }
    .logo-img { height: 38px; display: block; margin: 0 auto; }
    .tagline { margin-top: .6rem; font-size: .7rem; text-transform: uppercase; letter-spacing: .3em; color: #9a9aa2; padding-left: .3em; }
    form { display: flex; flex-direction: column; gap: 1rem; }
    .field label { display: block; font-size: .7rem; text-transform: uppercase; letter-spacing: .1em; color: #8a8a92; margin-bottom: .45rem; }
    .field input {
      width: 100%; padding: .85rem 1rem; font-size: 1rem; color: #111;
      background: #f7f7f9; border: 1.5px solid #e6e6ea; border-radius: 12px; transition: border-color .15s, background .15s;
    }
    .field input::placeholder { color: #b3b3ba; }
    .field input:focus { outline: none; border-color: #111; background: #fff; }
    .signin-btn {
      margin-top: .5rem; width: 100%; padding: .9rem; font-size: 1rem; font-weight: 700;
      background: #111; color: #fff; border: none; border-radius: 12px; cursor: pointer; transition: background .15s, transform .1s;
    }
    .signin-btn:hover { background: #000; }
    .signin-btn:active { transform: translateY(1px); }
    .error-msg { background: #fdf0f0; border: 1px solid #f3c9c9; color: #c0392b; padding: .7rem 1rem; border-radius: 11px; font-size: .88rem; margin-bottom: 1.3rem; text-align: center; }
    .foot { text-align: center; margin-top: 1.7rem; font-size: .72rem; letter-spacing: .03em; color: #aaa; }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">
      <img src="/logo.png" alt="buildoly" class="logo-img">
      <div class="tagline">Supply</div>
    </div>

    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <form method="POST" action="/login">
      <div class="field">
        <label for="username">Username or email</label>
        <input type="text" id="username" name="username" autocomplete="username" required autofocus placeholder="name or @buildoly.com email">
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
      </div>
      <button type="submit" class="signin-btn">Sign in</button>
    </form>

    <div class="foot">🔒 Secure sign-in</div>
  </div>
</body>
</html>

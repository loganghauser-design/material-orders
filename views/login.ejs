<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in — Buildoly Office</title>
  <link rel="icon" href="/icon.svg">
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
      font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
      background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 45%, #3b82f6 100%);
      padding: 1.25rem;
    }
    .login-bg-deco { position: fixed; inset: 0; overflow: hidden; z-index: 0; pointer-events: none; }
    .login-bg-deco span { position: absolute; border-radius: 50%; background: rgba(255,255,255,.07); }
    .login-bg-deco span:nth-child(1) { width: 340px; height: 340px; top: -120px; right: -80px; }
    .login-bg-deco span:nth-child(2) { width: 220px; height: 220px; bottom: -90px; left: -60px; background: rgba(255,255,255,.05); }
    .login-bg-deco span:nth-child(3) { width: 140px; height: 140px; top: 55%; right: 8%; background: rgba(255,255,255,.04); }

    .card {
      position: relative; z-index: 1;
      width: 100%; max-width: 410px;
      background: #fff; border-radius: 20px;
      box-shadow: 0 24px 60px rgba(0,0,0,.28);
      padding: 2.5rem 2.25rem 2.25rem;
    }
    .brand { display: flex; flex-direction: column; align-items: center; text-align: center; margin-bottom: 1.6rem; }
    .logo {
      width: 60px; height: 60px; border-radius: 16px; margin-bottom: .9rem;
      background: linear-gradient(135deg, #2563eb, #1e40af);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.7rem; font-weight: 800; color: #fff;
      box-shadow: 0 8px 20px rgba(37,99,235,.4);
    }
    .brand h1 { margin: 0; font-size: 1.55rem; font-weight: 800; color: #0f172a; letter-spacing: -.02em; }
    .brand p { margin: .35rem 0 0; font-size: .92rem; color: #64748b; line-height: 1.4; max-width: 280px; }

    .error-msg {
      background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c;
      padding: .65rem .85rem; border-radius: 10px; font-size: .88rem; margin-bottom: 1.1rem;
    }

    .field { margin-bottom: 1.1rem; }
    .field label { display: block; font-size: .82rem; font-weight: 600; color: #334155; margin-bottom: .4rem; }
    .field input {
      width: 100%; padding: .8rem .9rem; font-size: 1rem;
      border: 1.5px solid #e2e8f0; border-radius: 11px; background: #f8fafc;
      color: #0f172a; transition: border-color .15s, box-shadow .15s, background .15s;
    }
    .field input::placeholder { color: #94a3b8; }
    .field input:focus {
      outline: none; border-color: #2563eb; background: #fff;
      box-shadow: 0 0 0 4px rgba(37,99,235,.13);
    }

    .signin-btn {
      width: 100%; margin-top: .4rem; padding: .85rem; font-size: 1.02rem; font-weight: 700;
      color: #fff; border: none; border-radius: 11px; cursor: pointer;
      background: linear-gradient(135deg, #2563eb, #1d4ed8);
      box-shadow: 0 8px 18px rgba(37,99,235,.35);
      transition: transform .12s, box-shadow .12s, filter .12s;
    }
    .signin-btn:hover { filter: brightness(1.05); box-shadow: 0 10px 22px rgba(37,99,235,.45); transform: translateY(-1px); }
    .signin-btn:active { transform: translateY(0); box-shadow: 0 5px 12px rgba(37,99,235,.35); }

    .foot { text-align: center; margin-top: 1.4rem; font-size: .78rem; color: #94a3b8; }
  </style>
</head>
<body>
  <div class="login-bg-deco"><span></span><span></span><span></span></div>

  <div class="card">
    <div class="brand">
      <div class="logo">B</div>
      <h1>Buildoly Office</h1>
      <p>Sign in to manage your orders &amp; delivery schedule.</p>
    </div>

    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <form method="POST" action="/login">
      <div class="field">
        <label for="username">Username or email</label>
        <input type="text" id="username" name="username" autocomplete="username" required autofocus placeholder="your name or @buildoly.com email">
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
      </div>
      <button type="submit" class="signin-btn">Sign in</button>
    </form>

    <div class="foot">🔒 Buildoly · secure sign-in</div>
  </div>
</body>
</html>

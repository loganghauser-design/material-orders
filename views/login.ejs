<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Orders</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<div class="login-wrap">
  <div class="login-card">
    <h1>Buildoly Office</h1>
    <p>Sign in to manage your orders and delivery schedule.</p>
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
    <form method="POST" action="/login">
      <div class="form-group">
        <label for="username">Username or email</label>
        <input type="text" id="username" name="username" autocomplete="username" required autofocus placeholder="admin username, or your @buildoly.com email">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn btn-primary">Sign in</button>
    </form>
  </div>
</div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Report Issue — <%= project.address %></title>
  <link rel="stylesheet" href="/css/app.css?v=3">
  <style>
    .wrap { max-width:640px; margin:0 auto; padding:0 0 7rem; }
    .rhead { position:sticky; top:0; background:var(--bg); padding:.8rem 1rem; border-bottom:1px solid var(--border); z-index:5; }
    .rhead a { text-decoration:none; color:var(--muted); font-size:.9rem; }
    .rhead h1 { font-size:1.15rem; margin:.3rem 0 0; }
    .fld { margin:1rem; }
    .fld label { display:block; font-weight:700; font-size:.92rem; margin-bottom:.35rem; }
    .fld .hint { font-weight:400; color:var(--muted); }
    .fld input, .fld textarea, .fld select { width:100%; font-size:1rem; padding:.7rem .75rem; border:1px solid var(--border); border-radius:10px; background:var(--surface); font-family:inherit; }
    .fld textarea { min-height:110px; }
    .photo-btn { display:flex; align-items:center; justify-content:center; gap:.5rem; width:100%; padding:1.1rem; border:2px dashed var(--border); border-radius:12px; background:var(--surface); font-size:1rem; font-weight:600; color:#4f8ef7; cursor:pointer; }
    #photoInput { display:none; }
    #preview { margin-top:.7rem; max-width:100%; border-radius:10px; display:none; }
    .submitbar { position:fixed; left:0; right:0; bottom:0; padding:.8rem 1rem calc(.8rem + env(safe-area-inset-bottom)); background:var(--bg); border-top:1px solid var(--border); }
    .submitbar button { width:100%; font-size:1.05rem; padding:.9rem; border:none; border-radius:11px; background:#e0531f; color:#fff; font-weight:700; cursor:pointer; }
    .errbox { margin:1rem; padding:.7rem .9rem; border-radius:9px; background:rgba(204,34,34,.1); color:#cc2222; font-size:.9rem; }
    .addbtn { background:#e0531f; color:#fff; border:none; border-radius:9px; padding:0 1.1rem; font-weight:700; font-size:.95rem; cursor:pointer; }
    .chips { display:flex; flex-wrap:wrap; gap:.4rem; }
    .ichip { background:#fde2e1; color:#b91c1c; font-weight:600; font-size:.88rem; padding:.4rem .8rem; border-radius:14px; display:inline-flex; align-items:center; gap:.5rem; }
    .ichip .x { cursor:pointer; font-weight:800; }
    .chips-empty { color:var(--muted); font-size:.85rem; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="rhead">
    <a href="/my">← My projects</a>
    <h1>⚠️ Report a material issue</h1>
    <div style="color:var(--muted);font-size:.88rem;margin-top:.15rem"><%= project.address %></div>
  </div>

  <% if (err) { %><div class="errbox">Add a description, pick an item, or attach a photo.</div><% } %>

  <form method="POST" action="/my/issue/<%= project.id %>" enctype="multipart/form-data" id="issueForm">
    <div class="fld">
      <label>Which item(s) have the issue? <span class="hint">(add as many as you need)</span></label>
      <div style="display:flex;gap:.4rem">
      <select id="materialPicker" style="flex:1">
        <option value="">— pick an item —</option>
        <% STAGES.forEach(stage => { stage.items.forEach(it => {
             var mats = (typeof byCode !== 'undefined' && byCode[it.code]) ? byCode[it.code] : []; %>
          <optgroup label="<%= it.code %> · <%= it.name %>">
            <% if (mats.length) { var _seen = {}; mats.forEach(function(m){ var _lbl = m.room ? (m.room + ' — ' + m.name) : m.name; var _k = _lbl.trim().toLowerCase(); if (!_k || _seen[_k]) return; _seen[_k] = 1; %>
              <option value="<%= it.code %>" data-label="<%= _lbl %>"><%= _lbl %></option>
            <% }) } else { %>
              <option value="<%= it.code %>" data-label=""><%= it.name %> (whole section)</option>
            <% } %>
          </optgroup>
        <% }) }) %>
      </select>
      <button type="button" class="addbtn" onclick="addPickedItem()">Add</button>
      </div>
      <div style="display:flex;gap:.4rem;margin-top:.5rem">
        <input type="text" id="customItem" placeholder="…or type a custom item" style="flex:1" onkeydown="if(event.key==='Enter'){event.preventDefault();addCustomItem();}">
        <button type="button" class="addbtn" onclick="addCustomItem()">Add</button>
      </div>
      <div id="selectedItems" class="chips" style="margin-top:.7rem"></div>
      <input type="hidden" name="selected" id="selectedJson" value="[]">
    </div>

    <div class="fld">
      <label>What's the issue?</label>
      <textarea name="note" placeholder="Describe the problem — damaged, wrong size, missing parts, etc."></textarea>
    </div>

    <div class="fld">
      <label>Photo <span class="hint">(optional)</span></label>
      <label class="photo-btn" for="photoInput">📷 Take / choose a photo</label>
      <input type="file" id="photoInput" name="photo" accept="image/*" capture="environment" onchange="showPreview(this)">
      <img id="preview" alt="preview">
    </div>
  </form>
</div>

<div class="submitbar">
  <button type="submit" form="issueForm">Send to office</button>
</div>

<script>
let selIssues = [];   // [{code, label}]
function escH(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function addItemChip(code, label) {
  label = (label || '').trim();
  if (!label) return;
  if (selIssues.some(s => (s.label||'').toLowerCase() === label.toLowerCase() && s.code === code)) return;
  selIssues.push({ code: code || '', label });
  renderChips();
}
function addPickedItem() {
  const sel = document.getElementById('materialPicker');
  const opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value && !(opt.dataset && opt.dataset.label)) return;
  addItemChip(opt.value || '', (opt.dataset && opt.dataset.label) || opt.text);
  sel.selectedIndex = 0;
}
function addCustomItem() {
  const inp = document.getElementById('customItem');
  addItemChip('', inp.value);
  inp.value = '';
}
function removeItem(i) { selIssues.splice(i, 1); renderChips(); }
function renderChips() {
  const box = document.getElementById('selectedItems');
  box.innerHTML = selIssues.length
    ? selIssues.map((s, i) => `<span class="ichip">${escH(s.label)} <span class="x" onclick="removeItem(${i})">✕</span></span>`).join('')
    : '<span class="chips-empty">No items added yet — pick one above and tap Add.</span>';
  document.getElementById('selectedJson').value = JSON.stringify(selIssues);
}
renderChips();
function showPreview(input) {
  const f = input.files && input.files[0];
  const img = document.getElementById('preview');
  if (!f) { img.style.display = 'none'; return; }
  img.src = URL.createObjectURL(f);
  img.style.display = 'block';
}
</script>
</body>
</html>

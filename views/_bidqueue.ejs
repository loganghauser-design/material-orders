<%
  // Bid review queue — shared by the Subs page ("Needs decision" tab) and the Bids page.
  // Locals: pendingBids, bidProjects, composeAvailable (true on the Subs page).
  var _pbs = (typeof pendingBids !== 'undefined' && pendingBids) || [];
  var _bps = (typeof bidProjects !== 'undefined' && bidProjects) || [];
  var _hasCompose = (typeof composeAvailable !== 'undefined') && composeAvailable;
  function _bqMoney(a) { return a == null ? '—' : '$' + Number(a).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
%>
<style>
  .bq-card { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:1rem 1.2rem; margin-bottom:.9rem; box-shadow:0 1px 4px rgba(0,0,0,.04); }
  .bq-top { display:flex; align-items:baseline; gap:.7rem; flex-wrap:wrap; }
  .bq-co { font-size:1.05rem; font-weight:800; }
  .bq-amt { font-size:1.15rem; font-weight:800; color:#111; margin-left:auto; white-space:nowrap; }
  .bq-trade { background:#eef0f4; color:#555; font-size:.72rem; font-weight:700; padding:2px 9px; border-radius:9px; white-space:nowrap; }
  .bq-meta { color:var(--muted); font-size:.78rem; }
  .bq-checks { display:flex; gap:.45rem .6rem; flex-wrap:wrap; margin:.6rem 0 .7rem; }
  .bq-chk { font-size:.78rem; font-weight:600; padding:.28rem .65rem; border-radius:9px; border:1px solid; white-space:nowrap; }
  .bq-ok { background:#e7f6ec; border-color:#b9e4c8; color:#176b3a; }
  .bq-warn { background:#fff4dd; border-color:#f0d9a6; color:#8a6100; }
  .bq-bad { background:#fdeaea; border-color:#f3bcbc; color:#b42323; }
  .bq-none { background:var(--bg); border-color:var(--border); color:var(--muted); }
  .bq-proj { font-size:.84rem; margin-top:.35rem; }
  .bq-proj select { font-size:.8rem; padding:.22rem .35rem; border:1px solid var(--border); border-radius:8px; max-width:230px; }
  .bq-actions { display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.4rem; }
  .bq-actions .bqa { font:inherit; font-size:.85rem; font-weight:700; padding:.45rem .95rem; border-radius:9px; border:1px solid var(--border); background:var(--bg); cursor:pointer; }
  .bqa-approve { background:#16a34a !important; border-color:#16a34a !important; color:#fff; }
  .bqa-approve:hover { background:#15803d !important; }
  .bqa-pass:hover { background:#eee; }
  .bq-empty { background:var(--surface); border:1px dashed var(--border); border-radius:14px; padding:1.1rem 1.3rem; color:var(--muted); font-size:.9rem; }
</style>
<div id="bidQueue">
  <% if (!_pbs.length) { %>
    <div class="bq-empty">🎉 <strong style="color:var(--text)">All caught up</strong> — no bids waiting for a decision. New QuickBooks estimates land here automatically.</div>
  <% } %>
  <% _pbs.forEach(function (b) {
       var lf = []; try { lf = JSON.parse(b.license_flags || '[]'); } catch (e) {}
       var lw = lf.some(function (f) { return f.level === 'red'; }) ? 'red' : (lf.some(function (f) { return f.level === 'amber'; }) ? 'amber' : (b.license_checked_at ? 'ok' : 'none'));
       var licCls = lw === 'ok' ? 'bq-ok' : lw === 'red' ? 'bq-bad' : lw === 'amber' ? 'bq-warn' : 'bq-none';
       var licTxt = lw === 'ok' ? '✓ License active' + (b.license_expire ? ' thru ' + new Date(b.license_expire).toLocaleDateString() : '')
                  : lw === 'none' ? 'License not verified'
                  : (lw === 'red' ? '⛔ ' : '⚠ ') + ((lf.find(function (f) { return f.level === lw; }) || {}).text || 'license issue');
       var insD = b.ins_expires ? Math.floor((new Date(b.ins_expires) - Date.now()) / 86400000) : null;
       var insCls = insD == null ? 'bq-none' : insD < 0 ? 'bq-bad' : insD <= 60 ? 'bq-warn' : 'bq-ok';
       var insTxt = insD == null ? 'No COI on file'
                  : insD < 0 ? '🚨 Insurance EXPIRED ' + new Date(b.ins_expires).toLocaleDateString()
                  : (insD <= 60 ? '⚠' : '✓') + ' Insurance thru ' + new Date(b.ins_expires).toLocaleDateString() + (insD <= 60 ? ' (' + insD + 'd)' : '');
       var avg = (typeof b.trade_avg === 'number') ? b.trade_avg : null;
       var diff = (avg && b.amount != null) ? Math.round((Number(b.amount) - avg) / avg * 100) : null;
       var prCls = diff == null ? 'bq-none' : diff <= 5 ? 'bq-ok' : diff <= 25 ? 'bq-warn' : 'bq-bad';
       var prTxt = diff == null ? 'No other bids in this trade to compare' : 'Trade avg ' + _bqMoney(avg) + ' → this bid ' + (diff > 0 ? '+' : '') + diff + '%';
       var trade = (String(b.sub_type || '').split(',')[0] || '').trim() || 'Other';
       var pdfU = b.gmail_attachment_id ? '/threads/messages/' + b.gmail_message_id + '/attachment/' + b.gmail_attachment_id + '?name=' + encodeURIComponent(b.filename || 'estimate.pdf') + '&mime=application%2Fpdf' : null;
  %>
  <div class="bq-card" id="bq_<%= b.id %>">
    <div class="bq-top">
      <span class="bq-co"><%= b.company %></span>
      <span class="bq-trade"><%= trade %></span>
      <span class="bq-meta">est <%= b.estimate_no || '—' %> · <%= new Date(b.received_at).toLocaleDateString() %></span>
      <% if (pdfU) { %><a href="<%= pdfU %>" target="_blank" rel="noopener" title="Open the estimate PDF" style="font-size:.9rem">📄 PDF</a><% } %>
      <span class="bq-amt"><%= _bqMoney(b.amount) %></span>
    </div>
    <div class="bq-checks">
      <span class="bq-chk <%= licCls %>"><%= licTxt %></span>
      <span class="bq-chk <%= insCls %>"><%= insTxt %></span>
      <span class="bq-chk <%= prCls %>">💲 <%= prTxt %></span>
      <span class="bq-chk bq-none">📍 <%= (b.location || '').trim() || 'no service area set' %></span>
    </div>
    <div class="bq-proj">
      🏠 <strong>Project:</strong>
      <% if (b.project_address) { %>
        <%= b.project_address %><% if (b.auto_matched) { %> <span style="color:#b45309;font-size:.72rem;font-weight:700" title="Matched by address similarity — double-check me">≈ auto from “<%= b.job_hint %>”</span><% } %>
      <% } else { %>
        <select onchange="bqAssign(<%= b.id %>, this.value)">
          <option value="">— pick the project —</option>
          <% _bps.forEach(function (p) { %><option value="<%= p.id %>"><%= p.address %></option><% }) %>
        </select>
        <% if (b.job_hint) { %><span class="bq-meta">estimate says “<%= b.job_hint %>”</span><% } %>
      <% } %>
    </div>
    <div class="bq-actions">
      <button type="button" class="bqa bqa-approve" onclick="bqDecide(<%= b.id %>, 'approve', this)" title="Award the bid and move <%= b.company %> to Approved">✔ Approve &amp; award</button>
      <button type="button" class="bqa bqa-pass" onclick="bqDecide(<%= b.id %>, 'pass', this)" title="Pass on this bid — the sub stays in the pipeline">✋ Pass</button>
      <% if (_hasCompose && b.email) { %>
        <button type="button" class="bqa js-compose" data-id="<%= b.sub_id %>" data-email="<%= b.email %>" data-name="<%= b.company %>" data-trade="<%= trade %>" onclick="openCompose(this)" title="Email them for missing docs before deciding">✉ Ask for docs</button>
      <% } else if (b.email) { %>
        <a class="bqa" style="text-decoration:none;display:inline-block" href="mailto:<%= b.email %>?subject=<%= encodeURIComponent('Re: ' + (b.subject || 'your estimate')) %>" title="Email them for missing docs before deciding">✉ Ask for docs</a>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>
<script>
if (!window.bqDecide) {
  window.bqDecide = async function (id, action, btn) {
    if (action === 'pass' && !confirm('Pass on this bid?')) return;
    btn.disabled = true; btn.textContent = '…';
    try {
      const r = await fetch('/bids/' + id + '/decide', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams({ action: action }) });
      const d = await r.json();
      if (d.ok) location.reload(); else { alert(d.error || 'Could not save'); btn.disabled = false; }
    } catch (e) { alert('Could not save'); btn.disabled = false; }
  };
  window.bqAssign = async function (id, pid) {
    if (!pid) return;
    const r = await fetch('/bids/' + id + '/assign', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams({ project_id: pid }) });
    const d = await r.json().catch(function () { return {}; });
    if (d.ok) location.reload(); else alert('Could not assign');
  };
}
</script>

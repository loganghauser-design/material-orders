<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= project.address %></title>
  <link rel="stylesheet" href="/css/app.css?v=3">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#4f8ef7">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="apple-touch-icon" href="/icon.svg">
  <script>if('serviceWorker' in navigator){window.addEventListener('load',function(){navigator.serviceWorker.register('/sw.js').catch(function(){});});}</script>
</head>
<body>
<%- include('_nav', { active: '' }) %>

<div class="container">
  <%
    var _ph = project.phase || (project.overall_status === 'Fully Delivered' ? 'Complete' : (project.overall_status === 'Not Yet' ? 'Pre-Construction' : 'Under Construction'));
    var _assigned = (project.super_email || '').split(',').map(e => e.trim().toLowerCase()).filter(Boolean);
    var _asg = supers.filter(function(s){ return _assigned.includes(s.email.toLowerCase()); });
    var _siteNames = _asg.map(function(s){ return s.name; }).join(', ');
  %>
  <a href="/projects" class="proj-back">← All projects</a>
  <div class="proj-head">
    <div class="ph-top">
      <div style="min-width:0">
        <h1 style="margin:0"><%= project.address %></h1>
        <% if (project.version) { %><div class="ph-sub"><%= project.version %></div><% } %>
      </div>
      <a href="/projects/<%= project.id %>/edit" class="btn btn-ghost btn-sm" title="Edit address, client, status, notes">✎ Edit</a>
    </div>
    <div class="ph-grid">
      <div class="ph-field">
        <div class="ph-label">Client</div>
        <div class="ph-val"><%= project.client_name || '—' %></div>
        <% if (project.client_email) { %><a class="ph-link" href="mailto:<%= project.client_email %>"><%= project.client_email %></a><% } %>
      </div>
      <div class="ph-field">
        <div class="ph-label">Status</div>
        <div class="ph-status-wrap">
          <button type="button" class="ph-status phb-<%= _ph.toLowerCase().replace(/[^a-z]+/g,'_') %>" onclick="togglePhaseMenu(event)"><%= _ph %> <span class="ph-caret">▾</span></button>
          <div class="ph-menu" id="phaseMenu">
            <div class="ph-menu-h">Change status</div>
            <% PROJECT_PHASES.forEach(function(p){ %><button type="button" class="ph-menu-item<%= p===_ph?' on':'' %>" onclick="setPhase('<%= p %>')"><%= p %></button><% }) %>
          </div>
        </div>
      </div>
      <div class="ph-field">
        <div class="ph-label">Last delivery</div>
        <% if (lastDelivered) { var _dd = Math.floor((Date.now() - new Date(lastDelivered.date).getTime()) / 86400000); %>
          <div class="ph-val">🚚 <%= lastDelivered.name %></div>
          <div class="ph-sub">delivered <%= _dd <= 0 ? 'today' : _dd + 'd ago' %></div>
        <% } else { %><div class="ph-sub">No deliveries yet</div><% } %>
      </div>
      <div class="ph-field">
        <div class="ph-label">Team</div>
        <div class="ph-val"><span class="ph-role ph-role-pm">PM</span> Aziz Ibrahim</div>
        <div style="margin-top:.35rem" title="Assigned site contacts receive this project's delivery notices">
          <button type="button" class="dt-team" data-assigned="<%= JSON.stringify(_asg.map(function(s){ return { email: s.email, name: s.name, role: s.role }; })) %>" onclick="dtOpen(this)">
            <% if (_asg.length) { %><span class="dt-names"><%= _siteNames %></span><% } else { %><span class="dt-none">Assign site contact…</span><% } %>
            <span class="dt-caret">▾</span>
          </button>
        </div>
      </div>
    </div>
    <% if (project.notes) { %><div class="ph-notes"><%= project.notes %></div><% } %>
  </div>

  <style>
    .proj-back{display:inline-block;font-size:.82rem;color:#2563eb;text-decoration:none;margin:.1rem 0 .55rem}
    .proj-back:hover{text-decoration:underline}
    .proj-head{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:1rem 1.25rem;margin:0 0 1rem}
    .ph-top{display:flex;align-items:flex-start;gap:1rem}
    .ph-top h1{font-size:1.35rem}
    .ph-top .btn{margin-left:auto;white-space:nowrap}
    .ph-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:.9rem 1.3rem;margin-top:.9rem;padding-top:.85rem;border-top:1px solid var(--border)}
    .ph-label{font-size:.66rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);margin-bottom:.35rem}
    .ph-val{font-size:.9rem;color:var(--text)}
    .ph-sub{font-size:.78rem;color:var(--muted);margin-top:.12rem}
    .ph-link{font-size:.8rem;color:#2563eb;text-decoration:none;display:inline-block;margin-top:.12rem}
    .ph-link:hover{text-decoration:underline}
    .ph-role{font-size:.58rem;font-weight:800;padding:0 4px;border-radius:4px;margin-right:3px;vertical-align:middle}
    .ph-role-pm{background:#e6f1fb;color:#185fa5}
    .ph-status-wrap{position:relative;display:inline-block}
    .ph-status{display:inline-flex;align-items:center;gap:5px;font-size:.82rem;font-weight:600;padding:.32rem .6rem;border-radius:6px;border:1px solid var(--border);cursor:pointer;color:var(--text)}
    .ph-caret{font-size:.68rem;opacity:.65}
    .ph-menu{display:none;position:absolute;top:calc(100% + 5px);left:0;z-index:60;background:var(--surface);border:1px solid var(--border);border-radius:9px;box-shadow:0 8px 26px rgba(0,0,0,.14);padding:5px;min-width:200px}
    .ph-menu.open{display:block}
    .ph-menu-h{font-size:.62rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);padding:5px 9px 3px}
    .ph-menu-item{display:block;width:100%;text-align:left;background:none;border:none;border-radius:6px;padding:6px 9px;font-size:.85rem;color:var(--text);cursor:pointer}
    .ph-menu-item:hover{background:var(--bg)}
    .ph-menu-item.on{background:#eef4ff;color:#2563eb;font-weight:600}
    .ph-notes{color:var(--muted);font-size:.82rem;margin-top:.7rem;padding-top:.6rem;border-top:1px solid var(--border)}
    .del-emails{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:.8rem 1.1rem;margin:0 0 1.1rem}
    .del-emails-h{display:flex;align-items:center;gap:.5rem;font-size:.95rem;font-weight:700;margin-bottom:.45rem}
    .del-emails-c{margin-left:auto;font-size:.72rem;font-weight:600;color:var(--muted);background:var(--bg);border:1px solid var(--border);border-radius:999px;padding:1px 9px}
    .del-row{display:grid;grid-template-columns:64px 1fr 92px 1fr;gap:.6rem;align-items:center;padding:.45rem 0;border-top:1px solid var(--border);font-size:.85rem}
    .del-date{color:var(--muted)}
    .del-method{font-size:.8rem;white-space:nowrap}
    .del-to{color:var(--muted);font-size:.8rem}
    .del-empty{color:var(--muted);font-size:.85rem;padding:.25rem 0}
  </style>

  <style>
    .tabs{display:flex;align-items:flex-end;gap:.2rem;flex-wrap:wrap;margin:.25rem 0 1.15rem;border-bottom:2px solid var(--border)}
    .tab-btn{background:none;border:none;border-bottom:2px solid transparent;margin-bottom:-2px;border-radius:0;padding:.5rem .95rem .55rem;cursor:pointer;font-size:.9rem;font-weight:600;color:var(--muted);letter-spacing:.01em}
    .tab-btn:hover{color:var(--text)}
    .tab-btn.active{color:#2563eb;border-bottom-color:#2563eb;background:none}
    .super-chip{font-size:.82rem;padding:.25rem .7rem;border:1px solid var(--border);border-radius:14px;background:var(--surface);color:var(--text);cursor:pointer}
    .super-chip:hover{border-color:#4f8ef7}
    .super-chip.on{background:#4f8ef7;color:#fff;border-color:#4f8ef7;font-weight:600}
    .super-chip.on::before{content:'\2713 '}
    .super-chip:disabled{opacity:.55;cursor:default}
    .super-chip.add-contact{border-style:dashed;color:var(--muted);font-weight:700}
    .super-chip.add-contact:hover{color:#4f8ef7;border-color:#4f8ef7}
    .chip-role{font-size:.58rem;font-weight:800;letter-spacing:.03em;padding:0 4px;border-radius:5px;margin-left:4px;vertical-align:middle;background:#efe8fb;color:#6b3fc2}
    .super-chip.on .chip-role{background:rgba(255,255,255,.28);color:#fff}
    #addContactBox{display:none;align-items:center;gap:.4rem;flex-wrap:wrap;justify-content:flex-end;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:.5rem .6rem}
    #addContactBox input,#addContactBox select{font-size:.82rem;padding:.35rem .5rem;border:1px solid var(--border);border-radius:7px;background:var(--surface)}
    #addContactBox input{width:130px}
    .held-qty.qty-done{background:#6aa84f;color:#fff;border-color:#6aa84f;font-weight:600}
    .held-qty.qty-partial{background:#fde6c8;color:#8a4b00;border-color:#e0a106}
    .held-qty.qty-none{background:#ede0fb;color:#5b2a86}
    .field-requests{background:#fffbeb;border:1px solid #f6c886;border-radius:12px;padding:.9rem 1rem;margin:0 0 1.2rem}
    .fr-title{font-weight:800;font-size:1rem;color:#8a5300;margin-bottom:.3rem}
    .fr-count{background:#e0531f;color:#fff;border-radius:9px;padding:0 8px;font-size:.78rem;vertical-align:middle}
    .fr-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:.7rem .85rem;margin-top:.6rem}
    .fr-head{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .fr-need{font-size:.78rem;font-weight:700;color:#b45309;margin-left:.4rem}
    .fr-items{margin:.5rem 0 .2rem;line-height:1.9}
    .fr-item{display:inline-flex;align-items:center;gap:.3rem;margin-right:.7rem;font-weight:600;font-size:.92rem;white-space:nowrap}
    .fr-pill{font-size:.64rem;font-weight:700;padding:1px 7px;border-radius:9px}
    .fr-pill-deliv{background:#dcfce7;color:#166534}.fr-pill-order{background:#dbeafe;color:#1d4ed8}.fr-pill-rfq{background:#fef3c7;color:#92400e}.fr-pill-issue{background:#fee2e2;color:#b91c1c}.fr-pill-none{background:#e5e7eb;color:#555}
    .fr-note{font-size:.9rem;line-height:1.45;white-space:pre-wrap;margin:.35rem 0 .1rem;color:var(--text)}
    .fr-respond{display:flex;gap:.5rem;margin-top:.55rem}
    .fr-respond input{flex:1;padding:.45rem .65rem;border:1px solid var(--border);border-radius:8px;background:var(--surface);font-size:.86rem}
    .req-flag{display:inline-block;background:#fde68a;color:#92400e;font-size:.7rem;font-weight:700;padding:1px 8px;border-radius:10px;white-space:nowrap;vertical-align:middle;text-decoration:none;cursor:pointer}
    .req-flag:hover{background:#fcd34d}
    .iss-flag{display:inline-block;background:#fee2e2;color:#b91c1c;font-size:.7rem;font-weight:700;padding:1px 8px;border-radius:10px;white-space:nowrap;vertical-align:middle;text-decoration:none;cursor:pointer;max-width:260px;overflow:hidden;text-overflow:ellipsis}
    .iss-flag:hover{background:#fecaca}
    .item-date,.item-date-end{width:122px;font-size:.8rem}
    .item-date-end{opacity:.9}
    .notify-btn:disabled{opacity:.6;cursor:default}
    .tab-panel{display:none}
    .cat-thread{padding:.32rem .15rem;border-bottom:1px solid var(--border);cursor:pointer;font-size:.85rem}
    .cat-thread:hover{background:var(--surface)}
    .cat-thread.unread strong{color:#cc2222}
    .cat-conv{display:none}
    .cat-conv.open{display:block;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:.6rem .75rem;margin:.35rem 0 .7rem}
    .modal{max-height:90vh;overflow-y:auto}
    .modal-overlay{padding:2vh 0}
    /* Item Checklist (this is the Materials tab now) */
    .ck-toolbar{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap;margin:0 0 .9rem;padding:.6rem .8rem;background:var(--bg);border:1px solid var(--border);border-radius:11px}
    .ck-tb-label{font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-left:.35rem}
    .ck-src{font-size:.75rem;color:var(--muted);display:inline-flex;align-items:center;gap:.32rem}
    .ck-src select{font:inherit;font-size:.75rem;font-weight:600;color:var(--text);border:1px solid var(--border);border-radius:6px;padding:.18rem .35rem;background:var(--surface)}
    .ck-legend{color:var(--muted);font-size:.78rem;margin:0 0 1.1rem;max-width:820px}
    .ck-bucket{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:.85rem 1.1rem;margin-bottom:.85rem;max-width:none}
    .ck-head{display:flex;align-items:center;gap:.7rem;flex-wrap:wrap;margin-bottom:.5rem}
    .ck-head h2{font-size:.98rem;font-weight:800;margin:0;display:flex;align-items:baseline;gap:.45rem}
    .ck-hcode{font-size:.72rem;font-weight:800;color:#fff;background:#9aa3b2;border-radius:5px;padding:.08rem .35rem}
    .ck-bar{flex:1;min-width:120px;max-width:300px;height:10px;background:var(--bg);border:1px solid var(--border);border-radius:5px;overflow:hidden;display:flex}
    .ck-bar > i{height:100%;display:block}
    .ck-count{font-size:.82rem;font-weight:800;color:var(--muted);white-space:nowrap}
    .ck-count.all{color:#16a34a}
    .ck-count small{font-weight:600;color:var(--muted)}
    .ck-email{margin-left:auto;border:1px solid var(--border);background:var(--surface);border-radius:8px;padding:.2rem .5rem;font-size:.9rem;cursor:pointer;line-height:1}
    .ck-email:hover{background:var(--bg);border-color:#c7cdd8}
    .ck-row{display:flex;align-items:baseline;gap:.6rem;padding:.34rem 0;border-bottom:1px solid var(--border);font-size:.87rem;flex-wrap:wrap}
    .ck-row:last-child{border-bottom:none}
    .ck-check{flex:none;width:22px;text-align:center;cursor:pointer;user-select:none;font-size:1rem;line-height:1.2}
    .ck-manual{outline:1px dashed #9aa3b2;outline-offset:1px;border-radius:4px}
    .ck-code{font-weight:700;white-space:nowrap;color:var(--muted);font-size:.8rem;min-width:56px}
    .ck-name{font-weight:600}
    .ck-qty{font-size:.78rem;font-weight:800;color:#374151}
    .ck-model{font-family:monospace;font-size:.78rem;color:var(--muted);white-space:nowrap}
    .ck-when{color:#3730a3;font-size:.76rem;font-weight:600;white-space:nowrap}
    .ck-sup{margin-left:auto;font-size:.76rem;color:var(--muted);white-space:nowrap}
    .ck-done{opacity:.6}
    /* Site-contacts dropdown picker */
    .dt-team{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--border);background:var(--bg);border-radius:999px;padding:4px 11px;cursor:pointer;font-size:.86rem;max-width:340px;color:var(--text)}
    .dt-team:hover{border-color:#4f8ef7}
    .dt-names{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:600}
    .dt-none{color:var(--muted);font-weight:600}
    .dt-caret{color:var(--muted);font-size:.6rem;flex:none}
    .teampop{position:fixed;z-index:1000;width:252px;max-height:360px;overflow:auto;background:var(--surface);border:1px solid var(--border);border-radius:12px;box-shadow:0 14px 38px rgba(0,0,0,.20);padding:6px}
    .teampop[hidden]{display:none}
    .tp-group{font-size:.66rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);padding:9px 8px 3px}
    .tp-row{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:8px;cursor:pointer;font-size:.86rem;color:var(--text)}
    .tp-row:hover{background:var(--bg)}
    .tp-row.sel{background:#e6f1fb;color:#185fa5;font-weight:700}
    .tp-row .tp-check{margin-left:auto;color:#185fa5;font-weight:700}
    .tp-dot{width:8px;height:8px;border-radius:50%;flex:none}
    .tp-dot-super{background:#3b82f6}.tp-dot-gc{background:#8b5cf6}
    .tp-row .tm-name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .tp-sep{height:1px;background:var(--border);margin:5px 2px}
    .tp-addbtn{display:block;width:100%;text-align:left;background:none;border:none;padding:8px;font-size:.84rem;font-weight:700;color:#4f8ef7;cursor:pointer;border-radius:8px}
    .tp-addbtn:hover{background:var(--bg)}
    .tp-addform{display:flex;flex-direction:column;gap:6px;padding:6px 8px 8px}
    .tp-addform input,.tp-addform select{font-size:.82rem;padding:7px 8px;border:1px solid var(--border);border-radius:7px;background:var(--bg);color:var(--text)}
    .tp-addactions{display:flex;gap:6px}
    .tp-manage{display:block;padding:8px;font-size:.78rem;color:var(--muted);text-decoration:none;border-radius:8px}
    .tp-manage:hover{background:var(--bg);color:var(--text)}
  </style>
  <%- include('_terminal', { termProjectId: project.id, termProjectAddr: project.address }) %>
  <div class="tabs">
    <button type="button" class="tab-btn active" data-tab="materials" onclick="showTab('materials')">Materials</button>
    <button type="button" class="tab-btn" data-tab="orders" onclick="showTab('orders')">Orders</button>
    <button type="button" class="tab-btn" data-tab="emails" onclick="showTab('emails')">Emails</button>
    <button type="button" class="tab-btn" data-tab="schedule" onclick="showTab('schedule')">Finish Schedule</button>
    <a class="tab-btn" href="/projects/<%= project.id %>/checklist" style="text-decoration:none" title="Every item this project's finish schedule expects, with delivery status per item">Item Checklist</a>
  </div>

  <div class="tab-panel" data-tab="schedule">
    <div class="email-card">
      <div class="email-header">
        <div><strong>Finish Schedule</strong><div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Read live from your Google Sheet — verify what the app sees.</div></div>
        <button class="btn btn-ghost btn-sm" onclick="loadFinishSchedule(true)">↻ Refresh</button>
      </div>
      <div id="finSchedView" style="margin-top:.5rem;overflow-x:auto"><div style="color:var(--muted);font-size:.85rem">Open this tab to load…</div></div>
    </div>
  </div>

  <div class="tab-panel" data-tab="emails">
  <!-- Vendor email threads -->
  <div class="email-card">
    <div class="email-header">
      <div><strong>Vendor Email Threads</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Order, delivery & quote emails you've sent for this project — with replies.</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="loadThreads()">↻ Refresh</button>
    </div>
    <div id="threadList" style="margin-top:.5rem"><div style="color:var(--muted);font-size:.85rem">Loading…</div></div>
  </div>

  </div><!-- /emails (part 2) -->
  <div class="tab-panel" data-tab="orders">
  <!-- Confirmed orders, grouped by vendor -->
  <div class="email-card">
    <div class="email-header">
      <div><strong>Confirmed Orders</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Materials a vendor has confirmed, by vendor. Log from a vendor's reply (📦) or upload a receipt PDF →</div>
      </div>
      <button class="btn btn-primary btn-sm" onclick="openReceiptUpload()">⬆ Upload Receipt</button>
    </div>
    <% if (ordersByVendor && ordersByVendor.length) { %>
      <% ordersByVendor.forEach(v => { %>
        <div style="margin-top:.7rem">
          <div style="font-weight:600;font-size:.9rem">
            <%= v.name || v.email || 'Unknown vendor' %><% if (v.name && v.email) { %> <span style="color:var(--muted);font-weight:400;font-size:.8rem"><%= v.email %></span><% } %>
          </div>
          <table style="width:100%;font-size:.85rem;margin-top:.3rem">
            <% v.orders.forEach(o => { %>
              <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:.4rem 0;vertical-align:top"><%= o.item_codes.map(c => itemNames[c] || c).join(', ') %></td>
                <td style="padding:.4rem .5rem;white-space:nowrap;text-align:right;vertical-align:top"><% if (o.amount != null) { %><strong>$<%= Number(o.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></strong><% } %></td>
                <td style="padding:.4rem .5rem;white-space:nowrap;text-align:right;color:var(--muted);font-size:.78rem;vertical-align:top"><%= new Date(o.confirmed_at).toLocaleDateString() %></td>
                <td style="padding:.4rem .5rem;text-align:right;white-space:nowrap;vertical-align:top">
                  <span title="How did this delivery go? (feeds the vendor reliability chart on the Suppliers page)">
                    <button type="button" class="ocp oc-ontime <%= o.delivery_outcome==='ontime'?'on':'' %>" onclick="setOutcome(<%= o.id %>,'ontime',this)" title="Delivered on time">✓</button>
                    <button type="button" class="ocp oc-late <%= o.delivery_outcome==='late'?'on':'' %>" onclick="setOutcome(<%= o.id %>,'late',this)" title="Delivered late">⏰</button>
                    <button type="button" class="ocp oc-wrong <%= o.delivery_outcome==='wrong'?'on':'' %>" onclick="setOutcome(<%= o.id %>,'wrong',this)" title="Wrong / damaged items">✗</button>
                    <button type="button" class="ocp oc-missed <%= o.delivery_outcome==='missed'?'on':'' %>" onclick="setOutcome(<%= o.id %>,'missed',this)" title="Missed / no-show">🚫</button>
                  </span>
                </td>
                <td style="padding:.4rem 0;text-align:right;white-space:nowrap;vertical-align:top">
                  <% if (o.has_receipt) { %><a href="/orders/<%= o.id %>/receipt" target="_blank" class="btn btn-ghost btn-sm">📄 Receipt</a><% } %>
                  <form method="POST" action="/orders/<%= o.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this order record?')"><button class="btn btn-danger btn-sm">✕</button></form>
                </td>
              </tr>
            <% }) %>
          </table>
        </div>
      <% }) %>
    <% } else { %>
      <div style="color:var(--muted);font-size:.85rem;margin:.5rem 0">No confirmed orders yet. Open a vendor reply above and click “📦 Log Order Confirmation”.</div>
    <% } %>
  </div>

  <!-- Order tracking grouped by material category (itemized) -->
  <div class="email-card">
    <div class="email-header">
      <div><strong>Order Tracking by Category</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Items you've ordered, grouped by material category (Rough Plumb, Finish Plumb, Appliances…).</div>
      </div>
    </div>
    <% if (ordersByCategory && ordersByCategory.length) { %>
      <% ordersByCategory.forEach(cat => { %>
        <div style="margin-top:.85rem">
          <div style="font-weight:600;font-size:.9rem;display:flex;justify-content:space-between;align-items:center;gap:.5rem">
            <span><%= cat.name %> <span style="color:var(--muted);font-weight:400;font-size:.78rem"><%= cat.code %> · <%= cat.stage %></span></span>
            <span style="display:flex;align-items:center;gap:.6rem">
              <% if (cat.lines.length) { %><span style="font-weight:600;font-size:.82rem">$<%= cat.subtotal.toLocaleString(undefined,{minimumFractionDigits:2}) %></span><% } %>
              <% if (cat.lines.length) { %><button type="button" class="btn btn-ghost btn-sm" onclick="openCategoryRequest('<%= cat.code %>')" title="Email the vendor to request these items">✉ Request</button><% } %>
            </span>
          </div>
          <% if (cat.lines.length) { %>
            <table style="width:100%;font-size:.83rem;margin-top:.25rem">
              <% cat.lines.forEach(l => { %>
                <tr style="border-bottom:1px solid var(--border)">
                  <td style="padding:.3rem 0;vertical-align:top">
                    <%= l.description || l.product_code %><% if (l.qty && Number(l.qty) > 1) { %> <span style="color:var(--muted)">×<%= Number(l.qty) %></span><% } %>
                    <% if (l.product_code) { %><br><span style="color:var(--muted);font-size:.72rem"><%= l.product_code %><% if (l.supplier_name) { %> · <%= l.supplier_name %><% } %></span><% } %>
                  </td>
                  <td style="padding:.3rem 0;white-space:nowrap;text-align:right;vertical-align:top"><% if (l.price != null) { %>$<%= Number(l.price).toLocaleString(undefined,{minimumFractionDigits:2}) %><% } %></td>
                </tr>
              <% }) %>
            </table>
          <% } %>
          <% cat.summaryOrders.forEach(o => { %>
            <div style="font-size:.82rem;color:var(--muted);margin-top:.25rem">
              <%= o.supplier_name || o.supplier_email || 'Unknown vendor' %><% if (o.amount != null) { %> — $<%= Number(o.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %> (order total)<% } %><% if (o.has_receipt) { %> · <a href="/orders/<%= o.id %>/receipt" target="_blank">📄 receipt</a><% } %>
            </div>
          <% }) %>
        </div>
      <% }) %>
    <% } else { %>
      <div style="color:var(--muted);font-size:.85rem;margin:.5rem 0">No orders logged yet. When you log an order (📦 above), its items appear here grouped by category.</div>
    <% } %>
  </div>

  </div><!-- /orders -->
  <div class="tab-panel" data-tab="materials">
  <div class="del-emails">
    <div class="del-emails-h"><span>✉ Delivery emails sent</span><span class="del-emails-c"><%= (typeof deliveryNotices !== 'undefined' ? deliveryNotices.length : 0) %></span></div>
    <% if (typeof deliveryNotices !== 'undefined' && deliveryNotices.length) { %>
      <% deliveryNotices.forEach(function(n){ var _sd = new Date(n.sentAt); %>
        <div class="del-row">
          <span class="del-date"><%= _sd.toLocaleDateString('en-US', { month:'short', day:'numeric' }) %></span>
          <span class="del-items"><%= n.items %></span>
          <span class="del-method"><%= n.method === 'ups' ? '📦 UPS' : '🚚 Truck' %></span>
          <span class="del-to"><%= _siteNames || '—' %></span>
        </div>
      <% }) %>
    <% } else { %>
      <div class="del-empty">No delivery emails sent yet — they'll appear here once you approve one.</div>
    <% } %>
  </div>
  <% if (typeof projectRequests !== 'undefined' && projectRequests.length) { %>
  <div id="fieldRequests" class="field-requests">
    <div class="fr-title">📥 Field Requests <span class="fr-count"><%= projectRequests.length %></span></div>
    <div style="font-size:.82rem;color:var(--muted);margin:-.2rem 0 .7rem">Material your supers asked for. Work it on the grid below (RFQ → Order → Delivered auto-closes it), or reply / mark done here.</div>
    <% projectRequests.forEach(r => { %>
      <div class="fr-card" id="frq_<%= r.id %>">
        <div class="fr-head">
          <div>
            <strong>👷 <%= r.superName %></strong>
            <span style="color:var(--muted);font-size:.83rem">· <%= new Date(r.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></span>
            <% if (r.needed_by) { %><span class="fr-need">📅 need by <%= new Date(r.needed_by).toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'}) %></span><% } %>
          </div>
          <button type="button" class="btn btn-ghost btn-sm" onclick="frFulfill(<%= r.id %>)">✓ Mark done</button>
        </div>
        <div class="fr-items">
          <% r.items.forEach(it => { var s=(it.status||'').toLowerCase(); var cl = s.indexOf('delivered')>=0?'deliv':(s.indexOf('order')>=0?'order':(s.indexOf('rfq')>=0?'rfq':(s.indexOf('issue')>=0?'issue':'none'))); %>
            <span class="fr-item"><%= it.name %> <span class="fr-pill fr-pill-<%= cl %>"><%= it.status %></span></span>
          <% }) %>
        </div>
        <% if (r.note) { %><div class="fr-note"><%= r.note %></div><% } %>
        <div class="fr-respond">
          <input type="text" id="frresp_<%= r.id %>" placeholder="Reply to <%= r.superName %> (pings them in chat)…" onkeydown="if(event.key==='Enter')frRespond(<%= r.id %>)">
          <button type="button" class="btn btn-primary btn-sm" onclick="frRespond(<%= r.id %>)">Send</button>
        </div>
      </div>
    <% }) %>
  </div>
  <% } %>
  <!-- Sourcing controls + vendor email (project-level settings that used to live in the grid) -->
  <div class="ck-toolbar">
    <button type="button" class="btn btn-primary btn-sm" onclick="openRfqDialog('','','','')" title="Send an RFQ / order email to any vendor">✉ Email a vendor</button>
    <span class="ck-tb-label">Sourcing</span>
    <% if (typeof showBifold === 'undefined' || showBifold) { %>
    <label class="ck-src">Bifold
      <select onchange="setBifoldSource(this.value)">
        <option value="buildoly" <%= project.bifold_source==='vendor'?'':'selected' %>>Buildoly Stock</option>
        <option value="vendor" <%= project.bifold_source==='vendor'?'selected':'' %>>Vendor</option>
      </select>
    </label>
    <% } %>
    <% if (typeof showSliding === 'undefined' || showSliding) { %>
    <label class="ck-src">Sliding Door
      <select onchange="setSlidingSource(this.value)">
        <option value="vendor" <%= project.sliding_door_source==='buildoly'?'':'selected' %>>Vendor</option>
        <option value="buildoly" <%= project.sliding_door_source==='buildoly'?'selected':'' %>>Buildoly Stock</option>
      </select>
    </label>
    <% } %>
    <label class="ck-src">Rec. Light
      <select onchange="setRecSource(this.value)">
        <option value="gc" <%= project.rec_lighting_source==='oncall'?'':'selected' %>>GC Procure</option>
        <option value="oncall" <%= project.rec_lighting_source==='oncall'?'selected':'' %>>On Call LED</option>
      </select>
    </label>
    <label class="ck-src">Range Hood
      <select onchange="setRangeHoodSource(this.value)">
        <option value="default" <%= project.range_hood_source==='buildoly'?'':'selected' %>>Vendor</option>
        <option value="buildoly" <%= project.range_hood_source==='buildoly'?'selected':'' %>>Buildoly Stock</option>
      </select>
    </label>
    <label class="ck-src">Jedco
      <select onchange="setJedcoSource(this.value)">
        <option value="default" <%= project.jedco_source==='buildoly'?'':'selected' %>>JEDCO</option>
        <option value="buildoly" <%= project.jedco_source==='buildoly'?'selected':'' %>>Buildoly Stock</option>
      </select>
    </label>
  </div>
  <p class="ck-legend">✅ delivered &middot; 🚚 scheduled (date shown) &middot; 📦 on a confirmed order, not scheduled yet &middot; ⬜ not seen yet. Ferguson updates these automatically as orders and deliveries come in — for any other vendor, <strong>click the icon</strong> to set it by hand (⬜→📦→🚚→✅, one more click reverts to automatic). Giving a 🚚 item a real date also lists it on the <a href="/deliveries" style="color:#2563eb">Deliveries board</a> and sends a day-before confirmation.</p>

  <%
    var CK_LABEL = { '1a':'Doors & Windows','1b':'Rough Plumbing & Fans','1c':'HVAC Trim','1d':'Tile','1e':'Recessed Lighting','2a':'Millwork','2b':'Flooring','2c':'Decking','2d':'Finish Plumbing / Light / Hood','2e':'Water Heater','3a':'Countertops','3b':'Appliances','3c':'Cabinet Hardware','3d':'Misc','3e':'Shower Doors','4a':'Roofing','5a':'Solar' };
    var _ckItems = (typeof checklistItems !== 'undefined' && checklistItems) || [];
    var _ckBuckets = {};
    _ckItems.forEach(function (e) { var k = e.category_code || '—'; (_ckBuckets[k] = _ckBuckets[k] || []).push(e); });
    var _ckOrder = Object.keys(CK_LABEL).filter(function (k) { return _ckBuckets[k]; });
    Object.keys(_ckBuckets).forEach(function (k) { if (_ckOrder.indexOf(k) < 0) _ckOrder.push(k); });
  %>
  <% if (!_ckItems.length) { %>
    <div class="card" style="max-width:none;color:var(--muted)">No items on the schedule yet. Link this project's finish schedule under <strong>Edit Project</strong>, then reload.</div>
  <% } %>
  <% _ckOrder.forEach(function (k) {
       var list = _ckBuckets[k];
       var done = list.filter(function (e) { return e.delivered; }).length;
       var sched = list.filter(function (e) { return e.scheduled; }).length;
       var ord = list.filter(function (e) { return e.onOrder; }).length;
       var n = list.length;
       var _sup = (typeof suppliers !== 'undefined' && suppliers[k]) || {};
  %>
  <div class="ck-bucket" data-code="<%= k %>">
    <div class="ck-head">
      <h2><span class="ck-hcode"><%= k %></span> <%= CK_LABEL[k] || 'Uncategorized' %></h2>
      <span class="ck-bar" title="✅ <%= done %> delivered &middot; 🚚 <%= sched %> scheduled &middot; 📦 <%= ord %> ordered &middot; ⬜ <%= n - done - sched - ord %> not seen"><i style="width:<%= Math.round(done/n*100) %>%;background:#16a34a"></i><i style="width:<%= Math.round(sched/n*100) %>%;background:#6366f1"></i><i style="width:<%= Math.round(ord/n*100) %>%;background:#f0b429"></i></span>
      <span class="ck-count<%= done===n?' all':'' %>"><%= done %>✅<%= sched?' · '+sched+'🚚':'' %><%= ord?' · '+ord+'📦':'' %> <small>/ <%= n %></small></span>
      <button type="button" class="ck-email" data-code="<%= k %>" data-name="<%= CK_LABEL[k] || k %>" data-supname="<%= _sup.supplier_name || '' %>" data-supemail="<%= _sup.supplier_email || '' %>" onclick="catEmail(this)" title="Email this category's vendor">✉</button>
    </div>
    <% list.forEach(function (e) { %>
    <div class="ck-row<%= e.delivered ? ' ck-done' : '' %>">
      <span class="ck-check<%= e.manual ? ' ck-manual' : '' %>" data-key="<%= e.key %>" data-cur="<%= e.delivered ? 'd' : e.scheduled ? 's' : e.onOrder ? 'o' : '' %>" onclick="markItem(this)" title="<%= e.delivered ? 'Delivered' : e.scheduled ? ('Delivery scheduled' + (e.schedWhen ? ': ' + e.schedWhen : '')) : e.onOrder ? 'On a confirmed order — not scheduled yet' : 'Not yet seen on an order or delivery' %><%= e.manual ? ' (set by hand)' : '' %> — click to change: ⬜→📦→🚚→✅→auto"><%= e.delivered ? '✅' : e.scheduled ? '🚚' : e.onOrder ? '📦' : '⬜' %></span>
      <span class="ck-code"><%= e.prod_code || '' %></span>
      <span class="ck-name"><%= e.name %><% if (e.qty > 1) { %> <span class="ck-qty">×<%= e.qty %></span><% } %></span>
      <% if (e.model_no) { %><span class="ck-model"><%= e.model_no %></span><% } %>
      <% if (e.scheduled && e.schedWhen) { %><span class="ck-when">🗓 <%= e.schedWhen.length > 44 ? e.schedWhen.slice(0,44) + '…' : e.schedWhen %></span><% } %>
      <span class="ck-sup"><%= e.supplier || '' %></span>
    </div>
    <% }) %>
  </div>
  <% }) %>

  </div><!-- /materials -->
</div>

<!-- RFQ dialog -->
<div id="rfqModal" class="modal-overlay">
  <div class="modal" style="max-width:920px;width:94vw;max-height:92vh;overflow-y:auto">
    <h2 id="rfqModalTitle">Email Vendor</h2>
    <div id="rfqOrderBanner" style="display:none;background:#fef3c7;border:1px solid #f6c886;color:#8a5300;border-radius:9px;padding:.6rem .9rem;margin:0 0 .7rem;font-size:.88rem;line-height:1.4"></div>
    <p class="modal-sub">Drafts an email to the supplier. Paste your item list straight from Google Sheets.</p>
    <input type="hidden" id="rfqItemCode">
    <div class="form-group">
      <label>Vendor — auto-fill from finish schedule</label>
      <select id="rfqVendor" onchange="fillFromVendor()"><option value="">Loading vendors…</option></select>
      <small style="color:var(--muted);font-size:.75rem;margin-top:.25rem">Pick a vendor to auto-fill their items from this project's schedule, or just type below.</small>
    </div>
    <div class="form-group">
      <label>Email Type</label>
      <select id="rfqType" onchange="onRfqTypeChange()">
        <option value="order">Place Order (initial full order)</option>
        <option value="delivery">Request Delivery (deliver these now)</option>
        <option value="quote">Request Quote (pricing/availability)</option>
        <option value="damage">Report Damage (arrived damaged — replace at no charge)</option>
        <option value="replacement">Request Replacement (send a new one)</option>
        <option value="warehouse">Warehouse Outbound (ship from our warehouse)</option>
      </select>
    </div>
    <div class="form-group rfq-supplier-name" style="margin-top:.85rem">
      <label>Supplier Name</label>
      <input type="text" id="rfqSupplierName" placeholder="Supplier name">
    </div>
    <div class="form-group rfq-outbound-date" style="margin-top:.85rem;display:none">
      <label>Outbound Date</label>
      <input type="date" id="rfqOutboundDate">
      <small style="color:var(--muted);font-size:.75rem;margin-top:.25rem">Shows in the email as e.g. "Friday (3/20)".</small>
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label id="rfqEmailLabel">Supplier Email(s)</label>
      <input type="text" id="rfqSupplierEmail" placeholder="email@vendor.com, second@vendor.com">
      <small style="color:var(--muted);font-size:.75rem;margin-top:.25rem">Separate multiple addresses with commas — all get the same one email.</small>
    </div>
    <div class="form-group rfq-cc" style="margin-top:.85rem;display:none">
      <label>CC</label>
      <input type="text" id="rfqCc" placeholder="cc@example.com">
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label id="rfqItemsLabel">Items (paste from Google Sheets)</label>
      <div id="rfqStageWrap" style="display:none;margin:0 0 .45rem;font-size:.8rem">
        <label>Deliver which stage/category?
          <select id="rfqStage" onchange="filterByStage()" style="font-size:.8rem;padding:.18rem .4rem;border:1px solid var(--border);border-radius:6px;margin-left:.3rem"></select>
        </label>
      </div>
      <div id="rfqItemPick" style="display:none;align-items:center;gap:.6rem;flex-wrap:wrap;margin:0 0 .4rem;font-size:.78rem">
        <strong>Pick items to include:</strong>
        <button type="button" class="btn btn-ghost btn-sm" onclick="setAllItemChecks(true)">Select all</button>
        <button type="button" class="btn btn-ghost btn-sm" onclick="setAllItemChecks(false)">Clear all</button>
        <span id="rfqItemCount" style="color:var(--muted)"></span>
      </div>
      <div id="rfqItems" class="paste-box" contenteditable="true" data-placeholder="Select cells in your sheet, copy, and paste here — the table appears exactly as it looks."></div>
      <small style="color:var(--muted);font-size:.75rem;margin-top:.25rem">Pick a vendor above to auto-fill its items (each gets a checkbox — untick the ones you're not requesting), or paste from Google Sheets.</small>
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Extra note (optional)</label>
      <input type="text" id="rfqNote" placeholder="e.g. Needed by end of month">
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Attachments (optional)</label>
      <input type="file" id="rfqFiles" multiple>
      <small style="color:var(--muted);font-size:.75rem;margin-top:.25rem">You can select multiple files.</small>
    </div>
    <!-- Live preview of the exact email that will be sent -->
    <div id="rfqPreview" style="display:none;margin-top:1rem;border:1px solid var(--border);border-radius:10px;overflow:hidden">
      <div style="background:var(--bg);padding:.5rem .8rem;font-size:.8rem;font-weight:600;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
        <span>📧 Email preview — this is exactly what the vendor will receive</span>
        <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('rfqPreview').style.display='none'">Hide</button>
      </div>
      <div style="padding:.7rem .9rem;font-size:.82rem">
        <div><strong>To:</strong> <span id="pvTo"></span></div>
        <div id="pvCcRow" style="display:none"><strong>Cc:</strong> <span id="pvCc"></span></div>
        <div><strong>Subject:</strong> <span id="pvSubject"></span></div>
        <div id="pvAttachRow" style="display:none;margin-top:.2rem"><strong>Attachments:</strong> <span id="pvAttach"></span></div>
      </div>
      <div id="pvBody" style="padding:.4rem 1rem 1rem;border-top:1px solid var(--border);max-height:55vh;overflow:auto;background:#fff;color:#222"></div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-primary" id="rfqSendBtn" onclick="sendRfq(false)">Send</button>
      <button class="btn btn-ghost" id="rfqPreviewBtn" onclick="previewRfq()">👁 Preview email</button>
      <button class="btn btn-ghost" id="rfqDraftBtn" onclick="sendRfq(true)">Save as Draft</button>
      <button class="btn btn-ghost" onclick="document.getElementById('rfqModal').classList.remove('show')">Cancel</button>
    </div>
  </div>
</div>

<!-- Reply → material update confirmation -->
<div id="confirmUpdateModal" class="modal-overlay">
  <div class="modal">
    <h2>Update materials from your reply?</h2>
    <p class="modal-sub">Your reply mentioned these materials. Set a delivery date and/or status, then apply — or skip.</p>
    <div id="confirmItems" style="margin:.5rem 0 1rem"></div>
    <div class="form-group">
      <label>Delivery Date (optional)</label>
      <input type="date" id="confirmDate">
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Status (optional)</label>
      <select id="confirmStatus">
        <option value="">(no change)</option>
        <% ITEM_STATUSES.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-primary" onclick="applyConfirmUpdates()">Apply Updates</button>
      <button class="btn btn-ghost" onclick="document.getElementById('confirmUpdateModal').classList.remove('show')">Skip</button>
    </div>
  </div>
</div>

<!-- Log order confirmation dialog -->
<div id="orderModal" class="modal-overlay">
  <div class="modal">
    <h2>Log Order Confirmation</h2>
    <p class="modal-sub">Record what this vendor confirmed. Detected materials are pre-checked — adjust as needed.</p>
    <input type="hidden" id="orderThreadId">
    <input type="hidden" id="orderMessageId">
    <div style="font-size:.85rem;margin-bottom:.6rem">Vendor: <strong id="orderVendorLabel"></strong></div>
    <div class="form-group">
      <label>Materials ordered</label>
      <div id="orderMaterials" style="display:grid;grid-template-columns:1fr 1fr;gap:.35rem;margin-top:.35rem"></div>
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Total Amount ($) — optional</label>
      <input type="text" id="orderAmount" placeholder="e.g. 12,500.00">
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Receipt — optional</label>
      <div id="orderEmailAttachments" style="font-size:.85rem;margin:.25rem 0"></div>
      <small style="color:var(--muted);font-size:.75rem">Or upload a file:</small>
      <input type="file" id="orderReceiptFile">
    </div>
    <div class="modal-actions">
      <button class="btn btn-primary" id="orderSaveBtn" onclick="saveOrder()">Save Order</button>
      <button class="btn btn-ghost" onclick="document.getElementById('orderModal').classList.remove('show')">Cancel</button>
    </div>
  </div>
</div>

<!-- Upload a receipt PDF → auto-extract + categorize → review → save -->
<div id="receiptModal" class="modal-overlay">
  <div class="modal" style="max-width:660px">
    <h2>Upload Receipt</h2>
    <p class="modal-sub">Upload a vendor PDF — we'll pull the items and sort them into categories for you to review before saving.</p>
    <div id="receiptStep1">
      <div class="form-group">
        <label>Receipt PDF</label>
        <input type="file" id="receiptFile" accept="application/pdf">
      </div>
      <div class="modal-actions">
        <button class="btn btn-primary" id="receiptReadBtn" onclick="parseReceipt()">Read Receipt</button>
        <button class="btn btn-ghost" onclick="closeReceipt()">Cancel</button>
      </div>
    </div>
    <div id="receiptStep2" style="display:none">
      <div style="display:flex;gap:.6rem;flex-wrap:wrap">
        <div class="form-group" style="flex:1;min-width:200px"><label>Vendor</label><input type="text" id="receiptVendor"></div>
        <div class="form-group" style="width:130px"><label>Total ($)</label><input type="text" id="receiptAmount"></div>
      </div>
      <label style="font-size:.8rem;color:var(--muted)">Items — set the category for each (fix any that look wrong, ✕ to drop a row):</label>
      <div id="receiptLines" style="max-height:320px;overflow:auto;margin-top:.35rem"></div>
      <div class="modal-actions">
        <button class="btn btn-primary" id="receiptSaveBtn" onclick="saveReceiptOrder()">Save Order</button>
        <button class="btn btn-ghost" onclick="closeReceipt()">Cancel</button>
      </div>
    </div>
  </div>
</div>

<!-- Request delivery of a stage's items (replies to the order thread) -->
<div id="deliveryModal" class="modal-overlay">
  <div class="modal">
    <h2>Request Delivery</h2>
    <p class="modal-sub">Sends a reply on this order's thread asking the vendor to deliver these items now. Do this per stage, whenever you're ready.</p>
    <input type="hidden" id="delThreadId">
    <div class="form-group">
      <label>Stage</label>
      <select id="delStage" onchange="fillDeliveryItems()"></select>
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Items to request (uncheck any you're not ready for)</label>
      <div id="delItems" style="display:grid;grid-template-columns:1fr 1fr;gap:.35rem;margin-top:.3rem"></div>
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Delivery Date (sets the Delivery Date on these items)</label>
      <input type="date" id="delDate">
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Note (optional)</label>
      <input type="text" id="delNote" placeholder="e.g. Deliver Friday morning">
    </div>
    <div class="modal-actions">
      <button class="btn btn-primary" id="delSendBtn" onclick="sendDeliveryRequest()">Send Delivery Request</button>
      <button class="btn btn-ghost" onclick="document.getElementById('deliveryModal').classList.remove('show')">Cancel</button>
    </div>
  </div>
</div>

<!-- Request a category's items from the vendor -->
<div id="catReqModal" class="modal-overlay">
  <div class="modal">
    <h2 id="catReqTitle">Request Items</h2>
    <p class="modal-sub">Email the vendor a request for these items. Edit anything before sending.</p>
    <input type="hidden" id="catReqCode">
    <div class="form-group">
      <label>To</label>
      <input type="text" id="catReqTo" placeholder="vendor@example.com">
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Request type</label>
      <select id="catReqType">
        <option value="delivery">Request Delivery (deliver these now)</option>
        <option value="order">Reorder (place a new order)</option>
        <option value="quote">Request Quote (pricing/availability)</option>
        <option value="damage">Report Damage (arrived damaged — replace at no charge)</option>
        <option value="replacement">Request Replacement (send a new one)</option>
      </select>

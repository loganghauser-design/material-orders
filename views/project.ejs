<div id="toast" class="toast"></div>

<script>
const PROJECT_ID = '<%= project.id %>';
const ALL_MATERIALS = <%- JSON.stringify(STAGES.flatMap(s => s.items)) %>;
const STAGES_DATA = <%- JSON.stringify(STAGES) %>;
const CATEGORY_REQUEST_DATA = <%- JSON.stringify(categoryRequestData || []) %>;
const SUPPLIER_EMAILS = <%- JSON.stringify(Object.values(suppliers||{}).reduce((m,s)=>{ if(s&&s.name&&s.email) m[s.name.toLowerCase()]=s.email; return m; }, {})) %>;
// Forgiving vendor-name match (e.g. "Amerfit Hardware"=="Amerfit", "Tilebar"=="Tile Bar")
function normVendor(s){ return String(s||'').toLowerCase().replace(/\b(hardware|us|usa|inc|llc|co|enterprises|supply|construction|company|store|the)\b/g,'').replace(/[^a-z0-9]/g,''); }
function lookupVendorEmail(name){
  const n = normVendor(name);
  if (!n) return null;
  for (const k in SUPPLIER_EMAILS){
    const kn = normVendor(k);
    if (kn === n || (kn.length>=5 && n.length>=5 && (kn.includes(n)||n.includes(kn)))) return SUPPLIER_EMAILS[k];
  }
  return null;
}
let SCHEDULE_VENDORS = [];
let RFQ_COVERED = [];   // material codes the current auto-filled order covers
const STATUS_CLASSES = ['cell-not_yet_placed','cell-rfq_sent','cell-order_placed','cell-in_inventory','cell-delivered','cell-delivered_from_inv','cell-n_a','cell-issue'];
function statusToClass(st){ return 'cell-' + String(st).toLowerCase().replace(/[\s./]+/g,'_').replace(/[^a-z0-9_]/g,'').replace(/^_+|_+$/g,''); }
const THREAD_INFO = {};   // gmail_thread_id -> thread row (vendor name/email, item_code)
const THREAD_MSGS = {};   // gmail_thread_id -> messages array (with detected + attachments)

// ── Tabs ──────────────────────────────────────────────────────────────────
function showTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => { p.style.display = (p.dataset.tab === tab) ? 'block' : 'none'; });
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  if (tab === 'schedule') loadFinishSchedule();
  if (tab === 'materials') loadMaterialsSchedule();
}

let MAT_SCHED_LOADED = false;
async function loadMaterialsSchedule() {
  if (MAT_SCHED_LOADED) return;
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/schedule-by-category`);
    const data = await r.json();
    if (!data.ok || !data.byCode) { MAT_SCHED_LOADED = true; return; }
    const rhSrc = data.rangeHoodSource || 'default';
    const jSrc = data.jedcoSource || 'default';
    const heldStatuses = data.heldStatuses || ['In Office', 'Delivered'];
    function supplierCell(it) {
      if (it.hood) {
        const def = escapeHtmlJs(it.defaultSupplier || 'Vendor');
        return `<td style="padding:3px 6px"><select onchange="setRangeHoodSource(this.value)" title="Switch range hood supplier" style="font-size:.78rem;padding:1px 4px"><option value="default"${rhSrc !== 'buildoly' ? ' selected' : ''}>${def}</option><option value="buildoly"${rhSrc === 'buildoly' ? ' selected' : ''}>Buildoly Stock (office)</option></select></td>`;
      }
      if (it.jedco) {
        const def = escapeHtmlJs(it.defaultSupplier || 'JEDCO');
        return `<td style="padding:3px 6px"><select onchange="setJedcoSource(this.value)" title="Switch Jedco supplier" style="font-size:.78rem;padding:1px 4px"><option value="default"${jSrc !== 'buildoly' ? ' selected' : ''}>${def}</option><option value="buildoly"${jSrc === 'buildoly' ? ' selected' : ''}>Buildoly Stock (office)</option></select></td>`;
      }
      return `<td style="padding:3px 6px"><strong>${escapeHtmlJs(it.supplier || '')}</strong></td>`;
    }
    function officeCell(it) {
      if (!it.held) return '<td style="padding:3px 6px;color:var(--muted)">—</td>';
      const cur = it.officeStatus || 'In Office';
      const heldLabel = it.location === 'warehouse' ? 'In Warehouse' : 'In Office';
      const opts = heldStatuses.map(s => {
        const label = s === 'In Office' ? heldLabel : s;
        return `<option value="${escapeHtmlJs(s)}"${s === cur ? ' selected' : ''}>${escapeHtmlJs(label)}</option>`;
      }).join('');
      const cls = cur === 'Delivered' ? 'cell-delivered' : 'cell-in_inventory';
      const tag = it.location === 'warehouse' ? 'Warehouse-stock status' : 'Office-stock status';
      return `<td style="padding:3px 6px"><select class="status-select ${cls}" data-itemkey="${escapeHtmlJs(it.itemKey)}" data-loc="${it.location === 'warehouse' ? 'warehouse' : 'office'}" onchange="saveHeldStatus('${escapeHtmlJs(it.itemKey)}', this)" title="${tag}" style="font-size:.78rem;padding:1px 4px">${opts}</select></td>`;
    }
    Object.keys(data.byCode).forEach(code => {
      const items = data.byCode[code] || [];
      const cnt = document.getElementById('cnt_' + code);
      if (cnt) cnt.textContent = items.length ? '(' + items.length + ')' : '';
      const sub = document.getElementById('sub_' + code);
      if (sub) {
        const held = items.filter(i => i.held);
        const allDelivered = held.length > 0 && held.every(i => (i.officeStatus || 'In Office') === 'Delivered');
        const bulkBtn = held.length
          ? `<div style="margin:0 0 .5rem"><button type="button" class="btn btn-ghost btn-sm" onclick="markCategoryStock('${code}', '${allDelivered ? 'In Office' : 'Delivered'}')">${allDelivered ? '↩ Mark all stock back to in stock' : '✓ Mark all ' + held.length + ' stock item' + (held.length > 1 ? 's' : '') + ' delivered'}</button></div>`
          : '';
        sub.querySelector('.sched-items').innerHTML = items.length
          ? bulkBtn + '<table style="width:100%;border-collapse:collapse;font-size:.8rem"><tr style="border-bottom:2px solid var(--border);color:var(--muted);text-align:left"><th style="padding:3px 6px;font-weight:600">Item</th><th style="padding:3px 6px;font-weight:600">Product</th><th style="padding:3px 6px;font-weight:600">Brand</th><th style="padding:3px 6px;font-weight:600">Model #</th><th style="padding:3px 6px;font-weight:600">Qty</th><th style="padding:3px 6px;font-weight:600">Supplier</th><th style="padding:3px 6px;font-weight:600">Stock status</th></tr>' + items.map(it => `<tr style="border-bottom:1px solid var(--border)"><td style="padding:3px 6px">${escapeHtmlJs(it.name)}</td><td style="padding:3px 6px;color:var(--muted)">${escapeHtmlJs(it.product || '')}</td><td style="padding:3px 6px">${escapeHtmlJs(it.brand || '')}</td><td style="padding:3px 6px">${escapeHtmlJs(it.model || '')}</td><td style="padding:3px 6px">×${escapeHtmlJs(it.qty || '1')}</td>${supplierCell(it)}${officeCell(it)}</tr>`).join('') + '</table>'
          : '<div style="color:var(--muted);font-size:.8rem">No schedule items in this category.</div>';
      }
    });
    // Reveal the top "Mark all office stock delivered" bar with a live count.
    let officeHeld = 0, officeDelivered = 0;
    Object.keys(data.byCode).forEach(code => {
      (data.byCode[code] || []).forEach(i => {
        if (i.held && i.location !== 'warehouse') {
          officeHeld++;
          if ((i.officeStatus || 'In Office') === 'Delivered') officeDelivered++;
        }
      });
    });
    const bar = document.getElementById('bulkStockBar');
    const note = document.getElementById('bulkStockNote');
    if (bar) {
      bar.style.display = officeHeld ? 'flex' : 'none';
      if (note) note.textContent = officeHeld ? `${officeDelivered}/${officeHeld} delivered` : '';
    }
    MAT_SCHED_LOADED = true;
  } catch (e) { /* schedule unavailable — leave the materials list plain */ }
}
// Bulk-flip every held stock item in the project (optionally only office or warehouse).
async function markAllStock(status, locFilter) {
  let selects = Array.from(document.querySelectorAll('.tab-panel[data-tab="materials"] .status-select[data-itemkey]'));
  if (locFilter) selects = selects.filter(sel => (sel.dataset.loc || 'office') === locFilter);
  if (!selects.length) { showToast('Nothing to update (schedule still loading?)', true); return; }
  if (status === 'Delivered' && !confirm('Mark all ' + selects.length + ' office-stock item' + (selects.length > 1 ? 's' : '') + ' in this project as Delivered?')) return;
  showToast('Saving ' + selects.length + '…');
  try {
    await Promise.all(selects.map(sel => {
      sel.value = status;
      return fetch(`/projects/${PROJECT_ID}/held-status`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ item_key: sel.dataset.itemkey, status }) })
        .then(r => r.json())
        .then(d => { if (!d.ok) throw new Error('fail'); });
    }));
    showToast('Marked ' + selects.length + ' item' + (selects.length > 1 ? 's' : '') + ' → ' + status);
    MAT_SCHED_LOADED = false; loadMaterialsSchedule();
  } catch (e) { showToast('Some items could not be saved — please retry', true); }
}
function toggleCategory(code) {
  const sub = document.getElementById('sub_' + code), car = document.getElementById('car_' + code);
  if (!sub) return;
  const show = sub.style.display === 'none';
  sub.style.display = show ? '' : 'none';
  if (car) car.textContent = show ? '▾' : '▸';
}
async function setRecSource(source) {
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/rec-lighting-source`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ source }) });
    const data = await r.json();
    if (data.ok) {
      showToast(source === 'oncall' ? 'Recessed lighting → On Call LED' : 'Recessed lighting → GC Procure');
      MAT_SCHED_LOADED = false; loadMaterialsSchedule();   // refresh the 1e drill-down
    } else showToast('Could not save', true);
  } catch (e) { showToast('Could not save', true); }
}
async function setRangeHoodSource(source) {
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/range-hood-source`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ source }) });
    const data = await r.json();
    if (data.ok) {
      showToast(source === 'buildoly' ? 'Range hood → Buildoly Stock' : 'Range hood → schedule vendor');
      MAT_SCHED_LOADED = false; loadMaterialsSchedule();   // refresh the 2d drill-down
    } else showToast('Could not save', true);
  } catch (e) { showToast('Could not save', true); }
}
async function setJedcoSource(source) {
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/jedco-source`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ source }) });
    const data = await r.json();
    if (data.ok) {
      showToast(source === 'buildoly' ? 'Jedco items → Buildoly Stock' : 'Jedco items → JEDCO');
      MAT_SCHED_LOADED = false; loadMaterialsSchedule();   // refresh the drill-downs
    } else showToast('Could not save', true);
  } catch (e) { showToast('Could not save', true); }
}
async function saveHeldStatus(itemKey, sel) {
  const status = sel.value;
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/held-status`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ item_key: itemKey, status }) });
    const data = await r.json();
    if (data.ok) {
      sel.classList.remove('cell-in_inventory', 'cell-delivered');
      sel.classList.add(status === 'Delivered' ? 'cell-delivered' : 'cell-in_inventory');
      showToast('Stock status → ' + status);
    } else showToast('Could not save', true);
  } catch (e) { showToast('Could not save', true); }
}
// Bulk-flip every held item in a category (e.g. all Jedco grilles under HVAC Trim).
async function markCategoryStock(code, status) {
  const sub = document.getElementById('sub_' + code);
  if (!sub) return;
  const selects = Array.from(sub.querySelectorAll('.status-select[data-itemkey]'));
  if (!selects.length) return;
  showToast('Saving ' + selects.length + ' item' + (selects.length > 1 ? 's' : '') + '…');
  try {
    await Promise.all(selects.map(sel => {
      sel.value = status;
      return fetch(`/projects/${PROJECT_ID}/held-status`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ item_key: sel.dataset.itemkey, status }) })
        .then(r => r.json())
        .then(d => {
          if (d.ok) {
            sel.classList.remove('cell-in_inventory', 'cell-delivered');
            sel.classList.add(status === 'Delivered' ? 'cell-delivered' : 'cell-in_inventory');
          } else throw new Error('save failed');
        });
    }));
    showToast('Marked ' + selects.length + ' item' + (selects.length > 1 ? 's' : '') + ' → ' + status);
    // Re-render so the button flips to its opposite (Mark all delivered ⇄ revert).
    MAT_SCHED_LOADED = false; loadMaterialsSchedule();
  } catch (e) { showToast('Some items could not be saved — please retry', true); }
}
document.addEventListener('DOMContentLoaded', () => showTab('materials'));

let FIN_SCHED_LOADED = false;
async function loadFinishSchedule(force) {
  if (FIN_SCHED_LOADED && !force) return;
  const el = document.getElementById('finSchedView');
  el.innerHTML = '<div style="color:var(--muted);font-size:.85rem">Loading from Google Sheet…</div>';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/finish-schedule`);
    const data = await r.json();
    if (!data.ok) { el.innerHTML = `<div style="color:var(--danger);font-size:.85rem">${escapeHtmlJs(data.error || 'Could not load')}</div>`; return; }
    if (!data.items || !data.items.length) { el.innerHTML = `<div style="color:var(--muted);font-size:.85rem">${escapeHtmlJs(data.note || 'No schedule.')}</div>`; FIN_SCHED_LOADED = true; return; }
    let n = 0;
    let html = '<table style="width:100%;border-collapse:collapse;font-size:.82rem"><thead><tr>' +
      ['Item', 'Product', 'Cat', 'Brand', 'Model #', 'Qty', 'Cost', 'Supplier'].map(h => `<th style="text-align:left;border-bottom:2px solid var(--border);padding:5px 7px">${h}</th>`).join('') + '</tr></thead><tbody>';
    data.items.forEach(it => {
      if (it.type === 'section') html += `<tr><td colspan="8" style="background:var(--bg);font-weight:700;padding:6px 7px;border-top:1px solid var(--border)">${escapeHtmlJs(it.name)}</td></tr>`;
      else if (it.type === 'subtotal') html += `<tr><td colspan="7" style="text-align:right;color:var(--muted);padding:4px 7px;font-size:.78rem">Subtotal</td><td style="padding:4px 7px;color:var(--muted)">${escapeHtmlJs(it.total || '')}</td></tr>`;
      else { n++; html += `<tr style="border-bottom:1px solid var(--border)"><td style="padding:4px 7px">${escapeHtmlJs(it.name)}</td><td style="padding:4px 7px;color:var(--muted)">${escapeHtmlJs(it.product || '')}</td><td style="padding:4px 7px;color:var(--muted)">${escapeHtmlJs((it.category || '').slice(0, 2))}</td><td style="padding:4px 7px">${escapeHtmlJs(it.brand || '')}</td><td style="padding:4px 7px">${escapeHtmlJs(it.model || '')}</td><td style="padding:4px 7px">${escapeHtmlJs(it.qty || '')}</td><td style="padding:4px 7px">${escapeHtmlJs(it.cost || '')}</td><td style="padding:4px 7px"><strong>${escapeHtmlJs(it.supplier || '')}</strong></td></tr>`; }
    });
    html += '</tbody></table>';
    el.innerHTML = `<div style="font-size:.78rem;color:var(--muted);margin-bottom:.4rem">${n} items</div>` + html;
    FIN_SCHED_LOADED = true;
  } catch (e) {
    el.innerHTML = '<div style="color:var(--danger);font-size:.85rem">Could not load schedule.</div>';
  }
}

// Toggle a spec package (e.g. Moen) for this project, then refresh the views it affects.
async function togglePackage(key) {
  const btn = document.getElementById('pkgBtn_' + key);
  const turnOn = btn.dataset.on !== '1';
  const orig = btn.textContent;
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/package`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: key, on: turnOn }),
    });
    const data = await r.json();
    if (!data.ok) { showToast(data.error || 'Could not save', true); btn.textContent = orig; btn.disabled = false; return; }
    const on = data.active.includes(key);
    btn.dataset.on = on ? '1' : '0';
    btn.classList.toggle('btn-primary', on);
    btn.classList.toggle('btn-ghost', !on);
    btn.disabled = false;
    btn.textContent = (on ? '✓ ' : '') + key.charAt(0).toUpperCase() + key.slice(1) + ' package';
    showToast(on ? 'Package on — matching items now spec that brand' : 'Package off');
    // Refresh the views that read the schedule so the override shows immediately.
    FIN_SCHED_LOADED = false; loadFinishSchedule(true);
    MAT_SCHED_LOADED = false; if (typeof loadMaterialsSchedule === 'function') loadMaterialsSchedule();
    SCHEDULE_VENDORS = [];   // force Email Vendor to re-pull vendor items next open
  } catch (e) { showToast('Could not save', true); btn.textContent = orig; btn.disabled = false; }
}


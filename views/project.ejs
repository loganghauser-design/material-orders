  document.getElementById('deliveryModal').classList.add('show');
}
function fillDeliveryItems() {
  const i = Number(document.getElementById('delStage').value);
  const stage = STAGES_DATA[i] || { items: [] };
  document.getElementById('delItems').innerHTML = stage.items.map(m => `
    <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem">
      <input type="checkbox" class="del-cb" value="${m.code}" checked>
      <span>${escapeHtmlJs(m.name)}</span>
    </label>`).join('');
}
async function sendDeliveryRequest() {
  const btn = document.getElementById('delSendBtn');
  const threadId = document.getElementById('delThreadId').value;
  const itemCodes = Array.from(document.querySelectorAll('#delItems .del-cb:checked')).map(c => c.value);
  const note = document.getElementById('delNote').value.trim();
  const deliveryDate = document.getElementById('delDate').value;
  if (!itemCodes.length) { showToast('Pick at least one item', true); return; }
  btn.disabled = true; btn.textContent = 'Sending…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/request-delivery`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ threadId, itemCodes, note, deliveryDate }),
    });
    const data = await r.json();
    if (data.ok) {
      showToast('Delivery request sent — ' + data.count + ' item(s)');
      document.getElementById('deliveryModal').classList.remove('show');
      loadThreads();
    } else {
      showToast(data.error || 'Send failed', true);
    }
  } catch (e) {
    showToast('Send failed', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Send Delivery Request';
  }
}

// ── Request a category's items from the vendor ────────────────────────────
function openCategoryRequest(code) {
  const c = (CATEGORY_REQUEST_DATA || []).find(x => x.code === code);
  if (!c) { showToast('No items to request', true); return; }
  document.getElementById('catReqCode').value = code;
  document.getElementById('catReqTitle').textContent = 'Request — ' + c.name;
  document.getElementById('catReqTo').value = c.vendorEmail || '';
  document.getElementById('catReqType').value = 'delivery';
  document.getElementById('catReqItems').value = c.items
    .map(it => (it.qty > 1 ? it.qty + 'x ' : '') + it.desc + (it.code ? ' (' + it.code + ')' : ''))
    .join('\n');
  document.getElementById('catReqNote').value = '';
  document.getElementById('catReqModal').classList.add('show');
}

async function sendCategoryRequest() {
  const btn = document.getElementById('catReqSendBtn');
  const category = document.getElementById('catReqCode').value;
  const to = document.getElementById('catReqTo').value.trim();
  const emailType = document.getElementById('catReqType').value;
  const items = document.getElementById('catReqItems').value.trim();
  const note = document.getElementById('catReqNote').value.trim();
  if (!to) { showToast('Enter a recipient email', true); return; }
  if (!items) { showToast('No items to request', true); return; }
  btn.disabled = true; btn.textContent = 'Sending…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/category-request`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ category, to, emailType, items, note }),
    });
    const data = await r.json();
    if (data.ok) {
      showToast('Request sent to ' + data.sentTo);
      document.getElementById('catReqModal').classList.remove('show');
      loadThreads();
    } else {
      showToast(data.error || 'Send failed', true);
    }
  } catch (e) {
    showToast('Send failed', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Send Request';
  }
}

async function deleteThread(id) {
  if (!confirm('Remove this email from the list?\n(It stays in your Gmail — this only clears it from the app.)')) return;
  try {
    const r = await fetch(`/vendor-emails/${id}/delete`, { method: 'POST' });
    const data = await r.json();
    if (data.ok) { showToast('Removed'); loadThreads(); }
    else showToast(data.error || 'Could not remove', true);
  } catch (e) { showToast('Could not remove', true); }
}

function showToast(msg, err) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (err ? ' error' : '');
  setTimeout(() => t.className = 'toast', 2000);
}
</script>
</body>
</html>

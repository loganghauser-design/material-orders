// Save how many of a single held item are delivered (partial allowed).
async function saveHeldQty(input) {
  const max = parseInt(input.dataset.max, 10) || 0;
  let val = Math.max(0, Math.min(parseInt(input.value, 10) || 0, max));
  input.value = val;
  const prev = parseInt(input.dataset.prev, 10) || 0;
  if (val === prev) return;
  input.disabled = true;
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/held-status`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ item_key: input.dataset.itemkey, delivered_qty: val }) });
    const d = await r.json();
    if (!d.ok) throw new Error(d.error || 'fail');
    input.dataset.prev = val; applyHeldQtyClass(input, val, max);
    showToast('Delivered ' + val + ' of ' + max);
  } catch (e) { input.value = prev; showToast('Could not save', true); }
  finally { input.disabled = false; }
}
// Bulk-set every held item in a category (e.g. all Jedco grilles under HVAC Trim).
async function markCategoryStock(code, mode) {
  const sub = document.getElementById('sub_' + code);
  if (!sub) return;
  const inputs = Array.from(sub.querySelectorAll('.held-qty'));
  if (!inputs.length) return;
  showToast('Saving ' + inputs.length + ' item' + (inputs.length > 1 ? 's' : '') + '…');
  try {
    await setHeldQtyInputs(inputs, mode);
    showToast('Updated ' + inputs.length + ' item' + (inputs.length > 1 ? 's' : ''));
    MAT_SCHED_LOADED = false; loadMaterialsSchedule();
  } catch (e) { showToast('Some items could not be saved — please retry', true); }
}

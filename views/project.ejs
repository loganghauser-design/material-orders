// When ordering from a request, auto-tick only the requested category codes.
function applyOrderFilter() {
  if (!ORDER_CODES.length) return;
  let any = false;
  getItemChecks().forEach(chk => {
    const tr = chk.closest('tr');
    const on = !!(tr && ORDER_CODES.includes(tr.getAttribute('data-code')));
    chk.checked = on; if (on) any = true;
  });
  updateItemCount();
  return any;
}
// Tick only the items in the chosen stage/category (blank = all stages).
function filterByStage() {
  const code = document.getElementById('rfqStage').value;
  getItemChecks().forEach(chk => {
    const tr = chk.closest('tr');
    chk.checked = !code || (tr && tr.getAttribute('data-code') === code);
  });
  updateItemCount();
}

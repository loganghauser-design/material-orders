<script>
const PROJECT_ID = '<%= project.id %>';
const ALL_MATERIALS = <%- JSON.stringify(STAGES.flatMap(s => s.items)) %>;
const STAGES_DATA = <%- JSON.stringify(STAGES) %>;
const CATEGORY_REQUEST_DATA = <%- JSON.stringify(categoryRequestData || []) %>;
const PROJECT_ISSUES = <%- JSON.stringify(projectIssues || []) %>;
function issueForItem(code, name, room) {
  const full = (room ? room + ' — ' + name : name).trim().toLowerCase();
  const just = (name || '').trim().toLowerCase();
  return PROJECT_ISSUES.find(i => { const l = (i.label || '').trim().toLowerCase(); return i.code === code && (l === full || l === just); }) || null;
}
function issueBadge(code, name, room) {
  const i = issueForItem(code, name, room);
  if (!i) return '';
  return ` <span class="iss-flag" style="cursor:help" title="${escapeHtmlJs(i.sup + ': ' + (i.note || ''))}">⚠ Issue</span>`;
}
// Field Requests panel — act on a super's request without leaving the project
async function frFulfill(id) {
  if (!confirm('Mark this field request as done?')) return;
  try {
    const r = await fetch('/requests/' + id + '/fulfill', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ action:'fulfill' }) });
    const d = await r.json();
    if (d.ok) location.reload(); else alert('Could not update.');
  } catch (e) { alert('Could not update.'); }
}
async function frRespond(id) {
  const inp = document.getElementById('frresp_' + id);
  const body = (inp.value || '').trim();
  if (!body) return;
  inp.disabled = true;
  try {
    const r = await fetch('/requests/' + id + '/respond', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ body }) });
    const d = await r.json();
    if (d.ok) { inp.value = ''; inp.disabled = false; inp.placeholder = '✓ Sent — reply again if needed'; }
    else { alert('Could not send: ' + (d.error || 'error')); inp.disabled = false; }
  } catch (e) { alert('Could not send.'); inp.disabled = false; }
}
const SUPPLIER_EMAILS = <%- JSON.stringify(Object.values(suppliers||{}).reduce((m,s)=>{ if(s&&s.name&&s.email) m[s.name.toLowerCase()]=s.email; return m; }, {})) %>;
// Forgiving vendor-name match (e.g. "Amerfit Hardware"=="Amerfit", "Tilebar"=="Tile Bar")
function normVendor(s){ return String(s||'').toLowerCase().replace(/\b(hardware|us|usa|inc|llc|co|enterprises|supply|construction|company|store|the)\b/g,'').replace(/[^a-z0-9]/g,''); }
function lookupVendorEmail(name){
  const n = normVendor(name);
  if (!n) return null;
  for (const k in SUPPLIER_EMAILS){
    const kn = normVendor(k);
    if (kn === n || (kn.length>=5 && n.length>=5 && (kn.includes(n)||n.includes(kn)))) return SUPPLIER_EMAILS[k];
  }
  return null;
}
let SCHEDULE_VENDORS = [];
let RFQ_COVERED = [];   // material codes the current auto-filled order covers
const STATUS_CLASSES = ['cell-not_yet_placed','cell-delivery_requested','cell-rfq_sent','cell-order_placed','cell-in_inventory','cell-delivered','cell-delivered_from_inv','cell-n_a','cell-issue'];
function statusToClass(st){ return 'cell-' + String(st).toLowerCase().replace(/[\s./]+/g,'_').replace(/[^a-z0-9_]/g,'').replace(/^_+|_+$/g,''); }
const THREAD_INFO = {};   // gmail_thread_id -> thread row (vendor name/email, item_code)
const THREAD_MSGS = {};   // gmail_thread_id -> messages array (with detected + attachments)

// ── Tabs ──────────────────────────────────────────────────────────────────
function showTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => { p.style.display = (p.dataset.tab === tab) ? 'block' : 'none'; });
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  if (tab === 'schedule') loadFinishSchedule();
  if (tab === 'materials') loadMaterialsSchedule();
}

// Per-item delivery state, keyed by item key (PC:/MN:/NM:) and normalized model #
// (states come from Ferguson orders/emails; manual clicks override — st.m === 1).
const ITEM_STATES = <%- JSON.stringify(typeof itemStates !== 'undefined' ? itemStates : {}) %>;
function itemKeyForJs(prodCode, model, name) {
  const pc = String(prodCode || '').trim().toUpperCase();
  if (pc && pc !== 'CUSTOM') return 'PC:' + pc;
  const mn = String(model || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
  if (mn.length >= 5) return 'MN:' + mn;
  return 'NM:' + String(name || '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 60);
}
function deliveryBadge(key, mn) {
  const st = ITEM_STATES[key] || ((mn && mn.length >= 5) ? ITEM_STATES[mn] : null);
  const cur = st ? st.st : '';
  const man = st && st.m ? '1' : '';
  const attrs = `class="dlv-badge${man ? ' dlv-manual' : ''}" data-key="${escapeHtmlJs(key)}" data-cur="${cur}" data-m="${man}" onclick="cycleMark(this)"`;
  const hint = man ? ' Set by hand — click to change (✅ then reverts to auto).' : ' Click to set by hand.';
  if (cur === 'd') return `<span ${attrs} style="background:#e7f6ec;color:#176b3a" title="Delivered.${hint}">✅ Delivered</span>`;
  if (cur === 's') {
    const when = String(st.when || '').split(' between')[0].replace(/,?\s*\d{4}\s*$/, '');
    return `<span ${attrs} style="background:#e0e7ff;color:#3730a3" title="${escapeHtmlJs(st.when || 'Delivery scheduled')}.${hint}">🚚 ${escapeHtmlJs(when || 'Scheduled')}</span>`;
  }
  if (cur === 'o') return `<span ${attrs} style="background:#fff4dd;color:#8a6100" title="On a confirmed order — delivery not scheduled yet.${hint}">📦 Ordered</span>`;
  return `<span ${attrs} style="background:var(--bg);color:var(--muted)" title="No order or delivery seen yet. Click to mark 📦 ordered by hand.">—</span>`;
}
function deliveryCell(it) {
  const mn = String(it.model || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
  return '<td style="padding:3px 6px;white-space:nowrap">' + deliveryBadge(itemKeyForJs(it.prodCode, it.model, it.name), mn) + '</td>';
}
// Click a badge to cycle — → 📦 → 🚚 → ✅ → back to automatic.
async function cycleMark(el) {
  const cur = el.dataset.cur || '';
  const next = cur === '' ? 'ordered' : cur === 'o' ? 'scheduled' : cur === 's' ? 'delivered' : '';
  let when = '';
  if (next === 'scheduled') when = prompt('Scheduled for (optional — e.g. "Jul 12"):') || '';
  const key = el.dataset.key;
  try {
    const r = await fetch(`/projects/<%= project.id %>/item-mark`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key, state: next, when }),
    });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || 'save failed');
    if (data.st) ITEM_STATES[key] = data.st; else delete ITEM_STATES[key];
    el.outerHTML = deliveryBadge(key, '');
    if (data.agg && data.agg.counts) updateBucketBar(data.agg.code, data.agg.counts);
    if (data.bucketStatus) {
      const mr = document.querySelector(`tr.mat-row[data-code="${data.bucketStatus.code}"]`);
      const ss = mr && mr.querySelector('.item-status');
      if (ss && ss.value !== data.bucketStatus.status) {
        ss.value = data.bucketStatus.status;
        STATUS_CLASSES.forEach(c => ss.classList.remove(c));
        ss.classList.add(statusToClass(data.bucketStatus.status));
      }
      showToast('🎉 All ' + data.bucketStatus.code + ' items delivered — bucket marked Delivered');
    } else {
      showToast(next ? 'Marked ' + (next === 'delivered' ? '✅ delivered' : next === 'scheduled' ? '🚚 scheduled' : '📦 ordered') : '↩ Back to automatic');
    }
  } catch (e) { showToast('Not saved — please try again', true); }
}
// Keep the bucket row's progress bar + counts in sync after a manual mark.
function updateBucketBar(code, c) {
  const bar = document.getElementById('bar_' + code), chip = document.getElementById('chip_' + code);
  if (!bar || !chip || !c.total) return;
  const seg = bar.querySelectorAll('i');
  seg[0].style.width = Math.round(c.delivered / c.total * 100) + '%';
  seg[1].style.width = Math.round(c.scheduled / c.total * 100) + '%';
  seg[2].style.width = Math.round(c.ordered / c.total * 100) + '%';
  chip.textContent = c.delivered + '/' + c.total + ' delivered' + (c.scheduled ? ' · ' + c.scheduled + ' scheduled' : '') + (c.ordered ? ' · ' + c.ordered + ' ordered' : '');
  chip.style.color = c.delivered === c.total ? '#176b3a' : '';
}

let MAT_SCHED_LOADED = false;
async function loadMaterialsSchedule() {
  if (MAT_SCHED_LOADED) return;
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/schedule-by-category`);
    const data = await r.json();
    if (!data.ok || !data.byCode) { MAT_SCHED_LOADED = true; return; }
    const rhSrc = data.rangeHoodSource || 'default';
    const jSrc = data.jedcoSource || 'default';
    const heldStatuses = data.heldStatuses || ['In Office', 'Delivered'];
    function supplierCell(it) {
      if (it.hood) {
        const def = escapeHtmlJs(it.defaultSupplier || 'Vendor');
        return `<td style="padding:3px 6px"><select onchange="setRangeHoodSource(this.value)" title="Switch range hood supplier" style="font-size:.78rem;padding:1px 4px"><option value="default"${rhSrc !== 'buildoly' ? ' selected' : ''}>${def}</option><option value="buildoly"${rhSrc === 'buildoly' ? ' selected' : ''}>Buildoly Stock (office)</option></select></td>`;
      }
      if (it.jedco) {
        const def = escapeHtmlJs(it.defaultSupplier || 'JEDCO');
        return `<td style="padding:3px 6px"><select onchange="setJedcoSource(this.value)" title="Switch Jedco supplier" style="font-size:.78rem;padding:1px 4px"><option value="default"${jSrc !== 'buildoly' ? ' selected' : ''}>${def}</option><option value="buildoly"${jSrc === 'buildoly' ? ' selected' : ''}>Buildoly Stock (office)</option></select></td>`;
      }
      return `<td style="padding:3px 6px"><strong>${escapeHtmlJs(it.supplier || '')}</strong></td>`;
    }
    function officeCell(it) {
      if (!it.held) return '<td style="padding:3px 6px;color:var(--muted)">—</td>';
      const max = Number(it.allocQty) || 1;
      const cur = Number(it.deliveredQty) || 0;
      const loc = it.location === 'warehouse' ? 'warehouse' : 'office';
      const cls = cur >= max ? 'qty-done' : (cur > 0 ? 'qty-partial' : 'qty-none');
      return `<td style="padding:3px 6px;white-space:nowrap"><input type="number" class="held-qty ${cls}" min="0" max="${max}" value="${cur}" data-itemkey="${escapeHtmlJs(it.itemKey)}" data-max="${max}" data-prev="${cur}" data-loc="${loc}" onchange="saveHeldQty(this)" title="How many delivered (of ${max})" style="width:46px;text-align:center;font-size:.8rem;padding:2px 3px;border:1px solid var(--border);border-radius:5px"> <span style="color:var(--muted);font-size:.74rem">/ ${max} delivered</span></td>`;
    }
    Object.keys(data.byCode).forEach(code => {
      const items = data.byCode[code] || [];
      const cnt = document.getElementById('cnt_' + code);
      if (cnt) cnt.textContent = items.length ? '(' + items.length + ')' : '';
      const sub = document.getElementById('sub_' + code);
      if (sub) {
        const held = items.filter(i => i.held);
        const allDelivered = held.length > 0 && held.every(i => (Number(i.deliveredQty) || 0) >= (Number(i.allocQty) || 1));
        const bulkBtn = held.length
          ? `<div style="margin:0 0 .5rem"><button type="button" class="btn btn-ghost btn-sm" onclick="markCategoryStock('${code}', '${allDelivered ? 'none' : 'all'}')">${allDelivered ? '↩ Mark all stock back to in stock' : '✓ Mark all ' + held.length + ' stock item' + (held.length > 1 ? 's' : '') + ' delivered'}</button></div>`
          : '';
        sub.querySelector('.sched-items').innerHTML = items.length
          ? bulkBtn + '<table style="width:100%;border-collapse:collapse;font-size:.8rem"><tr style="border-bottom:2px solid var(--border);color:var(--muted);text-align:left"><th style="padding:3px 6px;font-weight:600">Item</th><th style="padding:3px 6px;font-weight:600">Product</th><th style="padding:3px 6px;font-weight:600">Brand</th><th style="padding:3px 6px;font-weight:600">Model #</th><th style="padding:3px 6px;font-weight:600">Finish/Color</th><th style="padding:3px 6px;font-weight:600">Qty</th><th style="padding:3px 6px;font-weight:600">Supplier</th><th style="padding:3px 6px;font-weight:600">Stock status</th><th style="padding:3px 6px;font-weight:600" title="Ferguson fills this automatically — for other vendors, click a badge to set it by hand (—→📦→🚚→✅→auto)">Delivery ✎</th></tr>' + items.map(it => `<tr style="border-bottom:1px solid var(--border)${issueForItem(code, it.name, it.room) ? ';background:#fef2f2' : ''}"><td style="padding:3px 6px">${it.room ? '<span style="color:var(--muted);font-weight:600">'+escapeHtmlJs(it.room)+' · </span>' : ''}${escapeHtmlJs(it.name)}${issueBadge(code, it.name, it.room)}</td><td style="padding:3px 6px;color:var(--muted)">${escapeHtmlJs(it.product || '')}</td><td style="padding:3px 6px">${escapeHtmlJs(it.brand || '')}</td><td style="padding:3px 6px">${escapeHtmlJs(it.model || '')}</td><td style="padding:3px 6px">${escapeHtmlJs(it.finishColor || '')}</td><td style="padding:3px 6px">×${escapeHtmlJs(it.qty || '1')}</td>${supplierCell(it)}${officeCell(it)}${deliveryCell(it)}</tr>`).join('') + '</table>'
          : '<div style="color:var(--muted);font-size:.8rem">No schedule items in this category.</div>';
      }
    });
    // Reveal the top "Mark all office stock delivered" bar with a live count.
    let officeHeld = 0, officeDelivered = 0;
    Object.keys(data.byCode).forEach(code => {
      (data.byCode[code] || []).forEach(i => {
        if (i.held && i.location !== 'warehouse') {
          officeHeld++;
          if ((Number(i.deliveredQty) || 0) >= (Number(i.allocQty) || 1)) officeDelivered++;
        }
      });
    });
    const bar = document.getElementById('bulkStockBar');
    const note = document.getElementById('bulkStockNote');
    if (bar) {
      bar.style.display = officeHeld ? 'flex' : 'none';
      if (note) note.textContent = officeHeld ? `${officeDelivered}/${officeHeld} delivered` : '';
    }
    MAT_SCHED_LOADED = true;
  } catch (e) { /* schedule unavailable — leave the materials list plain */ }
}
function applyHeldQtyClass(inp, val, max) {
  inp.classList.remove('qty-done', 'qty-partial', 'qty-none');
  inp.classList.add(val >= max ? 'qty-done' : (val > 0 ? 'qty-partial' : 'qty-none'));
}
// Set a list of held-qty inputs fully delivered ('all') or back to zero ('none').
async function setHeldQtyInputs(inputs, mode) {
  await Promise.all(inputs.map(inp => {
    const max = parseInt(inp.dataset.max, 10) || 0;
    const val = mode === 'all' ? max : 0;
    inp.value = val; inp.dataset.prev = val; applyHeldQtyClass(inp, val, max);
    return fetch(`/projects/${PROJECT_ID}/held-status`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ item_key: inp.dataset.itemkey, delivered_qty: val }) })
      .then(r => r.json()).then(d => { if (!d.ok) throw new Error('fail'); });
  }));
}
// Bulk-set every held stock item in the project (optionally only office or warehouse).
async function markAllStock(mode, locFilter) {
  let inputs = Array.from(document.querySelectorAll('.tab-panel[data-tab="materials"] .held-qty'));
  if (locFilter) inputs = inputs.filter(i => (i.dataset.loc || 'office') === locFilter);
  if (!inputs.length) { showToast('Nothing to update (schedule still loading?)', true); return; }
  if (mode === 'all' && !confirm('Mark all ' + inputs.length + ' office-stock item' + (inputs.length > 1 ? 's' : '') + ' fully delivered?')) return;
  showToast('Saving ' + inputs.length + '…');
  try {
    await setHeldQtyInputs(inputs, mode);
    showToast('Updated ' + inputs.length + ' item' + (inputs.length > 1 ? 's' : ''));
    MAT_SCHED_LOADED = false; loadMaterialsSchedule();
  } catch (e) { showToast('Some items could not be saved — please retry', true); }
}

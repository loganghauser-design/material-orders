<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= project.address %></title>
  <link rel="stylesheet" href="/css/app.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#4f8ef7">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="apple-touch-icon" href="/icon.svg">
  <script>if('serviceWorker' in navigator){window.addEventListener('load',function(){navigator.serviceWorker.register('/sw.js').catch(function(){});});}</script>
</head>
<body>
<%- include('_nav', { active: '' }) %>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
    <div>
      <h1><%= project.address %></h1>
      <div style="color:var(--muted);margin-top:.25rem"><%= project.version || '' %></div>
    </div>
    <% var _ph = project.phase || (project.overall_status === 'Fully Delivered' ? 'Complete' : (project.overall_status === 'Not Yet' ? 'Pre-Construction' : 'Under Construction')); %>
    <span class="badge phb-<%= _ph.toLowerCase().replace(/[^a-z]+/g,'_') %>" style="font-size:.95rem;padding:.4rem 1rem"><%= _ph %></span>
    <a href="/projects/<%= project.id %>/edit" class="btn btn-ghost btn-sm" title="Edit address, client name/email, status, notes">✎ Edit project</a>
    <% if (project.notes) { %><div style="color:var(--muted);font-size:.875rem"><%= project.notes %></div><% } %>
    <% const _assigned = (project.super_email || '').split(',').map(e => e.trim().toLowerCase()).filter(Boolean); %>
    <div style="margin-left:auto;display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;background:var(--bg);border:1px solid var(--border);border-radius:9px;padding:.4rem .65rem">
      <span style="font-size:.85rem;font-weight:600">👷 Supers:</span>
      <% supers.forEach(s => { const on = _assigned.includes(s.email.toLowerCase()); %>
        <button type="button" class="super-chip<%= on ? ' on' : '' %>" data-email="<%= s.email %>" onclick="toggleSuper(this)"><%= on ? '✓ ' : '' %><%= s.name %></button>
      <% }) %>
      <span style="font-size:.72rem;color:var(--muted)">click any working this job — they get tagged on delivery alerts</span>
    </div>
  </div>

  <style>
    .tabs{display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;margin:.25rem 0 1.1rem;border-bottom:1px solid var(--border);padding-bottom:.55rem}
    .tab-btn{background:none;border:1px solid var(--border);border-radius:7px;padding:.45rem 1rem;cursor:pointer;font-size:.92rem;color:var(--muted)}
    .tab-btn.active{background:#4f8ef7;color:#fff;border-color:#4f8ef7;font-weight:600}
    .super-chip{font-size:.82rem;padding:.25rem .7rem;border:1px solid var(--border);border-radius:14px;background:var(--surface);color:var(--text);cursor:pointer}
    .super-chip:hover{border-color:#4f8ef7}
    .super-chip.on{background:#4f8ef7;color:#fff;border-color:#4f8ef7;font-weight:600}
    .super-chip:disabled{opacity:.55;cursor:default}
    .held-qty.qty-done{background:#6aa84f;color:#fff;border-color:#6aa84f;font-weight:600}
    .held-qty.qty-partial{background:#fde6c8;color:#8a4b00;border-color:#e0a106}
    .held-qty.qty-none{background:#ede0fb;color:#5b2a86}
    .field-requests{background:#fffbeb;border:1px solid #f6c886;border-radius:12px;padding:.9rem 1rem;margin:0 0 1.2rem}
    .fr-title{font-weight:800;font-size:1rem;color:#8a5300;margin-bottom:.3rem}
    .fr-count{background:#e0531f;color:#fff;border-radius:9px;padding:0 8px;font-size:.78rem;vertical-align:middle}
    .fr-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:.7rem .85rem;margin-top:.6rem}
    .fr-head{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .fr-need{font-size:.78rem;font-weight:700;color:#b45309;margin-left:.4rem}
    .fr-items{margin:.5rem 0 .2rem;line-height:1.9}
    .fr-item{display:inline-flex;align-items:center;gap:.3rem;margin-right:.7rem;font-weight:600;font-size:.92rem;white-space:nowrap}
    .fr-pill{font-size:.64rem;font-weight:700;padding:1px 7px;border-radius:9px}
    .fr-pill-deliv{background:#dcfce7;color:#166534}.fr-pill-order{background:#dbeafe;color:#1d4ed8}.fr-pill-rfq{background:#fef3c7;color:#92400e}.fr-pill-issue{background:#fee2e2;color:#b91c1c}.fr-pill-none{background:#e5e7eb;color:#555}
    .fr-note{font-size:.9rem;line-height:1.45;white-space:pre-wrap;margin:.35rem 0 .1rem;color:var(--text)}
    .fr-respond{display:flex;gap:.5rem;margin-top:.55rem}
    .fr-respond input{flex:1;padding:.45rem .65rem;border:1px solid var(--border);border-radius:8px;background:var(--surface);font-size:.86rem}
    .req-flag{display:inline-block;background:#fde68a;color:#92400e;font-size:.7rem;font-weight:700;padding:1px 8px;border-radius:10px;white-space:nowrap;vertical-align:middle;text-decoration:none;cursor:pointer}
    .req-flag:hover{background:#fcd34d}
    .iss-flag{display:inline-block;background:#fee2e2;color:#b91c1c;font-size:.7rem;font-weight:700;padding:1px 8px;border-radius:10px;white-space:nowrap;vertical-align:middle;text-decoration:none;cursor:pointer;max-width:260px;overflow:hidden;text-overflow:ellipsis}
    .iss-flag:hover{background:#fecaca}
    .item-date,.item-date-end{width:122px;font-size:.8rem}
    .item-date-end{opacity:.9}
    .notify-btn{border:1px solid var(--border);background:var(--surface);border-radius:6px;padding:2px 7px;cursor:pointer;font-size:.85rem;margin-left:3px;vertical-align:middle}
    .notify-btn:hover{background:#4f8ef7;border-color:#4f8ef7}
    .notify-btn:disabled{opacity:.6;cursor:default}
    .tab-panel{display:none}
    .modal{max-height:90vh;overflow-y:auto}
    .modal-overlay{padding:2vh 0}
  </style>
  <div class="tabs">
    <button type="button" class="tab-btn active" data-tab="materials" onclick="showTab('materials')">🧱 Materials</button>
    <button type="button" class="tab-btn" data-tab="orders" onclick="showTab('orders')">📦 Orders</button>
    <button type="button" class="tab-btn" data-tab="emails" onclick="showTab('emails')">✉️ Emails</button>
    <button type="button" class="tab-btn" data-tab="docs" onclick="showTab('docs')">📄 Docs &amp; $</button>
    <button type="button" class="tab-btn" data-tab="schedule" onclick="showTab('schedule')">📋 Finish Schedule</button>
    <button type="button" class="btn btn-primary" style="margin-left:auto" onclick="openRfqDialog('','','','')">📧 Email Vendor</button>
  </div>

  <div class="tab-panel" data-tab="schedule">
    <div class="email-card">
      <div class="email-header">
        <div><strong>Finish Schedule</strong><div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Read live from your Google Sheet — verify what the app sees.</div></div>
        <button class="btn btn-ghost btn-sm" onclick="loadFinishSchedule(true)">↻ Refresh</button>
      </div>
      <div id="finSchedView" style="margin-top:.5rem;overflow-x:auto"><div style="color:var(--muted);font-size:.85rem">Open this tab to load…</div></div>
    </div>
  </div>

  <div class="tab-panel" data-tab="emails">
  <!-- Milestone payment emails -->
  <div class="email-card">
    <div class="email-header">
      <div>
        <strong>Send Client Milestone Email</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">
          <% if (project.client_email) { %>
            To: <%= project.client_name ? project.client_name + ' — ' : '' %><%= project.client_email %>
          <% } else { %>
            <span style="color:var(--danger)">No client email set — add one via Edit Project.</span>
          <% } %>
        </div>
      </div>
      <% if (!emailConfigured) { %>
        <span class="badge badge-not_yet" style="font-size:.75rem">Email not configured</span>
      <% } %>
    </div>
    <div class="email-buttons">
      <% EMAIL_PHASES.forEach(ph => { %>
        <button class="btn btn-ghost btn-phase" onclick="openEmailDialog('<%= ph.key %>', '<%= ph.label %>')"
          <%= (!emailConfigured || !project.client_email) ? 'disabled' : '' %>>
          <%= ph.label %>
        </button>
      <% }) %>
    </div>
  </div>

  </div><!-- /emails (part 1) -->
  <div class="tab-panel" data-tab="docs">
  <!-- Documents + milestone payments -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem" class="two-col">
    <div class="email-card" style="margin-bottom:0">
      <div class="email-header"><div><strong>Documents</strong><div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">BOLs, contracts, permits, invoices.</div></div></div>
      <% if (documents && documents.length) { %>
        <div style="margin:.5rem 0">
          <% documents.forEach(d => { %>
            <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;padding:.4rem 0;border-bottom:1px solid var(--border)">
              <a href="/documents/<%= d.id %>" target="_blank">📄 <%= d.filename %></a>
              <form method="POST" action="/documents/<%= d.id %>/delete" onsubmit="return confirm('Delete this document?')"><button class="btn btn-danger btn-sm">✕</button></form>
            </div>
          <% }) %>
        </div>
      <% } else { %><div style="color:var(--muted);font-size:.85rem;margin:.5rem 0">No documents yet.</div><% } %>
      <form method="POST" action="/projects/<%= project.id %>/documents" enctype="multipart/form-data" style="display:flex;gap:.5rem;align-items:center;margin-top:.5rem">
        <input type="file" name="document" required style="font-size:.8rem">
        <button class="btn btn-primary btn-sm">Upload</button>
      </form>
    </div>

    <div class="email-card" style="margin-bottom:0">
      <div class="email-header"><div><strong>Milestone Payments</strong><div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Recorded when you send a milestone email.</div></div></div>
      <% if (payments && payments.length) { %>
        <table style="width:100%;font-size:.85rem;margin-top:.5rem">
          <% payments.forEach(p => { %>
            <tr style="border-bottom:1px solid var(--border)">
              <td style="padding:.35rem 0"><%= p.phase_name %></td>
              <td style="padding:.35rem 0"><strong>$<%= Number(p.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></strong></td>
              <td style="padding:.35rem 0;text-align:right"><span class="badge <%= p.paid ? 'badge-all_delivered' : 'badge-not_yet' %>"><%= p.paid ? '✓ Paid' : 'Unpaid' %></span></td>
            </tr>
          <% }) %>
        </table>
      <% } else { %><div style="color:var(--muted);font-size:.85rem;margin:.5rem 0">No milestone payments recorded yet.</div><% } %>
    </div>
  </div>

  </div><!-- /docs -->
  <div class="tab-panel" data-tab="emails">
  <!-- Vendor email threads -->
  <div class="email-card">
    <div class="email-header">
      <div><strong>Vendor Email Threads</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Order, delivery & quote emails you've sent for this project — with replies.</div>
      </div>
      <button class="btn btn-ghost btn-sm" onclick="loadThreads()">↻ Refresh</button>
    </div>
    <div id="threadList" style="margin-top:.5rem"><div style="color:var(--muted);font-size:.85rem">Loading…</div></div>
  </div>

  </div><!-- /emails (part 2) -->
  <div class="tab-panel" data-tab="orders">
  <!-- Confirmed orders, grouped by vendor -->
  <div class="email-card">
    <div class="email-header">
      <div><strong>Confirmed Orders</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Materials a vendor has confirmed, by vendor. Log from a vendor's reply (📦) or upload a receipt PDF →</div>
      </div>
      <button class="btn btn-primary btn-sm" onclick="openReceiptUpload()">⬆ Upload Receipt</button>
    </div>
    <% if (ordersByVendor && ordersByVendor.length) { %>
      <% ordersByVendor.forEach(v => { %>
        <div style="margin-top:.7rem">
          <div style="font-weight:600;font-size:.9rem">
            <%= v.name || v.email || 'Unknown vendor' %><% if (v.name && v.email) { %> <span style="color:var(--muted);font-weight:400;font-size:.8rem"><%= v.email %></span><% } %>
          </div>
          <table style="width:100%;font-size:.85rem;margin-top:.3rem">
            <% v.orders.forEach(o => { %>
              <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:.4rem 0;vertical-align:top"><%= o.item_codes.map(c => itemNames[c] || c).join(', ') %></td>
                <td style="padding:.4rem .5rem;white-space:nowrap;text-align:right;vertical-align:top"><% if (o.amount != null) { %><strong>$<%= Number(o.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></strong><% } %></td>
                <td style="padding:.4rem .5rem;white-space:nowrap;text-align:right;color:var(--muted);font-size:.78rem;vertical-align:top"><%= new Date(o.confirmed_at).toLocaleDateString() %></td>
                <td style="padding:.4rem 0;text-align:right;white-space:nowrap;vertical-align:top">
                  <% if (o.has_receipt) { %><a href="/orders/<%= o.id %>/receipt" target="_blank" class="btn btn-ghost btn-sm">📄 Receipt</a><% } %>
                  <form method="POST" action="/orders/<%= o.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this order record?')"><button class="btn btn-danger btn-sm">✕</button></form>
                </td>
              </tr>
            <% }) %>
          </table>
        </div>
      <% }) %>
    <% } else { %>
      <div style="color:var(--muted);font-size:.85rem;margin:.5rem 0">No confirmed orders yet. Open a vendor reply above and click “📦 Log Order Confirmation”.</div>
    <% } %>
  </div>

  <!-- Order tracking grouped by material category (itemized) -->
  <div class="email-card">
    <div class="email-header">
      <div><strong>Order Tracking by Category</strong>
        <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem">Items you've ordered, grouped by material category (Rough Plumb, Finish Plumb, Appliances…).</div>
      </div>
    </div>
    <% if (ordersByCategory && ordersByCategory.length) { %>
      <% ordersByCategory.forEach(cat => { %>
        <div style="margin-top:.85rem">
          <div style="font-weight:600;font-size:.9rem;display:flex;justify-content:space-between;align-items:center;gap:.5rem">
            <span><%= cat.name %> <span style="color:var(--muted);font-weight:400;font-size:.78rem"><%= cat.code %> · <%= cat.stage %></span></span>
            <span style="display:flex;align-items:center;gap:.6rem">
              <% if (cat.lines.length) { %><span style="font-weight:600;font-size:.82rem">$<%= cat.subtotal.toLocaleString(undefined,{minimumFractionDigits:2}) %></span><% } %>
              <% if (cat.lines.length) { %><button type="button" class="btn btn-ghost btn-sm" onclick="openCategoryRequest('<%= cat.code %>')" title="Email the vendor to request these items">✉ Request</button><% } %>
            </span>
          </div>
          <% if (cat.lines.length) { %>
            <table style="width:100%;font-size:.83rem;margin-top:.25rem">
              <% cat.lines.forEach(l => { %>
                <tr style="border-bottom:1px solid var(--border)">
                  <td style="padding:.3rem 0;vertical-align:top">
                    <%= l.description || l.product_code %><% if (l.qty && Number(l.qty) > 1) { %> <span style="color:var(--muted)">×<%= Number(l.qty) %></span><% } %>
                    <% if (l.product_code) { %><br><span style="color:var(--muted);font-size:.72rem"><%= l.product_code %><% if (l.supplier_name) { %> · <%= l.supplier_name %><% } %></span><% } %>
                  </td>
                  <td style="padding:.3rem 0;white-space:nowrap;text-align:right;vertical-align:top"><% if (l.price != null) { %>$<%= Number(l.price).toLocaleString(undefined,{minimumFractionDigits:2}) %><% } %></td>
                </tr>
              <% }) %>
            </table>
          <% } %>
          <% cat.summaryOrders.forEach(o => { %>
            <div style="font-size:.82rem;color:var(--muted);margin-top:.25rem">
              <%= o.supplier_name || o.supplier_email || 'Unknown vendor' %><% if (o.amount != null) { %> — $<%= Number(o.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %> (order total)<% } %><% if (o.has_receipt) { %> · <a href="/orders/<%= o.id %>/receipt" target="_blank">📄 receipt</a><% } %>
            </div>
          <% }) %>
        </div>
      <% }) %>
    <% } else { %>
      <div style="color:var(--muted);font-size:.85rem;margin:.5rem 0">No orders logged yet. When you log an order (📦 above), its items appear here grouped by category.</div>
    <% } %>
  </div>

  </div><!-- /orders -->
  <div class="tab-panel" data-tab="materials">
  <% if (typeof projectRequests !== 'undefined' && projectRequests.length) { %>
  <div id="fieldRequests" class="field-requests">
    <div class="fr-title">📥 Field Requests <span class="fr-count"><%= projectRequests.length %></span></div>
    <div style="font-size:.82rem;color:var(--muted);margin:-.2rem 0 .7rem">Material your supers asked for. Work it on the grid below (RFQ → Order → Delivered auto-closes it), or reply / mark done here.</div>
    <% projectRequests.forEach(r => { %>
      <div class="fr-card" id="frq_<%= r.id %>">
        <div class="fr-head">
          <div>
            <strong>👷 <%= r.superName %></strong>
            <span style="color:var(--muted);font-size:.83rem">· <%= new Date(r.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></span>
            <% if (r.needed_by) { %><span class="fr-need">📅 need by <%= new Date(r.needed_by).toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'}) %></span><% } %>
          </div>
          <button type="button" class="btn btn-ghost btn-sm" onclick="frFulfill(<%= r.id %>)">✓ Mark done</button>
        </div>
        <div class="fr-items">
          <% r.items.forEach(it => { var s=(it.status||'').toLowerCase(); var cl = s.indexOf('delivered')>=0?'deliv':(s.indexOf('order')>=0?'order':(s.indexOf('rfq')>=0?'rfq':(s.indexOf('issue')>=0?'issue':'none'))); %>
            <span class="fr-item"><%= it.name %> <span class="fr-pill fr-pill-<%= cl %>"><%= it.status %></span></span>
          <% }) %>
        </div>
        <% if (r.note) { %><div class="fr-note"><%= r.note %></div><% } %>
        <div class="fr-respond">
          <input type="text" id="frresp_<%= r.id %>" placeholder="Reply to <%= r.superName %> (pings them in chat)…" onkeydown="if(event.key==='Enter')frRespond(<%= r.id %>)">
          <button type="button" class="btn btn-primary btn-sm" onclick="frRespond(<%= r.id %>)">Send</button>
        </div>
      </div>
    <% }) %>
  </div>
  <% } %>
  <div id="bulkStockBar" style="display:none;align-items:center;gap:.6rem;flex-wrap:wrap;margin:0 0 1rem;padding:.6rem .8rem;background:var(--bg);border:1px solid var(--border);border-radius:10px">
    <strong style="font-size:.85rem">Office stock (Jedco + hoods):</strong>
    <button type="button" class="btn btn-primary btn-sm" onclick="markAllStock('all','office')">✓ Mark all delivered</button>
    <button type="button" class="btn btn-ghost btn-sm" onclick="markAllStock('none','office')">↩ Mark all in office</button>
    <span id="bulkStockNote" style="font-size:.78rem;color:var(--muted)"></span>
  </div>
  <% STAGES.forEach(stage => { %>
  <div class="stage-card">
    <div class="stage-header" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
      <span><%= stage.name %></span>
      <span style="font-size:.74rem;font-weight:400;color:var(--muted);display:inline-flex;align-items:center;gap:.4rem">
        Set whole stage →
        <select onchange="setStageStatus(this)" title="Set every item in this stage to one status at once" style="font-size:.76rem;padding:.2rem .45rem;border:1px solid var(--border);border-radius:6px;background:var(--surface);font-weight:600;color:var(--text)">
          <option value="">— choose —</option>
          <% ITEM_STATUSES.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
        </select>
      </span>
    </div>
    <table class="stage-table">
      <thead>
        <tr>
          <th style="width:40px"></th>
          <th>Item</th>
          <th>Status</th>
          <th>Order Date</th>
          <th>Delivery Date</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% stage.items.forEach(item => {
          const row = itemMap[item.code] || {};
          const st = row.status || 'Not yet placed';
          const stCls = 'cell-' + st.toLowerCase().replace(/[\s./]+/g,'_').replace(/[^a-z0-9_]/g,'').replace(/^_+|_+$/g,'');
          const sup = suppliers[item.code] || {};
        %>
        <tr data-project="<%= project.id %>" data-code="<%= item.code %>">
          <td style="color:var(--muted);font-size:.8rem"><%= item.code %></td>
          <td><span style="cursor:pointer;user-select:none" onclick="toggleCategory('<%= item.code %>')"><span class="cat-caret" id="car_<%= item.code %>">▸</span> <strong><%= item.name %></strong></span><% var _rq = (typeof requestedByCode !== 'undefined') && requestedByCode[item.code]; if (_rq) { %> <a href="#fieldRequests" class="req-flag" title="Requested from the field — jump to the request">📥 <%= _rq.sup %><% if (_rq.needed_by) { %> · need <%= new Date(_rq.needed_by).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %><% } %></a><% } %><% var _iss = (typeof issueByCode !== 'undefined') && issueByCode[item.code]; if (_iss) { %> <a href="/issues" class="iss-flag" title="Reported by <%= _iss.sup %><%= _iss.label ? ' (' + _iss.label + ')' : '' %><%= _iss.note ? ': ' + _iss.note : '' %>">⚠ <%= _iss.label || 'Issue' %><% if (_iss.note) { %>: <%= _iss.note.length > 30 ? _iss.note.slice(0,30) + '…' : _iss.note %><% } %></a><% } %> <span id="cnt_<%= item.code %>" style="color:var(--muted);font-size:.78rem"></span><% if (item.code === '1e') { %><br><label style="font-size:.7rem;color:var(--muted)">Source: <select onchange="setRecSource(this.value)" style="font-size:.7rem;border:1px solid var(--border);border-radius:5px;padding:.1rem .3rem"><option value="gc" <%= project.rec_lighting_source==='oncall'?'':'selected' %>>GC Procure</option><option value="oncall" <%= project.rec_lighting_source==='oncall'?'selected':'' %>>On Call LED</option></select></label><% } %></td>
          <td>
            <select class="status-select item-status <%= stCls %>" onchange="saveItem(this)">
              <% ITEM_STATUSES.forEach(s => { %>
                <option value="<%= s %>" <%- st===s?'selected':'' %>><%= s %></option>
              <% }) %>
            </select>
          </td>
          <td>
            <input type="date" class="item-order-date" value="<%= row.order_date ? new Date(row.order_date).toISOString().slice(0,10) : '' %>" onchange="saveItem(this)">
          </td>

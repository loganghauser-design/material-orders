// Build the items table that actually gets sent: only ticked rows, checkbox column removed.
// If the table has no checkboxes (manual paste), send it as-is.
function getCleanItemsHtml() {
  const box = document.getElementById('rfqItems');
  const table = box.querySelector('table');
  if (!table || !table.querySelector('input.rfq-itemchk')) {
    return { html: box.innerHTML, text: box.innerText };
  }
  const newTable = document.createElement('table');
  Array.from(table.rows).forEach(tr => {
    const chk = tr.querySelector('input.rfq-itemchk');
    if (chk && !chk.checked) return;                 // skip unticked data rows
    const ntr = newTable.insertRow();
    Array.from(tr.cells).forEach((cell, idx) => {
      if (idx === 0) return;                          // drop the checkbox column
      ntr.insertCell().innerHTML = cell.innerHTML;
    });
  });
  return { html: newTable.outerHTML, text: newTable.innerText };
}


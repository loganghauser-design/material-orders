    if (data.ok) {
      showToast(data.draft ? 'Draft saved to your Gmail — review & send there' : 'Email sent to ' + data.sentTo);
      closeEmailDialog();
      document.getElementById('emailAmount').value = '';
      document.getElementById('emailMelio').value = '';
      document.getElementById('emailExtra').innerHTML = '';
      fileInput.value = '';
    } else {
      showToast(data.error || 'Failed', true);
    }
  } catch(e) {
    showToast('Failed', true);
  } finally {
    btn.disabled = false; btn.textContent = orig;
  }
}


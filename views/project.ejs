async function sendRfq(asDraft) {
  const btn = asDraft ? document.getElementById('rfqDraftBtn') : document.getElementById('rfqSendBtn');
  const supplierEmail = document.getElementById('rfqSupplierEmail').value.trim();
  if (!supplierEmail) { showToast('Enter a supplier email', true); return; }
  const fd = new FormData();
  fd.append('itemCode', document.getElementById('rfqItemCode').value);
  RFQ_COVERED.forEach(c => fd.append('coveredCodes', c));
  fd.append('emailType', document.getElementById('rfqType').value);
  fd.append('supplierName', document.getElementById('rfqSupplierName').value.trim());
  fd.append('supplierEmail', supplierEmail);
  fd.append('cc', document.getElementById('rfqCc').value.trim());
  fd.append('outboundDate', document.getElementById('rfqOutboundDate').value);
  if (asDraft) fd.append('asDraft', 'true');
  const clean = getCleanItemsHtml();
  fd.append('itemsHtml', clean.html);
  fd.append('items', clean.text);
  fd.append('note', document.getElementById('rfqNote').value.trim());
  for (const f of document.getElementById('rfqFiles').files) fd.append('attachments', f);
  const orig = btn.textContent;
  btn.disabled = true; btn.textContent = asDraft ? 'Saving…' : 'Sending…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/rfq`, { method: 'POST', body: fd });
    const data = await r.json();
    if (data.ok && data.draft) {
      showToast('Draft saved to your Gmail — review & send there');
      document.getElementById('rfqModal').classList.remove('show');
    } else if (data.ok) {
      // Reflect auto-advanced statuses in the item rows
      let bumped = 0;
      (data.updatedItems || []).forEach(u => {
        const row = document.querySelector(`tr[data-code="${u.code}"]`);
        if (row) {
          const sel = row.querySelector('.item-status');
          if (sel) { sel.value = u.status; STATUS_CLASSES.forEach(c => sel.classList.remove(c)); sel.classList.add(statusToClass(u.status)); bumped++; }
        }
      });
      showToast('Sent to ' + data.sentTo + (bumped ? ` · ${bumped} item(s) updated` : ''));
      document.getElementById('rfqModal').classList.remove('show');
      loadThreads();
    } else {
      showToast(data.error || 'Failed', true);
    }
  } catch(e) {
    showToast('Failed', true);
  } finally {
    btn.disabled = false; btn.textContent = orig;
  }
}

// Show the exact email (built server-side) for review before sending.
async function previewRfq() {
  const supplierEmail = document.getElementById('rfqSupplierEmail').value.trim();
  const btn = document.getElementById('rfqPreviewBtn');
  const fd = new FormData();
  fd.append('emailType', document.getElementById('rfqType').value);

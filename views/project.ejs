// Auto-fill the order with the selected vendor's items from the schedule
function fillFromVendor() {
  const name = document.getElementById('rfqVendor').value;
  const v = SCHEDULE_VENDORS.find(x => x.name === name);
  if (!v) { RFQ_COVERED = []; return; }
  document.getElementById('rfqSupplierName').value = v.name;
  const email = lookupVendorEmail(v.name);
  document.getElementById('rfqSupplierEmail').value = email || '';   // clear if this vendor has no saved email
  rfqSavedSupplierEmail = email || '';
  RFQ_COVERED = [...new Set(v.items.map(it => it.code))];
  const rowsHtml = v.items.map(it =>
    `<tr data-code="${escapeHtmlJs(it.code || '')}"><td contenteditable="false" style="text-align:center"><input type="checkbox" class="rfq-itemchk" checked onchange="updateItemCount()"></td><td>${escapeHtmlJs(it.name)}</td><td>${escapeHtmlJs(it.product || '')}</td><td>${escapeHtmlJs(it.brand || '')}</td><td>${escapeHtmlJs(it.model || '')}</td><td>${escapeHtmlJs(String(it.qty || '1'))}</td></tr>`).join('');
  document.getElementById('rfqItems').innerHTML =
    `<table><colgroup><col width="34"><col width="150"><col width="220"><col width="110"><col width="150"><col width="45"></colgroup><tr><td contenteditable="false"><b>✓</b></td><td><b>Item</b></td><td><b>Product</b></td><td><b>Brand</b></td><td><b>Model #</b></td><td><b>Qty</b></td></tr>${rowsHtml}</table>`;
  // Build the stage/category filter from this vendor's distinct codes (numeric order).
  const codeName = {}; ALL_MATERIALS.forEach(m => { codeName[m.code] = m.name; });
  const codes = [...new Set(v.items.map(it => it.code).filter(Boolean))].sort();
  const stageSel = document.getElementById('rfqStage');
  stageSel.innerHTML = '<option value="">All stages</option>' +
    codes.map(c => `<option value="${escapeHtmlJs(c)}">${escapeHtmlJs(c)} — ${escapeHtmlJs(codeName[c] || '')}</option>`).join('');
  document.getElementById('rfqStageWrap').style.display = codes.length > 1 ? '' : 'none';
  document.getElementById('rfqItemPick').style.display = 'flex';
  updateItemCount();
}
// Tick only the items in the chosen stage/category (blank = all stages).
function filterByStage() {
  const code = document.getElementById('rfqStage').value;
  getItemChecks().forEach(chk => {
    const tr = chk.closest('tr');
    chk.checked = !code || (tr && tr.getAttribute('data-code') === code);
  });

// Toggle a super on/off for this project. Multiple can be selected — all get tagged
// on delivery alerts. Saves the full current selection each click.
async function toggleSuper(btn) {
  btn.classList.toggle('on');
  await saveSupers(() => btn.classList.toggle('on'));
}
// Persist the currently-assigned site contacts (the "on" chips). The ✓ is handled by CSS.
async function saveSupers(onFail) {
  const chips = Array.from(document.querySelectorAll('.super-chip[data-email]'));
  const emails = chips.filter(c => c.classList.contains('on')).map(c => c.dataset.email);
  chips.forEach(c => c.disabled = true);
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/super`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ emails }),
    });
    const data = await r.json();
    if (data.ok) showToast(emails.length ? 'Site contacts updated — ' + emails.length + ' assigned' : 'No site contact assigned');
    else { showToast(data.error || 'Could not save', true); if (onFail) onFail(); }
  } catch (e) { showToast('Could not save', true); if (onFail) onFail(); }
  finally { chips.forEach(c => c.disabled = false); }
}
function openAddContact() { const b = document.getElementById('addContactBox'); b.style.display = 'flex'; document.getElementById('acName').focus(); }
function closeAddContact() { document.getElementById('addContactBox').style.display = 'none'; ['acName','acEmail','acPhone'].forEach(id => document.getElementById(id).value = ''); }
// Add a new site contact (super or GC), then assign them to this project immediately.
async function saveContact() {
  const name = document.getElementById('acName').value.trim();
  const email = document.getElementById('acEmail').value.trim();
  const phone = document.getElementById('acPhone').value.trim();
  const role = document.getElementById('acRole').value;
  if (!name || !email) { showToast('Name and email are required', true); return; }
  try {
    const r = await fetch('/contacts', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, email, phone, role }) });
    const d = await r.json();
    if (!d.ok) { showToast(d.error || 'Could not add contact', true); return; }
    const c = d.contact;
    const chip = document.createElement('button');
    chip.type = 'button'; chip.className = 'super-chip on'; chip.dataset.email = c.email;

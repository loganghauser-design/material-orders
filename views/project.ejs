    if (!data.ok || !data.threads.length) {
      el.innerHTML = '<div style="color:var(--muted);font-size:.85rem">No vendor emails sent yet.</div>';
      return;
    }
    data.threads.forEach(t => THREAD_INFO[t.gmail_thread_id] = t);
    el.innerHTML = data.threads.map(t => `
      <div class="thread-item${t.has_unread ? ' thread-unread' : ''}" id="ti_${t.gmail_thread_id}">
        <div class="thread-head" onclick="toggleThread('${t.gmail_thread_id}', this)">
          <div>

  fd.append('supplierEmail', supplierEmail);
  fd.append('cc', document.getElementById('rfqCc').value.trim());
  fd.append('outboundDate', document.getElementById('rfqOutboundDate').value);
  const clean = getCleanItemsHtml();
  fd.append('itemsHtml', clean.html);
  fd.append('items', clean.text);
  fd.append('note', document.getElementById('rfqNote').value.trim());
  for (const f of document.getElementById('rfqFiles').files) fd.append('attachments', f);
  const orig = btn.textContent;
  btn.disabled = true; btn.textContent = 'Building…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/rfq/preview`, { method: 'POST', body: fd });
    const data = await r.json();
    if (!data.ok) { showToast(data.error || 'Could not build preview', true); return; }

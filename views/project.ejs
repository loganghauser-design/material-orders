            <span class="thread-type">${escapeHtmlJs(t.email_type || '')}</span>
            ${t.has_unread ? '<span style="color:#cc2222;font-size:.72rem;font-weight:700;margin-left:.35rem">NEW REPLY</span>' : ''}
          </div>
          <div style="display:flex;align-items:center;gap:.6rem">
            <span style="font-size:.78rem;color:var(--muted)">${escapeHtmlJs(t.supplier_name||'')} · ${new Date(t.sent_at).toLocaleDateString()}</span>
            <button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();tagThread(${t.id}, '${t.gmail_thread_id}')" title="File this email under material categories">🏷 ${escapeHtmlJs(t.item_codes || t.item_code || 'Tag')}</button>
            <button class="btn btn-danger btn-sm" onclick="event.stopPropagation();deleteThread(${t.id})" title="Remove from list (does not delete from Gmail)">✕</button>
          </div>
        </div>
        <div class="thread-body" id="tb_${t.gmail_thread_id}"></div>
      </div>
    `).join('');
    THREADS_LOADED = true;
    // Refresh any open category email boxes on the Materials tab
    document.querySelectorAll('tr.sched-sub').forEach(tr => {
      if (tr.style.display !== 'none') renderCatThreads(tr.id.replace('sub_', ''));
    });
    // If we arrived here from a project notification, auto-open the newest unread thread
    const params = new URLSearchParams(location.search);
    if (params.get('openUnread')) {
      const firstUnread = data.threads.find(t => t.has_unread);
      if (firstUnread) {
        const head = document.querySelector('#ti_' + firstUnread.gmail_thread_id + ' .thread-head');
        if (head) { toggleThread(firstUnread.gmail_thread_id, head); head.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
      }
    }
  } catch(e) {
    el.innerHTML = '<div style="color:var(--danger);font-size:.85rem">Error loading threads.</div>';
  }
}

async function toggleThread(threadId, headEl) {
  const box = document.getElementById('tb_' + threadId);
  if (box.classList.contains('open')) { box.classList.remove('open'); box.innerHTML=''; return; }
  box.classList.add('open');
  renderThreadBody(threadId, box);
}

// Render a full conversation (+ reply box) into ANY container — used by the
// Emails tab and by the per-category boxes on the Materials tab.
async function renderThreadBody(threadId, box) {
  box.innerHTML = '<div style="color:var(--muted);font-size:.82rem;padding:.5rem">Loading conversation…</div>';
  try {
    const r = await fetch(`/threads/${threadId}`);
    const data = await r.json();
    if (!data.ok) { box.innerHTML = '<div style="color:var(--danger);padding:.5rem">'+(data.error||'Error')+'</div>'; return; }
    THREAD_MSGS[threadId] = data.messages;
    const msgs = data.messages.map((m, idx) => {
      const atts = (m.attachments || []).map(a => {
        const isPdf = /pdf/i.test(a.mimeType || '') || /\.pdf$/i.test(a.filename || '');
        const isImg = /^image\//i.test(a.mimeType || '') || /\.(png|jpe?g|gif|webp|heic)$/i.test(a.filename || '');
        const url = `/threads/messages/${m.id}/attachment/${a.attachmentId}?name=${encodeURIComponent(a.filename || 'attachment')}&mime=${encodeURIComponent(a.mimeType || '')}`;
        if (isImg) return `<a href="${url}" target="_blank" rel="noopener" title="${escapeHtmlJs(a.filename || 'image')} \u2014 click to open full size" style="display:inline-block;margin:.15rem .35rem .15rem 0"><img src="${url}" alt="" loading="lazy" style="max-height:120px;max-width:170px;border:1px solid var(--border);border-radius:9px;display:block"></a>`;
        return `<a href="${url}" target="_blank" rel="noopener" title="Open / download" style="display:inline-block;margin:.15rem .35rem .15rem 0;padding:3px 10px;border:1px solid var(--border);border-radius:14px;font-size:.8rem;text-decoration:none;color:var(--text);background:var(--surface)">${isPdf ? '\uD83D\uDCC4' : '\uD83D\uDCCE'} ${escapeHtmlJs(a.filename || 'attachment')}</a>`;
      }).join('');
      const attRow = atts ? `<div style="margin-top:.45rem">${atts}</div>` : '';
      return `
      <div class="msg ${m.fromMe ? 'msg-me':'msg-them'}">
        <div class="msg-meta"><strong>${escapeHtmlJs(m.from)}</strong> · ${escapeHtmlJs(m.date)}</div>
        <div class="msg-body" style="line-height:1.5;word-break:break-word;overflow-wrap:anywhere">${m.bodyHtml || (m.isHtml ? m.body : escapeHtmlJs(m.body).replace(/\n/g,'<br>'))}</div>
        ${attRow}
        ${m.fromMe ? '' : `<div style="margin-top:.4rem"><button class="btn btn-ghost btn-sm" onclick="openOrderDialog('${threadId}', ${idx})">\uD83D\uDCE6 Log Order Confirmation</button></div>`}
      </div>
    `; }).join('');
    box.innerHTML = msgs + `
      <div class="reply-box">
        <textarea rows="3" placeholder="Write a reply…"></textarea>
        <button class="btn btn-primary btn-sm" onclick="sendReply('${threadId}', this)">Send Reply</button>
        <button class="btn btn-ghost btn-sm" onclick="openDeliveryRequest('${threadId}')" title="Reply to this order asking for a stage's items to be delivered">\uD83D\uDCE6 Request Delivery</button>
      </div>`;
  } catch(e) {
    box.innerHTML = '<div style="color:var(--danger);padding:.5rem">Error loading conversation.</div>';
  }
}

async function sendReply(threadId, btn) {
  const wrap = btn.closest('.reply-box');
  const ta = wrap.querySelector('textarea');
  const body = ta.value.trim();
  if (!body) { showToast('Write a reply first', true); return; }
  ta.disabled = true; btn.disabled = true;
  try {
    const r = await fetch(`/threads/${threadId}/reply`, {
      method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ body })
    });
    const data = await r.json();
    if (data.ok) {
      showToast('Reply sent');
      renderThreadBody(threadId, wrap.parentElement);   // refresh this conversation in place
      if (data.detected && data.detected.length && data.projectId) {
        openConfirmUpdates(data.detected, data.projectId);
      }
    }
    else showToast(data.error || 'Send failed', true);
  } catch(e) { showToast('Send failed', true); }
  finally { ta.disabled = false; btn.disabled = false; }
}

let confirmCtx = { items: [], projectId: null };
function openConfirmUpdates(detected, projectId) {
  confirmCtx = { items: detected, projectId };
  document.getElementById('confirmItems').innerHTML = detected.map(d => `
    <label style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem;font-size:.9rem">
      <input type="checkbox" class="confirm-cb" value="${d.code}" checked>
      <span><strong>${escapeHtmlJs(d.name)}</strong> <span style="color:var(--muted)">(${d.code})</span></span>
    </label>`).join('');
  document.getElementById('confirmDate').value = '';
  document.getElementById('confirmStatus').value = '';
  document.getElementById('confirmUpdateModal').classList.add('show');
}

async function applyConfirmUpdates() {
  const date = document.getElementById('confirmDate').value;
  const status = document.getElementById('confirmStatus').value;
  if (!date && !status) { showToast('Set a date or status first', true); return; }
  const codes = Array.from(document.querySelectorAll('.confirm-cb:checked')).map(c => c.value);
  if (!codes.length) { document.getElementById('confirmUpdateModal').classList.remove('show'); return; }
  let done = 0;
  for (const code of codes) {
    const payload = {};
    if (status) payload.status = status; else payload.statusOnly = false;
    // Send current values: include status (or keep) and date
    const row = document.querySelector(`tr.mat-row[data-code="${code}"]`);
    const ed = document.querySelector(`tr.edit-row[data-code="${code}"]`);
    const curStatus = row ? row.querySelector('.item-status').value : '';
    await fetch(`/projects/${confirmCtx.projectId}/items/${code}`, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ status: status || curStatus, delivery_date: date || (ed ? ed.querySelector('.item-date').value : '') }),
    });
    // reflect in UI
    if (row && status) { const ss = row.querySelector('.item-status'); ss.value = status; STATUS_CLASSES.forEach(c => ss.classList.remove(c)); ss.classList.add(statusToClass(status)); }
    if (ed && date) { ed.querySelector('.item-date').value = date; updateSchedSummary(code); }
    done++;
  }
  document.getElementById('confirmUpdateModal').classList.remove('show');
  showToast(done + ' material(s) updated');
}

function escapeHtmlJs(s) {
  return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}


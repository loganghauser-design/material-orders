// Show/hide the picker controls + live count of how many items are ticked.
function getItemChecks() { return Array.from(document.querySelectorAll('#rfqItems input.rfq-itemchk')); }
function updateItemCount() {
  const chks = getItemChecks();
  const pick = document.getElementById('rfqItemPick');
  pick.style.display = chks.length ? 'flex' : 'none';
  const n = chks.filter(c => c.checked).length;

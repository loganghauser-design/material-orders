      <label>Items (one per line — edit as needed)</label>
      <textarea id="catReqItems" rows="7" style="width:100%;font-size:.85rem"></textarea>
    </div>
    <div class="form-group" style="margin-top:.85rem">
      <label>Note (optional)</label>
      <input type="text" id="catReqNote" placeholder="e.g. Needed by Friday">

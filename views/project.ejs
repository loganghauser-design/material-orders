async function applyConfirmUpdates() {
  const date = document.getElementById('confirmDate').value;
  const status = document.getElementById('confirmStatus').value;
  if (!date && !status) { showToast('Set a date or status first', true); return; }
  const codes = Array.from(document.querySelectorAll('.confirm-cb:checked')).map(c => c.value);
  if (!codes.length) { document.getElementById('confirmUpdateModal').classList.remove('show'); return; }
  let done = 0;
  for (const code of codes) {
    const payload = {};
    if (status) payload.status = status; else payload.statusOnly = false;
    // Send current values: include status (or keep) and date
    const row = document.querySelector(`tr[data-code="${code}"]`);
    const curStatus = row ? row.querySelector('.item-status').value : '';
    await fetch(`/projects/${confirmCtx.projectId}/items/${code}`, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ status: status || curStatus, delivery_date: date || (row ? row.querySelector('.item-date').value : '') }),
    });
    // reflect in UI
    if (row) {
      if (status) { const ss = row.querySelector('.item-status'); ss.value = status; STATUS_CLASSES.forEach(c => ss.classList.remove(c)); ss.classList.add(statusToClass(status)); }
      if (date) row.querySelector('.item-date').value = date;
    }
    done++;
  }
  document.getElementById('confirmUpdateModal').classList.remove('show');
  showToast(done + ' material(s) updated');
}

function escapeHtmlJs(s) {
  return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

function toggleEditor(code) {
  const ed = document.getElementById('edit_' + code);
  if (ed) ed.style.display = ed.style.display === 'none' ? '' : 'none';
}
// Rebuild the compact "Ordered Jul 1 · 🚚 Jul 6" summary from the editor inputs.
function updateSchedSummary(code) {
  const ed = document.querySelector(`tr.edit-row[data-code="${code}"]`);
  const sum = document.getElementById('sum_' + code);
  if (!ed || !sum) return;
  const fmt = v => { if (!v) return ''; const [y, m, d] = v.split('-'); return new Date(+y, +m - 1, +d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }); };
  const od = ed.querySelector('.item-order-date').value, dd = ed.querySelector('.item-date').value, de = ed.querySelector('.item-date-end').value, notes = ed.querySelector('.item-notes').value;
  const parts = [];
  if (od) parts.push('Ordered ' + fmt(od));
  const deTxt = de && fmt(de) !== fmt(dd) ? fmt(de) : '';
  if (dd) parts.push('Delivery ' + fmt(dd) + (deTxt ? ' – ' + deTxt : ''));
  sum.textContent = parts.join(' · ');
  if (notes) { const n = document.createElement('span'); n.title = notes; n.textContent = ' note'; n.style.cssText = 'border-bottom:1px dotted var(--muted);cursor:default'; sum.appendChild(n); }
}
async function saveItem(el) {
  // Status lives on the main row; dates + notes live on the hidden editor row.
  const tr = el.closest('tr');
  const projectId = tr.dataset.project;
  const code = tr.dataset.code;
  const main = document.querySelector(`tr.mat-row[data-code="${code}"]`);
  const ed = document.querySelector(`tr.edit-row[data-code="${code}"]`);
  const statusSel = main.querySelector('.item-status');
  const status = statusSel.value;
  // recolor the status pill like the main grid
  STATUS_CLASSES.forEach(c => statusSel.classList.remove(c));
  statusSel.classList.add(statusToClass(status));
  const delivery_date = ed.querySelector('.item-date').value;
  const delivery_date_end = ed.querySelector('.item-date-end').value;
  const order_date = ed.querySelector('.item-order-date').value;
  const notes = ed.querySelector('.item-notes').value;
  updateSchedSummary(code);
  try {
    const r = await fetch(`/projects/${projectId}/items/${code}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status, delivery_date, delivery_date_end, order_date, notes }),
    });
    if (r.redirected && /\/login/.test(r.url)) throw new Error('LOGGED_OUT');
    let data = null;
    try { data = await r.json(); } catch(e) { throw new Error('LOGGED_OUT'); }
    if (!r.ok || !data.ok) throw new Error('SAVE_FAILED');
    if (data.inv && data.inv.drewDown) showToast('✓ Drew down ' + data.inv.drewDown + ' from inventory');
    else if (data.inv && data.inv.restored) showToast('↩ Restored ' + data.inv.restored + ' to inventory');
    else showToast('Saved');
  } catch(e) {
    if (e.message === 'LOGGED_OUT') {
      showToast('Not saved — you were signed out. Reloading…', true);
      setTimeout(() => location.href = '/login', 1300);
    } else {
      showToast('Not saved — please try again', true);
    }
  }
}

// Bulk: set every item in a stage to one status at once (preserves dates/notes;
// still draws inventory down on "Delivered from Inv." and clears field requests).
async function setStageStatus(sel) {
  const status = sel.value;
  if (!status) return;
  const card = sel.closest('.stage-card');
  const rows = Array.from(card.querySelectorAll('tbody tr.mat-row[data-code]'));
  sel.selectedIndex = 0;
  if (!rows.length) return;
  const stageName = ((card.querySelector('.stage-header span') || {}).textContent || 'this stage').trim();
  if (!confirm('Set all ' + rows.length + ' items in "' + stageName + '" to "' + status + '"?')) return;
  const projectId = rows[0].dataset.project;
  showToast('Updating ' + rows.length + ' items…');
  const saves = rows.map(row => {
    const code = row.dataset.code;
    const ss = row.querySelector('.item-status');
    if (ss) { ss.value = status; STATUS_CLASSES.forEach(c => ss.classList.remove(c)); ss.classList.add(statusToClass(status)); }
    return fetch(`/projects/${projectId}/items/${code}`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status, statusOnly: true }),
    }).then(r => (r.ok ? r.json() : null)).catch(() => null);
  });
  const results = await Promise.all(saves);
  const failed = results.filter(r => !r || !r.ok).length;
  const drew = results.reduce((n, r) => n + ((r && r.inv && r.inv.drewDown) || 0), 0);
  if (failed) showToast(failed + ' of ' + rows.length + ' failed — reload to verify', true);
  else if (drew) showToast('✓ ' + rows.length + ' → ' + status + ' · drew ' + drew + ' from inventory');
  else showToast('✓ ' + rows.length + ' items set to ' + status);
}

// Send the delivery alert for this item to chat (single date or window).
async function notifyDelivery(btn) {
  const row = btn.closest('tr');
  const projectId = row.dataset.project, code = row.dataset.code;
  const dateEl = document.querySelector(`tr.edit-row[data-code="${code}"] .item-date`);
  if (!dateEl.value) {
    showToast('Set a delivery date first (✎)', true);
    const ed = document.getElementById('edit_' + code);
    if (ed) ed.style.display = '';
    return;
  }
  const orig = btn.textContent;
  btn.disabled = true; btn.textContent = '…';
  try {
    await saveItem(dateEl);   // persist the latest date(s) before alerting
    const r = await fetch(`/projects/${projectId}/items/${code}/notify`, { method: 'POST' });
    const data = await r.json();
    if (data.ok) {
      btn.textContent = '✓'; showToast('Delivery alert sent to chat');
      setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 1600);
    } else { showToast(data.error || 'Could not send', true); btn.textContent = orig; btn.disabled = false; }
  } catch (e) { showToast('Could not send', true); btn.textContent = orig; btn.disabled = false; }
}

// ── Log order confirmation ────────────────────────────────────────────────
function openOrderDialog(threadId, msgIndex) {
  const t = THREAD_INFO[threadId] || {};
  const msg = (THREAD_MSGS[threadId] || [])[msgIndex] || {};
  document.getElementById('orderThreadId').value = threadId;
  document.getElementById('orderMessageId').value = msg.id || '';
  const vName = t.supplier_name || '', vEmail = t.supplier_email || '';
  document.getElementById('orderVendorLabel').textContent =
    vName ? (vName + (vEmail ? ' — ' + vEmail : '')) : (vEmail || 'Unknown vendor');

  // Pre-check materials this email mentioned, plus the one this thread is about
  const detected = new Set((msg.detected || []).map(d => d.code));
  if (t.item_code) detected.add(t.item_code);
  document.getElementById('orderMaterials').innerHTML = ALL_MATERIALS.map(m => `
    <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem">
      <input type="checkbox" class="order-cb" value="${m.code}" ${detected.has(m.code) ? 'checked' : ''}>
      <span>${escapeHtmlJs(m.name)}</span>
    </label>`).join('');

  document.getElementById('orderAmount').value = '';
  document.getElementById('orderReceiptFile').value = '';

  // Offer this email's attachments as the receipt
  const atts = msg.attachments || [];
  const ae = document.getElementById('orderEmailAttachments');
  if (atts.length) {
    ae.innerHTML = '<div style="margin-bottom:.2rem">Save an attachment from this email:</div>' +
      atts.map((a, i) => `
        <label style="display:flex;align-items:center;gap:.4rem;font-size:.82rem">
          <input type="radio" name="orderAtt" value="${i}" ${i === 0 ? 'checked' : ''}>
          <span>📎 ${escapeHtmlJs(a.filename)}</span>
        </label>`).join('') +
      `<label style="display:flex;align-items:center;gap:.4rem;font-size:.82rem"><input type="radio" name="orderAtt" value="-1"><span>None</span></label>`;
  } else {
    ae.innerHTML = '<div style="color:var(--muted);font-size:.8rem">No attachments on this email.</div>';
  }

  document.getElementById('orderModal').classList.add('show');
}

async function saveOrder() {
  const btn = document.getElementById('orderSaveBtn');
  const threadId = document.getElementById('orderThreadId').value;
  const messageId = document.getElementById('orderMessageId').value;
  const t = THREAD_INFO[threadId] || {};
  const codes = Array.from(document.querySelectorAll('.order-cb:checked')).map(c => c.value);
  if (!codes.length) { showToast('Pick at least one material', true); return; }

  const fd = new FormData();
  codes.forEach(c => fd.append('codes', c));
  fd.append('supplierName', t.supplier_name || '');
  fd.append('supplierEmail', t.supplier_email || '');
  fd.append('amount', document.getElementById('orderAmount').value.trim());
  fd.append('gmailThreadId', threadId);
  fd.append('gmailMessageId', messageId);

  const file = document.getElementById('orderReceiptFile').files[0];
  if (file) {
    fd.append('receipt', file);
  } else {
    const sel = document.querySelector('input[name="orderAtt"]:checked');
    if (sel && sel.value !== '-1') {
      const msg = (THREAD_MSGS[threadId] || []).find(m => m.id === messageId) || {};
      const a = (msg.attachments || [])[Number(sel.value)];
      if (a) { fd.append('attachmentId', a.attachmentId); fd.append('attachmentName', a.filename); fd.append('attachmentMime', a.mimeType || ''); }
    }
  }

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/orders`, { method: 'POST', body: fd });
    const data = await r.json();
    if (data.ok) {
      showToast('Order logged');
      document.getElementById('orderModal').classList.remove('show');
      setTimeout(() => location.reload(), 600);
    } else {
      showToast(data.error || 'Save failed', true);
    }
  } catch (e) {
    showToast('Save failed', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Save Order';
  }
}

// ── Upload receipt → extract → review → save ──────────────────────────────
let RECEIPT_FILE = null;
function openReceiptUpload() {
  RECEIPT_FILE = null;
  document.getElementById('receiptStep1').style.display = '';
  document.getElementById('receiptStep2').style.display = 'none';
  document.getElementById('receiptFile').value = '';
  document.getElementById('receiptModal').classList.add('show');
}
function closeReceipt() {
  document.getElementById('receiptModal').classList.remove('show');
  RECEIPT_FILE = null;
}
function rcptAttr(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;'); }

async function parseReceipt() {
  const f = document.getElementById('receiptFile').files[0];
  if (!f) { showToast('Pick a PDF first', true); return; }
  RECEIPT_FILE = f;
  const btn = document.getElementById('receiptReadBtn');
  btn.disabled = true; btn.textContent = 'Reading…';
  const fd = new FormData(); fd.append('receipt', f);
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/parse-receipt`, { method: 'POST', body: fd });
    const data = await r.json();
    if (!data.ok) { showToast(data.error || 'Could not read PDF', true); return; }
    document.getElementById('receiptVendor').value = data.vendor || '';
    document.getElementById('receiptAmount').value = data.amount != null ? data.amount : '';
    renderReceiptLines(data.lines || []);
    document.getElementById('receiptStep1').style.display = 'none';
    document.getElementById('receiptStep2').style.display = '';
    if (!data.lines || !data.lines.length) showToast('No items detected — check the PDF', true);
  } catch (e) {
    showToast('Could not read PDF', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Read Receipt';
  }
}

function renderReceiptLines(lines) {
  const el = document.getElementById('receiptLines');
  el.innerHTML = lines.map(l => `
    <div class="rcpt-row" data-pc="${rcptAttr(l.product_code || '')}" data-qty="${l.qty || 1}" style="display:flex;gap:.4rem;align-items:center;border-bottom:1px solid var(--border);padding:.3rem 0">
      <input class="rcpt-desc" value="${rcptAttr(l.description || l.product_code || '')}" style="flex:1;font-size:.82rem">
      <input class="rcpt-price" value="${l.price != null ? l.price : ''}" style="width:72px;font-size:.82rem" placeholder="$">
      <select class="rcpt-cat" style="font-size:.82rem">${ALL_MATERIALS.map(m => `<option value="${m.code}" ${m.code === l.item_code ? 'selected' : ''}>${m.name}</option>`).join('')}</select>
      <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('.rcpt-row').remove()">✕</button>
    </div>`).join('') || '<div style="color:var(--muted);font-size:.85rem;padding:.5rem 0">No items detected in this PDF.</div>';
}

async function saveReceiptOrder() {
  if (!RECEIPT_FILE) { showToast('No file', true); return; }
  const lines = Array.from(document.querySelectorAll('#receiptLines .rcpt-row')).map(r => ({
    description: r.querySelector('.rcpt-desc').value.trim(),
    price: parseFloat(String(r.querySelector('.rcpt-price').value).replace(/[^0-9.]/g, '')) || null,
    item_code: r.querySelector('.rcpt-cat').value,
    product_code: r.dataset.pc || null,
    qty: Number(r.dataset.qty) || 1,
  })).filter(l => l.description);
  if (!lines.length) { showToast('No items to save', true); return; }
  const btn = document.getElementById('receiptSaveBtn');
  btn.disabled = true; btn.textContent = 'Saving…';
  const fd = new FormData();
  fd.append('receipt', RECEIPT_FILE);
  fd.append('vendorName', document.getElementById('receiptVendor').value.trim());
  fd.append('amount', document.getElementById('receiptAmount').value.trim());
  fd.append('linesJson', JSON.stringify(lines));
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/orders-from-receipt`, { method: 'POST', body: fd });
    const data = await r.json();
    if (data.ok) { showToast('Order saved'); closeReceipt(); setTimeout(() => location.reload(), 700); }
    else showToast(data.error || 'Save failed', true);
  } catch (e) {
    showToast('Save failed', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Save Order';
  }
}

// ── Request delivery of a stage's items (replies to the order thread) ──────
function openDeliveryRequest(threadId) {
  document.getElementById('delThreadId').value = threadId;
  const sel = document.getElementById('delStage');
  sel.innerHTML = STAGES_DATA.map((s, i) => `<option value="${i}">${escapeHtmlJs(s.name)}</option>`).join('');
  document.getElementById('delNote').value = '';
  document.getElementById('delDate').value = '';
  fillDeliveryItems();
  document.getElementById('deliveryModal').classList.add('show');
}
function fillDeliveryItems() {
  const i = Number(document.getElementById('delStage').value);
  const stage = STAGES_DATA[i] || { items: [] };
  document.getElementById('delItems').innerHTML = stage.items.map(m => `
    <label style="display:flex;align-items:center;gap:.4rem;font-size:.85rem">
      <input type="checkbox" class="del-cb" value="${m.code}" checked>
      <span>${escapeHtmlJs(m.name)}</span>
    </label>`).join('');
}
async function sendDeliveryRequest() {
  const btn = document.getElementById('delSendBtn');
  const threadId = document.getElementById('delThreadId').value;
  const itemCodes = Array.from(document.querySelectorAll('#delItems .del-cb:checked')).map(c => c.value);
  const note = document.getElementById('delNote').value.trim();
  const deliveryDate = document.getElementById('delDate').value;
  if (!itemCodes.length) { showToast('Pick at least one item', true); return; }
  btn.disabled = true; btn.textContent = 'Sending…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/request-delivery`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ threadId, itemCodes, note, deliveryDate }),
    });
    const data = await r.json();
    if (data.ok) {
      showToast('Delivery request sent — ' + data.count + ' item(s)');
      document.getElementById('deliveryModal').classList.remove('show');
      loadThreads();
    } else {
      showToast(data.error || 'Send failed', true);
    }
  } catch (e) {
    showToast('Send failed', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Send Delivery Request';
  }
}

// ── Request a category's items from the vendor ────────────────────────────
function openCategoryRequest(code) {
  const c = (CATEGORY_REQUEST_DATA || []).find(x => x.code === code);
  if (!c) { showToast('No items to request', true); return; }
  document.getElementById('catReqCode').value = code;
  document.getElementById('catReqTitle').textContent = 'Request — ' + c.name;
  document.getElementById('catReqTo').value = c.vendorEmail || '';
  document.getElementById('catReqType').value = 'delivery';
  document.getElementById('catReqItems').value = c.items
    .map(it => (it.qty > 1 ? it.qty + 'x ' : '') + it.desc + (it.code ? ' (' + it.code + ')' : ''))
    .join('\n');
  document.getElementById('catReqNote').value = '';
  document.getElementById('catReqModal').classList.add('show');
}

async function sendCategoryRequest() {
  const btn = document.getElementById('catReqSendBtn');
  const category = document.getElementById('catReqCode').value;
  const to = document.getElementById('catReqTo').value.trim();
  const emailType = document.getElementById('catReqType').value;
  const items = document.getElementById('catReqItems').value.trim();
  const note = document.getElementById('catReqNote').value.trim();
  if (!to) { showToast('Enter a recipient email', true); return; }
  if (!items) { showToast('No items to request', true); return; }
  btn.disabled = true; btn.textContent = 'Sending…';
  try {
    const r = await fetch(`/projects/${PROJECT_ID}/category-request`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ category, to, emailType, items, note }),
    });
    const data = await r.json();
    if (data.ok) {
      showToast('Request sent to ' + data.sentTo);
      document.getElementById('catReqModal').classList.remove('show');
      loadThreads();
    } else {
      showToast(data.error || 'Send failed', true);
    }
  } catch (e) {
    showToast('Send failed', true);
  } finally {
    btn.disabled = false; btn.textContent = 'Send Request';
  }
}

async function deleteThread(id) {
  if (!confirm('Remove this email from the list?\n(It stays in your Gmail — this only clears it from the app.)')) return;
  try {
    const r = await fetch(`/vendor-emails/${id}/delete`, { method: 'POST' });
    const data = await r.json();
    if (data.ok) { showToast('Removed'); loadThreads(); }
    else showToast(data.error || 'Could not remove', true);
  } catch (e) { showToast('Could not remove', true); }
}

function showToast(msg, err) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (err ? ' error' : '');
  setTimeout(() => t.className = 'toast', 2000);
}
</script>
</body>
</html>

let THREADS_LOADED = false;
async function ensureThreads() {
  if (THREADS_LOADED) return;
  THREADS_LOADED = true;   // set first — loadThreads re-renders open category boxes
  await loadThreads();
}
async function renderCatThreads(code) {
  const box = document.getElementById('catthreads_' + code);
  if (!box) return;
  await ensureThreads();
  const rows = Object.values(THREAD_INFO)
    .filter(t => t.item_code === code || String(t.item_codes || '').split(',').map(c => c.trim()).includes(code))
    .sort((a, b) => new Date(b.sent_at) - new Date(a.sent_at));
  if (!rows.length) { box.innerHTML = '<span style="font-size:.78rem;color:var(--muted)">No emails for this category yet.</span>'; return; }
  box.innerHTML = rows.map(t => `
    <div class="cat-thread${t.has_unread ? ' unread' : ''}" onclick="catToggleConv('${code}', '${t.gmail_thread_id}')">
      <span class="cat-caret" id="cc_${code}_${t.gmail_thread_id}">\u25B8</span>
      ${t.has_unread ? '<span class="reply-dot">\u25CF</span> ' : ''}<strong>${escapeHtmlJs(t.subject || '')}</strong>
      <span style="color:var(--muted);font-size:.76rem">· ${escapeHtmlJs(t.email_type || '')} · ${escapeHtmlJs(t.supplier_name || t.supplier_email || '')} · ${new Date(t.sent_at).toLocaleDateString()}</span>
    </div>
    <div class="cat-conv" id="ctb_${code}_${t.gmail_thread_id}"></div>`).join('');
}
// Open/close a conversation right inside the category box — read and reply here.
function catToggleConv(code, threadId) {
  const box = document.getElementById('ctb_' + code + '_' + threadId);
  const car = document.getElementById('cc_' + code + '_' + threadId);
  if (!box) return;
  if (box.classList.contains('open')) { box.classList.remove('open'); box.innerHTML = ''; if (car) car.textContent = '\u25B8'; return; }
  box.classList.add('open');
  if (car) car.textContent = '\u25BE';
  renderThreadBody(threadId, box);
}
// File a thread under material categories (checkbox popup on the tag button)
function tagThread(veId, threadId) {
  const t = THREAD_INFO[threadId] || {};
  const cur = new Set(String(t.item_codes || t.item_code || '').split(',').map(c => c.trim()).filter(Boolean));
  const wrap = document.createElement('div');
  wrap.className = 'modal-overlay';
  wrap.style.display = 'flex';
  wrap.innerHTML = `<div class="modal" style="max-width:440px"><h2 style="margin-top:0">File under categories</h2>
    <p class="modal-sub">This email shows in each checked category's box on the Materials tab.</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.35rem">${ALL_MATERIALS.map(m => `<label style="font-size:.85rem;cursor:pointer"><input type="checkbox" value="${m.code}" ${cur.has(m.code) ? 'checked' : ''}> ${m.code} ${escapeHtmlJs(m.name)}</label>`).join('')}</div>
    <div class="modal-actions"><button class="btn btn-primary" id="tagSaveBtn">Save</button><button class="btn btn-ghost" onclick="this.closest('.modal-overlay').remove()">Cancel</button></div></div>`;
  document.body.appendChild(wrap);
  wrap.querySelector('#tagSaveBtn').onclick = async () => {
    const codes = Array.from(wrap.querySelectorAll('input:checked')).map(i => i.value);
    try {
      const r = await fetch(`/vendor-emails/${veId}/codes`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ codes }) });
      const d = await r.json();
      if (!d.ok) throw new Error(d.error || 'fail');
      wrap.remove();
      showToast('Filed under ' + (codes.join(', ') || 'nothing'));
      THREADS_LOADED = false;
      await ensureThreads();   // refresh the Emails list + any open category boxes
    } catch (e) { showToast('Could not save tags', true); }
  };
}

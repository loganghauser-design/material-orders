<%
  var A = (typeof active !== 'undefined') ? active : '';
  function _nb(n){ return n ? ' <span class="navbadge">' + n + '</span>' : ''; }
  var pReq = (typeof pendingRequests !== 'undefined') ? pendingRequests : 0;
  var pIss = (typeof pendingIssues !== 'undefined') ? pendingIssues : 0;
  var pWar = (typeof openWarranty !== 'undefined') ? openWarranty : 0;
  var NP = (typeof navPages !== 'undefined') ? navPages : '*';
  function can(k){ return NP === '*' || (Array.isArray(NP) && NP.indexOf(k) >= 0); }
  var iL = (typeof isLogan !== 'undefined') ? isLogan : true;
  var showMore = can('suppliers') || can('inventory') || can('driving');
%>
<nav class="nav">
  <div class="nav-left">
    <a href="/" class="nav-brand">Buildoly Office</a>
    <% if (can('projects')) { %><a href="/projects" class="nav-tab <%= A==='projects'?'active':'' %>">Projects</a><% } %>
    <% if (can('deliveries')) { %><a href="/deliveries" class="nav-tab <%= A==='deliveries'?'active':'' %>">Deliveries</a><% } %>
    <% if (can('requests')) { %><a href="/requests" class="nav-tab <%= A==='requests'?'active':'' %>">Requests<%- _nb(pReq) %></a><% } %>
    <% if (can('issues')) { %><a href="/issues" class="nav-tab <%= A==='issues'?'active':'' %>">Issues<%- _nb(pIss) %></a><% } %>
    <% if (can('warranty')) { %><a href="/warranty-claims" class="nav-tab <%= A==='warranty'?'active':'' %>">Warranty<%- _nb(pWar) %></a><% } %>
    <% if (can('subs')) { %><a href="/subs" class="nav-tab <%= A==='subs'?'active':'' %>">Subs</a><% } %>
    <% if (showMore) { %>
    <div class="nav-more">
      <button type="button" class="nav-tab nav-more-btn <%= ['suppliers','inventory','driving'].indexOf(A)>=0?'active':'' %>" onclick="navToggleMore(event)">More ▾</button>
      <div class="nav-more-menu" id="navMoreMenu">
        <% if (can('suppliers')) { %><a href="/suppliers" class="<%= A==='suppliers'?'on':'' %>">Suppliers</a><% } %>
        <% if (can('inventory')) { %><a href="/inventory" class="<%= A==='inventory'?'on':'' %>">Inventory</a><% } %>
        <% if (can('driving')) { %><a href="/driving" class="<%= A==='driving'?'on':'' %>">Driving Log</a><% } %>
      </div>
    </div>
    <% } %>
    <% if (iL) { %><a href="/team" class="nav-tab <%= A==='team'?'active':'' %>">Team</a><% } %>
    <% if (can('settings')) { %><a href="/settings" class="nav-tab <%= A==='settings'?'active':'' %>">Settings</a><% } %>
    <a href="/account" class="nav-tab <%= A==='account'?'active':'' %>">Account</a>
  </div>
  <div class="nav-actions">
    <% if (can('projects')) { %><a href="/projects/new" class="btn btn-primary btn-sm">+ New</a><% } %>
    <form method="POST" action="/logout" style="margin:0"><button type="submit" class="btn btn-ghost btn-sm">Sign out</button></form>
  </div>
</nav>
<script>
function navToggleMore(e){ e.stopPropagation(); var m=document.getElementById('navMoreMenu'); if(!m) return; var open=m.classList.toggle('open'); if(open){ document.addEventListener('click', function h(){ m.classList.remove('open'); document.removeEventListener('click', h); }); } }
</script>

<%
  var A = (typeof active !== 'undefined') ? active : '';
  var moreItems = ['payments','suppliers','inventory','driving'];
  function _nb(n){ return n ? ' <span class="navbadge">' + n + '</span>' : ''; }
  var pReq = (typeof pendingRequests !== 'undefined') ? pendingRequests : 0;
  var pIss = (typeof pendingIssues !== 'undefined') ? pendingIssues : 0;
  var pWar = (typeof openWarranty !== 'undefined') ? openWarranty : 0;
%>
<nav class="nav">
  <div class="nav-left">
    <a href="/" class="nav-brand">Buildoly Supply</a>
    <a href="/deliveries" class="nav-tab <%= A==='deliveries'?'active':'' %>">Deliveries</a>
    <a href="/requests" class="nav-tab <%= A==='requests'?'active':'' %>">Requests<%- _nb(pReq) %></a>
    <a href="/issues" class="nav-tab <%= A==='issues'?'active':'' %>">Issues<%- _nb(pIss) %></a>
    <a href="/warranty-claims" class="nav-tab <%= A==='warranty'?'active':'' %>">Warranty<%- _nb(pWar) %></a>
    <a href="/subs" class="nav-tab <%= A==='subs'?'active':'' %>">Subs</a>
    <div class="nav-more">
      <button type="button" class="nav-tab nav-more-btn <%= moreItems.indexOf(A)>=0?'active':'' %>" onclick="navToggleMore(event)">More ▾</button>
      <div class="nav-more-menu" id="navMoreMenu">
        <a href="/payments" class="<%= A==='payments'?'on':'' %>">Payments</a>
        <a href="/suppliers" class="<%= A==='suppliers'?'on':'' %>">Suppliers</a>
        <a href="/inventory" class="<%= A==='inventory'?'on':'' %>">Inventory</a>
        <a href="/driving" class="<%= A==='driving'?'on':'' %>">Driving Log</a>
      </div>
    </div>
    <a href="/settings" class="nav-tab <%= A==='settings'?'active':'' %>">Settings</a>
  </div>
  <div class="nav-actions">
    <a href="/projects/new" class="btn btn-primary btn-sm">+ New</a>
    <form method="POST" action="/logout" style="margin:0"><button type="submit" class="btn btn-ghost btn-sm">Sign out</button></form>
  </div>
</nav>
<script>
function navToggleMore(e){ e.stopPropagation(); var m=document.getElementById('navMoreMenu'); if(!m) return; var open=m.classList.toggle('open'); if(open){ document.addEventListener('click', function h(){ m.classList.remove('open'); document.removeEventListener('click', h); }); } }
</script>

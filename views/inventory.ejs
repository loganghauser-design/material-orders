<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory — Material Orders</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .inv-table { width:100%; border-collapse:collapse; font-size:.9rem; }
    .inv-table th { font-size:.72rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); padding:.55rem .8rem; text-align:left; border-bottom:1px solid var(--border); }
    .inv-table td { padding:.7rem .8rem; border-bottom:1px solid var(--border); vertical-align:middle; }
    .inv-table tbody tr:hover { background:var(--bg); }
    .num { text-align:center; font-weight:600; }
    .prod-tag { font-family:ui-monospace,Menlo,monospace; font-size:.76rem; color:var(--muted); background:rgba(120,120,160,.12); padding:1px 7px; border-radius:8px; }
    .proj-breakdown { font-size:.75rem; color:var(--muted); margin-top:3px; }
    .avail-pos { color:#4caf7d; } .avail-low { color:#e0a106; } .avail-neg { color:#cc2222; }
    .qty-input { width:62px; padding:5px 6px; text-align:center; font-size:.95rem; border:1px solid var(--border); border-radius:6px; background:var(--surface); }
    .qty-step { border:1px solid var(--border); background:var(--surface); width:26px; height:30px; border-radius:6px; cursor:pointer; font-size:1rem; line-height:1; }
    .qty-step:hover { background:var(--bg); }
    .saved-tick { color:#4caf7d; font-size:.8rem; opacity:0; transition:opacity .2s; }
    .saved-tick.show { opacity:1; }
    .link-danger { color:#cc2222; cursor:pointer; background:none; border:none; font-size:.82rem; }
    .form-group { margin-bottom:.85rem; }
    .form-group label { display:block; margin-bottom:.25rem; }
    .form-group input { width:100%; }
  </style>
</head>
<body>
<nav class="nav">
  <div style="display:flex;align-items:center;gap:1.25rem">
    <a href="/" class="nav-brand" style="text-decoration:none">Material Orders</a>
    <a href="/inventory" class="nav-tab active">Inventory</a>
    <a href="/suppliers" class="nav-tab">Suppliers</a>
    <a href="/settings" class="nav-tab">Settings</a>
  </div>
  <div class="nav-actions">
    <a href="/" class="btn btn-ghost">← Back</a>
  </div>
</nav>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between">
    <h1>Inventory</h1>
    <button class="btn btn-primary" onclick="openAdd()">+ Add Inventory</button>
  </div>
  <p style="color:var(--muted);font-size:.9rem;margin-bottom:1.25rem;max-width:780px">
    Office/warehouse stock you buy and hold. Add an item with a <strong>Product</strong> keyword and a <strong>Qty</strong>.
    Each project that uses it as held stock (<%= heldSuppliers.join(' / ') %> — e.g. a range hood flipped to Buildoly Stock)
    automatically subtracts one, so <strong>Available</strong> always shows what's still free.
  </p>

  <% if (error) { %>
    <div class="error-msg">Couldn't read one or more schedules right now: <%= error %></div>
  <% } %>

  <div class="card" style="padding:0;overflow:hidden;max-width:none">
    <% if (!items.length) { %>
      <div style="padding:1.6rem;color:var(--muted)">
        No inventory items yet. Click <strong>+ Add Inventory</strong> to add your first one
        (e.g. name <em>Range Hood</em>, product keyword <em>hood</em>, qty <em>13</em>).
      </div>
    <% } else { %>
    <table class="inv-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Product</th>
          <th style="text-align:center">Qty</th>
          <th style="text-align:center">In use</th>
          <th style="text-align:center">Available</th>
          <th style="width:1rem"></th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(it => {
             const cls = it.available < 0 ? 'avail-neg' : (it.available === 0 ? 'avail-low' : 'avail-pos'); %>
          <tr data-id="<%= it.id %>">
            <td>
              <strong><%= it.name %></strong>
              <% if (it.byProject && it.byProject.length) { %>
                <div class="proj-breakdown">In use: <%= it.byProject.map(p => `${p.address.split(',')[0]} ×${p.qty}`).join('  ·  ') %></div>
              <% } %>
            </td>
            <td><% if (it.product) { %><span class="prod-tag"><%= it.product %></span><% } else { %><span style="color:var(--muted)">—</span><% } %></td>
            <td class="num">
              <div style="display:inline-flex;align-items:center;gap:4px">
                <button class="qty-step" onclick="stepQty(this,-1)" title="Remove one">−</button>
                <input class="qty-input" type="number" min="0" value="<%= it.qty %>" data-inuse="<%= it.inUse %>" onchange="saveQty(this)">
                <button class="qty-step" onclick="stepQty(this,1)" title="Add one">+</button>
                <span class="saved-tick">✓</span>
              </div>
            </td>
            <td class="num"><%= it.inUse %></td>
            <td class="num avail-cell <%= cls %>"><%= it.available %><% if (it.available < 0) { %> ⚠<% } %></td>
            <td><button class="link-danger" title="Delete" onclick="deleteItem(<%= it.id %>, '<%= it.name.replace(/'/g, "\\'") %>')">✕</button></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
  <p style="color:var(--muted);font-size:.78rem;margin-top:.8rem">
    <strong>Available = Qty − In use.</strong> A <span class="avail-neg">red ⚠</span> means more projects need it than you have — time to order more.
  </p>
</div>

<!-- Add item modal (uses the app's standard modal classes) -->
<div class="modal-overlay" id="addModal">
  <div class="modal">
    <h2>Add inventory item</h2>
    <p class="modal-sub">Stock you keep in the office. The <strong>Product</strong> keyword is what the app looks for in your finish schedules.</p>
    <form onsubmit="return submitAdd(event)">
      <div class="form-group">
        <label>Item name</label>
        <input type="text" id="add_name" placeholder="Range Hood" required>
      </div>
      <div class="form-group">
        <label>Product (keyword to match in the schedule — e.g. "hood")</label>
        <input type="text" id="add_product" placeholder="hood">
      </div>
      <div class="form-group">
        <label>Qty on hand</label>
        <input type="number" id="add_qty" min="0" value="0" placeholder="13">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" onclick="closeAdd()">Cancel</button>
        <button type="submit" class="btn btn-primary">Add item</button>
      </div>
    </form>
  </div>
</div>

<script>
function openAdd() { document.getElementById('addModal').classList.add('show'); document.getElementById('add_name').focus(); }
function closeAdd() { document.getElementById('addModal').classList.remove('show'); }
async function post(url, body) {
  const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body || {}) });
  return r.json();
}
async function submitAdd(e) {
  e.preventDefault();
  const name = document.getElementById('add_name').value.trim();
  const product = document.getElementById('add_product').value.trim();
  const qty = document.getElementById('add_qty').value;
  if (!name) return false;
  const d = await post('/inventory/item/add', { name, product, qty });
  if (d.ok) location.reload(); else alert('Could not add: ' + (d.error || 'error'));
  return false;
}
function stepQty(btn, delta) {
  const input = btn.parentElement.querySelector('.qty-input');
  input.value = Math.max(0, (parseInt(input.value, 10) || 0) + delta);
  saveQty(input);
}
async function saveQty(input) {
  const tr = input.closest('tr');
  const id = tr.getAttribute('data-id');
  const qty = Math.max(0, parseInt(input.value, 10) || 0);
  input.value = qty;
  const d = await post('/inventory/item/' + id + '/qty', { qty });
  if (!d.ok) { alert('Could not save: ' + (d.error || 'error')); return; }
  // recompute available
  const inUse = parseInt(input.getAttribute('data-inuse'), 10) || 0;
  const avail = qty - inUse;
  const cell = tr.querySelector('.avail-cell');
  cell.textContent = avail + (avail < 0 ? ' ⚠' : '');
  cell.className = 'num avail-cell ' + (avail < 0 ? 'avail-neg' : (avail === 0 ? 'avail-low' : 'avail-pos'));
  const tick = tr.querySelector('.saved-tick');
  tick.classList.add('show'); setTimeout(() => tick.classList.remove('show'), 1200);
}
async function deleteItem(id, name) {
  if (!confirm('Delete "' + name + '"?')) return;
  const d = await post('/inventory/item/' + id + '/delete', {});
  if (d.ok) location.reload(); else alert('Could not delete.');
}
document.getElementById('addModal').addEventListener('click', e => { if (e.target.id === 'addModal') closeAdd(); });
</script>
</body>
</html>

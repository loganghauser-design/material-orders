<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory — Material Orders</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .inv-table { width:100%; border-collapse:collapse; font-size:.9rem; }
    .inv-table th { font-size:.7rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); padding:.55rem .7rem; text-align:center; border-bottom:1px solid var(--border); white-space:nowrap; }
    .inv-table th.l, .inv-table td.l { text-align:left; }
    .inv-table td { padding:.7rem .7rem; border-bottom:1px solid var(--border); vertical-align:middle; text-align:center; }
    .inv-table tbody tr.item-row:hover { background:var(--bg); }
    .num { font-weight:600; }
    .prod-tag { font-family:ui-monospace,Menlo,monospace; font-size:.76rem; color:var(--muted); background:rgba(120,120,160,.12); padding:1px 7px; border-radius:8px; }
    .avail-pos { color:#4caf7d; } .avail-low { color:#e0a106; } .avail-neg { color:#cc2222; }
    .col-deliv { color:#16a34a; } .col-office { color:#7c3aed; }
    .grp-sep { border-left:1px solid var(--border); }
    .qty-input { width:58px; padding:5px 6px; text-align:center; font-size:.95rem; border:1px solid var(--border); border-radius:6px; background:var(--surface); }
    .qty-step { border:1px solid var(--border); background:var(--surface); width:24px; height:30px; border-radius:6px; cursor:pointer; font-size:1rem; line-height:1; }
    .qty-step:hover { background:var(--bg); }
    .saved-tick { color:#4caf7d; font-size:.8rem; opacity:0; transition:opacity .2s; }
    .saved-tick.show { opacity:1; }
    .link-danger { color:#cc2222; cursor:pointer; background:none; border:none; font-size:.82rem; }
    .caret { cursor:pointer; user-select:none; color:var(--muted); margin-right:.4rem; display:inline-block; width:.8rem; }
    .name-toggle { cursor:pointer; }
    .name-toggle:hover { text-decoration:underline; }
    .detail-cell { background:var(--bg); padding:0 !important; }
    .alloc { width:auto; border-collapse:collapse; font-size:.84rem; margin:.5rem 0 .7rem 2.4rem; }
    .alloc th, .alloc td { padding:5px 16px 5px 0; text-align:left; }
    .alloc th { color:var(--muted); font-weight:600; font-size:.72rem; text-transform:uppercase; }
    .status-pill { padding:3px 11px; border-radius:11px; font-size:.78rem; font-weight:600; display:inline-block; }
    .cell-in_office { background:#ede0fb; color:#5b2a86; }
    .cell-in_ware { background:#fde6c8; color:#8a4b00; }
    .cell-delivered { background:#6aa84f; color:#fff; }
    .col-ware { color:#c2710c; }
    .sec-head { display:flex; align-items:flex-end; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin:0 0 .7rem; }
    .sec-title { font-size:1.25rem; font-weight:700; margin:0; }
    .sec-sub { color:var(--muted); font-size:.83rem; margin-top:.15rem; max-width:620px; }
    .sec-totals { display:flex; gap:1.2rem; font-size:.85rem; color:var(--muted); }
    .sec-totals b { font-size:1.05rem; color:var(--text); margin-left:.25rem; }
    .sec-totals .col-deliv b { color:#16a34a; }
    .sec-totals .col-office b { color:#7c3aed; }
    .sec-totals .col-ware b { color:#c2710c; }
    .spinner { width:30px; height:30px; border:3px solid var(--border); border-top-color:#4361ee; border-radius:50%; animation:invspin .8s linear infinite; }
    @keyframes invspin { to { transform:rotate(360deg); } }
    .toggle-btn { border:none; cursor:pointer; font-family:inherit; }
    .toggle-btn:hover { filter:brightness(.96); box-shadow:0 0 0 2px rgba(0,0,0,.07); }
    .toggle-btn:disabled { opacity:.6; cursor:default; }
    .stat-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:.7rem 1.3rem; }
    .stat-label { font-size:.72rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); }
    .stat-value { font-size:1.5rem; font-weight:700; }
    .form-group { margin-bottom:.85rem; }
    .form-group label { display:block; margin-bottom:.25rem; }
    .form-group input { width:100%; }
  </style>
</head>
<body>
<nav class="nav">
  <div style="display:flex;align-items:center;gap:1.25rem">
    <a href="/" class="nav-brand" style="text-decoration:none">Material Orders</a>
    <a href="/deliveries" class="nav-tab">Deliveries</a>
    <a href="/payments" class="nav-tab">Payments</a>
    <a href="/driving" class="nav-tab">Driving Log</a>
    <a href="/inventory" class="nav-tab active">Inventory</a>
    <a href="/suppliers" class="nav-tab">Suppliers</a>
    <a href="/settings" class="nav-tab">Settings</a>
  </div>
  <div class="nav-actions">
    <a href="/" class="btn btn-ghost">← Back</a>
  </div>
</nav>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
      <h1>Inventory</h1>
      <button class="btn btn-primary" onclick="openAdd()">+ Add Office Item</button>
    </div>
  </div>

  <div id="invTables">
    <div id="invLoading" style="padding:2.5rem 1rem;text-align:center;color:var(--muted)">
      <div class="spinner" style="margin:0 auto .8rem"></div>
      Loading inventory from your schedules…
    </div>
  </div>
</div>

<!-- Add item modal (uses the app's standard modal classes) -->
<div class="modal-overlay" id="addModal">
  <div class="modal">
    <h2>Add inventory item</h2>
    <p class="modal-sub">Stock you keep in the office. The <strong>Model # or Prod. Code</strong> is matched <em>exactly</em> against your schedules to track usage — so two specs sharing a name (e.g. S-VG01 vs S-VG01B) stay separate.</p>
    <form onsubmit="return submitAdd(event)">
      <div class="form-group" style="position:relative">
        <label>🔍 Search your schedules (auto-fills the model #)</label>
        <input type="text" id="add_search" placeholder="Type an item, e.g. hood" autocomplete="off" oninput="onSearch()" onfocus="onSearch()">
        <div id="searchResults" style="display:none;position:absolute;z-index:5;left:0;right:0;background:var(--surface);border:1px solid var(--border);border-radius:8px;margin-top:2px;max-height:230px;overflow-y:auto;box-shadow:0 6px 24px rgba(0,0,0,.15)"></div>
      </div>
      <div class="form-group">
        <label>Item name</label>
        <input type="text" id="add_name" placeholder="Range Hood" required>
      </div>
      <div class="form-group">
        <label>Model # or Prod. Code (exact match — e.g. HP30IDCHX4, or S-VG01B for items with no model)</label>
        <input type="text" id="add_product" placeholder="HP30IDCHX4 or S-VG01B">
      </div>
      <div class="form-group">
        <label>Qty on hand</label>
        <input type="number" id="add_qty" min="0" value="0" placeholder="13">
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" onclick="closeAdd()">Cancel</button>
        <button type="submit" class="btn btn-primary">Add item</button>
      </div>
    </form>
  </div>
</div>

<script>
// Load the heavy office/warehouse tables after the page shell shows, so the tab
// opens instantly instead of blocking on reading every project's schedule.
function loadInventory() {
  fetch('/inventory/data')
    .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
    .then(html => { document.getElementById('invTables').innerHTML = html; })
    .catch(e => {
      document.getElementById('invTables').innerHTML =
        '<div style="padding:2rem;color:#cc2222">Could not load inventory: ' + e.message +
        ' — <a href="/inventory">retry</a></div>';
    });
}
loadInventory();

let CATALOG = null;
let CATALOG_LOADING = false;
async function loadCatalog() {
  if (CATALOG || CATALOG_LOADING) return;
  CATALOG_LOADING = true;
  try {
    const r = await fetch('/inventory/catalog');
    const d = await r.json();
    CATALOG = d.items || [];
  } catch (e) { CATALOG = []; }
  finally { CATALOG_LOADING = false; }
  if (document.getElementById('add_search').value.trim()) onSearch();
}
function onSearch() {
  const box = document.getElementById('searchResults');
  const q = document.getElementById('add_search').value.trim().toLowerCase();
  if (!q) { box.style.display = 'none'; return; }
  if (!CATALOG) {
    box.innerHTML = '<div style="padding:8px 10px;color:var(--muted);font-size:.82rem">Loading your schedules…</div>';
    box.style.display = 'block';
    loadCatalog();
    return;
  }
  const hits = CATALOG.filter(it =>
    it.name.toLowerCase().includes(q) ||
    (it.model && it.model.toLowerCase().includes(q)) ||
    (it.product && it.product.toLowerCase().includes(q))
  ).slice(0, 40);
  if (!hits.length) { box.innerHTML = '<div style="padding:8px 10px;color:var(--muted);font-size:.82rem">No matches in your schedules.</div>'; box.style.display = 'block'; return; }
  box.innerHTML = hits.map((it, i) => {
    const code = bestCode(it);
    const idText = code || 'no model/code';
    const idCol = code ? 'var(--muted)' : '#cc8800';
    return `<div class="search-hit" data-i="${i}" style="padding:7px 10px;cursor:pointer;border-bottom:1px solid var(--border);font-size:.85rem">
       <strong>${escapeHtml(it.name)}</strong>
       <span style="font-family:ui-monospace,monospace;color:${idCol}"> · ${escapeHtml(idText)}</span>
       ${it.product && it.product.toLowerCase() !== it.name.toLowerCase() ? `<span style="color:var(--muted);font-size:.78rem"> · ${escapeHtml(it.product)}</span>` : ''}
       ${it.supplier ? `<span style="color:var(--muted);font-size:.78rem"> · ${escapeHtml(it.supplier)}</span>` : ''}
     </div>`; }).join('');
  box.style.display = 'block';
  Array.from(box.querySelectorAll('.search-hit')).forEach(el => {
    el.addEventListener('click', () => pickHit(hits[parseInt(el.getAttribute('data-i'), 10)]));
    el.addEventListener('mouseover', () => el.style.background = 'var(--bg)');
    el.addEventListener('mouseout', () => el.style.background = '');
  });
}
function pickHit(it) {
  document.getElementById('add_name').value = it.name + (it.product && it.product.toLowerCase() !== it.name.toLowerCase() ? ' (' + it.product + ')' : '');
  document.getElementById('add_product').value = bestCode(it);
  document.getElementById('searchResults').style.display = 'none';
  document.getElementById('add_search').value = it.name;
  document.getElementById('add_qty').focus();
}
// The product code that identifies an item: Prod. Code first (unless "custom"/blank), else Model #
function bestCode(it) {
  if (it.prodCode && !/^custom$/i.test(it.prodCode)) return it.prodCode;
  return it.model || it.prodCode || '';
}
function escapeHtml(s) { return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function openAdd() {
  document.getElementById('addModal').classList.add('show');
  document.getElementById('add_search').value = '';
  document.getElementById('searchResults').style.display = 'none';
  loadCatalog();
  document.getElementById('add_search').focus();
}
function closeAdd() { document.getElementById('addModal').classList.remove('show'); }
async function post(url, body) {
  const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body || {}) });
  return r.json();
}
async function submitAdd(e) {
  e.preventDefault();
  const name = document.getElementById('add_name').value.trim();
  const product = document.getElementById('add_product').value.trim();
  const qty = document.getElementById('add_qty').value;
  if (!name) return false;
  const d = await post('/inventory/item/add', { name, product, qty });
  if (d.ok) location.reload(); else alert('Could not add: ' + (d.error || 'error'));
  return false;
}
function toggleAlloc(id) {
  const row = document.getElementById('det_' + id);
  const car = document.getElementById('car_' + id);
  if (!row) return;
  const show = row.style.display === 'none';
  row.style.display = show ? '' : 'none';
  if (car) car.textContent = show ? '▾' : '▸';
}
function stepQty(btn, delta) {
  const input = btn.parentElement.querySelector('.qty-input');
  input.value = Math.max(0, (parseInt(input.value, 10) || 0) + delta);
  saveQty(input);
}
async function saveQty(input) {
  const tr = input.closest('tr');
  const id = tr.getAttribute('data-id');
  const qty = Math.max(0, parseInt(input.value, 10) || 0);
  input.value = qty;
  const d = await post('/inventory/item/' + id + '/qty', { qty });
  if (!d.ok) { alert('Could not save: ' + (d.error || 'error')); return; }
  // recompute Available and In office live
  const inUse = parseInt(input.getAttribute('data-inuse'), 10) || 0;
  const deliv = parseInt(input.getAttribute('data-deliv'), 10) || 0;
  const avail = qty - inUse;
  const aCell = tr.querySelector('.avail-cell');
  aCell.textContent = avail + (avail < 0 ? ' ⚠' : '');
  aCell.className = 'num avail-cell ' + (avail < 0 ? 'avail-neg' : (avail === 0 ? 'avail-low' : 'avail-pos'));
  const oCell = tr.querySelector('.office-cell');
  const office = qty - deliv;
  oCell.textContent = office + (office < 0 ? ' ⚠' : '');
  oCell.style.color = office < 0 ? '#cc2222' : '';
  const tick = tr.querySelector('.saved-tick');
  tick.classList.add('show'); setTimeout(() => tick.classList.remove('show'), 1200);
}
async function deleteItem(id, name) {
  if (!confirm('Delete "' + name + '"?')) return;
  const d = await post('/inventory/item/' + id + '/delete', {});
  if (d.ok) location.reload(); else alert('Could not delete.');
}
// Manually flip an office-stock item between In office / Delivered for one project,
// as you physically pull and drop it off. Reloads so the totals recompute.
function bump(id, delta) {
  const el = document.getElementById(id);
  if (el) el.textContent = (parseInt(el.textContent, 10) || 0) + delta;
}
async function toggleDelivered(btn) {
  const pid = btn.dataset.pid;
  const keys = (btn.dataset.keys || '').split('||').filter(Boolean);
  const toDelivered = btn.dataset.status !== 'Delivered';
  const newStatus = toDelivered ? 'Delivered' : 'In Office';
  const prevText = btn.textContent;
  if (!keys.length) { alert('This item has no tracking key — cannot mark delivered.'); return; }
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    for (const key of keys) {
      const r = await fetch('/projects/' + pid + '/held-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'item_key=' + encodeURIComponent(key) + '&status=' + encodeURIComponent(newStatus),
      });
      if (!r.ok) throw new Error('save failed (' + r.status + ')');
    }
    // Update the button in place — no reload, so the expanded row stays open.
    const ware = btn.dataset.loc === 'ware';
    btn.dataset.status = newStatus;
    btn.classList.toggle('cell-delivered', toDelivered);
    btn.classList.toggle(ware ? 'cell-in_ware' : 'cell-in_office', !toDelivered);
    btn.textContent = toDelivered ? '✓ Delivered' : (ware ? 'In warehouse — mark delivered' : 'In office — mark delivered');
    btn.disabled = false;
    // Update this item's Delivered / In-office(warehouse) counts and the section totals.
    const qty = parseInt(btn.dataset.qty, 10) || 0;
    const sign = toDelivered ? 1 : -1;
    const row = document.querySelector('tr.item-row[data-id="' + btn.dataset.itemid + '"]');
    if (row) {
      const d = row.querySelector('.deliv-cell');
      const o = row.querySelector(ware ? '.ware-cell' : '.office-cell');
      if (d) d.textContent = (parseInt(d.textContent, 10) || 0) + sign * qty;
      if (o) o.textContent = (parseInt(o.textContent, 10) || 0) - sign * qty;
    }
    bump(ware ? 'tot-wdeliv' : 'tot-odeliv', sign * qty);
    bump(ware ? 'tot-wware' : 'tot-ooffice', -sign * qty);
  } catch (e) {
    btn.disabled = false;
    btn.textContent = prevText;
    alert('Could not save: ' + e.message + '. Please try again.');
  }
}
document.getElementById('addModal').addEventListener('click', e => { if (e.target.id === 'addModal') closeAdd(); });
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buildoly — Warranty</title>
  <link rel="icon" href="/icon.svg">
  <meta name="theme-color" content="#000000">
  <style>
    * { box-sizing:border-box; margin:0; padding:0; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif; }
    body { background:#f3f3f5; color:#111; min-height:100vh; -webkit-font-smoothing:antialiased; }
    .hero { background:#000; color:#fff; padding:34px 20px 28px; text-align:center; }
    .hero .wm { font-weight:800; font-size:2.2rem; letter-spacing:-.04em; }
    .hero .sub { color:#9a9a9a; font-size:.8rem; letter-spacing:.18em; text-transform:uppercase; margin-top:6px; }
    .wrap { max-width:560px; margin:0 auto; padding:22px 16px 70px; }
    .card { background:#fff; border:1px solid #ececef; border-radius:16px; padding:1.6rem 1.4rem; box-shadow:0 8px 26px rgba(0,0,0,.06); }
    .intro { color:#555; font-size:.95rem; margin-bottom:1.3rem; line-height:1.5; text-align:center; }
    .choice { display:flex; flex-direction:column; gap:1rem; }
    .bigbtn { display:block; width:100%; text-align:left; border:2px solid #e3e3e8; border-radius:14px; padding:1.1rem 1.2rem; background:#fafafb; cursor:pointer; }
    .bigbtn:hover { border-color:#111; }
    .bigbtn .t { font-size:1.15rem; font-weight:800; }
    .bigbtn .d { font-size:.86rem; color:#666; margin-top:.25rem; line-height:1.4; }
    .bigbtn.emerg { border-color:#f3c9c9; background:#fdf3f3; }
    .bigbtn.emerg .t { color:#c0392b; }
    .fld { margin-bottom:1.1rem; }
    .fld > label { display:block; font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#666; margin-bottom:.45rem; }
    .fld input, .fld textarea { width:100%; padding:.8rem .9rem; font-size:1rem; border:1.5px solid #e3e3e8; border-radius:11px; background:#fafafb; color:#111; }
    .fld input:focus, .fld textarea:focus { outline:none; border-color:#111; background:#fff; }
    .req { color:#c0392b; }
    .hint { font-size:.78rem; color:#999; margin-top:.35rem; }
    .chips { display:flex; flex-wrap:wrap; gap:.45rem; }
    .chip { padding:.5rem .9rem; border:1.5px solid #e3e3e8; border-radius:18px; font-size:.9rem; cursor:pointer; user-select:none; background:#fafafb; }
    .chip.on { background:#111; color:#fff; border-color:#111; }
    .photo-btn { display:flex; align-items:center; justify-content:center; gap:.5rem; width:100%; padding:1rem; border:2px dashed #cfcfd6; border-radius:12px; background:#fafafb; font-weight:600; color:#333; cursor:pointer; }
    #photoInput { display:none; }
    .thumbs { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:.7rem; }
    .thumbs img { width:72px; height:72px; object-fit:cover; border-radius:9px; border:1px solid #e3e3e8; }
    .submit { width:100%; padding:.95rem; font-size:1.05rem; font-weight:700; background:#111; color:#fff; border:none; border-radius:12px; cursor:pointer; }
    .submit:hover { background:#000; }
    .ghost { background:none; border:none; color:#888; font-size:.86rem; cursor:pointer; text-decoration:underline; margin-top:1rem; display:block; }
    .hp { position:absolute; left:-9999px; }
    .thanks { text-align:center; padding:2rem 1rem; }
    .thanks .big { font-size:3rem; }
    .thanks h2 { font-size:1.3rem; margin:.6rem 0 .4rem; }
    .thanks p { color:#555; line-height:1.5; }
    .errbox { background:#fdf0f0; border:1px solid #f3c9c9; color:#c0392b; padding:.7rem 1rem; border-radius:10px; font-size:.9rem; margin-bottom:1.1rem; }
    .callrow { display:flex; gap:.7rem; margin-top:1.1rem; }
    .callrow a { flex:1; text-align:center; padding:.9rem; border-radius:12px; font-weight:700; font-size:1rem; text-decoration:none; }
    .callrow .call { background:#111; color:#fff; }
    .callrow .text { background:#fff; color:#111; border:2px solid #111; }
    .emph { font-size:1.5rem; font-weight:800; text-align:center; margin:.4rem 0; letter-spacing:.01em; }
  </style>
</head>
<body>
  <div class="hero"><div class="wm">buildoly</div><div class="sub">Warranty &amp; Service</div></div>
  <div class="wrap">
    <% if (ok) { %>
      <div class="card thanks">
        <div class="big">✅</div>
        <h2>Thanks — we received your request.</h2>
        <p>Our team will review the details and photos and reach out to you. You can close this page.</p>
      </div>
    <% } else { %>
      <!-- Step 1: choose emergency vs standard -->
      <div class="card" id="panelChoice">
        <div class="intro">How can we help with your home? Choose the option that fits.</div>
        <div class="choice">
          <button type="button" class="bigbtn emerg" onclick="show('panelEmerg')">
            <div class="t">🚨 Emergency</div>
            <div class="d">Active leak, no power/water, gas smell, or anything unsafe that can't wait. Call or text us right away.</div>
          </button>
          <button type="button" class="bigbtn" onclick="show('panelForm')">
            <div class="t">🛠️ Warranty Request</div>
            <div class="d">A non-urgent issue you'd like us to look at. Send a few details and photos and we'll follow up.</div>
          </button>
        </div>
      </div>

      <!-- Emergency -->
      <div class="card" id="panelEmerg" style="display:none">
        <div class="intro" style="margin-bottom:.6rem">For an emergency, please contact <strong>Logan</strong> directly at this number — don't wait on the form.</div>
        <% if (emergencyPhone) { %>
          <div class="emph"><%= emergencyPhone %></div>
          <div class="callrow">
            <a class="call" href="tel:<%= emergencyPhone.replace(/[^0-9+]/g,'') %>">📞 Call now</a>
            <a class="text" href="sms:<%= emergencyPhone.replace(/[^0-9+]/g,'') %>">💬 Text us</a>
          </div>
        <% } else { %>
          <p style="text-align:center;color:#555">Please call your Buildoly project manager directly. If you don't have the number, submit a warranty request below and mark it urgent in the description.</p>
        <% } %>
        <button type="button" class="ghost" onclick="show('panelChoice')">← Back</button>
      </div>

      <!-- Standard warranty form -->
      <div class="card" id="panelForm" style="display:none">
        <% if (typeof err !== 'undefined' && err) { %><div class="errbox">Please add your name and your property address so we can identify your project.</div><% } %>
        <form method="POST" action="/warranty" enctype="multipart/form-data" id="wForm">
          <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off">

          <div class="fld"><label>Your name <span class="req">*</span></label><input name="client_name" required placeholder="First name is fine"></div>
          <div class="fld"><label>Property address <span class="req">*</span></label><input name="project_address" required placeholder="The address of your home / project"><div class="hint">This helps us pull up your project — you won't see anyone else's.</div></div>
          <div class="fld"><label>Best phone or email <span style="font-weight:400;text-transform:none;letter-spacing:0;color:#999">(so we can reach you)</span></label><input name="client_contact" placeholder="(555) 123-4567 or you@email.com"></div>

          <div class="fld">
            <label>Which room(s)? <span style="font-weight:400;text-transform:none;letter-spacing:0;color:#999">tap all that apply</span></label>
            <div id="roomChips" class="chips"></div>
            <input type="hidden" name="rooms" id="f_rooms">
          </div>

          <div class="fld"><label>Describe the issue</label><textarea name="description" rows="4" placeholder="Tell us what's going on…"></textarea></div>

          <div class="fld">
            <label>Photos <span style="font-weight:400;text-transform:none;letter-spacing:0;color:#999">(add as many as you like)</span></label>
            <label class="photo-btn" for="photoInput">📷 Add photos</label>
            <input type="file" id="photoInput" name="photos" accept="image/*" multiple onchange="previewPhotos(this)">
            <div class="thumbs" id="thumbs"></div>
          </div>

          <button type="submit" class="submit">Submit request</button>
        </form>
        <button type="button" class="ghost" onclick="show('panelChoice')">← Back</button>
      </div>
    <% } %>
  </div>

<script>
function show(id) {
  ['panelChoice','panelEmerg','panelForm'].forEach(p => { var el = document.getElementById(p); if (el) el.style.display = (p === id) ? '' : 'none'; });
  window.scrollTo(0, 0);
}
const ROOMS = ['Living Room','Kitchen','Bedroom','Bathroom','Hallway','Exterior'];
let selRooms = [];
function renderRooms() {
  var box = document.getElementById('roomChips');
  if (!box) return;
  box.innerHTML = ROOMS.map(r => `<span class="chip${selRooms.includes(r)?' on':''}" onclick="togRoom(this.dataset.r)" data-r="${r}">${r}</span>`).join('');
  document.getElementById('f_rooms').value = selRooms.join(', ');
}
function togRoom(r) { const i = selRooms.indexOf(r); if (i >= 0) selRooms.splice(i,1); else selRooms.push(r); renderRooms(); }
function previewPhotos(input) {
  const box = document.getElementById('thumbs');
  box.innerHTML = '';
  Array.from(input.files || []).forEach(f => { const img = document.createElement('img'); img.src = URL.createObjectURL(f); box.appendChild(img); });
}
renderRooms();
</script>
</body>
</html>

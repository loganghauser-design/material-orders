<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buildoly — Warranty &amp; Service</title>
  <link rel="icon" href="/icon.svg">
  <meta name="theme-color" content="#000000">
  <style>
    :root { --ink:#15171a; --muted:#6b7177; --line:#e8e8eb; --bg:#f4f4f3; --accent:#111; --emerg:#c0392b; }
    * { box-sizing:border-box; margin:0; padding:0; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif; }
    body { background:var(--bg); color:var(--ink); min-height:100vh; -webkit-font-smoothing:antialiased; }

    .hero { background:linear-gradient(165deg,#000 0%,#202024 100%); color:#fff; padding:44px 22px 32px; text-align:center; }
    .hero .mark { width:48px; height:48px; border-radius:13px; background:#fff; color:#000; font-weight:800; font-size:1.5rem; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; letter-spacing:-.06em; }
    .hero .wm { font-weight:800; font-size:1.95rem; letter-spacing:-.045em; }
    .hero h1 { font-size:1.02rem; font-weight:600; margin-top:.55rem; }
    .hero .sub { color:#a9a9af; font-size:.9rem; margin-top:.3rem; line-height:1.5; }

    .wrap { max-width:580px; margin:0 auto; padding:22px 16px 36px; }
    .card { background:#fff; border:1px solid var(--line); border-radius:18px; padding:1.7rem 1.5rem; box-shadow:0 10px 30px rgba(20,23,26,.055); }
    .eyebrow { font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.11em; color:var(--muted); }
    .h2 { font-size:1.45rem; font-weight:800; letter-spacing:-.02em; margin:.35rem 0 .4rem; }
    .lead { color:var(--muted); font-size:.96rem; line-height:1.55; margin-bottom:1.4rem; }

    .opt { display:flex; align-items:center; gap:1rem; width:100%; text-align:left; border:1.5px solid var(--line); border-radius:15px; padding:1.15rem; background:#fff; cursor:pointer; transition:border-color .15s, box-shadow .15s, transform .05s; margin-bottom:.9rem; }
    .opt:hover { border-color:var(--ink); box-shadow:0 6px 18px rgba(20,23,26,.07); }
    .opt:active { transform:scale(.992); }
    .opt .ic { flex:none; width:48px; height:48px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; background:#f1f1f0; }
    .opt .body { flex:1; min-width:0; }
    .opt .ttl { font-size:1.12rem; font-weight:800; letter-spacing:-.01em; display:block; }
    .opt .dsc { font-size:.85rem; color:var(--muted); margin-top:.22rem; line-height:1.4; display:block; }
    .opt .arw { color:#c4c4c9; font-size:1.6rem; flex:none; line-height:1; }
    .opt.emerg { border-color:#f0cfca; background:#fdf6f5; }
    .opt.emerg .ic { background:#f6ddd8; }
    .opt.emerg .ttl { color:var(--emerg); }
    .opt.emerg:hover { border-color:var(--emerg); }

    .fld { margin-bottom:1.15rem; }
    .fld > label { display:block; font-size:.83rem; font-weight:700; color:var(--ink); margin-bottom:.42rem; }
    .fld .opt2 { font-weight:400; color:var(--muted); }
    .fld input, .fld textarea { width:100%; padding:.85rem .95rem; font-size:1rem; border:1.5px solid var(--line); border-radius:12px; background:#fcfcfb; color:var(--ink); transition:border-color .15s, box-shadow .15s, background .15s; }
    .fld input::placeholder, .fld textarea::placeholder { color:#b4b4b9; }
    .fld input:focus, .fld textarea:focus { outline:none; border-color:var(--ink); background:#fff; box-shadow:0 0 0 3px rgba(20,23,26,.06); }
    .req { color:var(--emerg); }
    .hint { font-size:.8rem; color:var(--muted); margin-top:.4rem; line-height:1.4; }

    .chips { display:flex; flex-wrap:wrap; gap:.5rem; }
    .chip { display:inline-flex; align-items:center; gap:.35rem; padding:.55rem .95rem; border:1.5px solid var(--line); border-radius:22px; font-size:.92rem; cursor:pointer; user-select:none; background:#fcfcfb; transition:all .12s; }
    .chip:hover { border-color:#c7c7cc; }
    .chip.on { background:var(--ink); color:#fff; border-color:var(--ink); }
    .chip .ck { display:none; font-size:.78rem; }
    .chip.on .ck { display:inline; }

    .drop { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.35rem; width:100%; padding:1.5rem 1rem; border:2px dashed #d4d4d9; border-radius:14px; background:#fafafa; color:var(--muted); cursor:pointer; transition:border-color .15s, background .15s; text-align:center; }
    .drop:hover { border-color:var(--ink); background:#fff; }
    .drop .di { font-size:1.7rem; }
    .drop .dt { font-weight:700; color:var(--ink); font-size:.95rem; }
    .drop .ds { font-size:.78rem; }
    #photoInput { display:none; }
    .thumbs { display:flex; flex-wrap:wrap; gap:.55rem; margin-top:.8rem; }
    .thumbs img { width:76px; height:76px; object-fit:cover; border-radius:11px; border:1px solid var(--line); }

    .submit { width:100%; padding:1.05rem; font-size:1.05rem; font-weight:800; letter-spacing:.01em; background:var(--ink); color:#fff; border:none; border-radius:13px; cursor:pointer; transition:background .15s, transform .05s; }
    .submit:hover { background:#000; }
    .submit:active { transform:scale(.99); }
    .reassure { text-align:center; font-size:.82rem; color:var(--muted); margin-top:.85rem; line-height:1.5; }
    .back { display:inline-flex; align-items:center; gap:.25rem; background:none; border:none; color:var(--muted); font-size:.92rem; cursor:pointer; margin-top:1.3rem; padding:.2rem 0; }
    .back:hover { color:var(--ink); }

    .callbox { text-align:center; }
    .callnum { font-size:2rem; font-weight:800; letter-spacing:-.01em; margin:.3rem 0 .1rem; }
    .callrow { display:flex; gap:.7rem; margin-top:1.2rem; }
    .callrow a { flex:1; text-align:center; padding:1rem; border-radius:13px; font-weight:800; font-size:1rem; text-decoration:none; transition:transform .05s; }
    .callrow a:active { transform:scale(.99); }
    .callrow .call { background:var(--emerg); color:#fff; }
    .callrow .text { background:#fff; color:var(--emerg); border:2px solid var(--emerg); }

    .thanks { text-align:center; }
    .checkbadge { width:74px; height:74px; border-radius:50%; background:#e7f5ee; color:#1a8a4f; display:flex; align-items:center; justify-content:center; font-size:2.3rem; margin:0 auto 1.1rem; }
    .thanks h2 { font-size:1.5rem; font-weight:800; letter-spacing:-.02em; }
    .thanks .ptext { color:var(--muted); font-size:.96rem; line-height:1.55; margin:.55rem 0 1.5rem; }
    .steps { text-align:left; border-top:1px solid var(--line); padding-top:1.3rem; }
    .step { display:flex; gap:.8rem; align-items:flex-start; margin-bottom:.95rem; }
    .step:last-child { margin-bottom:0; }
    .step .sn { flex:none; width:28px; height:28px; border-radius:50%; background:var(--ink); color:#fff; font-size:.85rem; font-weight:700; display:flex; align-items:center; justify-content:center; }
    .step .sl { font-size:.92rem; line-height:1.45; padding-top:.2rem; }

    .foot { text-align:center; color:#9a9aa0; font-size:.76rem; margin-top:1.6rem; line-height:1.7; }
    .foot b { color:#6b7177; font-weight:800; letter-spacing:-.01em; }
    .errbox { background:#fdf0f0; border:1px solid #f3c9c9; color:var(--emerg); padding:.8rem 1rem; border-radius:12px; font-size:.9rem; margin-bottom:1.2rem; line-height:1.45; }
    .hp { position:absolute; left:-9999px; }
  </style>
</head>
<body>
  <div class="hero">
    <div class="mark">b</div>
    <div class="wm">buildoly</div>
    <h1>Warranty &amp; Service</h1>
    <div class="sub">We stand behind our work — tell us how we can help.</div>
  </div>

  <div class="wrap">
    <% if (ok) { %>
      <div class="card thanks">
        <div class="checkbadge">✓</div>
        <h2>Thank you — we've got it.</h2>
        <p class="ptext">Your request is now with our team. We'll review the details and photos and follow up with you directly.</p>
        <div class="steps">
          <div class="step"><span class="sn">1</span><span class="sl"><strong>We review</strong> your request and any photos you sent.</span></div>
          <div class="step"><span class="sn">2</span><span class="sl"><strong>We reach out</strong> to you to schedule a closer look or a fix.</span></div>
          <div class="step"><span class="sn">3</span><span class="sl"><strong>We make it right.</strong></span></div>
        </div>
        <% if (emergencyPhone) { %><p class="reassure" style="margin-top:1.3rem">Something urgent in the meantime? Call <a href="tel:<%= emergencyPhone.replace(/[^0-9+]/g,'') %>" style="color:var(--ink);font-weight:700;text-decoration:none"><%= emergencyPhone %></a>.</p><% } %>
      </div>
    <% } else { %>
      <!-- Step 1: choose -->
      <div class="card" id="panelChoice">
        <div class="eyebrow">How can we help?</div>
        <div class="h2">What do you need?</div>
        <div class="lead">Pick the option that fits your situation — we'll take it from there.</div>
        <button type="button" class="opt emerg" onclick="show('panelEmerg')">
          <span class="ic">🚨</span>
          <span class="body"><span class="ttl">Emergency</span><span class="dsc">Active leak, no power or water, gas smell, or anything unsafe. Reach us right away.</span></span>
          <span class="arw">›</span>
        </button>
        <button type="button" class="opt" onclick="show('panelForm')">
          <span class="ic">🛠️</span>
          <span class="body"><span class="ttl">Warranty Request</span><span class="dsc">A non-urgent issue you'd like us to look at. Send a few details and photos.</span></span>
          <span class="arw">›</span>
        </button>
      </div>

      <!-- Emergency -->
      <div class="card" id="panelEmerg" style="display:none">
        <div class="eyebrow" style="color:var(--emerg)">Emergency</div>
        <div class="h2">Let's get you help now</div>
        <div class="lead">For anything urgent, please contact <strong>Logan</strong> directly — don't wait on the form.</div>
        <% if (emergencyPhone) { %>
          <div class="callbox"><div class="callnum"><%= emergencyPhone %></div></div>
          <div class="callrow">
            <a class="call" href="tel:<%= emergencyPhone.replace(/[^0-9+]/g,'') %>">📞 Call now</a>
            <a class="text" href="sms:<%= emergencyPhone.replace(/[^0-9+]/g,'') %>">💬 Text us</a>
          </div>
        <% } else { %>
          <p class="lead" style="text-align:center;margin-bottom:0">Please call your Buildoly project manager directly. If you don't have the number, submit a request below and note that it's urgent.</p>
        <% } %>
        <button type="button" class="back" onclick="show('panelChoice')">‹ Back</button>
      </div>

      <!-- Standard form -->
      <div class="card" id="panelForm" style="display:none">
        <div class="eyebrow">Warranty Request</div>
        <div class="h2">Tell us about the issue</div>
        <div class="lead">A few quick details and photos help us come prepared.</div>
        <% if (typeof err !== 'undefined' && err) { %><div class="errbox">Please add your name and property address so we can find your project.</div><% } %>
        <form method="POST" action="/warranty" enctype="multipart/form-data" id="wForm">
          <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off">

          <div class="fld"><label>Your name <span class="req">*</span></label><input name="client_name" required placeholder="First name is fine"></div>
          <div class="fld"><label>Property address <span class="req">*</span></label><input name="project_address" required placeholder="Street address of your home"><div class="hint">This is just so we can pull up your project — you'll never see anyone else's.</div></div>
          <div class="fld"><label>Best phone or email <span class="opt2">— so we can reach you</span></label><input name="client_contact" placeholder="(555) 123-4567 or you@email.com"></div>

          <div class="fld">
            <label>Which room(s)? <span class="opt2">tap all that apply</span></label>
            <div id="roomChips" class="chips"></div>
            <input type="hidden" name="rooms" id="f_rooms">
          </div>

          <div class="fld"><label>Describe the issue</label><textarea name="description" rows="4" placeholder="What's going on? The more detail, the better."></textarea></div>

          <div class="fld">
            <label>Photos <span class="opt2">— optional, but they help a lot</span></label>
            <label class="drop" for="photoInput"><span class="di">📷</span><span class="dt">Tap to add photos</span><span class="ds">Add as many as you like</span></label>
            <input type="file" id="photoInput" name="photos" accept="image/*" multiple onchange="previewPhotos(this)">
            <div class="thumbs" id="thumbs"></div>
          </div>

          <button type="submit" class="submit">Submit request</button>
          <div class="reassure">We'll review and get back to you — usually within one business day.</div>
        </form>
        <button type="button" class="back" onclick="show('panelChoice')">‹ Back</button>
      </div>
    <% } %>

    <div class="foot"><b>buildoly</b><br>Warranty &amp; Service</div>
  </div>

<script>
function show(id) {
  ['panelChoice','panelEmerg','panelForm'].forEach(p => { var el = document.getElementById(p); if (el) el.style.display = (p === id) ? '' : 'none'; });
  window.scrollTo(0, 0);
}
const ROOMS = ['Living Room','Kitchen','Bedroom','Bathroom','Hallway','Exterior'];
let selRooms = [];
function renderRooms() {
  var box = document.getElementById('roomChips');
  if (!box) return;
  box.innerHTML = ROOMS.map(r => `<span class="chip${selRooms.includes(r)?' on':''}" onclick="togRoom(this.dataset.r)" data-r="${r}"><span class="ck">✓</span>${r}</span>`).join('');
  document.getElementById('f_rooms').value = selRooms.join(', ');
}
function togRoom(r) { const i = selRooms.indexOf(r); if (i >= 0) selRooms.splice(i,1); else selRooms.push(r); renderRooms(); }
function previewPhotos(input) {
  const box = document.getElementById('thumbs');
  box.innerHTML = '';
  Array.from(input.files || []).forEach(f => { const img = document.createElement('img'); img.src = URL.createObjectURL(f); box.appendChild(img); });
}
renderRooms();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Permit Notifications — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .pn { max-width:640px; margin:0 auto; padding:1.4rem 1.2rem 3rem; }
    .scard { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:1.3rem 1.25rem; margin-bottom:1.1rem; }
    .scard h2 { font-size:.8rem; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); font-weight:800; margin:0 0 .3rem; }
    .scard .sub { color:var(--muted); font-size:.86rem; margin-bottom:1.1rem; }
    .frow { margin-bottom:1rem; }
    .frow label.fl { display:block; font-size:.74rem; font-weight:700; color:var(--muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.04em; }
    .frow input[type=text], .frow input[type=email], .frow input[type=number], .frow select { width:100%; padding:.7rem .85rem; font-size:1rem; border:1px solid var(--border); border-radius:10px; background:var(--bg); color:var(--text); }
    .frow input:focus, .frow select:focus { outline:none; border-color:#111; }
    .inline { display:flex; align-items:center; gap:.6rem; cursor:pointer; font-size:.95rem; font-weight:600; }
    .inline input { width:20px; height:20px; accent-color:#15161a; }
    .daybox { max-width:140px; }
    .save-btn { padding:.72rem 1.4rem; font-size:.95rem; font-weight:700; background:#15161a; color:#fff; border:none; border-radius:10px; cursor:pointer; }
    .save-btn:hover { background:#000; }
    .ghost-btn { padding:.72rem 1.2rem; font-size:.92rem; font-weight:700; background:var(--surface); color:var(--text); border:1px solid var(--border); border-radius:10px; cursor:pointer; }
    .ghost-btn:hover { border-color:#15161a; }
    .banner { padding:.7rem 1rem; border-radius:10px; font-weight:600; margin-bottom:1rem; font-size:.9rem; }
    .ok { background:rgba(76,175,125,.12); border:1px solid rgba(76,175,125,.4); color:#16a34a; }
    .bad { background:rgba(204,34,34,.1); border:1px solid rgba(204,34,34,.35); color:#cc2222; }
    .warn { background:rgba(224,169,82,.13); border:1px solid rgba(224,169,82,.45); color:#a86a13; font-size:.84rem; }
    .idle-row { display:flex; align-items:center; gap:.8rem; padding:.6rem 0; border-bottom:1px solid var(--border); font-size:.9rem; }
    .idle-row:last-child { border-bottom:none; }
    .idle-row .nm { font-weight:700; }
    .idle-row .dur { margin-left:auto; font-weight:800; color:#b4521c; white-space:nowrap; }
    .idle-row .lu { color:var(--muted); font-size:.8rem; white-space:nowrap; }
    .muted { color:var(--muted); font-size:.9rem; }
    .topbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem; gap:1rem; flex-wrap:wrap; }
  </style>
</head>
<body>
<%- include('_nav', { active: 'permits' }) %>

<div class="pn">
  <div class="topbar">
    <h1 style="margin:0">Permit Notifications</h1>
    <a href="/permits" class="btn btn-ghost btn-sm">← Back to board</a>
  </div>

  <% if (saved) { %><div class="banner ok">✓ Notification settings saved.</div><% } %>
  <% if (tested === 'ok') { %><div class="banner ok">✓ Test sent — check the chat space / inbox you configured.</div><% } %>
  <% if (tested === 'err') { %><div class="banner bad">Couldn't send the test. Check the channel/recipient below.</div><% } %>

  <form method="POST" action="/permits/notifications">
    <div class="scard">
      <h2>Idle-permit alerts</h2>
      <div class="sub">Each day we check the board. If a permit hasn't been touched in your set number of days, we send you the permit name and how long it's been sitting. Editing <em>any</em> cell on a permit resets its timer.</div>

      <label class="inline" style="margin-bottom:1.1rem">
        <input type="checkbox" name="enabled" <%= settings.enabled ? 'checked' : '' %>> Notifications on
      </label>

      <div class="frow daybox">
        <label class="fl">Alert after… (days idle)</label>
        <input type="number" name="idle_days" min="1" max="90" value="<%= settings.idle_days || 7 %>">
      </div>

      <div class="frow">
        <label class="fl">Send via</label>
        <select name="channel">
          <option value="both"  <%= settings.channel === 'both'  ? 'selected' : '' %>>Google Chat + Email</option>
          <option value="chat"  <%= settings.channel === 'chat'  ? 'selected' : '' %>>Google Chat only</option>
          <option value="email" <%= settings.channel === 'email' ? 'selected' : '' %>>Email only</option>
        </select>
        <% if (!chatOn) { %><div class="banner warn" style="margin-top:.5rem">Google Chat isn't connected on the server — Chat options won't deliver until it is.</div><% } %>
        <% if (!emailOn) { %><div class="banner warn" style="margin-top:.5rem">Email isn't configured on the server — Email options won't deliver until it is.</div><% } %>
      </div>

      <div class="frow">
        <label class="fl">Email to</label>
        <input type="text" name="email_to" value="<%= settings.email_to || '' %>" placeholder="aziz@buildoly.com (commas for multiple)">
      </div>

      <label class="inline">
        <input type="checkbox" name="active_only" <%= settings.active_only ? 'checked' : '' %>> Only watch <strong>Active Permits</strong> (ignore Issued / Misc / Cancelled)
      </label>

      <div style="margin-top:1.4rem;display:flex;gap:.6rem;flex-wrap:wrap">
        <button type="submit" class="save-btn">Save settings</button>
      </div>
    </div>
  </form>

  <div class="scard">
    <h2>Test it</h2>
    <div class="sub">Sends a sample alert right now to whatever channel you saved above, so you can confirm it lands. (Doesn't affect the daily schedule.)</div>
    <form method="POST" action="/permits/notifications/test" style="margin:0">
      <button type="submit" class="ghost-btn">Send a test now</button>
    </form>
    <% if (settings.last_run) { %><p class="muted" style="margin-top:.9rem">Last automatic check: <%= new Date(settings.last_run).toLocaleString('en-US') %></p><% } %>
  </div>

  <div class="scard">
    <h2>Idle right now (<%= idle.length %>)</h2>
    <% if (idle.length) { %>
      <% idle.forEach(p => { %>
        <div class="idle-row">
          <span class="nm"><%= p.name %></span>
          <span class="lu">last update <%= p.last %></span>
          <span class="dur"><%= p.idle %> days idle</span>
        </div>
      <% }) %>
    <% } else { %>
      <p class="muted">Nothing is idle past the threshold. 🎉</p>
    <% } %>
  </div>
</div>
</body>
</html>

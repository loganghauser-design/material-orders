<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Permit Notifications — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .pn { max-width:720px; margin:0 auto; padding:1.4rem 1.2rem 3rem; }
    .scard { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:1.3rem 1.25rem; margin-bottom:1.1rem; }
    .scard h2 { font-size:.8rem; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); font-weight:800; margin:0 0 .3rem; }
    .scard .sub { color:var(--muted); font-size:.86rem; margin-bottom:1.1rem; }
    .frow { margin-bottom:1rem; }
    .frow label.fl { display:block; font-size:.74rem; font-weight:700; color:var(--muted); margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.04em; }
    .frow input[type=text], .frow input[type=number], .frow select { padding:.7rem .85rem; font-size:1rem; border:1px solid var(--border); border-radius:10px; background:var(--bg); color:var(--text); width:100%; }
    .frow.inlineflds { display:flex; gap:1rem; flex-wrap:wrap; }
    .frow.inlineflds > div { flex:1; min-width:180px; }
    .daybox { max-width:150px; }
    .inline { display:flex; align-items:center; gap:.6rem; cursor:pointer; font-size:.95rem; font-weight:600; }
    .inline input { width:20px; height:20px; accent-color:#15161a; }
    .save-btn { padding:.72rem 1.4rem; font-size:.95rem; font-weight:700; background:#15161a; color:#fff; border:none; border-radius:10px; cursor:pointer; }
    .save-btn:hover { background:#000; }
    .ghost-btn { padding:.72rem 1.2rem; font-size:.92rem; font-weight:700; background:var(--surface); color:var(--text); border:1px solid var(--border); border-radius:10px; cursor:pointer; }
    .ghost-btn:hover { border-color:#15161a; }
    .banner { padding:.7rem 1rem; border-radius:10px; font-weight:600; margin-bottom:1rem; font-size:.9rem; }
    .ok { background:rgba(76,175,125,.12); border:1px solid rgba(76,175,125,.4); color:#16a34a; }
    .bad { background:rgba(204,34,34,.1); border:1px solid rgba(204,34,34,.35); color:#cc2222; }
    .warn { background:rgba(224,169,82,.13); border:1px solid rgba(224,169,82,.45); color:#a86a13; font-size:.84rem; }
    .muted { color:var(--muted); font-size:.9rem; }
    .topbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem; gap:1rem; flex-wrap:wrap; }
    /* per-box blocks */
    .box-list { display:flex; flex-direction:column; gap:.55rem; }
    .box-block { border:1px solid var(--border); border-radius:11px; padding:.7rem .85rem; }
    .box-head { display:flex; align-items:center; gap:1rem; flex-wrap:wrap; }
    .box-head .bname { font-weight:800; font-size:.95rem; min-width:120px; }
    .box-head .wlabel { display:flex; align-items:center; gap:.4rem; font-size:.86rem; font-weight:700; cursor:pointer; }
    .box-head .wlabel input.bwatch { width:18px; height:18px; accent-color:#15161a; }
    .box-head .dlabel { font-size:.85rem; color:var(--muted); display:flex; align-items:center; gap:.4rem; }
    .box-head .dlabel input.bdays { width:62px; padding:.35rem; border:1px solid var(--border); border-radius:7px; background:var(--bg); color:var(--text); text-align:center; font-size:.9rem; }
    .silence { margin-top:.65rem; display:flex; flex-wrap:wrap; gap:.35rem; align-items:center; }
    .silence .slbl { font-size:.72rem; color:var(--muted); font-weight:800; text-transform:uppercase; letter-spacing:.03em; margin-right:.25rem; }
    .chip-lbl { font-size:.74rem; font-weight:700; padding:.26rem .58rem; border-radius:999px; border:1px solid var(--border); background:var(--bg); cursor:pointer; color:var(--text); user-select:none; }
    .chip-lbl input { display:none; }
    .chip-lbl.on { background:#e3f6ec; border-color:#9fdcb8; color:#16794a; }
    .bulk { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:.7rem; }
    .bulk button { font-size:.78rem; font-weight:700; padding:.35rem .7rem; border-radius:8px; border:1px solid var(--border); background:var(--bg); cursor:pointer; color:var(--text); }
    .bulk button:hover { border-color:#15161a; }
    /* idle preview */
    .idle-permit { padding:.6rem 0; border-bottom:1px solid var(--border); }
    .idle-permit:last-child { border-bottom:none; }
    .idle-permit .nm { font-weight:700; font-size:.92rem; }
    .idle-permit .bxs { margin-top:.25rem; display:flex; flex-wrap:wrap; gap:.35rem; }
    .ibox { font-size:.72rem; font-weight:700; padding:.2rem .5rem; border-radius:999px; background:#fbe9e0; color:#b4521c; white-space:nowrap; }
  </style>
</head>
<body>
<%- include('_nav', { active: 'permits' }) %>

<div class="pn">
  <div class="topbar">
    <h1 style="margin:0">Permit Notifications</h1>
    <a href="/permits" class="btn btn-ghost btn-sm">← Back to board</a>
  </div>

  <% if (saved) { %><div class="banner ok">✓ Notification settings saved.</div><% } %>
  <% if (tested === 'ok') { %><div class="banner ok">✓ Test sent — check the chat space / inbox you configured.</div><% } %>
  <% if (tested === 'err') { %><div class="banner bad">Couldn't send the test. Check the channel/recipient below.</div><% } %>

  <form method="POST" action="/permits/notifications" id="pnform">
    <!-- Global -->
    <div class="scard">
      <h2>Delivery</h2>
      <div class="sub">Each day we check the board. A box reminds you on its own repeat schedule while it sits unchanged. Editing a box resets just that box's timer.</div>

      <label class="inline" style="margin-bottom:1.1rem">
        <input type="checkbox" name="enabled" <%= settings.enabled ? 'checked' : '' %>> Notifications on
      </label>

      <div class="frow inlineflds">
        <div>
          <label class="fl">Send via</label>
          <select name="channel">
            <option value="both"  <%= settings.channel === 'both'  ? 'selected' : '' %>>Google Chat + Email</option>
            <option value="chat"  <%= settings.channel === 'chat'  ? 'selected' : '' %>>Google Chat only</option>
            <option value="email" <%= settings.channel === 'email' ? 'selected' : '' %>>Email only</option>
          </select>
        </div>
        <div class="daybox">
          <label class="fl">Default frequency (days)</label>
          <input type="number" name="idle_days" min="1" max="90" value="<%= settings.idle_days || 7 %>">
        </div>
      </div>

      <div class="frow">
        <label class="fl">Email to</label>
        <input type="text" name="email_to" value="<%= settings.email_to || '' %>" placeholder="aziz@buildoly.com (commas for multiple)">
      </div>

      <label class="inline">
        <input type="checkbox" name="active_only" <%= settings.active_only ? 'checked' : '' %>> Only watch <strong>Active Permits</strong>
      </label>

      <% if (!chatOn) { %><div class="banner warn" style="margin-top:.9rem">Google Chat isn't connected on the server — Chat won't deliver until it is.</div><% } %>
      <% if (!emailOn) { %><div class="banner warn" style="margin-top:.9rem">Email isn't configured on the server — Email won't deliver until it is.</div><% } %>
    </div>

    <!-- Per-box rules -->
    <div class="scard">
      <h2>Each box</h2>
      <div class="sub">Pick which status boxes to watch and how often each should remind you while it sits. The timer resets every time you change a box's value, the reminder repeats at that box's frequency until it moves, and a box goes quiet once it reaches a status you tag below (e.g. Soils → Completed). A blank box never alerts.</div>
      <div class="bulk">
        <button type="button" onclick="boxAll(true)">Watch all</button>
        <button type="button" onclick="boxAll(false)">Watch none</button>
        <button type="button" onclick="boxDays()">Set all days…</button>
      </div>
      <div class="box-list">
        <% boxes.forEach(b => { %>
          <div class="box-block">
            <div class="box-head">
              <span class="bname"><%= b.title %></span>
              <label class="wlabel"><input type="checkbox" name="watch_<%= b.key %>" class="bwatch" <%= b.on ? 'checked' : '' %>> Notify</label>
              <span class="dlabel">remind every <input type="number" name="days_<%= b.key %>" class="bdays" min="1" max="90" value="<%= b.days %>"> days</span>
            </div>
            <% if (b.opts && b.opts.length) { %>
              <div class="silence">
                <span class="slbl">Stop once it's</span>
                <% b.opts.forEach(o => { %>
                  <label class="chip-lbl <%= b.done.indexOf(o) >= 0 ? 'on' : '' %>"><input type="checkbox" name="done_<%= b.key %>" value="<%= o %>" <%= b.done.indexOf(o) >= 0 ? 'checked' : '' %> onchange="this.closest('.chip-lbl').classList.toggle('on', this.checked)"><%= o %></label>
                <% }) %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
      <div style="margin-top:1.3rem"><button type="submit" class="save-btn">Save settings</button></div>
    </div>
  </form>

  <!-- Test -->
  <div class="scard">
    <h2>Test it</h2>
    <div class="sub">Sends a sample alert right now to the channel you saved, so you can confirm it lands. (Doesn't affect the daily schedule.)</div>
    <form method="POST" action="/permits/notifications/test" style="margin:0">
      <button type="submit" class="ghost-btn">Send a test now</button>
    </form>
    <% if (settings.last_run) { %><p class="muted" style="margin-top:.9rem">Last automatic check: <%= new Date(settings.last_run).toLocaleString('en-US') %></p><% } %>
  </div>

  <!-- Idle preview -->
  <div class="scard">
    <h2>Idle right now (<%= stale.reduce((n,r)=>n+r.boxes.length,0) %>)</h2>
    <% if (stale.length) { %>
      <% stale.forEach(r => { %>
        <div class="idle-permit">
          <div class="nm"><%= r.name %><% if (r.owner) { %> · <%= r.owner %><% } %></div>
          <div class="bxs">
            <% r.boxes.forEach(b => { %><span class="ibox"><%= b.title %> — <%= b.days %>d</span><% }) %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="muted">No boxes are idle past their window. 🎉</p>
    <% } %>
  </div>
</div>

<script>
  function boxAll(on){ document.querySelectorAll('.bwatch').forEach(function(c){ c.checked = on; }); }
  function boxDays(){ var v = prompt('Alert after how many days idle (applies to every box)?', '7'); if(v===null) return; var n = parseInt(v,10); if(!(n>=1 && n<=90)) return; document.querySelectorAll('.bdays').forEach(function(i){ i.value = n; }); }
</script>
</body>
</html>

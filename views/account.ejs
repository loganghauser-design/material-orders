<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Account — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .acct { max-width:560px; margin:0 auto; padding:1.6rem 1.2rem 3rem; }
    .scard { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:1.3rem 1.25rem; margin-bottom:1.1rem; }
    .scard h2 { font-size:.78rem; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); font-weight:800; margin:0 0 .9rem; }
    .idtop { display:flex; align-items:center; gap:1rem; margin-bottom:.6rem; }
    .avatar { width:54px; height:54px; border-radius:50%; background:#15161a; color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.3rem; flex:none; }
    .idname { font-size:1.25rem; font-weight:800; letter-spacing:-.01em; }
    .rbadge { display:inline-block; font-size:.7rem; font-weight:800; padding:.2rem .6rem; border-radius:999px; background:#e8efff; color:#1d4ed8; text-transform:uppercase; letter-spacing:.03em; margin-top:.25rem; }
    .rbadge.super { background:#e3f6ec; color:#16794a; }
    .info-row { display:flex; justify-content:space-between; padding:.55rem 0; border-bottom:1px solid var(--border); font-size:.92rem; }
    .info-row:last-child { border-bottom:none; }
    .info-row .lbl { color:var(--muted); }
    .chips { display:flex; flex-wrap:wrap; gap:.4rem; }
    .chip { font-size:.78rem; font-weight:600; padding:.28rem .65rem; border-radius:999px; background:var(--bg); border:1px solid var(--border); color:var(--text); }
    .hint { color:var(--muted); font-size:.85rem; margin:-.3rem 0 .9rem; }
    .frow { margin-bottom:.8rem; }
    .frow label { display:block; font-size:.74rem; font-weight:700; color:var(--muted); margin-bottom:.3rem; text-transform:uppercase; letter-spacing:.04em; }
    .frow input { width:100%; padding:.7rem .85rem; font-size:1rem; border:1px solid var(--border); border-radius:10px; background:var(--bg); color:var(--text); }
    .frow input:focus { outline:none; border-color:#111; }
    .save-btn { padding:.7rem 1.3rem; font-size:.95rem; font-weight:700; background:#15161a; color:#fff; border:none; border-radius:10px; cursor:pointer; }
    .save-btn:hover { background:#000; }
    .banner { padding:.7rem 1rem; border-radius:10px; font-weight:600; margin-bottom:1rem; font-size:.9rem; }
    .ok { background:rgba(76,175,125,.12); border:1px solid rgba(76,175,125,.4); color:#16a34a; }
    .bad { background:rgba(204,34,34,.1); border:1px solid rgba(204,34,34,.35); color:#cc2222; }
    .homeview { display:flex; align-items:center; gap:.5rem; }
    .hv { font-size:.84rem; font-weight:700; padding:.36rem .85rem; border-radius:9px; border:1px solid var(--border); text-decoration:none; color:var(--muted); cursor:pointer; }
    .hv.on { background:#15161a; color:#fff; border-color:#15161a; }
  </style>
</head>
<body>
<%- include('_nav', { active: 'account' }) %>

<div class="acct">
  <div class="page-header" style="margin:.2rem 0 1rem"><h1 style="margin:0">My Account</h1></div>

  <% if (pw === 'ok') { %><div class="banner ok">✓ Password updated. Use it next time you sign in.</div><% } %>
  <% if (pw === 'bad') { %><div class="banner bad">Current password is incorrect.</div><% } %>
  <% if (pw === 'short') { %><div class="banner bad">New password must be at least 4 characters.</div><% } %>
  <% if (pw === 'mismatch') { %><div class="banner bad">New passwords don't match.</div><% } %>

  <!-- Identity -->
  <div class="scard">
    <div class="idtop">
      <div class="avatar"><%= (name || '?').trim().charAt(0).toUpperCase() %></div>
      <div>
        <div class="idname"><%= name %></div>
        <span class="rbadge <%= role === 'super' ? 'super' : '' %>"><%= roleLabel %></span>
      </div>
    </div>
    <div class="info-row"><span class="lbl"><%= role === 'super' ? 'Email' : 'Username' %></span><span><%= login %></span></div>
    <% if (phone) { %><div class="info-row"><span class="lbl">Phone</span><span><%= phone %></span></div><% } %>
    <% if (isLogan) { %><div class="info-row"><span class="lbl">Access</span><span>Owner — full access</span></div><% } %>
  </div>

  <!-- Role-based access -->
  <div class="scard">
    <h2>What you can access</h2>
    <p class="hint">Driven by your role<% if (!isLogan) { %> — Logan manages this in the Team hub<% } %>.</p>
    <% if (accessLabels.length) { %>
      <div class="chips">
        <% accessLabels.forEach(l => { %><span class="chip"><%= l %></span><% }) %>
      </div>
    <% } else { %>
      <p class="hint">No pages assigned yet.</p>
    <% } %>
    <% if (role === 'admin' && home) { %>
      <div style="margin-top:1.1rem">
        <label style="display:block; font-size:.74rem; font-weight:700; color:var(--muted); margin-bottom:.4rem; text-transform:uppercase; letter-spacing:.04em">Home view</label>
        <div class="homeview">
          <a class="hv <%= home === 'office' ? 'on' : '' %>" onclick="setDash('office')">Office</a>
          <a class="hv <%= home === 'permits' ? 'on' : '' %>" onclick="setDash('permits')">Permits</a>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Change password -->
  <div class="scard">
    <h2>Change my password</h2>
    <p class="hint">Set a personal password for signing in.</p>
    <form method="POST" action="/account/password">
      <div class="frow"><label>Current password</label><input type="password" name="current" required></div>
      <div class="frow"><label>New password</label><input type="password" name="new1" required></div>
      <div class="frow"><label>Confirm new password</label><input type="password" name="new2" required></div>
      <button type="submit" class="save-btn">Update password</button>
    </form>
  </div>
</div>

<script>
function setDash(d){
  fetch('/dashboard-pref',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({dashboard:d})})
    .then(function(){ location.reload(); }).catch(function(){ location.reload(); });
}
</script>
</body>
</html>

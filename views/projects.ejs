<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Projects — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css?v=5">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#000000">
  <style>
    .psummary { display:flex; gap:12px; margin-bottom:1.3rem; flex-wrap:wrap; }
    .psum { border-radius:11px; padding:.7rem 1.15rem; min-width:130px; }
    .psum .l { font-size:.78rem; font-weight:600; }
    .psum .v { font-size:1.8rem; font-weight:700; line-height:1.1; }
    .psum-need { background:#fdeaea; } .psum-need .l, .psum-need .v { color:#b42323; }
    .psum-wait { background:#e6f1fb; } .psum-wait .l, .psum-wait .v { color:#185fa5; }
    .psum-ok   { background:#eaf6ee; } .psum-ok .l, .psum-ok .v { color:#176b3a; }
    .pcards { display:flex; flex-direction:column; gap:10px; margin-bottom:1.6rem; }
    .pcard { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:11px 14px; }
    .pcard-top { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .drag-handle { cursor:grab; color:var(--muted); font-size:1rem; user-select:none; }
    .urg-dot { width:10px; height:10px; border-radius:50%; flex:none; background:#4caf7d; }
    .urg-red .urg-dot { background:#e24b4a; } .urg-amber .urg-dot { background:#e0a952; }
    .pcard-name { font-size:1rem; color:var(--text); text-decoration:none; }
    .pcard-name:hover { text-decoration:underline; }
    .pcard-ver { font-size:.8rem; color:var(--muted); font-weight:400; }
    .reply-dot { color:#e5484d; font-size:1rem; text-decoration:none; }
    .pcard-right { margin-left:auto; display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .pc-avatars { display:flex; align-items:center; gap:4px; }
    .pc-avatar { width:24px; height:24px; border-radius:50%; background:#e6f1fb; color:#185fa5; font-size:.7rem; font-weight:700; display:inline-flex; align-items:center; justify-content:center; }
    .pc-nosup { font-size:.72rem; color:var(--muted); }
    .pc-phase { font-size:.76rem; border:1px solid var(--border); border-radius:7px; padding:2px 6px; background:var(--bg); cursor:pointer; color:var(--text); }
    .pc-del { background:none; border:none; cursor:pointer; font-size:.9rem; opacity:.5; }
    .pc-del:hover { opacity:1; }
    .pipe { display:flex; gap:5px; margin:11px 0 9px; }
    .pipe-seg { flex:1; min-width:0; }
    .pipe-lbl { font-size:.66rem; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-bottom:3px; }
    .pipe-bar { height:9px; border-radius:3px; background:var(--bg); border:1px solid var(--border); overflow:hidden; display:flex; }
    .pipe-fill-d { background:#4caf7d; } .pipe-fill-o { background:#378add; }
    .pipe-cnt { font-size:.66rem; color:var(--muted); margin-top:2px; }
    .needs { display:flex; gap:6px; flex-wrap:wrap; border-top:1px solid var(--border); padding-top:9px; }
    .need { font-size:.74rem; font-weight:600; border-radius:999px; padding:3px 10px; white-space:nowrap; }
    .need-bad { background:#fdeaea; color:#b42323; } .need-warn { background:#fff4dd; color:#8a6100; }
    .need-info { background:#e6f1fb; color:#185fa5; } .need-mute { background:var(--bg); color:var(--muted); }
    .need-ok { background:#eaf6ee; color:#176b3a; }
    .pipe-legend { display:flex; gap:14px; font-size:.72rem; color:var(--muted); margin-left:auto; }
    .pipe-legend span { display:inline-flex; align-items:center; gap:5px; }
    .lg-sw { width:10px; height:10px; border-radius:2px; display:inline-block; }
    .row-dragging { opacity:.5; }
    /* Team picker chip on each card */
    .pc-team { display:inline-flex; align-items:center; gap:6px; border:1px solid var(--border); background:var(--bg); border-radius:999px; padding:3px 9px 3px 9px; cursor:pointer; font-size:.8rem; max-width:210px; color:var(--text); }
    .pc-team:hover { border-color:#4f8ef7; }
    .tm-dot { width:8px; height:8px; border-radius:50%; flex:none; }
    .tm-name { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-weight:600; }
    .tm-badge { font-size:.56rem; font-weight:800; letter-spacing:.03em; padding:1px 5px; border-radius:5px; flex:none; }
    .tm-badge-gc { background:#efe8fb; color:#6b3fc2; } .tm-badge-sup { background:#e6f1fb; color:#185fa5; }
    .tm-more { font-size:.68rem; color:var(--muted); flex:none; }
    .tm-none { color:var(--muted); font-weight:600; }
    .tm-caret { color:var(--muted); font-size:.58rem; margin-left:1px; flex:none; }
    /* Shared grouped dropdown popover */
    .teampop { position:fixed; z-index:1000; width:252px; max-height:360px; overflow:auto; background:var(--surface); border:1px solid var(--border); border-radius:12px; box-shadow:0 14px 38px rgba(0,0,0,.20); padding:6px; }
    .teampop[hidden] { display:none; }
    .tp-group { font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); padding:9px 8px 3px; }
    .tp-row { display:flex; align-items:center; gap:8px; padding:7px 8px; border-radius:8px; cursor:pointer; font-size:.86rem; color:var(--text); }
    .tp-row:hover { background:var(--bg); }
    .tp-row.sel { background:#e6f1fb; color:#185fa5; font-weight:700; }
    .tp-row .tp-check { margin-left:auto; color:#185fa5; font-weight:700; }
    .tp-dot { width:8px; height:8px; border-radius:50%; flex:none; }
    .tp-dot-super { background:#3b82f6; } .tp-dot-gc { background:#8b5cf6; }
    .tp-sep { height:1px; background:var(--border); margin:5px 2px; }
    .tp-addbtn { display:block; width:100%; text-align:left; background:none; border:none; padding:8px; font-size:.84rem; font-weight:700; color:#4f8ef7; cursor:pointer; border-radius:8px; }
    .tp-addbtn:hover { background:var(--bg); }
    .tp-addform { display:flex; flex-direction:column; gap:6px; padding:6px 8px 8px; }
    .tp-addform input, .tp-addform select { font-size:.82rem; padding:7px 8px; border:1px solid var(--border); border-radius:7px; background:var(--bg); color:var(--text); }
    .tp-addactions { display:flex; gap:6px; }
    @media (max-width:760px){ .pipe-lbl,.pipe-cnt{ font-size:.6rem; } }
  </style>
</head>
<body>
<%- include('_nav', { active: 'projects' }) %>

<div class="container wide">
  <% const sortedNow = (typeof sort !== 'undefined' && sort === 'delivered'); %>
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem;margin:.2rem 0 1rem">
    <h1 style="margin:0">Projects</h1>
    <div class="pipe-legend">
      <span><span class="lg-sw" style="background:#4caf7d"></span>Delivered</span>
      <span><span class="lg-sw" style="background:#378add"></span>On order</span>
    </div>
  </div>

  <div class="psummary">
    <div class="psum psum-need"><div class="l">Need action</div><div class="v"><%= summary.needAction %></div></div>
    <div class="psum psum-wait"><div class="l">Awaiting vendor</div><div class="v"><%= summary.awaiting %></div></div>
    <div class="psum psum-ok"><div class="l">On track</div><div class="v"><%= summary.onTrack %></div></div>
  </div>

  <form method="GET" action="/projects" class="toolbar">
    <input type="text" name="search" placeholder="Search address…" value="<%= query.search || '' %>">
    <select name="status" onchange="this.form.submit()">
      <option value="">All statuses</option>
      <% PROJECT_PHASES.forEach(s => { %>
        <option value="<%= s %>" <%- query.status===s?'selected':'' %>><%= s %></option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-ghost">Search</button>
    <% if (query.search || query.status) { %><a href="/projects" class="btn btn-ghost">Clear</a><% } %>
  </form>

  <%
    const PHASE_CLASSES = { 'In Permitting': 'ph-ip', 'Pre-Construction': 'ph-pc', 'Under Construction': 'ph-uc', 'Complete': 'ph-co', 'Under Warranty': 'ph-uw' };
    function phaseOf(p) {
      if (PROJECT_PHASES.includes(p.phase)) return p.phase;
      if (p.overall_status === 'Fully Delivered') return 'Complete';
      if (p.overall_status === 'In Progress' || p.overall_status === 'All Delivered') return 'Under Construction';
      return 'Pre-Construction';
    }
    var _phaseOrder = ['Under Construction', 'Pre-Construction', 'In Permitting', 'Under Warranty', 'Complete'].filter(ph => PROJECT_PHASES.includes(ph));
    PROJECT_PHASES.forEach(ph => { if (!_phaseOrder.includes(ph)) _phaseOrder.push(ph); });
  %>
  <% _phaseOrder.forEach(ph => { const rows = projects.filter(p => phaseOf(p) === ph); %>
    <div class="phase-divider <%= PHASE_CLASSES[ph] %>"><span><%= ph %> (<%= rows.length %>)</span></div>
    <% if (rows.length) { %>
      <div class="pcards" data-phase="<%= ph %>">
        <% rows.forEach(p => { var c = (cards && cards[p.id]) || { stages: [], needs: [], urgency: 'green', sup: [] }; %>
          <div class="pcard urg-<%= c.urgency %>" data-id="<%= p.id %>">
            <div class="pcard-top">
              <span class="drag-handle" title="Drag to reorder">⠿</span>
              <span class="urg-dot"></span>
              <a href="/projects/<%= p.id %>" class="pcard-name"><strong><%= p.address %></strong><% if (p.version) { %> <span class="pcard-ver"><%= p.version %></span><% } %></a>
              <% if (unread && unread[p.id]) { %><a href="/projects/<%= p.id %>?tab=emails&openUnread=1" class="reply-dot" title="New vendor reply">●</a><% } %>
              <div class="pcard-right">
                <% var _t0 = (c.sup || [])[0]; %>
                <button type="button" class="pc-team" data-id="<%= p.id %>" data-email="<%= _t0 ? _t0.email : '' %>" onclick="openTeam(this)" title="Assign in-house super or outside GC">
                  <% if (_t0) { %>
                    <span class="tm-dot" style="background:<%= _t0.role === 'gc' ? '#8b5cf6' : '#3b82f6' %>"></span>
                    <span class="tm-name"><%= _t0.name %></span>
                    <span class="tm-badge <%= _t0.role === 'gc' ? 'tm-badge-gc' : 'tm-badge-sup' %>"><%= _t0.role === 'gc' ? 'GC' : 'IH' %></span>
                    <% if ((c.sup || []).length > 1) { %><span class="tm-more">+<%= c.sup.length - 1 %></span><% } %>
                  <% } else { %>
                    <span class="tm-none">Assign team</span>
                  <% } %>
                  <span class="tm-caret">▾</span>
                </button>
                <select class="pc-phase" data-project="<%= p.id %>" onchange="savePhase(this)" title="Project phase">
                  <% PROJECT_PHASES.forEach(ph2 => { %><option value="<%= ph2 %>" <%= ph===ph2?'selected':'' %>><%= ph2 %></option><% }) %>
                </select>
                <a href="/projects/<%= p.id %>" class="btn btn-ghost btn-sm">Open</a>
                <form method="POST" action="/projects/<%= p.id %>/delete" onsubmit="return confirm('Delete this project?')" style="margin:0"><button type="submit" class="pc-del" title="Delete">🗑</button></form>
              </div>
            </div>
            <div class="pipe">
              <% (c.stages || []).forEach(s => { var g = s.total ? Math.round(s.deliv / s.total * 100) : 0; var b = s.total ? Math.round(s.order / s.total * 100) : 0; %>
                <div class="pipe-seg">
                  <div class="pipe-lbl"><%= s.short %></div>
                  <div class="pipe-bar"><div class="pipe-fill-d" style="width:<%= g %>%"></div><div class="pipe-fill-o" style="width:<%= b %>%"></div></div>
                  <div class="pipe-cnt"><%= s.deliv %>/<%= s.total %></div>
                </div>
              <% }) %>
            </div>
            <div class="needs">
              <% (c.needs || []).forEach(n => { %><span class="need need-<%= n.kind %>"><%= n.text %></span><% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  <% }) %>
</div>

<div id="toast" class="toast"></div>

<div id="teamPop" class="teampop" hidden><div class="tp-list"></div></div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
(function initSortable() {
  if (!window.Sortable) return;
  document.querySelectorAll('.pcards').forEach(box => {
    Sortable.create(box, {
      handle: '.drag-handle', animation: 150, ghostClass: 'row-dragging',
      onEnd: async () => {
        const ids = Array.from(document.querySelectorAll('.pcards .pcard[data-id]')).map(el => el.dataset.id);
        try {
          await fetch('/reorder-projects', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ order: ids }) });
          showToast('Order saved');
        } catch (e) { showToast('Could not save order', true); }
      },
    });
  });
})();

async function savePhase(sel) {
  try {
    await postJson('/projects/' + sel.dataset.project + '/phase', { phase: sel.value });
    try { sessionStorage.setItem('projScroll', String(window.scrollY)); } catch (e) {}
    location.reload();
  } catch (e) { handleSaveError(e); }
}
window.addEventListener('DOMContentLoaded', function () {
  try { const y = sessionStorage.getItem('projScroll'); if (y) { sessionStorage.removeItem('projScroll'); window.scrollTo(0, parseInt(y, 10) || 0); } } catch (e) {}
});
async function postJson(url, body) {
  const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  if (r.redirected && /\/login/.test(r.url)) throw new Error('LOGGED_OUT');
  let data = null; try { data = await r.json(); } catch (e) { throw new Error('LOGGED_OUT'); }
  if (!r.ok || !data.ok) throw new Error((data && data.error) || 'SAVE_FAILED');
  return data;
}
function handleSaveError(e) {
  if (e && e.message === 'LOGGED_OUT') { showToast('Not saved — you were signed out. Reloading…', true); setTimeout(() => location.href = '/login', 1300); }
  else { showToast('Not saved — please try again', true); }
}
function showToast(msg, err) {
  const t = document.getElementById('toast'); t.textContent = msg;
  t.className = 'toast show' + (err ? ' error' : ''); setTimeout(() => t.className = 'toast', 1500);
}

// ── Team picker (grouped In-house supers / Outside GCs, + Add new) ──────────────
const CONTACTS = <%- JSON.stringify(contacts || []) %>;
let tpBtn = null;   // the .pc-team button currently being edited
function tpEsc(s){ return String(s==null?'':s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function openTeam(btn) {
  if (tpBtn === btn) { closeTeam(); return; }
  tpBtn = btn;
  renderTeamPop(btn.dataset.email || '');
  const pop = document.getElementById('teamPop');
  pop.hidden = false;
  positionPop(pop, btn);
}
function closeTeam() { document.getElementById('teamPop').hidden = true; tpBtn = null; }
function positionPop(pop, btn) {
  const r = btn.getBoundingClientRect();
  const pw = pop.offsetWidth || 252, ph = pop.offsetHeight || 300;
  let left = Math.max(10, Math.min(r.left, window.innerWidth - pw - 10));
  let top = r.bottom + 6;
  if (top + ph > window.innerHeight - 10) top = Math.max(10, r.top - ph - 6);
  pop.style.left = left + 'px'; pop.style.top = top + 'px';
}
function renderTeamPop(selEmail) {
  const sel = String(selEmail || '').toLowerCase();
  const supers = CONTACTS.filter(c => c.role !== 'gc');
  const gcs = CONTACTS.filter(c => c.role === 'gc');
  let h = '';
  h += `<div class="tp-row${!sel?' sel':''}" data-val=""><span class="tm-none">— Unassigned —</span>${!sel?'<span class="tp-check">✓</span>':''}</div>`;
  const grp = (label, list, dotCls) => {
    if (!list.length) return '';
    let g = `<div class="tp-group">${tpEsc(label)}</div>`;
    list.forEach(c => {
      const on = String(c.email).toLowerCase() === sel;
      g += `<div class="tp-row${on?' sel':''}" data-val="${tpEsc(c.email)}"><span class="tp-dot ${dotCls}"></span><span class="tm-name">${tpEsc(c.name)}</span>${on?'<span class="tp-check">✓</span>':''}</div>`;
    });
    return g;
  };
  h += grp('In-house supers', supers, 'tp-dot-super');
  h += grp('Outside GCs', gcs, 'tp-dot-gc');
  h += `<div class="tp-sep"></div>`;
  h += `<button type="button" class="tp-addbtn" onclick="tpShowAdd()">+ Add new…</button>`;
  h += `<div class="tp-addform" hidden>`
     + `<input class="tp-name" placeholder="Full name / company" autocomplete="off">`
     + `<input class="tp-email" type="email" placeholder="Email" autocomplete="off">`
     + `<input class="tp-phone" placeholder="Phone (optional)" autocomplete="off">`
     + `<select class="tp-role"><option value="super">In-house super</option><option value="gc">Outside GC</option></select>`
     + `<div class="tp-addactions"><button type="button" class="btn btn-primary btn-sm" onclick="tpSaveAdd()">Add &amp; assign</button>`
     + `<button type="button" class="btn btn-ghost btn-sm" onclick="tpHideAdd()">Cancel</button></div></div>`;
  document.querySelector('#teamPop .tp-list').innerHTML = h;
}
function tpShowAdd() {
  const pop = document.getElementById('teamPop');
  pop.querySelector('.tp-addform').hidden = false;
  pop.querySelector('.tp-addbtn').style.display = 'none';
  pop.querySelector('.tp-name').focus();
  if (tpBtn) positionPop(pop, tpBtn);
}
function tpHideAdd() {
  const pop = document.getElementById('teamPop');
  pop.querySelector('.tp-addform').hidden = true;
  pop.querySelector('.tp-addbtn').style.display = 'block';
}
async function tpSaveAdd() {
  const pop = document.getElementById('teamPop');
  const name = pop.querySelector('.tp-name').value.trim();
  const email = pop.querySelector('.tp-email').value.trim();
  const phone = pop.querySelector('.tp-phone').value.trim();
  const role = pop.querySelector('.tp-role').value;
  if (!name || !email) { showToast('Name and email are required', true); return; }
  try {
    const r = await fetch('/contacts', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ name, email, phone, role }) });
    const d = await r.json();
    if (!d.ok) { showToast(d.error || 'Could not add contact', true); return; }
    CONTACTS.push({ email: d.contact.email, name: d.contact.name, role: d.contact.role });
    await pickTeam(d.contact.email);
  } catch (e) { showToast('Could not add contact', true); }
}
async function pickTeam(email) {
  if (!tpBtn) return;
  const btn = tpBtn, id = btn.dataset.id;
  try {
    const r = await fetch('/projects/' + id + '/super', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ emails: email ? [email] : [] }) });
    const d = await r.json();
    if (!d.ok) { showToast(d.error || 'Could not save', true); return; }
    updateTeamBtn(btn, email);
    showToast(email ? 'Team updated' : 'Unassigned');
    closeTeam();
  } catch (e) { showToast('Could not save', true); }
}
function updateTeamBtn(btn, email) {
  btn.dataset.email = email || '';
  const c = CONTACTS.find(x => String(x.email).toLowerCase() === String(email).toLowerCase());
  let inner;
  if (c) {
    const gc = c.role === 'gc';
    inner = `<span class="tm-dot" style="background:${gc?'#8b5cf6':'#3b82f6'}"></span><span class="tm-name">${tpEsc(c.name)}</span><span class="tm-badge ${gc?'tm-badge-gc':'tm-badge-sup'}">${gc?'GC':'IH'}</span>`;
  } else {
    inner = `<span class="tm-none">Assign team</span>`;
  }
  btn.innerHTML = inner + `<span class="tm-caret">▾</span>`;
}
document.getElementById('teamPop').addEventListener('click', (e) => {
  const row = e.target.closest('.tp-row');
  if (row) pickTeam(row.dataset.val || '');
});
document.addEventListener('click', (e) => {
  const pop = document.getElementById('teamPop');
  if (pop.hidden) return;
  if (pop.contains(e.target) || e.target.closest('.pc-team')) return;
  closeTeam();
});
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeTeam(); });
window.addEventListener('resize', () => { const p = document.getElementById('teamPop'); if (!p.hidden && tpBtn) positionPop(p, tpBtn); });
</script>
</body>
</html>

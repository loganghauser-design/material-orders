<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Projects — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css?v=5">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#000000">
  <style>
    /* Summary strip */
    .pstrip { display:flex; flex-wrap:wrap; gap:8px 30px; align-items:flex-start; padding:2px 2px 15px; border-bottom:1px solid var(--border); margin-bottom:14px; }
    .pstat { line-height:1.12; white-space:nowrap; }
    .pstat .v { font-size:1.5rem; font-weight:800; }
    .pstat .l { font-size:.82rem; color:var(--muted); margin-left:5px; font-weight:600; }
    .pstat .sub { font-size:.67rem; color:var(--muted); margin-top:2px; }
    .pstat-total .v { color:var(--text); }
    .ps-uc .v { color:#176b3a; } .ps-pc .v { color:#185fa5; } .ps-ip .v { color:#8a6100; }
    .ps-uw .v { color:#7c3aed; } .ps-co .v { color:#6b7280; }
    /* Toolbar */
    .ptools { display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; margin-bottom:.8rem; }
    .ptools form.toolbar { display:flex; gap:.5rem; flex:1; margin:0; }
    .dlegend { display:flex; gap:12px; font-size:.7rem; color:var(--muted); }
    .dlegend span { display:inline-flex; align-items:center; gap:4px; }
    .lg-dot { width:9px; height:9px; border-radius:50%; display:inline-block; }
    /* Table rows */
    .ptable-head, .pcard { display:grid; grid-template-columns: 16px minmax(0,1.4fr) 32px minmax(0,1.2fr) 226px 132px minmax(0,1.15fr) 116px; gap:10px; align-items:center; }
    .col-last { min-width:0; }
    .ll-name { font-size:.8rem; font-weight:600; color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ll-sub { font-size:.7rem; color:var(--muted); }
    .ll-mail { font-size:.68rem; color:#185fa5; margin-top:1px; white-space:nowrap; }
    .ptable-head { padding:2px 14px 4px; font-size:.64rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); }
    .pcards { display:flex; flex-direction:column; gap:6px; margin:7px 0 1.4rem; }
    .pcard { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:8px 14px; }
    .pcard.urg-red { box-shadow: inset 3px 0 0 #e24b4a; } .pcard.urg-amber { box-shadow: inset 3px 0 0 #e0a952; }
    .drag-handle { cursor:grab; color:var(--muted); font-size:.9rem; user-select:none; }
    .col-name { min-width:0; }
    .pcard-name { font-size:.92rem; color:var(--text); text-decoration:none; font-weight:600; }
    .pcard-name:hover { text-decoration:underline; }
    .col-sub { font-size:.72rem; color:var(--muted); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .reply-dot { color:#e5484d; font-size:.85rem; text-decoration:none; margin-left:4px; }
    .col-ver { font-size:.75rem; color:var(--muted); }
    .col-team { display:flex; flex-direction:column; gap:3px; min-width:0; align-items:flex-start; }
    .pm-line { font-size:.73rem; color:var(--muted); display:flex; align-items:center; gap:5px; white-space:nowrap; }
    .pm-badge { background:#e6f1fb; color:#185fa5; font-size:.56rem; font-weight:800; letter-spacing:.03em; padding:1px 5px; border-radius:5px; }
    /* Delivery dots — one per category (1a…), with vertical stage-name labels in the header */
    .ptable-head { align-items:end; }
    .col-dots { display:flex; align-items:center; gap:0; }
    .dhead { display:flex; align-items:flex-end; gap:0; }
    .dcell { width:12px; text-align:center; flex:none; }
    .dgap { width:6px; flex:none; }
    .dhead .dcell { display:flex; justify-content:center; align-items:flex-end; }
    .dhead .dcell > span { writing-mode:vertical-rl; transform:rotate(180deg); white-space:nowrap; font-size:.56rem; color:var(--muted); font-weight:600; line-height:12px; padding-bottom:2px; }
    .ddot { display:block; width:10px; height:10px; border-radius:50%; background:var(--bg); border:1px solid var(--border); margin:0 auto; box-sizing:border-box; }
    .ddot-full { background:#16a34a; border-color:#16a34a; }
    .ddot-order { background:#378add; border-color:#378add; }
    .ddot-none { background:var(--bg); }
    .ddot-na { opacity:.22; }
    .col-needs { display:flex; gap:5px; flex-wrap:wrap; min-width:0; }
    .need { font-size:.7rem; font-weight:600; border-radius:999px; padding:2px 8px; white-space:nowrap; }
    .need-bad { background:#fdeaea; color:#b42323; } .need-warn { background:#fff4dd; color:#8a6100; }
    .need-info { background:#e6f1fb; color:#185fa5; } .need-mute { background:var(--bg); color:var(--muted); }
    .need-ok { background:#eaf6ee; color:#176b3a; }
    .col-actions { display:flex; align-items:center; gap:6px; justify-content:flex-end; }
    .pc-phase { font-size:.72rem; border:1px solid var(--border); border-radius:7px; padding:3px 5px; background:var(--bg); cursor:pointer; color:var(--text); max-width:118px; }
    .pc-del { background:none; border:none; cursor:pointer; font-size:.85rem; opacity:.5; }
    .pc-del:hover { opacity:1; }
    .row-dragging { opacity:.5; }
    /* Team picker chip on each card */
    .pc-team { display:inline-flex; align-items:center; gap:6px; border:1px solid var(--border); background:var(--bg); border-radius:999px; padding:3px 9px 3px 9px; cursor:pointer; font-size:.8rem; max-width:210px; color:var(--text); }
    .pc-team:hover { border-color:#4f8ef7; }
    .tm-dot { width:8px; height:8px; border-radius:50%; flex:none; }
    .tm-name { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-weight:600; }
    .tm-badge { font-size:.56rem; font-weight:800; letter-spacing:.03em; padding:1px 5px; border-radius:5px; flex:none; }
    .tm-badge-gc { background:#efe8fb; color:#6b3fc2; } .tm-badge-sup { background:#e6f1fb; color:#185fa5; }
    .tm-more { font-size:.68rem; color:var(--muted); flex:none; }
    .tm-none { color:var(--muted); font-weight:600; }
    .tm-caret { color:var(--muted); font-size:.58rem; margin-left:1px; flex:none; }
    /* Shared grouped dropdown popover */
    .teampop { position:fixed; z-index:1000; width:252px; max-height:360px; overflow:auto; background:var(--surface); border:1px solid var(--border); border-radius:12px; box-shadow:0 14px 38px rgba(0,0,0,.20); padding:6px; }
    .teampop[hidden] { display:none; }
    .tp-group { font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); padding:9px 8px 3px; }
    .tp-row { display:flex; align-items:center; gap:8px; padding:7px 8px; border-radius:8px; cursor:pointer; font-size:.86rem; color:var(--text); }
    .tp-row:hover { background:var(--bg); }
    .tp-row.sel { background:#e6f1fb; color:#185fa5; font-weight:700; }
    .tp-row .tp-check { margin-left:auto; color:#185fa5; font-weight:700; }
    .tp-dot { width:8px; height:8px; border-radius:50%; flex:none; }
    .tp-dot-super { background:#3b82f6; } .tp-dot-gc { background:#8b5cf6; }
    .tp-sep { height:1px; background:var(--border); margin:5px 2px; }
    .tp-addbtn { display:block; width:100%; text-align:left; background:none; border:none; padding:8px; font-size:.84rem; font-weight:700; color:#4f8ef7; cursor:pointer; border-radius:8px; }
    .tp-addbtn:hover { background:var(--bg); }
    .tp-addform { display:flex; flex-direction:column; gap:6px; padding:6px 8px 8px; }
    .tp-addform input, .tp-addform select { font-size:.82rem; padding:7px 8px; border:1px solid var(--border); border-radius:7px; background:var(--bg); color:var(--text); }
    .tp-addactions { display:flex; gap:6px; }
    .tp-manage { display:block; padding:8px; font-size:.78rem; color:var(--muted); text-decoration:none; border-radius:8px; }
    .tp-manage:hover { background:var(--bg); color:var(--text); }
    @media (max-width:900px){
      .ptable-head { display:none; }
      .pcard { grid-template-columns: 16px 1fr; grid-auto-rows:min-content; row-gap:7px; }
      .col-name { grid-column:2; } .col-ver { display:none; }
      .col-team, .col-dots, .col-last, .col-needs { grid-column:2; }
      .col-actions { grid-column:2; justify-content:flex-start; }
    }
  </style>
</head>
<body>
<%- include('_nav', { active: 'projects' }) %>

<div class="container wide">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem;margin:.2rem 0 1rem">
    <h1 style="margin:0">Projects</h1>
    <a href="/contacts" class="btn btn-ghost btn-sm">Manage assignees</a>
  </div>

  <%
    var _phOrder = ['Under Construction','Pre-Construction','In Permitting','Under Warranty','Complete'].filter(function(p){ return PROJECT_PHASES.includes(p); });
    PROJECT_PHASES.forEach(function(p){ if (_phOrder.indexOf(p) < 0) _phOrder.push(p); });
    var _psCls = { 'Under Construction':'ps-uc','Pre-Construction':'ps-pc','In Permitting':'ps-ip','Under Warranty':'ps-uw','Complete':'ps-co' };
  %>
  <div class="pstrip">
    <div class="pstat pstat-total"><span class="v"><%= totalCount %></span><span class="l">Total</span></div>
    <% _phOrder.forEach(function(ph){ var n = phaseCounts[ph] || 0; if (!n) return; var t = phaseTeam[ph] || { inHouse:0, gc:0 }; %>
      <div class="pstat <%= _psCls[ph] || '' %>">
        <div><span class="v"><%= n %></span><span class="l"><%= ph %></span></div>
        <% if (ph !== 'Complete' && ph !== 'Under Warranty') { %><div class="sub"><%= t.inHouse %> in-house &middot; <%= t.gc %> GC</div><% } %>
      </div>
    <% }) %>
  </div>

  <div class="ptools">
    <form method="GET" action="/projects" class="toolbar">
      <input type="text" name="search" placeholder="Search address…" value="<%= query.search || '' %>">
      <select name="status" onchange="this.form.submit()">
        <option value="">All statuses</option>
        <% PROJECT_PHASES.forEach(s => { %><option value="<%= s %>" <%- query.status===s?'selected':'' %>><%= s %></option><% }) %>
      </select>
      <button type="submit" class="btn btn-ghost">Search</button>
      <% if (query.search || query.status) { %><a href="/projects" class="btn btn-ghost">Clear</a><% } %>
    </form>
    <div class="dlegend">
      <span><span class="lg-dot" style="background:#16a34a"></span>Delivered</span>
      <span><span class="lg-dot" style="background:#378add"></span>On order</span>
    </div>
  </div>

  <%
    const PHASE_CLASSES = { 'In Permitting': 'ph-ip', 'Pre-Construction': 'ph-pc', 'Under Construction': 'ph-uc', 'Complete': 'ph-co', 'Under Warranty': 'ph-uw' };
    function phaseOf(p) {
      if (PROJECT_PHASES.includes(p.phase)) return p.phase;
      if (p.overall_status === 'Fully Delivered') return 'Complete';
      if (p.overall_status === 'In Progress' || p.overall_status === 'All Delivered') return 'Under Construction';
      return 'Pre-Construction';
    }
    var _phaseOrder = ['Under Construction', 'Pre-Construction', 'In Permitting', 'Under Warranty', 'Complete'].filter(ph => PROJECT_PHASES.includes(ph));
    PROJECT_PHASES.forEach(ph => { if (!_phaseOrder.includes(ph)) _phaseOrder.push(ph); });
  %>
  <div class="ptable-head">
    <span></span><span>Address / Client</span><span>Ver</span><span>Team</span><div class="dhead"><% STAGES.forEach(function(g,gi){ g.items.forEach(function(it){ %><span class="dcell"><span><%= it.name %></span></span><% }); if(gi<STAGES.length-1){ %><span class="dgap"></span><% } }) %></div><span>Last delivery</span><span>Action items</span><span style="text-align:right">Phase</span>
  </div>
  <% _phaseOrder.forEach(ph => { const rows = projects.filter(p => phaseOf(p) === ph); %>
    <div class="phase-divider <%= PHASE_CLASSES[ph] %>"><span><%= ph %> (<%= rows.length %>)</span></div>
    <% if (rows.length) { %>
      <div class="pcards" data-phase="<%= ph %>">
        <% rows.forEach(p => {
             var c = (cards && cards[p.id]) || { stages: [], needs: [], urgency: 'green', sup: [] };
             var _sup = (c.sup || []); var _t0 = _sup[0];
             var _sub = (p.full_address && p.full_address.indexOf(',') >= 0) ? p.full_address.split(',').slice(1).join(',').trim() : '';
             var _needs = (c.needs || []);
        %>
          <div class="pcard urg-<%= c.urgency %>" data-id="<%= p.id %>">
            <span class="drag-handle" title="Drag to reorder">⠿</span>
            <div class="col-name">
              <a href="/projects/<%= p.id %>" class="pcard-name"><%= p.address %></a><% if (unread && unread[p.id]) { %><a href="/projects/<%= p.id %>?tab=emails&openUnread=1" class="reply-dot" title="New vendor reply">●</a><% } %>
              <div class="col-sub"><%= _sub %><% if (p.client_name) { %><%= _sub ? ' · ' : '' %><%= p.client_name %><% } %></div>
            </div>
            <div class="col-ver"><%= p.version || '' %></div>
            <div class="col-team">
              <div class="pm-line"><span class="pm-badge">PM</span> Aziz Ibrahim</div>
              <button type="button" class="pc-team" data-id="<%= p.id %>" data-assigned="<%= JSON.stringify(_sup.map(function(s){ return { email: s.email, name: s.name, role: s.role }; })) %>" onclick="openTeam(this)" title="Assign in-house super or outside GC">
                <% if (_t0) { %>
                  <span class="tm-dot" style="background:<%= _t0.role === 'gc' ? '#8b5cf6' : (_t0.role === 'unknown' ? '#9aa0aa' : '#3b82f6') %>"></span>
                  <span class="tm-name"><%= _t0.name %></span>
                  <% if (_t0.role !== 'unknown') { %><span class="tm-badge <%= _t0.role === 'gc' ? 'tm-badge-gc' : 'tm-badge-sup' %>"><%= _t0.role === 'gc' ? 'GC' : 'IH' %></span><% } %>
                  <% if (_sup.length > 1) { %><span class="tm-more">+<%= _sup.length - 1 %></span><% } %>
                <% } else { %>
                  <span class="tm-none">Assign team</span>
                <% } %>
                <span class="tm-caret">▾</span>
              </button>
            </div>
            <div class="col-dots">
              <% STAGES.forEach(function(g,gi){ g.items.forEach(function(it){ var d = (c.dotState && c.dotState[it.code]) || { state:'na', status:'N/A' }; %><span class="dcell"><span class="ddot ddot-<%= d.state %>" title="<%= it.code %> <%= it.name %>: <%= d.status %>"></span></span><% }); if(gi<STAGES.length-1){ %><span class="dgap"></span><% } }) %>
            </div>
            <div class="col-last">
              <% var _ld = lastDeliv && lastDeliv[p.id]; var _ln = lastNotice && lastNotice[p.id]; %>
              <% if (_ld) { var _da = Math.floor((Date.now() - new Date(_ld.date).getTime()) / 86400000); %>
                <div class="ll-name"><%= _ld.name %></div>
                <div class="ll-sub">delivered <%= _da <= 0 ? 'today' : _da + 'd ago' %></div>
              <% } else { %>
                <div class="ll-sub">No deliveries yet</div>
              <% } %>
              <% if (_ln) { var _na = Math.floor((Date.now() - new Date(_ln.sentAt).getTime()) / 86400000); %>
                <div class="ll-mail" title="Delivery notice emailed to the on-site contact">✉ emailed <%= _na <= 0 ? 'today' : _na + 'd ago' %></div>
              <% } %>
            </div>
            <div class="col-needs">
              <% _needs.slice(0, 3).forEach(function(n){ %><span class="need need-<%= n.kind %>"><%= n.text %></span><% }) %>
              <% if (_needs.length > 3) { %><span class="need need-mute" title="<%= _needs.slice(3).map(function(n){return n.text;}).join(', ') %>">+<%= _needs.length - 3 %></span><% } %>
            </div>
            <div class="col-actions">
              <select class="pc-phase" data-project="<%= p.id %>" onchange="savePhase(this)" title="Project phase">
                <% PROJECT_PHASES.forEach(ph2 => { %><option value="<%= ph2 %>" <%= ph===ph2?'selected':'' %>><%= ph2 %></option><% }) %>
              </select>
              <a href="/projects/<%= p.id %>" class="btn btn-ghost btn-sm">Open</a>
              <form method="POST" action="/projects/<%= p.id %>/delete" onsubmit="return confirm('Delete this project?')" style="margin:0"><button type="submit" class="pc-del" title="Delete">🗑</button></form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  <% }) %>
</div>

<div id="toast" class="toast"></div>

<div id="teamPop" class="teampop" hidden><div class="tp-list"></div></div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
(function initSortable() {
  if (!window.Sortable) return;
  document.querySelectorAll('.pcards').forEach(box => {
    Sortable.create(box, {
      handle: '.drag-handle', animation: 150, ghostClass: 'row-dragging',
      onEnd: async () => {
        const ids = Array.from(document.querySelectorAll('.pcards .pcard[data-id]')).map(el => el.dataset.id);
        try {
          await fetch('/reorder-projects', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ order: ids }) });
          showToast('Order saved');
        } catch (e) { showToast('Could not save order', true); }
      },
    });
  });
})();

async function savePhase(sel) {
  try {
    await postJson('/projects/' + sel.dataset.project + '/phase', { phase: sel.value });
    try { sessionStorage.setItem('projScroll', String(window.scrollY)); } catch (e) {}
    location.reload();
  } catch (e) { handleSaveError(e); }
}
window.addEventListener('DOMContentLoaded', function () {
  try { const y = sessionStorage.getItem('projScroll'); if (y) { sessionStorage.removeItem('projScroll'); window.scrollTo(0, parseInt(y, 10) || 0); } } catch (e) {}
});
async function postJson(url, body) {
  const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  if (r.redirected && /\/login/.test(r.url)) throw new Error('LOGGED_OUT');
  let data = null; try { data = await r.json(); } catch (e) { throw new Error('LOGGED_OUT'); }
  if (!r.ok || !data.ok) throw new Error((data && data.error) || 'SAVE_FAILED');
  return data;
}
function handleSaveError(e) {
  if (e && e.message === 'LOGGED_OUT') { showToast('Not saved — you were signed out. Reloading…', true); setTimeout(() => location.href = '/login', 1300); }
  else { showToast('Not saved — please try again', true); }
}
function showToast(msg, err) {
  const t = document.getElementById('toast'); t.textContent = msg;
  t.className = 'toast show' + (err ? ' error' : ''); setTimeout(() => t.className = 'toast', 1500);
}

// ── Team picker (grouped In-house supers / Outside GCs, + Add new) ──────────────
// JSON is emitted raw (unescaped by EJS), so neutralize the closing-script sequence and HTML-context breakout.
const CONTACTS = <%- JSON.stringify(contacts || []).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026') %>;
let tpBtn = null;        // the .pc-team button currently being edited
let tpAssigned = [];     // [{email,name,role}] currently assigned on the open card
function tpEsc(s){ return String(s==null?'':s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function openTeam(btn) {
  if (tpBtn === btn) { closeTeam(); return; }
  tpBtn = btn;
  try { tpAssigned = JSON.parse(btn.dataset.assigned || '[]'); } catch (e) { tpAssigned = []; }
  renderTeamPop(tpAssigned);
  const pop = document.getElementById('teamPop');
  pop.hidden = false;
  positionPop(pop, btn);
}
function closeTeam() { document.getElementById('teamPop').hidden = true; tpBtn = null; }
function positionPop(pop, btn) {
  const r = btn.getBoundingClientRect();
  const pw = pop.offsetWidth || 252, ph = pop.offsetHeight || 300;
  let left = Math.max(10, Math.min(r.left, window.innerWidth - pw - 10));
  let top = r.bottom + 6;
  if (top + ph > window.innerHeight - 10) top = Math.max(10, r.top - ph - 6);
  pop.style.left = left + 'px'; pop.style.top = top + 'px';
}
function renderTeamPop(assigned) {
  const selSet = new Set((assigned || []).map(a => String(a.email).toLowerCase()));
  const supers = CONTACTS.filter(c => c.role !== 'gc');
  const gcs = CONTACTS.filter(c => c.role === 'gc');
  let h = '';
  h += `<div class="tp-row${selSet.size===0?' sel':''}" data-val=""><span class="tm-none">— Unassigned —</span>${selSet.size===0?'<span class="tp-check">✓</span>':''}</div>`;
  const grp = (label, list, dotCls) => {
    if (!list.length) return '';
    let g = `<div class="tp-group">${tpEsc(label)}</div>`;
    list.forEach(c => {
      const on = selSet.has(String(c.email).toLowerCase());
      g += `<div class="tp-row${on?' sel':''}" data-val="${tpEsc(c.email)}"><span class="tp-dot ${dotCls}"></span><span class="tm-name">${tpEsc(c.name)}</span>${on?'<span class="tp-check">✓</span>':''}</div>`;
    });
    return g;
  };
  h += grp('In-house supers', supers, 'tp-dot-super');
  h += grp('Outside GCs', gcs, 'tp-dot-gc');
  // Anyone assigned who's no longer in the contact list (e.g. deactivated) — keep them visible.
  const known = new Set(CONTACTS.map(c => String(c.email).toLowerCase()));
  const orphans = (assigned || []).filter(a => a.email && !known.has(String(a.email).toLowerCase()));
  if (orphans.length) {
    h += `<div class="tp-group">Currently assigned</div>`;
    orphans.forEach(a => {
      h += `<div class="tp-row sel" data-val="${tpEsc(a.email)}"><span class="tp-dot" style="background:#9aa0aa"></span><span class="tm-name">${tpEsc(a.name || a.email)}</span><span class="tp-check">✓</span></div>`;
    });
  }
  h += `<div class="tp-sep"></div>`;
  h += `<button type="button" class="tp-addbtn" onclick="tpShowAdd()">+ Add new…</button>`;
  h += `<div class="tp-addform" hidden>`
     + `<input class="tp-name" placeholder="Full name / company" autocomplete="off">`
     + `<input class="tp-email" type="email" placeholder="Email" autocomplete="off">`
     + `<input class="tp-phone" placeholder="Phone (optional)" autocomplete="off">`
     + `<select class="tp-role"><option value="super">In-house super</option><option value="gc">Outside GC</option></select>`
     + `<div class="tp-addactions"><button type="button" class="btn btn-primary btn-sm" onclick="tpSaveAdd()">Add &amp; assign</button>`
     + `<button type="button" class="btn btn-ghost btn-sm" onclick="tpHideAdd()">Cancel</button></div></div>`;
  h += `<a class="tp-manage" href="/contacts">⚙ Manage contacts &amp; emails</a>`;
  document.querySelector('#teamPop .tp-list').innerHTML = h;
}
function tpShowAdd() {
  const pop = document.getElementById('teamPop');
  pop.querySelector('.tp-addform').hidden = false;
  pop.querySelector('.tp-addbtn').style.display = 'none';
  pop.querySelector('.tp-name').focus();
  if (tpBtn) positionPop(pop, tpBtn);
}
function tpHideAdd() {
  const pop = document.getElementById('teamPop');
  pop.querySelector('.tp-addform').hidden = true;
  pop.querySelector('.tp-addbtn').style.display = 'block';
}
async function tpSaveAdd() {
  const pop = document.getElementById('teamPop');
  const name = pop.querySelector('.tp-name').value.trim();
  const email = pop.querySelector('.tp-email').value.trim();
  const phone = pop.querySelector('.tp-phone').value.trim();
  const role = pop.querySelector('.tp-role').value;
  if (!name || !email) { showToast('Name and email are required', true); return; }
  try {
    const r = await fetch('/contacts', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ name, email, phone, role }) });
    const d = await r.json();
    if (!d.ok) { showToast(d.error || 'Could not add contact', true); return; }
    CONTACTS.push({ email: d.contact.email, name: d.contact.name, role: d.contact.role });
    renderTeamPop(tpAssigned);   // refresh list so the new contact is a selectable row even if the assign below fails
    await pickTeam(d.contact.email);
  } catch (e) { showToast('Could not add contact', true); }
}
async function pickTeam(email) {
  if (!tpBtn) return;
  const btn = tpBtn, id = btn.dataset.id;
  const lc = String(email).toLowerCase();
  const entry = email ? (CONTACTS.find(c => String(c.email).toLowerCase() === lc) || tpAssigned.find(a => String(a.email).toLowerCase() === lc) || null) : null;
  // Don't silently drop a multi-person assignment — the grid picker is single-select.
  if (tpAssigned.length > 1) {
    if (!confirm('This project has ' + tpAssigned.length + ' people assigned. Replace all of them with ' + (entry ? entry.name : 'no one') + '?')) return;
  }
  try {
    const r = await fetch('/projects/' + id + '/super', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ emails: email ? [email] : [] }) });
    const d = await r.json();
    if (!d.ok) { showToast(d.error || 'Could not save', true); return; }
    // Reflect what the server actually accepted (it drops emails that aren't a live contact).
    const accepted = Array.isArray(d.emails) ? d.emails : (email ? [email] : []);
    const acceptedEntry = accepted.length
      ? (CONTACTS.find(c => String(c.email).toLowerCase() === String(accepted[0]).toLowerCase())
         || tpAssigned.find(a => String(a.email).toLowerCase() === String(accepted[0]).toLowerCase())
         || { email: accepted[0], name: accepted[0], role: 'unknown' })
      : null;
    tpAssigned = acceptedEntry ? [acceptedEntry] : [];
    btn.dataset.assigned = JSON.stringify(tpAssigned);
    updateTeamBtn(btn, acceptedEntry);
    showToast(accepted.length ? 'Team updated' : 'Unassigned');
    closeTeam();
  } catch (e) { showToast('Could not save', true); }
}
function updateTeamBtn(btn, entry) {
  let inner;
  if (entry) {
    const gc = entry.role === 'gc', unknown = entry.role === 'unknown';
    const color = gc ? '#8b5cf6' : (unknown ? '#9aa0aa' : '#3b82f6');
    inner = `<span class="tm-dot" style="background:${color}"></span><span class="tm-name">${tpEsc(entry.name)}</span>`
          + (unknown ? '' : `<span class="tm-badge ${gc?'tm-badge-gc':'tm-badge-sup'}">${gc?'GC':'IH'}</span>`);
  } else {
    inner = `<span class="tm-none">Assign team</span>`;
  }
  btn.innerHTML = inner + `<span class="tm-caret">▾</span>`;
}
document.getElementById('teamPop').addEventListener('click', (e) => {
  const row = e.target.closest('.tp-row');
  if (row) pickTeam(row.dataset.val || '');
});
document.addEventListener('click', (e) => {
  const pop = document.getElementById('teamPop');
  if (pop.hidden) return;
  if (pop.contains(e.target) || e.target.closest('.pc-team')) return;
  closeTeam();
});
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeTeam(); });
window.addEventListener('resize', () => { const p = document.getElementById('teamPop'); if (!p.hidden && tpBtn) positionPop(p, tpBtn); });
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subcontractors — Material Orders</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .subs-toolbar { display:flex; gap:.6rem; flex-wrap:wrap; align-items:center; margin-bottom:1rem; }
    .subs-toolbar input[type=search], .subs-toolbar select { padding:.5rem .7rem; border:1px solid var(--border); border-radius:9px; background:var(--surface); font-size:.9rem; }
    .subs-toolbar input[type=search] { min-width:240px; flex:1; }
    .sec-title { font-size:1.6rem; font-weight:800; margin:2.4rem 0 .6rem; padding:.7rem 1rem; border-radius:9px; display:flex; align-items:center; gap:.6rem; }
    .sec-title .cnt { font-weight:600; font-size:1.05rem; opacity:.7; }
    .sec-gc { background:#fce5cd; color:#7a4a16; }
    .sec-sub { background:#ead1dc; color:#7a2c52; }
    .sub-section:first-of-type .sec-title { margin-top:.4rem; }
    .tbl-wrap { overflow-x:auto; border:1px solid var(--border); border-radius:10px; }
    .subs-table { width:100%; border-collapse:collapse; font-size:.85rem; }
    .subs-table th { text-align:left; font-size:.68rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); padding:.55rem .7rem; border-bottom:2px solid var(--border); white-space:nowrap; background:var(--bg); position:sticky; top:0; }
    .subs-table td { padding:.55rem .7rem; border-bottom:1px solid var(--border); vertical-align:top; }
    .subs-table tr:last-child td { border-bottom:none; }
    .subs-table tbody tr:hover td { background:var(--bg); }
    .subs-table tr.subhdr td { background:#dededf; color:#1a1a1a; font-size:1.15rem; font-weight:800; padding:.6rem .8rem; border-top:2px solid #cfcfd2; }
    .subs-table tr.subhdr:hover td { background:#dededf; }
    .spill { display:inline-block; padding:3px 12px; border-radius:13px; font-size:.78rem; font-weight:700; white-space:nowrap; }
    select.spill { border:1px solid rgba(0,0,0,.15); cursor:pointer; padding:3px 6px; }
    .pill-review { background:#ffe599; color:#7f6000; }
    .pill-approved { background:#b6d7a8; color:#274e13; }
    .pill-active { background:#38761d; color:#fff; }
    .pill-rejected { background:#e06666; color:#fff; }
    .pill-black { background:#111; color:#fff; }
    .pill-default { background:#e6e6e6; color:#555; }
    .subs-table a { color:#1d4ed8; text-decoration:none; white-space:nowrap; }
    .subs-table .co { font-weight:600; }
    .subs-table .notes { color:var(--muted); max-width:240px; }
    .thumbs { display:flex; gap:.25rem; margin-top:.25rem; }
    .thumbs img { width:30px; height:30px; object-fit:cover; border-radius:5px; border:1px solid var(--border); }
    .row-actions { white-space:nowrap; }
    .row-actions button, .row-actions label.upl { font-size:.85rem; padding:.2rem .4rem; border:1px solid var(--border); background:var(--surface); border-radius:6px; cursor:pointer; line-height:1; }
    .moveSel { font-size:.74rem; padding:.2rem .3rem; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; max-width:130px; }
    .drag-h { cursor:grab; color:var(--muted); text-align:center; user-select:none; font-size:1.05rem; width:24px; }
    .drag-h:active { cursor:grabbing; }
    .subs-table tr.drop-hi > td { background:#dbeafe !important; box-shadow:inset 0 2px 0 #4f8ef7; }
    .row-actions .del { color:var(--danger); border-color:rgba(204,34,34,.3); }
    .modal-bk { position:fixed; inset:0; background:rgba(0,0,0,.5); display:none; align-items:flex-start; justify-content:center; z-index:50; padding:2rem 1rem; overflow:auto; }
    .modal-bk.show { display:flex; }
    .modal-card { background:var(--surface); border-radius:14px; padding:1.3rem; width:100%; max-width:520px; }
    .modal-card h2 { font-size:1.15rem; margin:0 0 1rem; }
    .mg { margin-bottom:.7rem; } .mg label { display:block; font-size:.8rem; font-weight:600; margin-bottom:.25rem; }
    .mg input, .mg textarea { width:100%; padding:.5rem .6rem; border:1px solid var(--border); border-radius:8px; background:var(--bg); font-size:.92rem; }
    .mg2 { display:grid; grid-template-columns:1fr 1fr; gap:.7rem; }
  </style>
</head>
<body>
<nav class="nav">
  <div style="display:flex;align-items:center;gap:1.25rem;flex-wrap:wrap">
    <a href="/" class="nav-brand" style="text-decoration:none">Material Orders</a>
    <a href="/deliveries" class="nav-tab">Deliveries</a>
    <a href="/payments" class="nav-tab">Payments</a>
    <a href="/driving" class="nav-tab">Driving Log</a>
    <a href="/inventory" class="nav-tab">Inventory</a>
    <a href="/suppliers" class="nav-tab">Suppliers</a>
    <a href="/subs" class="nav-tab active">Subs</a>
    <a href="/settings" class="nav-tab">Settings</a>
  </div>
  <div class="nav-actions"><a href="/" class="btn btn-ghost">← Back</a></div>
</nav>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem">
    <h1>Subcontractors <span style="color:var(--muted);font-weight:400;font-size:1rem">(<%= subs.length %>)</span></h1>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
      <button class="btn btn-primary" onclick="openAdd()">+ Add</button>
      <form method="POST" action="/subs/import" style="margin:0" onsubmit="this.querySelector('button').textContent='Importing…'">
        <button type="submit" class="btn btn-ghost" title="Pull any new companies from the GC & Sub Database Google Sheet">↻ Import from Sheet</button>
      </form>
    </div>
  </div>

  <% if (typeof imported !== 'undefined' && imported !== undefined) { %>
    <div class="card" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a;font-weight:600;margin-bottom:1rem">✓ Imported <%= imported %> new subcontractor(s) from the sheet.</div>
  <% } %>
  <% if (typeof added !== 'undefined' && added) { %>
    <div class="card" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a;font-weight:600;margin-bottom:1rem">✓ Subcontractor added.</div>
  <% } %>

  <div class="subs-toolbar">
    <input type="search" id="subSearch" placeholder="Search name, trade, phone…" oninput="filterSubs()">
    <select id="typeFilter" onchange="filterSubs()"><option value="">All trades</option></select>
  </div>

  <%
    function catOf(s) { return s.category || (/general\s*contractor|^\s*gc\b/i.test(s.type || '') ? 'gc' : 'sub'); }
    function pillClass(st) { st = (st || '').toLowerCase();
      if (/black/.test(st)) return 'pill-black';
      if (/reject|declin/.test(st)) return 'pill-rejected';
      if (/active/.test(st)) return 'pill-active';
      if (/approv/.test(st)) return 'pill-approved';
      if (/review|vetting|pending/.test(st)) return 'pill-review';
      return 'pill-default'; }
    const STATUS_OPTS = ['Under Review', 'Approved', 'Active', 'Rejected', 'Blacklisted'];
    const sections = [
      { title: 'Outside GCs', key: 'gc', list: subs.filter(s => catOf(s) === 'gc') },
      { title: 'Subcontractors', key: 'sub', list: subs.filter(s => catOf(s) !== 'gc') },
    ];
    // Distinct buckets you can move a sub into (preserving sheet order)
    const moveTargets = []; const _seenT = {};
    subs.forEach(s => { const cat = catOf(s), grp = s.group_label || '', k = cat + '||' + grp; if (!_seenT[k]) { _seenT[k] = 1; moveTargets.push({ cat, grp }); } });
  %>

  <% if (!subs.length) { %>
    <div class="card" style="color:var(--muted)">No subcontractors yet. Click <strong>Import from Sheet</strong> or <strong>+ Add</strong>.</div>
  <% } %>

  <% sections.forEach(sec => { %>
    <div class="sub-section" data-section>
      <div class="sec-title sec-<%= sec.key %>"><%= sec.title %> <span class="cnt">(<%= sec.list.length %>)</span></div>
      <% if (!sec.list.length) { %>
        <div style="color:var(--muted);font-size:.85rem">None.</div>
      <% } else { %>
      <div class="tbl-wrap">
        <table class="subs-table">
          <thead><tr>
            <th></th><th>Company</th><th>Location</th><th>Type</th><th>Status</th><th>Contact</th><th>Email</th><th>Phone</th><th>Notes</th><th></th>
          </tr></thead>
          <tbody>
            <%
              const groups = []; const gmap = {};
              sec.list.forEach(x => { const g = x.group_label || ''; if (!(g in gmap)) { gmap[g] = []; groups.push(g); } gmap[g].push(x); });
            %>
            <% groups.forEach(g => { %>
              <% if (g) { %><tr class="subhdr" data-cat="<%= sec.key %>" data-grp="<%= g %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)"><td colspan="10"><%= g %></td></tr><% } %>
              <% gmap[g].forEach(s => { var ph = photosBySub[s.id] || []; %>
              <tr data-cat="<%= catOf(s) %>" data-grp="<%= s.group_label||'' %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)" data-search="<%= [s.company,s.owner,s.type,s.phone,s.email,s.location].filter(Boolean).join(' ').toLowerCase() %>" data-type="<%= (s.type||'').toLowerCase() %>">
                <td class="drag-h" draggable="true" ondragstart="onDragStart(event,'<%= s.id %>')" title="Drag to move">⠿</td>
                <td class="co"><%= s.company || '—' %>
                  <% if (ph.length) { %><div class="thumbs"><% ph.forEach(pid => { %><a href="/sub-photo/<%= pid %>" target="_blank"><img src="/sub-photo/<%= pid %>"></a><% }) %></div><% } %>
                </td>
                <td><%= s.location || '' %></td>
                <td><%= s.type || '' %></td>
                <td>
                  <select class="spill <%= pillClass(s.status) %>" data-id="<%= s.id %>" onchange="changeStatus(this)">
                    <option value="">—</option>
                    <% STATUS_OPTS.forEach(o => { %><option value="<%= o %>" <%= s.status===o?'selected':'' %>><%= o %></option><% }) %>
                    <% if (s.status && STATUS_OPTS.indexOf(s.status) < 0) { %><option value="<%= s.status %>" selected><%= s.status %></option><% } %>
                  </select>
                </td>
                <td><%= s.owner || '' %></td>
                <td><% if (s.email) { %><a href="mailto:<%= s.email %>"><%= s.email %></a><% } %></td>
                <td><% if (s.phone) { %><a href="tel:<%= s.phone.replace(/[^0-9+]/g,'') %>"><%= s.phone %></a><% } %></td>
                <td class="notes"><%= s.notes || '' %></td>
                <td class="row-actions">
                  <select class="moveSel" data-id="<%= s.id %>" onchange="changeMove(this)" title="Move to another section / group">
                    <option value="">Move…</option>
                    <optgroup label="Outside GCs">
                      <% moveTargets.filter(t => t.cat === 'gc').forEach(t => { %><option value="gc||<%= t.grp %>"><%= t.grp || '(no group)' %></option><% }) %>
                    </optgroup>
                    <optgroup label="Subcontractors">
                      <% moveTargets.filter(t => t.cat !== 'gc').forEach(t => { %><option value="sub||<%= t.grp %>"><%= t.grp || '(no group)' %></option><% }) %>
                    </optgroup>
                  </select>
                  <button onclick='openEdit(<%- JSON.stringify(s) %>)' title="Edit">✏</button>
                  <form method="POST" action="/subs/<%= s.id %>/photo" enctype="multipart/form-data" style="margin:0;display:inline">
                    <label class="upl" title="Add photo">📷<input type="file" name="photo" accept="image/*" style="display:none" onchange="this.form.submit()"></label>
                  </form>
                  <form method="POST" action="/subs/<%= s.id %>/delete" style="margin:0;display:inline" onsubmit="return confirm('Delete this subcontractor?')">
                    <button type="submit" class="del" title="Delete">🗑</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  <% }) %>
</div>

<!-- Add / Edit modal -->
<div class="modal-bk" id="subModal">
  <div class="modal-card">
    <h2 id="modalTitle">Add Subcontractor</h2>
    <form id="subForm" method="POST" action="/subs">
      <input type="hidden" id="editId" value="">
      <div class="mg"><label>Company</label><input name="company" id="f_company" placeholder="e.g. Pyramid Drywall"></div>
      <div class="mg2">
        <div class="mg"><label>Contact / Owner</label><input name="owner" id="f_owner"></div>
        <div class="mg"><label>Trade / Type</label><input name="type" id="f_type" list="tradeList" placeholder="General Contractor, Electrician…"></div>
      </div>
      <div class="mg2">
        <div class="mg"><label>Phone</label><input name="phone" id="f_phone"></div>
        <div class="mg"><label>Email</label><input name="email" id="f_email"></div>
      </div>
      <div class="mg2">
        <div class="mg"><label>Location</label><input name="location" id="f_location"></div>
        <div class="mg"><label>Status</label><input name="status" id="f_status"></div>
      </div>
      <div class="mg"><label>Buildoly Projects</label><input name="projects" id="f_projects"></div>
      <div class="mg"><label>Notes</label><textarea name="notes" id="f_notes" rows="2"></textarea></div>
      <input type="hidden" name="group_label" id="f_group">
      <div style="display:flex;gap:.6rem;justify-content:flex-end;margin-top:.4rem">
        <button type="button" class="btn btn-ghost" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="saveBtn">Save</button>
      </div>
    </form>
  </div>
</div>
<datalist id="tradeList">
  <option>General Contractor</option><option>Electrician</option><option>Plumber</option>
  <option>Drywall</option><option>Framing</option><option>Painter</option><option>Handyman</option>
  <option>HVAC</option><option>Flooring</option><option>Roofing</option><option>Concrete</option>
  <option>Demolition</option><option>Junk Removal</option><option>Landscaping</option><option>Tile</option>
</datalist>

<script>
(function () {
  const types = [...new Set([...document.querySelectorAll('tr[data-type]')].map(c => c.dataset.type).filter(Boolean))].sort();
  const sel = document.getElementById('typeFilter');
  types.forEach(t => { const o = document.createElement('option'); o.value = t; o.textContent = t.replace(/\b\w/g, m => m.toUpperCase()); sel.appendChild(o); });
})();
function filterSubs() {
  const q = document.getElementById('subSearch').value.toLowerCase().trim();
  const tf = document.getElementById('typeFilter').value;
  document.querySelectorAll('tr[data-search]').forEach(r => {
    const okQ = !q || r.dataset.search.includes(q);
    const okT = !tf || r.dataset.type === tf;
    r.style.display = (okQ && okT) ? '' : 'none';
  });
  // Hide sub-section headers that have no visible rows beneath them
  document.querySelectorAll('.subs-table tbody').forEach(tb => {
    const trs = [...tb.children];
    trs.forEach((tr, i) => {
      if (!tr.classList.contains('subhdr')) return;
      let any = false;
      for (let j = i + 1; j < trs.length; j++) { if (trs[j].classList.contains('subhdr')) break; if (trs[j].style.display !== 'none') { any = true; break; } }
      tr.style.display = any ? '' : 'none';
    });
  });
  // Hide a whole section if it has no visible rows
  document.querySelectorAll('.sub-section').forEach(sec => {
    const vis = [...sec.querySelectorAll('tr[data-search]')].some(r => r.style.display !== 'none');
    sec.style.display = vis ? '' : 'none';
  });
}
function openAdd() {
  document.getElementById('modalTitle').textContent = 'Add Subcontractor';
  document.getElementById('editId').value = '';
  ['company','owner','type','phone','email','location','status','projects','notes','group'].forEach(k => document.getElementById('f_' + k).value = '');
  document.getElementById('subModal').classList.add('show');
}
function openEdit(s) {
  document.getElementById('modalTitle').textContent = 'Edit Subcontractor';
  document.getElementById('editId').value = s.id;
  document.getElementById('f_company').value = s.company || '';
  document.getElementById('f_owner').value = s.owner || '';
  document.getElementById('f_type').value = s.type || '';
  document.getElementById('f_phone').value = s.phone || '';
  document.getElementById('f_email').value = s.email || '';
  document.getElementById('f_location').value = s.location || '';
  document.getElementById('f_status').value = s.status || '';
  document.getElementById('f_projects').value = s.projects || '';
  document.getElementById('f_notes').value = s.notes || '';
  document.getElementById('f_group').value = s.group_label || '';
  document.getElementById('subModal').classList.add('show');
}
function pillClassJS(st) { st = (st || '').toLowerCase();
  if (/black/.test(st)) return 'pill-black';
  if (/reject|declin/.test(st)) return 'pill-rejected';
  if (/active/.test(st)) return 'pill-active';
  if (/approv/.test(st)) return 'pill-approved';
  if (/review|vetting|pending/.test(st)) return 'pill-review';
  return 'pill-default'; }
// ── Drag & drop to move between buckets / sections ──
let dragId = null;
function onDragStart(e, id) { dragId = id; e.dataTransfer.effectAllowed = 'move'; try { e.dataTransfer.setData('text/plain', id); } catch (x) {} }
function onDragOver(e) { if (!dragId) return; e.preventDefault(); e.currentTarget.classList.add('drop-hi'); }
function onDragLeave(e) { e.currentTarget.classList.remove('drop-hi'); }
async function onDrop(e) {
  e.preventDefault();
  const t = e.currentTarget; t.classList.remove('drop-hi');
  const cat = t.dataset.cat, grp = t.dataset.grp || '';
  const id = dragId; dragId = null;
  if (!id || cat == null) return;
  const body = new URLSearchParams({ category: cat, group_label: grp });
  try {
    const r = await fetch('/subs/' + id + '/move', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    if (r.ok) location.reload(); else throw 0;
  } catch (err) { alert('Could not move — try again'); }
}
async function changeMove(sel) {
  if (!sel.value) return;
  const [cat, grp] = sel.value.split('||');
  const body = new URLSearchParams({ category: cat, group_label: grp });
  try {
    const r = await fetch('/subs/' + sel.dataset.id + '/move', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    if (r.ok) location.reload(); else throw 0;
  } catch (e) { alert('Could not move — try again'); sel.value = ''; }
}
async function changeStatus(sel) {
  sel.className = 'spill ' + pillClassJS(sel.value);   // recolor instantly
  const body = new URLSearchParams({ status: sel.value });
  try {
    const r = await fetch('/subs/' + sel.dataset.id + '/status', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    if (!r.ok) throw 0;
  } catch (e) { alert('Could not save status — try again'); }
}
function closeModal() { document.getElementById('subModal').classList.remove('show'); }
document.getElementById('subForm').addEventListener('submit', async function (e) {
  const id = document.getElementById('editId').value;
  if (!id) return;
  e.preventDefault();
  const body = new URLSearchParams();
  ['company','owner','type','phone','email','location','status','projects','notes'].forEach(k => body.set(k, document.getElementById('f_' + k).value));
  document.getElementById('saveBtn').textContent = 'Saving…';
  const r = await fetch('/subs/' + id, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
  if (r.ok) location.reload(); else { alert('Could not save'); document.getElementById('saveBtn').textContent = 'Save'; }
});
document.getElementById('subModal').addEventListener('click', e => { if (e.target.id === 'subModal') closeModal(); });
</script>
</body>
</html>

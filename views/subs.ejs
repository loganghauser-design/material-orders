      const ts = String(s.t).split(',').map(function (x) { return x.trim().toLowerCase(); });
      if (!ts.includes(mtrade.toLowerCase())) return;
    }
    let placed = false;
    String(s.l).split(',').forEach(function (loc) {
      loc = loc.trim().toLowerCase();
      const hit = Object.keys(AREA_GEO).find(function (a) { return a.toLowerCase() === loc; });
      if (hit) { counts[hit]++; placed = true; }
    });
    if (!placed) unmapped.push(s.n || '(unnamed)');
  });
  const um = document.getElementById('mapUnmapped');
  if (um) {
    if (unmapped.length) {
      um.style.display = '';
      um.innerHTML = '⚠ <strong>' + unmapped.length + '</strong> matching contractor' + (unmapped.length > 1 ? 's aren\'t' : ' isn\'t') + ' on the map — no service area set. Click to see who, then set their Location (✎ edit) to place them.';
      um.onclick = function () { alert('Not on the map (no Location set):\n\n• ' + unmapped.join('\n• ')); };
    } else um.style.display = 'none';
  }
  const label = (mtrade ? mtrade + ' ' : '') + (mode === 'gc' ? 'outside GC' : (mode === 'sub' ? 'sub' : 'contractor'));
  const group = [];
  Object.keys(AREA_GEO).forEach(function (a) {
    const n = counts[a];
    const color = n === 0 ? '#8a909c' : (n < 3 ? '#d99a06' : '#1a7f37');
    const circle = L.circle(AREA_GEO[a], {
      radius: 5500 + Math.min(n, 25) * 1100,
      color: color, weight: 2, dashArray: n === 0 ? '6 6' : null,
      fillColor: color, fillOpacity: n === 0 ? .05 : .18,
    }).addTo(covMap);
    circle.bindTooltip(a.replace(' County', '') + ': ' + n, { permanent: true, direction: 'center', className: 'map-count' });
    circle.bindPopup('<strong>' + a + '</strong><br>' + n + ' ' + label + (n === 1 ? '' : 's') + ' cover this area<br><a href="#" onclick="mapFilter(\'' + a.replace(/'/g, "\\'") + '\');return false">Show them in the list</a>');
    mapLayers.push(circle); group.push(circle);
  });
  if (group.length) covMap.fitBounds(L.featureGroup(group).getBounds().pad(0.1));
}

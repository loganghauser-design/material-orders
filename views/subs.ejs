function covRender() {
  const county = document.getElementById('covCounty').value.toLowerCase();
  const tradeList = TRADES.filter(function (t) { return t !== 'General Contractor'; });
  const counts = {};
  tradeList.forEach(function (t) { counts[t] = 0; });
  COV_DATA.forEach(function (s) {
    if (/reject|black/i.test(s.st)) return;                                       // unusable
    const isGc = s.cat === 'gc' || (!s.cat && /general\s*contractor|^\s*gc\b/i.test(s.t));
    if (isGc) return;                                                              // outside GCs aren't trade coverage
    if (county) {
      const locs = String(s.l).split(',').map(function (x) { return x.trim().toLowerCase(); });
      if (!locs.includes(county)) return;
    }
    const ts = String(s.t).split(',').map(function (x) { return x.trim().toLowerCase(); }).filter(Boolean);
    tradeList.forEach(function (t) { if (ts.includes(t.toLowerCase())) counts[t]++; });
  });

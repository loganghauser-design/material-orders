<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subcontractors — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .subs-toolbar { display:flex; gap:.6rem; flex-wrap:wrap; align-items:center; margin-bottom:1rem; }
    .subs-toolbar input[type=search], .subs-toolbar select { padding:.5rem .7rem; border:1px solid var(--border); border-radius:9px; background:var(--surface); font-size:.9rem; }
    .subs-toolbar input[type=search] { min-width:240px; flex:1; }
    .email-edit { background:none; border:none; cursor:pointer; font-size:.85rem; opacity:.55; padding:0 .2rem; }
    .email-edit:hover { opacity:1; }
    .trade-select { min-width:170px; font-weight:600; }
    .trade-select:focus { outline:none; border-color:#1d4ed8; }
    .recent-toggle { display:inline-flex; align-items:center; gap:.4rem; font-size:.88rem; font-weight:700; color:#16794a; background:#e3f6ec; border:1px solid #9fdcb8; border-radius:9px; padding:.45rem .7rem; cursor:pointer; white-space:nowrap; }
    .recent-toggle input { width:17px; height:17px; accent-color:#16794a; }
    .newdot { font-size:.85rem; }
    .blurred { filter: blur(4.5px); user-select:none; cursor:pointer; transition:filter .12s; }
    .blurred:hover, .blurred.show { filter:none; }
    .reject-reason { color:#b4231f; font-weight:700; font-size:.78rem; background:#fde8e7; border:1px solid #f3b5b2; border-radius:6px; padding:.2rem .45rem; display:inline-block; margin-bottom:.25rem; }
    .flagged-row { position:relative; }
    .row-reason { position:absolute; inset:0; z-index:6; display:flex; align-items:center; justify-content:flex-start; gap:.7rem; padding:.2rem 1.1rem; background:rgba(192,57,43,.93); color:#fff; font-weight:800; font-size:.9rem; line-height:1.25; cursor:pointer; border-radius:6px; }
    .row-reason .rr-name { flex:none; max-width:34%; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; padding-right:.7rem; border-right:2px solid rgba(255,255,255,.55); }
    .row-reason .rr-reason { flex:1; min-width:0; text-align:left; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .row-reason.off { display:none; }
    .row-reason.black { background:rgba(15,15,17,.96); }
    .row-reason .rr-actions { margin-left:auto; display:flex; gap:.3rem; flex:none; }
    .row-reason .rr-actions button { background:rgba(255,255,255,.22); border:none; color:#fff; border-radius:5px; padding:.14rem .45rem; cursor:pointer; font-size:.82rem; line-height:1; }
    .row-reason .rr-actions button:hover { background:rgba(255,255,255,.42); }
    .conote-btn { display:inline-block; font-size:.72rem; font-weight:700; color:#1d4ed8; cursor:pointer; margin-top:.25rem; }
    .conote-body { display:none; font-size:.8rem; font-weight:400; color:var(--text); margin-top:.3rem; white-space:normal; max-width:260px; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:.45rem .6rem; line-height:1.35; }
    .conote-body.show { display:block; }
    /* ── Guided card scan: front/back photo slots ── */
    .cs-slot { flex:1; border:2px dashed var(--border); border-radius:10px; min-height:110px; position:relative; display:flex; align-items:center; justify-content:center; overflow:hidden; background:var(--bg); }
    .cs-slot .cs-lbl { position:absolute; top:6px; left:8px; font-size:.66rem; font-weight:800; color:var(--muted); letter-spacing:.04em; background:rgba(255,255,255,.85); padding:1px 6px; border-radius:6px; z-index:2; }
    .cs-slot img { width:100%; height:110px; object-fit:cover; }
    .cs-slot .cs-empty { color:var(--border); font-size:1.6rem; font-weight:800; }
    .cs-slot.done { border-style:solid; border-color:#16a34a; }
    .cs-slot.done .cs-lbl { color:#16a34a; }
    .cs-slot.done .cs-empty { display:none; }
    /* ── Outreach stats: one horizontal band per group — who │ pipeline │ pool ── */
    .of-groups { display:flex; flex-direction:column; gap:.7rem; margin-top:.8rem; }
    .of-group { display:flex; align-items:center; gap:1.1rem; background:var(--bg); border:1px solid var(--border); border-radius:12px; padding:.7rem 1rem; flex-wrap:wrap; }
    .of-left { flex:none; width:130px; display:flex; flex-direction:column; gap:.1rem; }
    .of-title { font-weight:800; font-size:.9rem; white-space:nowrap; }
    .of-rr { font-size:1.45rem; font-weight:800; line-height:1.1; }
    .of-rr .of-rrl { display:block; font-size:.66rem; font-weight:600; color:var(--muted); }
    .of-steps { flex:1; min-width:320px; display:flex; align-items:stretch; gap:.25rem; }
    .of-step { flex:1; background:var(--surface); border:1px solid var(--border); border-top:3px solid; border-radius:9px; padding:.35rem .3rem .3rem; text-align:center; min-width:0; }
    .of-n { font-size:1.05rem; font-weight:800; line-height:1.1; }
    .of-l { font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.02em; color:var(--muted); margin-top:.1rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .of-p { font-size:.66rem; color:var(--muted); margin-top:.05rem; }
    .of-arrow { align-self:center; color:var(--muted); font-size:1rem; font-weight:700; flex:none; }
    .of-right { flex:none; width:230px; }
    .of-poolbar { display:flex; height:12px; border-radius:6px; overflow:hidden; background:var(--surface); border:1px solid var(--border); }
    .of-chips { display:flex; gap:.25rem .7rem; flex-wrap:wrap; margin-top:.4rem; font-size:.72rem; color:var(--muted); }
    .of-chip { white-space:nowrap; }
    .of-chip .dot { display:inline-block; width:8px; height:8px; border-radius:3px; margin-right:.25rem; vertical-align:-1px; }
    .of-chip strong { color:var(--text); }
    .of-chip .mut { color:var(--muted); }
    .of-chip-warn { cursor:pointer; user-select:none; background:#fff7e6; border:1px solid #f0d9a8; border-radius:8px; padding:.05rem .4rem; color:#7a5b00; }
    @media (max-width: 800px) { .of-left { width:100%; flex-direction:row; align-items:baseline; gap:.6rem; } .of-right { width:100%; } }
    .c-owner { font-weight:600; font-size:.85rem; }
    .c-phone { font-size:.8rem; margin-top:.15rem; }
    .c-email { margin-top:.1rem; }
    .refby-line { color:var(--muted); font-size:.72rem; margin-bottom:.2rem; }
    .emlog-btn { display:inline-block; font-size:.72rem; font-weight:700; color:#1d4ed8; cursor:pointer; margin-left:.35rem; white-space:nowrap; }
    /* Email history opens as a Gmail-style reading pane: every email rendered inline. */
    .emlog-body { display:none; }
    .emlog-body.show { display:block; position:fixed; inset:0; margin:auto; width:min(820px, 95vw); height:min(86vh, 950px); background:var(--card, #fff); border:1px solid var(--border); border-radius:14px; box-shadow:0 24px 70px rgba(10,15,25,.4); z-index:600; overflow-y:auto; text-align:left; }
    .emlog-head { position:sticky; top:0; z-index:5; display:flex; align-items:center; justify-content:space-between; background:var(--card, #fff); border-bottom:1px solid var(--border); padding:.7rem 1rem; font-size:.95rem; }
    .emlog-close { background:none; border:none; font-size:1.05rem; color:var(--muted); cursor:pointer; padding:.1rem .4rem; }
    .emlog-close:hover { color:var(--text); }
    .emlog-backdrop { display:none; position:fixed; inset:0; background:rgba(12,17,27,.45); z-index:590; }
    .emlog-backdrop.show { display:block; }
    .emlog-item { font-size:.84rem; color:var(--text); border-top:1px solid var(--border); padding:.6rem 1rem .7rem; white-space:normal; }
    .emlog-item:first-of-type { border-top:none; }
    .emlog-date { color:var(--muted); font-size:.74rem; margin-right:.3rem; }
    .emlog-text { color:var(--muted); margin-top:.2rem; white-space:pre-wrap; }
    .emlog-frame { display:block; width:100%; height:150px; margin-top:.45rem; border:1px solid var(--border); border-radius:10px; background:#fff; }
    .emlog-view { display:inline-block; font-size:.72rem; font-weight:700; color:#1d4ed8; text-decoration:none; margin-left:.35rem; white-space:nowrap; }
    .emlog-view:hover { color:#1e40af; }
    .emlog-btn.has-reply { color:#b91c1c; }
    .reply-dot { font-weight:800; color:#b91c1c; }
    .emlog-item.inbound { background:#eef6ff; border-left:3px solid #1d4ed8; padding-left:.4rem; }
    .emlog-tag { display:inline-block; font-size:.66rem; font-weight:800; color:#1d4ed8; margin-right:.25rem; }
    .emlog-atts { margin-top:.3rem; display:flex; flex-direction:column; gap:.2rem; }
    .emlog-att { font-size:.72rem; font-weight:600; color:#1d4ed8; text-decoration:none; background:#eef2ff; border:1px solid #c7d2fe; border-radius:8px; padding:.15rem .4rem; word-break:break-all; }
    .emlog-att:hover { background:#e0e7ff; }
    .emlog-att.emlog-attimg { padding:0; background:none; border:none; }
    .emlog-attimg img { max-height:110px; max-width:150px; border:1px solid #c7d2fe; border-radius:8px; display:block; }
    .emlog-reply { margin-top:.45rem; border-top:1px solid var(--border); padding:.6rem 1rem .8rem; }
    .emlog-reply-text { width:100%; font-size:.84rem; border:1px solid var(--border); border-radius:8px; padding:.4rem .5rem; resize:vertical; box-sizing:border-box; margin-top:.35rem; }
    .emlog-reply-btn { margin-top:.25rem; font-size:.72rem; font-weight:700; color:#fff; background:#1d4ed8; border:none; border-radius:8px; padding:.25rem .6rem; cursor:pointer; }
    .emlog-reply-btn:hover { background:#1742b8; }
    .emlog-reply-btn:disabled { opacity:.6; cursor:default; }
    .emlog-reply-hint { display:block; font-size:.66rem; color:var(--muted); margin-top:.2rem; }
    .emlog-fu { display:block; width:100%; max-width:240px; margin-bottom:.3rem; font-size:.74rem; font-weight:600; color:#1d4ed8; border:1px solid #c7d2fe; background:#eef2ff; border-radius:8px; padding:.28rem .4rem; cursor:pointer; }
    .emptybucket-cell { color:var(--muted); font-size:.85rem; font-weight:600; padding:.7rem .9rem; border:2px dashed var(--border); border-radius:8px; background:var(--bg); text-align:center; }
    tr.emptybucket.drop-hi .emptybucket-cell { background:#fde8e7; border-color:#c0392b; color:#b4231f; }
    .sec-title { font-size:1.6rem; font-weight:800; margin:2.4rem 0 .6rem; padding:.7rem 1rem; border-radius:9px; display:flex; align-items:center; gap:.6rem; }
    .sec-title .cnt { font-weight:600; font-size:1.05rem; opacity:.7; }
    .sec-gc { background:#fce5cd; color:#7a4a16; }
    .sec-sub { background:#ead1dc; color:#7a2c52; }
    .sub-section:first-of-type .sec-title { margin-top:.4rem; }
    .container.container-wide { max-width: none; }   /* fill the space beside the sidebar */
    .tbl-wrap { overflow:auto; max-height:76vh; border:1px solid var(--border); border-radius:10px; }
    .tbl-wrap::-webkit-scrollbar { height:13px; width:13px; }
    .tbl-wrap::-webkit-scrollbar-thumb { background:#aab0be; border-radius:7px; border:2px solid var(--surface); }
    .tbl-wrap::-webkit-scrollbar-thumb:hover { background:#8b92a3; }
    .tbl-wrap::-webkit-scrollbar-track { background:#eef0f4; border-radius:7px; }
    .subs-table { width:100%; border-collapse:collapse; font-size:.85rem; }
    .subs-table th { text-align:left; font-size:.68rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); padding:.55rem .7rem; border-bottom:2px solid var(--border); white-space:nowrap; background:var(--bg); position:sticky; top:0; }
    .subs-table td { padding:.55rem .7rem; border-bottom:1px solid var(--border); vertical-align:top; }
    .subs-table tr:last-child td { border-bottom:none; }
    .subs-table tbody tr:hover td { background:var(--bg); }
    .subs-table tr.subhdr td { background:#dededf; color:#1a1a1a; font-size:1.15rem; font-weight:800; padding:.6rem .8rem; border-top:2px solid #cfcfd2; }
    .subs-table tr.subhdr:hover td { background:#dededf; }
    .spill { display:inline-block; padding:3px 12px; border-radius:13px; font-size:.78rem; font-weight:700; white-space:nowrap; }
    select.spill { border:1px solid rgba(0,0,0,.15); cursor:pointer; padding:3px 6px; }
    .pill-review { background:#ffe599; color:#7f6000; }
    .pill-approved { background:#b6d7a8; color:#274e13; }
    .pill-active { background:#38761d; color:#fff; }
    .pill-inactive { background:#6b7280; color:#fff; }
    .pill-bid { background:#7c3aed; color:#fff; }
    .pill-called { background:#dbeafe; color:#1e40af; }
    .pill-sent { background:#c7d2fe; color:#3730a3; }
    .bidline { display:flex; align-items:center; gap:.35rem; margin-top:.3rem; white-space:nowrap; }
    .bidamt { font-weight:800; font-size:.92rem; cursor:pointer; }
    .bidamt:hover { text-decoration:underline; }
    .bidadd { color:var(--muted); font-size:.72rem; font-weight:600; cursor:pointer; border:1px dashed var(--border); border-radius:8px; padding:.05rem .4rem; }
    .bidadd:hover { color:var(--text); }
    .biddoc { text-decoration:none; font-size:.88rem; }
    .pill-rejected { background:#e06666; color:#fff; }
    .pill-black { background:#111; color:#fff; }
    .pill-default { background:#e6e6e6; color:#555; }
    .bid-sel { border:1px solid rgba(0,0,0,.15); border-radius:11px; padding:3px 6px; font-size:.76rem; font-weight:700; cursor:pointer; background:#eef0f4; color:#444; }
    .bid-sel.bid-called { background:#dbe9ff; color:#1d4ed8; }
    .bid-sel.bid-sent { background:#fff0c2; color:#7a5b00; }
    .bid-sel.bid-received { background:#cdeccd; color:#1a6b1a; }
    .bid-sel.bid-awarded { background:#38761d; color:#fff; }
    .bid-sel.bid-passed { background:#e6e6e6; color:#777; }
    .bid-price { width:78px; margin-top:.25rem; padding:3px 6px; border:1px solid var(--border); border-radius:7px; font-size:.8rem; }
    .lic-sel { border:1px solid var(--border); border-radius:8px; padding:3px 5px; font-size:.76rem; cursor:pointer; }
    .lic-num { width:108px; margin-top:.25rem; padding:3px 6px; border:1px solid var(--border); border-radius:7px; font-size:.8rem; }
    .vbtn { background:none; border:1px solid var(--border); border-radius:6px; cursor:pointer; font-size:.72rem; padding:1px 6px; vertical-align:middle; }
    .vbtn:hover { background:var(--bg); }
    .licb { display:block; margin-top:.25rem; font-size:.68rem; font-weight:700; padding:2px 7px; border-radius:9px; max-width:160px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; cursor:pointer; }
    .licb:hover { filter:brightness(.93); text-decoration:underline; }
    .licb-ok { background:#dcfce7; color:#166534; }
    .licb-amber { background:#fde68a; color:#7a5b00; }
    .licb-red { background:#dc2626; color:#fff; }
    .insb { display:block; margin-top:.25rem; font-size:.68rem; font-weight:700; padding:2px 7px; border-radius:9px; max-width:160px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; cursor:default; }
    .insb-ok { background:#e0f2fe; color:#075985; }
    .insb-amber { background:#fde68a; color:#7a5b00; }
    .insb-red { background:#dc2626; color:#fff; }
    .licb-more { display:block; margin-top:2px; font-size:.66rem; font-weight:700; color:#dc2626; cursor:pointer; }
    .licb-more:hover { text-decoration:underline; }
    .lm-row { display:flex; gap:.7rem; padding:.4rem 0; border-bottom:1px solid var(--border); font-size:.9rem; }
    .lm-row .k { flex:none; width:110px; color:var(--muted); font-size:.78rem; font-weight:700; text-transform:uppercase; padding-top:.1rem; }
    .lm-flag { display:flex; gap:.5rem; align-items:flex-start; padding:.45rem .6rem; border-radius:8px; margin-bottom:.4rem; font-size:.88rem; line-height:1.4; }
    .lm-flag.red { background:#fde8e7; color:#991b1b; }
    .lm-flag.amber { background:#fdf3d0; color:#7a5b00; }
    .lm-flag.info { background:#eef2f7; color:#475569; }
    .lm-ok { background:#dcfce7; color:#166534; padding:.5rem .7rem; border-radius:8px; font-weight:700; font-size:.9rem; }
    .lm-copy { background:none; border:1px solid var(--border); border-radius:6px; cursor:pointer; font-size:.72rem; padding:1px 7px; margin-left:.35rem; }
    .subs-table a { color:#1d4ed8; text-decoration:none; white-space:nowrap; }
    .subs-table .co { font-weight:600; }
    .subs-table .notes { color:var(--muted); max-width:260px; }
    .note-clip { display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; cursor:pointer; }
    .note-clip.open { -webkit-line-clamp:unset; line-clamp:unset; overflow:visible; }
    .thumbs { display:flex; gap:.3rem; margin-top:.3rem; flex-wrap:wrap; }
    .thumb { position:relative; display:inline-block; }
    .thumbs img { width:46px; height:46px; object-fit:cover; border-radius:6px; border:1px solid var(--border); display:block; }
    .thx { position:absolute; top:-6px; right:-6px; width:17px; height:17px; line-height:15px; text-align:center; font-size:.7rem; background:#cc2222; color:#fff; border-radius:50%; cursor:pointer; border:1.5px solid var(--surface); }
    #modalPhotos .thumbs, #modalPhotos { gap:.4rem; }
    #modalPhotos img { width:60px; height:60px; }
    .addphotos { display:inline-flex; align-items:center; gap:.4rem; padding:.55rem 1rem; border:1.5px dashed var(--border); border-radius:9px; cursor:pointer; font-size:.92rem; font-weight:600; background:var(--bg); }
    .addphotos:hover { border-color:#111; }

    /* ── Phone: stack each contractor into a readable card ── */
    @media (max-width: 760px) {
      .subs-toolbar { flex-wrap:wrap; }
      .subs-toolbar input[type="search"] { flex:1 1 100%; }
      .tbl-wrap { overflow-x:visible; max-height:none; }
      .subs-table { border:none; }
      .subs-table thead { display:none; }
      .subs-table, .subs-table tbody { display:block; width:100%; }
      .subs-table tr.subhdr { display:block; margin:1.1rem 0 .5rem; }
      .subs-table tr.subhdr td { display:block; padding:.4rem .2rem; }
      .subs-table tr:not(.subhdr) { display:block; border:1px solid var(--border); border-radius:13px; padding:.8rem .95rem; margin:0 0 .8rem; background:var(--surface); box-shadow:0 1px 4px rgba(0,0,0,.04); }
      .subs-table tr:not(.subhdr) td { display:block; border:none; padding:.14rem 0; font-size:.95rem; }
      .subs-table .drag-h { display:none; }
      .subs-table .co { font-size:1.15rem; font-weight:800; margin-bottom:.2rem; }
      .subs-table td[data-label]:not(:empty)::before { content:attr(data-label) ": "; font-weight:700; color:var(--muted); font-size:.76rem; text-transform:uppercase; letter-spacing:.03em; }
      .subs-table .notes { white-space:normal; }
      .subs-table .note-clip { -webkit-line-clamp:unset; max-height:none; }
      .subs-table .spill { font-size:1rem; padding:.4rem .6rem; }
      .subs-table .row-actions { display:flex; flex-wrap:wrap; align-items:center; gap:.7rem; margin-top:.7rem; padding-top:.6rem; border-top:1px dashed var(--border); }
      .subs-table .moveSel { max-width:60%; font-size:.85rem; }
      .subs-table .row-actions button, .subs-table .row-actions label.upl { font-size:1.25rem; padding:.45rem .7rem; }
      .thumbs img { width:64px; height:64px; }
      .modal-card { width:96vw; max-width:96vw; max-height:92vh; overflow-y:auto; }
    }
    .row-actions { white-space:nowrap; }
    .row-actions button, .row-actions label.upl { font-size:.85rem; padding:.2rem .4rem; border:1px solid var(--border); background:var(--surface); border-radius:6px; cursor:pointer; line-height:1; }
    .moveSel { font-size:.74rem; padding:.2rem .3rem; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; max-width:130px; }
    .drag-h { cursor:grab; color:var(--muted); text-align:center; user-select:none; font-size:1.05rem; width:24px; }
    .drag-h:active { cursor:grabbing; }
    .subs-table tr.drop-hi > td { background:#dbeafe !important; box-shadow:inset 0 2px 0 #4f8ef7; }
    /* read-only super view: hide all the editing controls */
    .super-view .admin-actions { display:none; }
    .super-view .subs-table th:first-child, .super-view .subs-table td.drag-h { display:none; }
    .super-view .subs-table th:last-child, .super-view .subs-table td.row-actions { display:none; }
    .super-view select.spill { pointer-events:none; -webkit-appearance:none; appearance:none; padding:3px 12px; }
    .super-view .bid-sel, .super-view .lic-sel { pointer-events:none; -webkit-appearance:none; appearance:none; }
    .super-view .bid-price, .super-view .lic-num { pointer-events:none; background:transparent; }
    .row-actions .del { color:var(--danger); border-color:rgba(204,34,34,.3); }
    .modal-bk { position:fixed; inset:0; background:rgba(0,0,0,.5); display:none; align-items:flex-start; justify-content:center; z-index:50; padding:2rem 1rem; overflow:auto; }
    .modal-bk.show { display:flex; }
    .modal-card { background:var(--surface); border-radius:14px; padding:1.3rem; width:100%; max-width:520px; }
    .modal-card h2 { font-size:1.15rem; margin:0 0 1rem; }
    .mg { margin-bottom:.7rem; } .mg label { display:block; font-size:.8rem; font-weight:600; margin-bottom:.25rem; }
    .mg input, .mg textarea, .mg select { width:100%; padding:.5rem .6rem; border:1px solid var(--border); border-radius:8px; background:var(--bg); font-size:.92rem; }
    .mg2 { display:grid; grid-template-columns:1fr 1fr; gap:.7rem; }
    .trade-chips { display:flex; flex-wrap:wrap; gap:.4rem; }
    .trade-chip { padding:.32rem .7rem; border:1px solid var(--border); border-radius:16px; font-size:.82rem; cursor:pointer; user-select:none; background:var(--bg); white-space:nowrap; }
    .trade-chip.on { background:#111; color:#fff; border-color:#111; }
    .cov-panel { display:none; background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:1rem 1.1rem; margin-bottom:1.1rem; }
    .cov-panel.show { display:block; }
    .cov-head { display:flex; gap:.8rem; align-items:center; flex-wrap:wrap; margin-bottom:.8rem; }
    .cov-head select { padding:.4rem .6rem; border:1px solid var(--border); border-radius:9px; background:var(--bg); font-size:.86rem; }
    .cov-legend-inline { font-size:.76rem; color:var(--muted); }
    .cov-grid { display:flex; flex-wrap:wrap; gap:.45rem; }
    .cov-areas { display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:.5rem; margin-bottom:.9rem; }
    .cov-tile { border:1px solid var(--border); border-radius:10px; padding:.5rem .65rem; cursor:pointer; background:var(--bg); transition:transform .08s; }
    .cov-tile:hover { transform:translateY(-1px); }
    .cov-tile.sel { outline:2px solid #1d4ed8; outline-offset:1px; }
    .ct-n { font-size:1.35rem; font-weight:800; line-height:1.1; }
    .ct-a { font-size:.78rem; font-weight:700; margin-top:.05rem; }
    .ct-s { font-size:.68rem; color:var(--muted); margin-top:.15rem; }
    .cov-tile-bad { background:#fef2f2; border-color:#fecaca; } .cov-tile-bad .ct-n { color:#dc2626; }
    .cov-tile-mid { background:#fffbeb; border-color:#fde68a; } .cov-tile-mid .ct-n { color:#b45309; }
    .cov-tile-good { background:#f0fdf4; border-color:#bbf7d0; } .cov-tile-good .ct-n { color:#16a34a; }
    .cov-tile-na { border-style:dashed; cursor:default; } .cov-tile-na .ct-n { color:#b45309; }
    .cov-tile-na:hover { transform:none; }
    /* Coverage matrix: trade × zone, colored against the 4-sub minimum */
    .cov-matrix-wrap { overflow-x:auto; margin-bottom:.7rem; }
    .cov-matrix { border-collapse:separate; border-spacing:3px; font-size:.8rem; width:100%; }
    .cov-matrix th { font-size:.66rem; text-transform:uppercase; letter-spacing:.02em; color:var(--muted); padding:.3rem .45rem; text-align:center; white-space:nowrap; }
    .cov-matrix td { padding:.32rem .45rem; text-align:center; font-weight:800; border-radius:7px; min-width:42px; }
    .cov-matrix .cm-t { text-align:left; font-weight:700; font-size:.78rem; cursor:pointer; white-space:nowrap; max-width:160px; overflow:hidden; text-overflow:ellipsis; background:none; }
    .cov-matrix .cm-t:hover { text-decoration:underline; }
    .cm-gap { background:#fdeaea; color:#b42323; }
    .cm-thin { background:#fff4dd; color:#8a6100; }
    .cm-ok { background:#e7f6ec; color:#176b3a; }
    .cm-na, .cm-nah { color:var(--muted); font-weight:600; background:var(--bg); }
    .cm-sel { outline:2px solid #1d4ed8; outline-offset:-1px; }
    .cm-selh { color:#1d4ed8; font-weight:800; }
    .cov-chip { display:inline-flex; align-items:center; gap:.45rem; border-radius:16px; padding:.34rem .75rem; font-size:.82rem; font-weight:600; cursor:pointer; border:1px solid; }
    .cov-chip .n { font-weight:800; }
    .cov-ok { background:#e7f6ec; border-color:#b9e4c8; color:#176b3a; }
    .cov-thin { background:#fff4dd; border-color:#f0d9a6; color:#8a6100; }
    .cov-gap { background:#fdeaea; border-color:#f3bcbc; color:#b42323; }
    .cov-legend { margin-top:.7rem; display:flex; gap:.4rem; }
    #covMapEl { height:460px; border-radius:10px; border:1px solid var(--border); background:#eef0f4; }
    .map-radio { display:inline-flex; align-items:center; gap:.3rem; font-size:.84rem; font-weight:600; cursor:pointer; }
    .leaflet-tooltip.map-count { background:transparent; border:none; box-shadow:none; font-weight:800; font-size:.86rem; color:#15161a; text-shadow:0 1px 3px rgba(255,255,255,.9); }
    @media (max-width: 760px) { #covMapEl { height:330px; } }
    .sortbtn { font:inherit; font-size:.82rem; padding:.32rem .8rem; border:1px solid var(--border); border-radius:8px; text-decoration:none; color:var(--text); background:var(--surface); cursor:pointer; }
    .sortbtn.on { background:#111; color:#fff; border-color:#111; }
    .vetsel { font-size:.82rem; padding:.3rem .5rem; border:1px solid var(--border); border-radius:8px; background:var(--surface); }
    .seg { display:flex; gap:.5rem; }
    .segbtn { flex:1; font:inherit; font-size:.95rem; font-weight:700; padding:.6rem; border:2px solid var(--border); border-radius:10px; background:var(--bg); color:var(--text); cursor:pointer; }
    .segbtn.on { background:#111; color:#fff; border-color:#111; }
    .subs-table .refby { color:var(--muted); font-size:.8rem; max-width:160px; }
    /* ── Tabbed layout ── */
    .subtabs { display:flex; gap:.35rem; flex-wrap:wrap; border-bottom:2px solid var(--border); margin-bottom:1.1rem; }
    .subtab { font:inherit; font-size:.92rem; font-weight:700; color:var(--muted); background:none; border:none; border-bottom:3px solid transparent; padding:.55rem .9rem; margin-bottom:-2px; cursor:pointer; white-space:nowrap; }
    .subtab:hover { color:var(--text); background:var(--bg); border-radius:9px 9px 0 0; }
    .subtab.on { color:var(--text); border-bottom-color:#111; }
    .subtab .tabn { display:inline-block; background:#eef0f4; color:#555; font-size:.72rem; font-weight:800; padding:1px 8px; border-radius:9px; margin-left:.25rem; }
    .subtab .tabn.hot { background:#d97706; color:#fff; }
    .subtab.pulse .tabn.hot { animation:bqpulse 2s ease-in-out infinite; }
    @keyframes bqpulse { 0%,100% { transform:scale(1); } 50% { transform:scale(1.15); } }
    /* ── Visual refresh ── */
    .subs-toolbar { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:.6rem .8rem; box-shadow:0 2px 8px rgba(0,0,0,.05); }
    .subs-table tr.subhdr td { background:var(--bg); color:var(--muted); font-size:.78rem; font-weight:800; text-transform:uppercase; letter-spacing:.04em; padding:.55rem .8rem; border-top:none; }
    .subs-table tr.subhdr:hover td { background:var(--bg); }
    .subs-table tbody tr:not(.subhdr):not(.emptybucket):nth-child(even) { background:rgba(0,0,0,.014); }
    .subs-table tbody tr:not(.subhdr):not(.emptybucket):hover { background:rgba(29,78,216,.045); }
    .sub-section { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:1rem 1.2rem 1.2rem; margin-bottom:1.3rem; box-shadow:0 1px 4px rgba(0,0,0,.04); }
  </style>
</head>
<body class="<%= (isSuper && !(typeof canEdit !== 'undefined' && canEdit)) ? 'super-view' : '' %>">
<%- include('_nav', { active: 'subs' }) %>

<div class="container container-wide">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem">
    <h1>Subcontractors <span style="color:var(--muted);font-weight:400;font-size:1rem">(<%= subs.length %>)</span></h1>
    <div class="admin-actions" style="display:flex;gap:.5rem;flex-wrap:wrap">
      <a href="/subs/finder" class="btn btn-primary" title="Search the state license board (CSLB) by trade + county and add contractors">🔎 Find subs</a>
      <button type="button" class="btn btn-ghost" onclick="verifyAllLic(this)" title="Check every contractor's license against CSLB — flags expired / suspended / disciplinary">🛡 Verify licenses</button>
      <button class="btn btn-primary" onclick="openAdd()">+ Add</button>
      <button type="button" class="btn btn-ghost" onclick="openCardScan()" title="Guided scan: photo of the front, then the back — I'll read both and prefill the Add form">📇 Scan card</button>
      <%
        var _fxN = subs.filter(function (s) { return !/reject|black/i.test(s.status || ''); }).reduce(function (n, s) {
          return n + ((!String(s.company || '').trim() && !String(s.owner || '').trim()) ? 1 : 0)
                   + (String(s.location || '').trim() ? 0 : 1)
                   + (String(s.email || '').trim() ? 0 : 1);
        }, 0);
      %>
      <% if (!isSuper && canEdit && _fxN > 0) { %>
      <button type="button" class="btn btn-ghost" id="fixitBtn" onclick="openFixit()" title="Walk through subs missing a name, service area, or email — one card at a time">🛠 Needs info <span id="fixitN" style="background:#d97706;color:#fff;font-size:.72rem;font-weight:800;padding:1px 8px;border-radius:9px"><%= _fxN %></span></button>
      <% } %>
      <form method="POST" action="/subs/import" style="margin:0" onsubmit="this.querySelector('button').textContent='Importing…'">
        <button type="submit" class="btn btn-ghost" title="Pull any new companies from the GC & Sub Database Google Sheet">↻ Import from Sheet</button>
      </form>
    </div>
  </div>

  <% if (typeof imported !== 'undefined' && imported !== undefined) { %>
    <div class="card" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a;font-weight:600;margin-bottom:1rem">✓ Imported <%= imported %> new subcontractor(s) from the sheet.</div>
  <% } %>
  <% if (typeof added !== 'undefined' && added) { %>
    <div class="card" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a;font-weight:600;margin-bottom:1rem">✓ Subcontractor added.</div>
  <% } %>

  <!-- Tabs: the page's main navigation. Rejected/Blacklisted live in their own tab;
       Inactive stays on the main tabs as its own section (dormant ≠ banned). -->
  <%
    var _flagRe = /reject|black/i;
    var _catQ = function (s) { return s.category || (/general\s*contractor|^\s*gc\b/i.test(s.type || '') ? 'gc' : 'sub'); };
    var _cntSub = subs.filter(function (s) { return _catQ(s) !== 'gc' && !_flagRe.test(s.status || ''); }).length;
    var _cntGc = subs.filter(function (s) { return _catQ(s) === 'gc' && !_flagRe.test(s.status || ''); }).length;
    var _cntFlag = subs.filter(function (s) { return _flagRe.test(s.status || ''); }).length;
  %>
  <div class="subtabs" id="subTabs">
    <button type="button" class="subtab on" data-tab="sub" onclick="switchTab('sub')">🔧 Subcontractors <span class="tabn"><%= _cntSub %></span></button>
    <button type="button" class="subtab" data-tab="gc" onclick="switchTab('gc')">🏗 Outside GCs <span class="tabn"><%= _cntGc %></span></button>
    <button type="button" class="subtab" data-tab="flagged" onclick="switchTab('flagged')">🚩 Flagged <span class="tabn"><%= _cntFlag %></span></button>
  </div>

  <div id="mainPanel">

  <% if (typeof outreach !== 'undefined' && outreach && outreach.gc && !isSuper) {
       var _pct = function(a, b) { return b ? Math.round(a / b * 100) : 0; };
       var _groups = [
         { key: 'sub', title: '🔧 Subcontractors', o: outreach.sub },
         { key: 'gc',  title: '🏗 Outside GCs',    o: outreach.gc },
       ];
  %>
  <details class="card" style="margin-bottom:1rem;padding:1rem 1.3rem" open>
    <summary style="cursor:pointer;font-weight:800;font-size:.95rem">📊 Outreach stats
      <span style="color:var(--muted);font-weight:400;font-size:.83rem">— Subs respond <strong style="color:#16a34a"><%= _pct(outreach.sub.responded, outreach.sub.contacted) %>%</strong> · GCs respond <strong style="color:#16a34a"><%= _pct(outreach.gc.responded, outreach.gc.contacted) %>%</strong></span>
    </summary>

    <div class="of-groups">
    <% _groups.forEach(function(g) { var _o = g.o;
         var _rr = _pct(_o.responded, _o.contacted);
         var _funnel = [
           { label: 'Contacted', n: _o.contacted, color: '#3b82f6', pct: _o.contacted ? 100 : 0 },
           { label: 'Responded', n: _o.responded, color: '#16a34a', pct: _pct(_o.responded, _o.contacted) },
           { label: 'Bids',      n: _o.bids,      color: '#d97706', pct: _pct(_o.bids, _o.contacted) },
           { label: 'Approved',  n: _o.approved,  color: '#7c3aed', pct: _pct(_o.approved, _o.contacted) },
         ]; %>
      <!-- One horizontal band per group: who │ pipeline flowing left → right │ prospect pool -->
      <div class="of-group">
        <div class="of-left">
          <span class="of-title"><%= g.title %></span>
          <span class="of-rr" style="color:<%= _rr >= 50 ? '#16a34a' : _rr >= 25 ? '#d97706' : '#dc2626' %>"><%= _rr %>%<span class="of-rrl">respond</span></span>
        </div>
        <div class="of-steps">
          <% _funnel.forEach(function(f, i) { %>
            <% if (i) { %><div class="of-arrow">›</div><% } %>
            <div class="of-step" style="border-top-color:<%= f.color %>" title="<%= f.label %>: <%= f.n %> (<%= f.pct %>% of contacted)">
              <div class="of-n" style="color:<%= f.color %>"><%= f.n %></div>
              <div class="of-l"><%= f.label %></div>
              <div class="of-p"><%= f.pct %>%</div>
            </div>
          <% }) %>
        </div>
        <div class="of-right">
          <div class="of-poolbar" title="Prospect pool: <%= _o.pool %>">
            <% if (_o.poolContacted) { %><div style="width:<%= _pct(_o.poolContacted, _o.pool) %>%;background:#3b82f6" title="Contacted <%= _o.poolContacted %>"></div><% } %>
            <% if (_o.untouched) { %><div style="width:<%= _pct(_o.untouched, _o.pool) %>%;background:#cbd5e1" title="Untouched <%= _o.untouched %>"></div><% } %>
            <% if (_o.noEmail) { %><div style="width:<%= _pct(_o.noEmail, _o.pool) %>%;background:#f0d9a8" title="Missing email <%= _o.noEmail %>"></div><% } %>
          </div>
          <div class="of-chips">
            <span class="of-chip"><span class="dot" style="background:#3b82f6"></span>Pool <strong><%= _o.pool %></strong></span>
            <span class="of-chip"><span class="dot" style="background:#3b82f6"></span>Reached <strong><%= _o.poolContacted %></strong> <span class="mut">(<%= _pct(_o.poolContacted, _o.pool) %>%)</span></span>
            <span class="of-chip"><span class="dot" style="background:#cbd5e1"></span>Untouched <strong><%= _o.untouched %></strong></span>
            <% if (_o.noEmail > 0) { %>
            <span class="of-chip of-chip-warn" onclick="toggleMissingEmail(this, '<%= g.key %>')" title="Prospects with no email — click to show &amp; fix them in the list"><span class="dot" style="background:#f0d9a8"></span>📭 <strong><%= _o.noEmail %></strong></span>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
    </div>

    <% if (outreach.tradeStats && outreach.tradeStats.length) { %>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:.95rem 1.1rem;margin-top:.9rem">
      <div style="font-weight:800;font-size:.95rem;margin-bottom:.6rem">📈 Sub response rate by trade <span style="color:var(--muted);font-weight:400;font-size:.78rem">(responded / contacted)</span></div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:.35rem 2rem">
      <% outreach.tradeStats.forEach(function(t) { var rp = _pct(t.responded, t.contacted); %>
        <div style="display:flex;align-items:center;gap:.6rem">
          <span style="flex:none;width:120px;font-size:.78rem;font-weight:600;color:#334155;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= t.trade %></span>
          <div style="flex:1;background:var(--surface);border:1px solid var(--border);border-radius:6px;height:16px;position:relative;overflow:hidden">
            <div style="width:<%= Math.max(rp, 2) %>%;background:<%= rp >= 50 ? '#16a34a' : rp >= 25 ? '#d97706' : '#dc2626' %>;height:100%"></div>
            <span style="position:absolute;left:8px;top:0;line-height:16px;font-size:.68rem;font-weight:800;color:#fff;text-shadow:0 0 3px rgba(0,0,0,.5)"><%= rp %>% (<%= t.responded %>/<%= t.contacted %>)</span>
          </div>
        </div>
      <% }) %>
      </div>
    </div>
    <% } %>
    <div style="font-size:.74rem;color:var(--muted);margin-top:.6rem"><strong>Untouched</strong> = has an email but never contacted (ready to reach out); prospects <strong>missing an email</strong> move to untouched once you add one. <strong>Approved</strong> = the recruiting win — vetted &amp; we want to work with them (includes anyone who's gone on to Active). Phone-only contact isn't counted (yet).</div>
  </details>
  <% } %>

  <!-- Insurance watch: COI expirations parsed from the certificates subs email us -->
  <%
    var _insAll = subs.filter(function(s){ return s.ins_expires && !/reject|black/i.test(s.status || ''); });
    function _insDays(d){ return Math.floor((new Date(d) - Date.now()) / 86400000); }
    var _insExp = _insAll.filter(function(s){ return _insDays(s.ins_expires) < 0; });
    var _insSoon = _insAll.filter(function(s){ var d = _insDays(s.ins_expires); return d >= 0 && d <= 90; }).sort(function(a,b){ return new Date(a.ins_expires) - new Date(b.ins_expires); });
  %>
  <% if (!isSuper && (canEdit || _insAll.length)) { %>
  <details class="card" style="margin-bottom:1.1rem;padding:1rem 1.3rem" <%= (_insExp.length || _insSoon.length) ? 'open' : '' %>>
    <summary style="cursor:pointer;font-weight:800;font-size:.95rem">🛡 Insurance watch
      <span style="color:var(--muted);font-weight:400;font-size:.83rem">— <%= _insAll.length %> on file<% if (_insExp.length) { %> · <strong style="color:#dc2626"><%= _insExp.length %> EXPIRED</strong><% } %><% if (_insSoon.length) { %> · <strong style="color:#b45309"><%= _insSoon.length %> expiring ≤90d</strong><% } %></span>
    </summary>
    <div style="margin-top:.8rem;display:flex;flex-direction:column;gap:.35rem">
      <% if (!_insAll.length) { %><div style="color:var(--muted);font-size:.85rem">Nothing scanned yet — hit the button below and I'll read every COI/insurance certificate the subs have emailed us and pull the expiration dates.</div><% } %>
      <% _insExp.forEach(function(s){ %>
        <div style="font-size:.86rem"><span style="background:#dc2626;color:#fff;font-size:.7rem;font-weight:800;padding:2px 8px;border-radius:9px">EXPIRED</span> <strong><%= s.company %></strong> — lapsed <%= new Date(s.ins_expires).toLocaleDateString() %> <span style="color:var(--muted);font-size:.76rem">(<%= s.ins_note %>)</span></div>
      <% }) %>
      <% _insSoon.forEach(function(s){ var d = _insDays(s.ins_expires); %>
        <div style="font-size:.86rem"><span style="background:#fde68a;color:#7a5b00;font-size:.7rem;font-weight:800;padding:2px 8px;border-radius:9px"><%= d %>d</span> <strong><%= s.company %></strong> — expires <%= new Date(s.ins_expires).toLocaleDateString() %> <span style="color:var(--muted);font-size:.76rem">(<%= s.ins_note %>)</span></div>
      <% }) %>
      <% if (_insAll.length && !_insExp.length && !_insSoon.length) { %><div style="color:#16a34a;font-size:.86rem">✓ Nothing expired or expiring in the next 90 days.</div><% } %>
    </div>
    <% if (canEdit) { %>
    <div style="margin-top:.8rem;display:flex;align-items:center;gap:.7rem">
      <button type="button" class="btn btn-ghost btn-sm" id="insScanBtn" onclick="insScanAll()">🔍 Scan emailed COIs now</button>
      <span style="font-size:.74rem;color:var(--muted)">Reads every insurance certificate in the email log (OCR for scans) and pulls the next expiration. Also re-runs automatically every Sunday.</span>
    </div>
    <% } %>
  </details>
  <% } %>

  <div class="subs-toolbar">
    <input type="search" id="subSearch" placeholder="Search name, trade, phone…" oninput="filterSubs()">
    <select id="typeFilter" onchange="filterSubs()" class="trade-select"><option value="">All trades</option></select>
    <select id="statusFilter" onchange="filterSubs()" class="trade-select">
      <option value="">All statuses</option>
      <option value="under review">Under Review</option>
      <option value="called">Called</option>
      <option value="bid requested">Bid Requested</option>
      <option value="bid under review">Bid Under Review</option>
      <option value="approved">Approved</option>
      <option value="active">Active</option>
      <option value="inactive">Inactive</option>
      <option value="rejected">Rejected</option>
      <option value="blacklisted">Blacklisted</option>
    </select>
    <button type="button" class="btn btn-ghost btn-sm" id="mapBtn" onclick="mapToggle()">🗺 Map</button>
    <button type="button" class="btn btn-ghost btn-sm" id="covBtn" onclick="covToggle()">📊 Coverage</button>
    <% if (typeof recentCount !== 'undefined' && recentCount > 0) { %>
      <label class="recent-toggle"><input type="checkbox" id="recentOnly" onchange="filterSubs()"> 🆕 Recently added (<%= recentCount %>)</label>
      <form method="POST" action="/subs/clear-recent" style="margin:0" onsubmit="return confirm('Clear the “Recently added” tag from all <%= recentCount %>? (They stay in the list — this just removes the tag.)')">
        <button type="submit" class="btn btn-ghost btn-sm">Clear tag</button>
      </form>
    <% } %>
  </div>

  <!-- Coverage matrix: subs per TRADE per COUNTY, every cell measured against the 4-sub minimum -->
  <div class="cov-panel" id="covPanel">
    <div class="cov-head">
      <strong>Coverage</strong>
      <span class="cov-legend-inline">Target: <strong>4+ Active subs per trade in every coverage zone</strong>. Only Active subs count (no GCs, no prospects). Click a zone tile to highlight its column; click a trade name to filter the list.</span>
    </div>
    <div class="cov-areas" id="covAreas"></div>
    <div class="cov-matrix-wrap"><table class="cov-matrix" id="covMatrix"></table></div>
    <div class="cov-legend"><span class="cov-chip cov-gap" style="cursor:default">Gap · 0</span> <span class="cov-chip cov-thin" style="cursor:default">Thin · 1–3</span> <span class="cov-chip cov-ok" style="cursor:default">Covered · 4+</span></div>
  </div>

  <!-- Outreach map: a circle per service area sized by how many contractors cover it -->
  <div class="cov-panel" id="mapPanel">
    <div class="cov-head">
      <strong>Outreach map</strong>
      <label class="map-radio"><input type="radio" name="mapMode" value="gc" checked onchange="mapRender()"> Outside GCs</label>
      <label class="map-radio"><input type="radio" name="mapMode" value="sub" onchange="mapRender()"> Subs</label>
      <label class="map-radio"><input type="radio" name="mapMode" value="all" onchange="mapRender()"> Both</label>
      <select id="mapTrade" onchange="mapRender()"><option value="">All trades</option></select>
      <select id="mapStatus" onchange="mapRender()">
        <option value="">All usable</option>
        <option value="ready">Approved + Active</option>
        <option value="review">Under Review</option>
      </select>
      <span class="cov-legend-inline">Circle size = how many cover that area. Click a circle for details.</span>
    </div>
    <div id="covMapEl"></div>
    <div id="mapUnmapped" style="display:none;margin-top:.5rem;font-size:.83rem;background:#fff7e6;border:1px solid #f0d9a8;border-radius:9px;padding:.55rem .8rem;cursor:pointer" title="Click to see who's missing"></div>
  </div>

  <%
    function catOf(s) { return s.category || (/general\s*contractor|^\s*gc\b/i.test(s.type || '') ? 'gc' : 'sub'); }
    function pillClass(st) { st = (st || '').toLowerCase();
      if (/bid under review/.test(st)) return 'pill-bid';   // must beat /review/
      if (/black/.test(st)) return 'pill-black';
      if (/reject|declin/.test(st)) return 'pill-rejected';
      if (/inactive/.test(st)) return 'pill-inactive';   // must beat /active/ — "inactive" contains it
      if (/active/.test(st)) return 'pill-active';
      if (/approv/.test(st)) return 'pill-approved';
      if (/bid (sent|request)/.test(st)) return 'pill-sent';
      if (/^called$/.test(st)) return 'pill-called';
      if (/review|vetting|pending/.test(st)) return 'pill-review';
      return 'pill-default'; }
    // One pipeline: the old Bidding stages are statuses now (Bid Requested = we asked them to bid).
    const STATUS_OPTS = ['Under Review', 'Called', 'Bid Requested', 'Bid Under Review', 'Approved', 'Active', 'Inactive', 'Rejected', 'Blacklisted'];
    const LOCATION_OPTS = ['LA County', 'Orange County', 'Riverside County', 'San Diego County', 'Ventura County', 'San Bernardino County', 'The Valley'];
    const sections = [
      { title: 'Outside GCs', key: 'gc', list: subs.filter(s => catOf(s) === 'gc') },
      { title: 'Subcontractors', key: 'sub', list: subs.filter(s => catOf(s) !== 'gc') },
    ];
    // Distinct buckets you can move a sub into (preserving sheet order)
    const moveTargets = []; const _seenT = {};
    subs.forEach(s => { const cat = catOf(s), grp = s.group_label || '', k = cat + '||' + grp; if (!_seenT[k]) { _seenT[k] = 1; moveTargets.push({ cat, grp }); } });
    // Always offer Rejected + Blacklisted as drop targets, even when those buckets are empty
    [['gc', ['Bid Under Review', 'Bid Requested', 'Inactive GCs', 'Rejected GCs', 'Blacklisted Buildoly General Contractors']], ['sub', ['Bid Under Review', 'Bid Requested', 'Inactive Subcontractors', 'Rejected Subcontractors', 'Blacklisted Buildoly Sub Contractors']]].forEach(function (pair) {
      pair[1].forEach(function (grp) { const k = pair[0] + '||' + grp; if (!_seenT[k]) { _seenT[k] = 1; moveTargets.push({ cat: pair[0], grp: grp }); } });
    });
  %>

  <% if (!subs.length) { %>
    <div class="card" style="color:var(--muted)">No subcontractors yet. Click <strong>Import from Sheet</strong> or <strong>+ Add</strong>.</div>
  <% } %>

  <% sections.forEach(sec => { %>
    <div class="sub-section" data-section>
      <div class="sec-title sec-<%= sec.key %>"><%= sec.title %> <span class="cnt">(<%= sec.list.length %>)</span></div>
      <% if (sec.list.length) { %>
      <div style="display:flex;align-items:center;gap:.5rem;margin:.1rem 0 .7rem;flex-wrap:wrap">
        <span style="font-size:.82rem;color:var(--muted)">Vetting:</span>
        <% var vetOpts = [...new Set(sec.list.map(s => s.status).filter(Boolean))].sort(); %>
        <select id="vetFilter_<%= sec.key %>" class="vetsel" onchange="filterSubs()">
          <option value="">All</option>
          <% vetOpts.forEach(v => { %><option value="<%= v %>"><%= v %></option><% }) %>
        </select>
        <span style="font-size:.82rem;color:var(--muted);margin-left:.7rem">Group by:</span>
        <span id="sortbtns_<%= sec.key %>">
          <button type="button" class="sortbtn on" data-sort="status" onclick="setGroupBy('<%= sec.key %>','status')">Status</button>
          <button type="button" class="sortbtn" data-sort="trade" onclick="setGroupBy('<%= sec.key %>','trade')">Trade</button>
        </span>
      </div>
      <% } %>
      <% if (!sec.list.length) { %>
        <div style="color:var(--muted);font-size:.85rem">None.</div>
      <% } else { %>
      <div class="tbl-wrap">
        <table class="subs-table">
          <thead><tr>
            <th></th><th>Company</th><th>Location</th><th>Type</th><th>Status / Bid</th><th>License</th><th>Contact</th><th>Notes</th><th></th>
          </tr></thead>
          <tbody id="tbody_<%= sec.key %>">
            <%
              const byTrade = false;   // initial render is by status; the Group-by toggle re-groups client-side (no reload)
              const keyOf = x => byTrade ? ((x.type || '').split(',')[0].trim() || 'Other') : (x.group_label || '');
              const groups = []; const gmap = {};
              sec.list.forEach(x => { const g = keyOf(x); if (!(g in gmap)) { gmap[g] = []; groups.push(g); } gmap[g].push(x); });
              if (byTrade) groups.sort((a, b) => a.localeCompare(b));
              // Pipeline order: Bid Under Review on top, then Bid Requested; Inactive sinks to the bottom
              if (!byTrade) {
                ['Bid Requested', 'Bid Under Review'].forEach(function (top) {
                  const i = groups.indexOf(top); if (i > 0) { groups.splice(i, 1); groups.unshift(top); }
                });
                const ig = sec.key === 'gc' ? 'Inactive GCs' : 'Inactive Subcontractors';
                const ii = groups.indexOf(ig); if (ii >= 0) { groups.splice(ii, 1); groups.push(ig); }
              }
              // Always show a Rejected (and Blacklisted) drop zone for this section, even if empty
              if (!byTrade) {
                (sec.key === 'gc' ? ['Rejected GCs', 'Blacklisted Buildoly General Contractors'] : ['Rejected Subcontractors', 'Blacklisted Buildoly Sub Contractors'])
                  .forEach(b => { if (!(b in gmap)) { gmap[b] = []; groups.push(b); } });
              }
            %>
            <% groups.forEach(g => { %>
              <% if (g) { %><tr class="subhdr" data-cat="<%= sec.key %>" data-grp="<%= g %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)"><td colspan="9"><%= g %></td></tr><% } %>
              <% if (g && !gmap[g].length) { %><tr class="emptybucket" data-cat="<%= sec.key %>" data-grp="<%= g %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)"><td colspan="9" class="emptybucket-cell">⤵ Drag a contractor here to mark them <%= /black/i.test(g) ? 'Blacklisted' : /inactive/i.test(g) ? 'Inactive' : 'Rejected' %></td></tr><% } %>
              <% gmap[g].forEach(s => { var ph = photosBySub[s.id] || []; var flagged = /reject|black/.test((s.status||'').toLowerCase()); %>
              <tr class="<%= flagged ? 'flagged-row' : '' %>" data-cat="<%= catOf(s) %>" data-grp="<%= s.group_label||'' %>" data-status="<%= (s.status||'').toLowerCase() %>" data-trade="<%= (s.type||'').split(',')[0].trim() %>" data-recent="<%= s.recent_add ? '1' : '' %>" data-noemail="<%= (s.email || '').trim() ? '' : '1' %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)" data-search="<%= [s.company,s.owner,s.type,s.phone,s.email,s.location].filter(Boolean).join(' ').toLowerCase() %>" data-type="<%= (s.type||'').toLowerCase() %>">
                <td class="drag-h" draggable="true" ondragstart="onDragStart(event,'<%= s.id %>')" title="Drag to move">⠿</td>
                <td class="co"><% if (flagged) { var isBlack = /black/.test((s.status||'').toLowerCase()); %><span class="row-reason <%= isBlack ? 'black' : '' %>" data-reason="<%= s.reject_reason || '' %>"><span class="rr-name"><%= s.company || s.owner || 'Contractor' %></span><span class="rr-reason">⛔ <%= (s.status||'').toUpperCase() %><%= s.reject_reason ? ': ' + s.reject_reason : '' %></span><span class="rr-actions"><button type="button" onclick="blNote(<%= s.id %>, this)" title="Add / edit a note">✏️</button><button type="button" onclick="blReveal(this)" title="Reveal info underneath">👁</button></span></span><% } %><% if (s.recent_add) { %><span class="newdot" title="Recently added — verify">🆕</span> <% } %><a href="/subs/profile/<%= s.id %>" style="color:inherit;text-decoration:none;font-weight:inherit" title="Open <%= (s.company || s.owner || 'this contractor').replace(/"/g,'&quot;') %>'s profile — emails, bids, docs, history" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'"><%= s.company || s.owner || '—' %></a>
                  <% if (ph.length) { %><div class="thumbs"><% ph.forEach(pid => { %><span class="thumb"><a href="/sub-photo/<%= pid %>" target="_blank"><img src="/sub-photo/<%= pid %>"></a><span class="thx" onclick="delPhoto(<%= pid %>, this)" title="Remove photo">✕</span></span><% }) %></div><% } %>
                  <% if (s.notes) { %><span class="conote-btn" onclick="this.nextElementSibling.classList.toggle('show')" title="Show / hide notes">📝 notes</span><div class="conote-body"><%= s.notes %></div><% } %>
                </td>
                <td data-label="Location"><% if (flagged && s.location) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.location %></span><% } else { %><%= s.location || '' %><% } %></td>
                <td data-label="Trade"><%= s.type || '' %></td>
                <td data-label="Status">
                  <select class="spill <%= pillClass(s.status) %>" data-id="<%= s.id %>" onchange="changeStatus(this)">
                    <option value="">—</option>
                    <% STATUS_OPTS.forEach(o => { %><option value="<%= o %>" <%= s.status===o?'selected':'' %>><%= o %></option><% }) %>
                    <% if (s.status && STATUS_OPTS.indexOf(s.status) < 0) { %><option value="<%= s.status %>" selected><%= s.status %></option><% } %>
                  </select>
                  <%
                    var _bd = (typeof bidDocs !== 'undefined' && bidDocs[s.id]) || null;
                    var _bpNum = Number(String(s.bid_price || '').replace(/[^0-9.]/g, ''));
                    var _bpFmt = _bpNum ? '$' + _bpNum.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '';
                  %>
                  <div class="bidline">
                    <% if (_bpFmt) { %>
                      <span class="bidamt" onclick="editBidPrice(<%= s.id %>, this)" title="Their bid — click to edit"><%= _bpFmt %></span>
                      <% if (/awarded/i.test(s.bid_status || '')) { %><span title="Bid awarded" style="font-size:.8rem">🏆</span><% } %>
                    <% } else { %>
                      <span class="bidadd" onclick="editBidPrice(<%= s.id %>, this)" title="Add a bid price">+ $ bid</span>
                    <% } %>
                    <% if (_bd && _bd.gmail_attachment_id) {
                         var _bmime = /\.docx?$/i.test(_bd.filename || '') ? 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' : 'application/pdf'; %>
                      <a class="biddoc" href="/threads/messages/<%= _bd.gmail_message_id %>/attachment/<%= _bd.gmail_attachment_id %>?name=<%= encodeURIComponent(_bd.filename || 'estimate.pdf') %>&mime=<%= encodeURIComponent(_bmime) %>" target="_blank" rel="noopener" title="Open the bid: <%= _bd.filename || 'estimate PDF' %>">📄</a>
                    <% } else if (_bd && _bd.email_id) { %>
                      <a class="biddoc" href="/subs/emails/<%= _bd.email_id %>/html" target="_blank" rel="noopener" title="Open the bid email">✉</a>
                    <% } %>
                  </div>
                </td>
                <td data-label="License">
                  <select class="lic-sel" data-id="<%= s.id %>" onchange="saveLicense(this)">
                    <option value="" <%= s.licensed==null?'selected':'' %>>—</option>
                    <option value="true" <%= s.licensed===true?'selected':'' %>>✓ Licensed</option>
                    <option value="false" <%= s.licensed===false?'selected':'' %>>✕ Not licensed</option>
                  </select>
                  <span class="admin-actions"><button type="button" class="vbtn" onclick="verifyLic(<%= s.id %>, this)" title="Verify this license against CSLB (state license board)">🛡</button></span>
                  <input type="text" class="lic-num" data-id="<%= s.id %>" value="<%= s.license_number || '' %>" placeholder="License #" onchange="saveLicenseNum(this)" style="<%= s.licensed===true ? '' : 'display:none' %>">
                  <%
                    var _lf = []; try { _lf = JSON.parse(s.license_flags || '[]'); } catch (e) {}
                    var _worst = _lf.some(function(f){return f.level==='red';}) ? 'red' : (_lf.some(function(f){return f.level==='amber';}) ? 'amber' : (s.license_checked_at ? 'ok' : null));
                    var _tip = _lf.map(function(f){return f.text;}).join('  |  ');
                  %>
                  <% if (_worst === 'ok') { %>
                    <span class="licb licb-ok" onclick="openLicModal(<%= s.id %>)" title="Click for the full CSLB report">✓ Active<%= s.license_expire ? ' · exp ' + new Date(s.license_expire).toLocaleDateString('en-US',{month:'numeric',day:'numeric',year:'2-digit'}) : '' %></span>
                  <% } else if (_worst) { %>
                    <span class="licb licb-<%= _worst %>" onclick="openLicModal(<%= s.id %>)" title="Click to see what the issue is"><%= _worst==='red' ? '⛔' : '⚠' %> <%= (_lf.find(function(f){return f.level===_worst;})||{}).text %></span>
                    <% var _more = _lf.filter(function(f){return f.level!=='info';}).length - 1; if (_more > 0) { %><span class="licb-more" onclick="openLicModal(<%= s.id %>)">+<%= _more %> more issue<%= _more>1?'s':'' %> — click</span><% } %>
                  <% } %>
                  <% if (s.ins_expires) {
                       var _insD = Math.floor((new Date(s.ins_expires) - Date.now()) / 86400000);
                       var _insCls = _insD < 0 ? 'red' : (_insD <= 60 ? 'amber' : 'ok'); %>
                    <span class="insb insb-<%= _insCls %>" title="Insurance (from <%= s.ins_note || 'emailed COI' %> — checked <%= s.ins_checked_at ? new Date(s.ins_checked_at).toLocaleDateString() : '' %>)">🛡 ins <%= _insD < 0 ? 'EXPIRED' : 'exp' %> <%= new Date(s.ins_expires).toLocaleDateString('en-US',{month:'numeric',day:'numeric',year:'2-digit'}) %></span>
                  <% } %>
                </td>
                <td data-label="Contact" data-email="<%= s.email || '' %>"><% if (s.owner) { %><div class="c-owner"><% if (flagged && s.owner) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.owner %></span><% } else { %><%= s.owner || '' %><% } %></div><% } %><div class="c-email"><% if (s.email) { %><% if (flagged) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.email %></span><% } else { %><a href="mailto:<%= s.email %>"><%= s.email %></a><% } %> <% } %><button type="button" class="email-edit" onclick="editEmail(<%= s.id %>, this)" title="<%= s.email ? 'Edit' : 'Add' %> email">✏️</button><% var _em = (typeof emailsBySub !== 'undefined' && emailsBySub[s.id]) || []; if (_em.length) { %><span class="emlog-btn<%= s.reply_unread ? ' has-reply' : '' %>" onclick="openEmlog(this, <%= s.id %>)" title="Email history with this sub">✉ <%= _em.length %><% if (s.reply_unread) { %> <span class="reply-dot">● reply</span><% } %></span><div class="emlog-body"><div class="emlog-head"><strong>✉ <%= s.company || s.owner || 'Emails' %></strong><button type="button" class="emlog-close" onclick="closeEmlogAll()" title="Close">✕</button></div><% _em.forEach(function(e){ var _inb = e.direction === 'in'; %><div class="emlog-item<%= _inb ? ' inbound' : '' %>"><span class="emlog-date"><%= new Date(e.created_at).toLocaleDateString() %></span><% if (_inb) { %><span class="emlog-tag">↩ reply</span><% } %><strong><%= e.subject %></strong><% if (e.has_html) { %><a class="emlog-view" href="/subs/emails/<%= e.id %>/html" target="_blank" rel="noopener" title="Open in its own tab">🗖</a><iframe class="emlog-frame" data-src="/subs/emails/<%= e.id %>/html?embed=1" sandbox="allow-same-origin allow-popups" loading="lazy" title="<%= e.subject %>"></iframe><% } else if (e.body) { %><div class="emlog-text"><%= e.body %></div><% } %><% var _att = (typeof attByEmail !== 'undefined' && attByEmail[e.id]) || []; if (_att.length) { %><div class="emlog-atts"><% _att.forEach(function(a){ %><% var _isImg = /^image\//i.test(a.mime || '') || /\.(png|jpe?g|gif|webp|heic)$/i.test(a.filename || ''); var _aurl = '/threads/messages/' + a.gmail_message_id + '/attachment/' + a.gmail_attachment_id + '?name=' + encodeURIComponent(a.filename || 'file') + '&mime=' + encodeURIComponent(a.mime || ''); %><% if (_isImg) { %><a class="emlog-att emlog-attimg" href="<%= _aurl %>" target="_blank" rel="noopener" title="<%= a.filename || 'image' %> - click to open full size"><img src="<%= _aurl %>" alt="" loading="lazy"></a><% } else { %><a class="emlog-att" href="<%= _aurl %>" target="_blank" rel="noopener" title="Open / download attachment">&#128206; <%= a.filename || 'attachment' %></a><% } %><% }) %></div><% } %></div><% }) %><% if (canEdit) { %><div class="emlog-reply"><select class="emlog-fu" data-name="<%= s.company || s.owner || '' %>" onchange="applyFollowup(this)"><option value="">Follow-up templates...</option><option value="checkin">Quick check-in</option><option value="docs">Missing docs reminder</option><option value="deadline">Proposal deadline nudge</option><option value="final">Final follow-up</option></select><textarea class="emlog-reply-text" rows="2" placeholder="Reply to this sub…"></textarea><button type="button" class="emlog-reply-btn" onclick="sendSubReply(this, <%= s.id %>)">Send reply</button><span class="emlog-reply-hint">✓ Your email signature is added automatically</span></div><% } %></div><% } %></div><% if (s.phone) { %><div class="c-phone"><% if (s.phone) { %><% if (flagged) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.phone %></span><% } else { %><a href="tel:<%= s.phone.replace(/[^0-9+]/g,'') %>"><%= s.phone %></a><% } %><% } %></div><% } %></td>
                <td class="notes" data-label="Notes"><% if (s.referenced_by) { %><div class="refby-line">Ref: <%= s.referenced_by %></div><% } %><% if (flagged && s.reject_reason) { %><div class="reject-reason">⛔ <%= s.status %>: <%= s.reject_reason %></div><% } %><% if (s.notes) { %><div class="note-clip" onclick="this.classList.toggle('open')" title="Click to expand / collapse"><%= s.notes %></div><% } %></td>
                <td class="row-actions">
                  <select class="moveSel" data-id="<%= s.id %>" onchange="changeMove(this)" title="Move to another section / group">
                    <option value="">Move…</option>
                    <optgroup label="Outside GCs">
                      <% moveTargets.filter(t => t.cat === 'gc').forEach(t => { %><option value="gc||<%= t.grp %>"><%= t.grp || '(no group)' %></option><% }) %>
                    </optgroup>
                    <optgroup label="Subcontractors">
                      <% moveTargets.filter(t => t.cat !== 'gc').forEach(t => { %><option value="sub||<%= t.grp %>"><%= t.grp || '(no group)' %></option><% }) %>
                    </optgroup>
                  </select>
                  <button onclick='openEdit(<%- JSON.stringify(s) %>, <%- JSON.stringify(photosBySub[s.id] || []) %>)' title="Edit">✏</button><button class="js-compose" data-id="<%= s.id %>" data-email="<%= s.email || '' %>" data-name="<%= s.company || s.owner || '' %>" data-trade="<%= (s.type || '').split(',')[0].trim() %>" onclick="openCompose(this)" title="Email this sub"<%= s.email ? '' : ' disabled' %>>✉</button>
                  <form method="POST" action="/subs/<%= s.id %>/photo" enctype="multipart/form-data" style="margin:0;display:inline">
                    <label class="upl" title="Add photos (pick several at once — work, vehicle, job site)">📷<input type="file" name="photos" accept="image/*" multiple style="display:none" onchange="this.form.submit()"></label>
                  </form>
                  <form method="POST" action="/subs/<%= s.id %>/delete" style="margin:0;display:inline" onsubmit="return confirm('Delete this subcontractor?')">
                    <button type="submit" class="del" title="Delete">🗑</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  <% }) %>
  </div><!-- /mainPanel -->
</div>

<!-- Email subcontractor modal -->
<div class="modal-bk" id="emailModal">
  <div class="modal-card">
    <h2>✉ Email subcontractor</h2>
    <div style="font-size:.85rem;color:var(--muted);margin-bottom:.7rem">To: <span id="emTo" style="font-weight:700;color:var(--text)"></span></div>
    <form id="emForm" onsubmit="event.preventDefault();sendCompose()">
      <div class="form-group" style="margin-bottom:.7rem"><label>Template</label>
        <select id="emTemplate" onchange="applyTemplate(this)">
          <option value="">— blank —</option>
          <option value="generic">Generic outreach</option>
          <option value="altadena">Met in person (Altadena)</option>
          <option value="marvin">Referred by Marvin Han</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:.7rem"><label>Subject</label><input type="text" id="emSubject" required></div>
      <div class="form-group" style="margin-bottom:.7rem"><label>Proposal due date <span style="font-weight:400;color:var(--muted)">(sets the deadline in the email)</span></label><input type="date" id="emDeadline" onchange="updateDeadline(this)"></div>
      <div class="form-group" style="margin-bottom:.7rem"><label>Message</label><textarea id="emBody" rows="8" placeholder="Write your message…"></textarea></div>
      <div class="form-group" style="margin-bottom:.7rem"><label>Plans link — Google Drive CD set <span style="font-weight:400;color:var(--muted)">(saved & auto-filled next time)</span></label><input type="url" id="emPlans" placeholder="https://drive.google.com/…"></div>
      <div style="display:flex;gap:.6rem;justify-content:flex-end">
        <button type="button" class="btn btn-ghost" onclick="closeEmail()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="emSendBtn">Send email</button>
      </div>
    </form>
    <div style="font-size:.74rem;color:var(--muted);margin-top:.7rem">Sends from your Buildoly Gmail and saves a copy under this sub.</div>
  </div>
</div>

<!-- Add / Edit modal -->
<div class="modal-bk" id="subModal">
  <div class="modal-card">
    <h2 id="modalTitle">Add Subcontractor</h2>
    <form id="subForm" method="POST" action="/subs" enctype="multipart/form-data">
      <input type="hidden" id="editId" value="">
      <div class="mg"><label>Adding to which list?</label>
        <div class="seg" id="catSeg">
          <button type="button" class="segbtn" data-cat="gc" onclick="setCat('gc')">🏗️ Outside GC</button>
          <button type="button" class="segbtn on" data-cat="sub" onclick="setCat('sub')">🔧 Subcontractor</button>
        </div>
        <input type="hidden" name="category" id="f_category" value="sub">
      </div>
      <div class="mg"><label>Company</label><input name="company" id="f_company" placeholder="e.g. Pyramid Drywall"></div>
      <div class="mg"><label>Contact / Owner</label><input name="owner" id="f_owner"></div>
      <div class="mg"><label>Trade / Type <span style="font-weight:400;color:var(--muted)">— tap all that apply</span></label>
        <div id="tradeChips" class="trade-chips"></div>
        <div style="display:flex;gap:.4rem;margin-top:.45rem">
          <input id="tradeOther" placeholder="Add another trade…" style="flex:1;padding:.45rem .6rem;border:1px solid var(--border);border-radius:8px;background:var(--bg);font-size:.88rem" onkeydown="if(event.key==='Enter'){event.preventDefault();addTradeOther();}">
          <button type="button" class="btn btn-ghost btn-sm" onclick="addTradeOther()">Add</button>
        </div>
        <input type="hidden" name="type" id="f_type">
      </div>
      <div class="mg2">
        <div class="mg"><label>Phone</label><input name="phone" id="f_phone"></div>
        <div class="mg"><label>Email</label><input name="email" id="f_email"></div>
      </div>
      <div class="mg"><label>Status</label>
        <select name="status" id="f_status">
          <option value="">—</option>

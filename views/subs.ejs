function mapMode() { const r = document.querySelector('input[name=mapMode]:checked'); return r ? r.value : 'gc'; }
function mapRender() {
  if (!covMap) return;
  // Populate the trade dropdown once (TRADES is the canonical list)
  const tsel = document.getElementById('mapTrade');
  if (tsel && tsel.options.length <= 1) TRADES.forEach(function (t) { const o = document.createElement('option'); o.value = t; o.textContent = t; tsel.appendChild(o); });
  const mtrade = tsel ? tsel.value : '';
  const mstat = (document.getElementById('mapStatus') || {}).value || '';

// Default proposal deadline = one week out (yyyy-mm-dd for the date input).
function defaultDeadline() {
  const d = new Date(); d.setDate(d.getDate() + 7);
  return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
}
// Turn a yyyy-mm-dd value into "July 1, 2026" (no timezone shifts).
function formatDeadline(iso) {
  const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(iso || '');
  if (!m) return '[due date]';
  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  return months[+m[2] - 1] + ' ' + (+m[3]) + ', ' + m[1];
}
// When the date changes, remember it and update the deadline already in the email body.
function updateDeadline(inp) {
  if (inp.value) localStorage.setItem('subDeadline', inp.value); else localStorage.removeItem('subDeadline');
  const body = document.getElementById('emBody');
  if (body && body.value) body.value = body.value.replace(/proposal by [^.\n]+/i, 'proposal by ' + formatDeadline(inp.value));
}
function applyTemplate(sel) {
  const key = sel.value;
  if (!key || !EMAIL_TEMPLATES[key]) return;
  const name = composeName || '[Subcontractor Name]';
  const trade = composeTrade || '[trade]';
  const areas = AREA_LIST.map(function (a) { return '     • ' + a; }).join('\n');
  document.getElementById('emSubject').value = EMAIL_SUBJECT;
  document.getElementById('emBody').value = EMAIL_TEMPLATES[key]
    .split('{NAME}').join(name).split('{TRADE}').join(trade).split('{AREAS}').join(areas)
    .split('{DEADLINE}').join(formatDeadline(document.getElementById('emDeadline').value));
}

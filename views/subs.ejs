// 📇 Guided business-card scan: step 1 FRONT photo, step 2 BACK photo, then both
// get OCR'd together and the Add form opens prefilled with both photos attached.
let csFiles = { front: null, back: null };
function openCardScan() {
  csFiles = { front: null, back: null };
  csRender();
  document.getElementById('cardModal').classList.add('show');
}
function closeCardScan() { document.getElementById('cardModal').classList.remove('show'); }
function csRender() {
  const onBack = !!csFiles.front;
  document.getElementById('csTitle').textContent = '📇 Scan card — step ' + (onBack ? '2' : '1') + ' of 2';
  document.getElementById('csHint').innerHTML = onBack ? 'Now flip it over — photo of the <strong>BACK</strong>. Or read the card with just the front.' : 'Take a photo of the <strong>FRONT</strong> of the card.';
  document.getElementById('csTakeTxt').textContent = onBack ? '📸 Take photo of the BACK' : '📸 Take photo of the FRONT';
  ['Front', 'Back'].forEach(function (side) {
    const f = csFiles[side.toLowerCase()];
    const img = document.getElementById('csImg' + side);
    const slot = document.getElementById('csSlot' + side);
    if (f) { img.src = URL.createObjectURL(f); img.style.display = 'block'; slot.classList.add('done'); }
    else { img.style.display = 'none'; slot.classList.remove('done'); }
  });
  document.getElementById('csSkipBtn').style.display = onBack ? '' : 'none';
}
function csTook(input) {
  const f = input.files && input.files[0];
  input.value = '';
  if (!f) return;
  if (!csFiles.front) { csFiles.front = f; csRender(); }
  else { csFiles.back = f; csRender(); csProcess(); }   // both sides in → read the card
}
async function csProcess() {
  const files = [csFiles.front, csFiles.back].filter(Boolean);
  if (!files.length) return;
  document.getElementById('csTakeTxt').textContent = '⏳ Reading card…';
  try {
    const fd = new FormData();
    files.forEach(function (f) { fd.append('card', f); });
    const r = await fetch('/subs/card/scan', { method: 'POST', body: fd });
    const d = await r.json();
    if (!d.ok) { alert(d.error || 'Could not read the card'); csRender(); return; }
    closeCardScan();
    openAdd();
    const fill = function (id, v) { const el = document.getElementById(id); if (el && v && !el.value.trim()) el.value = v; };
    fill('f_company', d.company);
    fill('f_owner', d.owner);
    fill('f_email', d.email);
    fill('f_phone', d.phone);
    if (d.trade && typeof setTradesFromString === 'function' && !document.getElementById('f_type').value.trim()) setTradesFromString(d.trade);
    if (d.license_number) {
      const n = document.getElementById('f_notes');
      if (n && !n.value.includes(d.license_number)) n.value = ('Lic #' + d.license_number + (n.value ? '\n' + n.value : ''));
    }
    // Both card photos ride along with the form and save onto the new contractor
    const pi = document.getElementById('modalPhotoInput');
    if (pi) {
      try {
        const dt = new DataTransfer();
        files.forEach(function (f) { dt.items.add(f); });
        pi.files = dt.files;
        if (typeof onPhotoInput === 'function') onPhotoInput();
      } catch (e) { /* older browser — photos can be added after saving */ }
    }
  } catch (e) { alert('Could not read the card — try again'); csRender(); }
}

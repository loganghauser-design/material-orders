      span.className = 'emlog-btn'; span.title = 'Email history with this sub'; span.textContent = '✉ 1 ';
      span.setAttribute('onclick', 'openEmlog(this, ' + id + ')');
      const bodyDiv = document.createElement('div'); bodyDiv.className = 'emlog-body';
      const item = document.createElement('div'); item.className = 'emlog-item';
      const d = document.createElement('span'); d.className = 'emlog-date'; d.textContent = new Date().toLocaleDateString();
      const st = document.createElement('strong'); st.textContent = subject || '';
      item.appendChild(d); item.appendChild(st); bodyDiv.appendChild(item);
      cell.appendChild(span); cell.appendChild(bodyDiv);
    }
  }
}
function showToast(msg) {
  let t = document.getElementById('subToast');
  if (!t) {
    t = document.createElement('div'); t.id = 'subToast';
    t.style.cssText = 'position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:#1a6b1a;color:#fff;padding:10px 18px;border-radius:10px;font-weight:700;font-size:.9rem;box-shadow:0 4px 18px rgba(0,0,0,.25);z-index:9999;opacity:0;transition:opacity .2s';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  requestAnimationFrame(function () { t.style.opacity = '1'; });
  clearTimeout(t._h); t._h = setTimeout(function () { t.style.opacity = '0'; }, 2200);
}
// Ready-made follow-up emails for the reply box. {NAME} = the sub's company/owner.
// The reply sends in-thread ("Re: ADU BID REQUEST BUILDOLY") and your signature is
// appended automatically, so these end at the last sentence.
const FOLLOWUP_TEMPLATES = {
  checkin: `Hi {NAME},

I wanted to follow up on the bid request I sent over for our upcoming ADU project. Have you had a chance to review it?

If you have any questions about the scope or need anything else from us to put a proposal together, just let me know.`,
  docs: `Hi {NAME},

Thanks again for your interest in working with Buildoly. To get you set up in our subcontractor network, we still need the following:

- Contractor license number
- Proof of workers' compensation insurance
- General liability insurance (COI)
- Service areas you cover

Once we have these on file, we can include you in our upcoming bid rounds.`,
  deadline: `Hi {NAME},

Just a quick reminder that we're finalizing proposals for our current project soon, and we'd love to have yours in before we make decisions.

If you're still interested, please send over your bid at your earliest convenience. If you need a little more time or have any questions, let me know.`,
  final: `Hi {NAME},

I haven't heard back on the bid request I sent over, so this will be my last follow-up for now.

If you're still interested in working on Resi + ADU projects with Buildoly, just reply here and I'll get you into our next round of bids. Either way, we'd be glad to keep you in our network for future opportunities.`,
};
function applyFollowup(sel) {
  const key = sel.value;
  if (!key || !FOLLOWUP_TEMPLATES[key]) return;
  const name = sel.dataset.name || '[Subcontractor Name]';
  const ta = sel.closest('.emlog-reply').querySelector('.emlog-reply-text');
  ta.value = FOLLOWUP_TEMPLATES[key].split('{NAME}').join(name);
  ta.rows = 9;   // expand so the drafted follow-up is easy to review/edit
  ta.focus();
}
async function sendSubReply(btn, id) {
  const bodyWrap = btn.closest('.emlog-body');
  const ta = btn.closest('.emlog-reply').querySelector('.emlog-reply-text');
  const body = ta.value.trim();
  if (!body) { ta.focus(); return; }
  btn.disabled = true; btn.textContent = 'Sending…';
  try {
    const r = await fetch('/subs/' + id + '/reply', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ body }) });
    const data = await r.json();
    if (data.ok) {
      ta.value = '';
      ta.rows = 2;
      const fu = btn.closest('.emlog-reply').querySelector('.emlog-fu');
      if (fu) fu.value = '';
      // Show the sent reply at the top of the log (newest-first), no reload.
      const item = document.createElement('div'); item.className = 'emlog-item';
      const d = document.createElement('span'); d.className = 'emlog-date'; d.textContent = new Date().toLocaleDateString();
      const st = document.createElement('strong'); st.textContent = data.subject || 'Re:';
      const tx = document.createElement('div'); tx.className = 'emlog-text'; tx.textContent = body;
      item.appendChild(d); item.appendChild(st); item.appendChild(tx);
      bodyWrap.insertBefore(item, bodyWrap.firstChild);
      const row = btn.closest('tr');
      const badge = row ? row.querySelector('.emlog-btn') : null;
      if (badge && badge.firstChild && badge.firstChild.nodeType === 3) {
        const m = badge.textContent.match(/\d+/); const n = (m ? parseInt(m[0], 10) : 0) + 1;
        badge.firstChild.textContent = '✉ ' + n + ' ';
      }
      showToast('✓ Reply sent');
    } else { alert(data.error || 'Reply failed'); }
  } catch (e) { alert('Reply failed'); }
  btn.disabled = false; btn.textContent = 'Send reply';
}
document.getElementById('emailModal').addEventListener('click', e => { if (e.target.id === 'emailModal') closeEmail(); });
document.getElementById('subForm').addEventListener('submit', async function (e) {
  const id = document.getElementById('editId').value;
  if (!id) return;
  e.preventDefault();
  const body = new URLSearchParams();
  ['company','owner','type','phone','email','location','status','notes','category','referenced_by'].forEach(k => body.set(k, document.getElementById('f_' + k).value));
  document.getElementById('saveBtn').textContent = 'Saving…';
  const r = await fetch('/subs/' + id, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
  if (r.ok) reloadKeepScroll(); else { alert('Could not save'); document.getElementById('saveBtn').textContent = 'Save'; }
});
document.getElementById('subModal').addEventListener('click', e => { if (e.target.id === 'subModal') closeModal(); });
</script>

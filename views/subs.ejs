<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subcontractors — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .subs-toolbar { display:flex; gap:.6rem; flex-wrap:wrap; align-items:center; margin-bottom:1rem; }
    .subs-toolbar input[type=search], .subs-toolbar select { padding:.5rem .7rem; border:1px solid var(--border); border-radius:9px; background:var(--surface); font-size:.9rem; }
    .subs-toolbar input[type=search] { min-width:240px; flex:1; }
    .recent-toggle { display:inline-flex; align-items:center; gap:.4rem; font-size:.88rem; font-weight:700; color:#16794a; background:#e3f6ec; border:1px solid #9fdcb8; border-radius:9px; padding:.45rem .7rem; cursor:pointer; white-space:nowrap; }
    .recent-toggle input { width:17px; height:17px; accent-color:#16794a; }
    .newdot { font-size:.85rem; }
    .blurred { filter: blur(4.5px); user-select:none; cursor:pointer; transition:filter .12s; }
    .blurred:hover, .blurred.show { filter:none; }
    .reject-reason { color:#b4231f; font-weight:700; font-size:.78rem; background:#fde8e7; border:1px solid #f3b5b2; border-radius:6px; padding:.2rem .45rem; display:inline-block; margin-bottom:.25rem; }
    .flagged-row { position:relative; }
    .row-reason { position:absolute; inset:0; z-index:6; display:flex; align-items:center; justify-content:center; gap:.45rem; padding:.2rem 1.1rem; background:rgba(192,57,43,.92); color:#fff; font-weight:800; font-size:.9rem; line-height:1.25; text-align:center; cursor:pointer; border-radius:6px; }
    .row-reason.off { display:none; }
    .sec-title { font-size:1.6rem; font-weight:800; margin:2.4rem 0 .6rem; padding:.7rem 1rem; border-radius:9px; display:flex; align-items:center; gap:.6rem; }
    .sec-title .cnt { font-weight:600; font-size:1.05rem; opacity:.7; }
    .sec-gc { background:#fce5cd; color:#7a4a16; }
    .sec-sub { background:#ead1dc; color:#7a2c52; }
    .sub-section:first-of-type .sec-title { margin-top:.4rem; }
    .tbl-wrap { overflow-x:auto; border:1px solid var(--border); border-radius:10px; }
    .subs-table { width:100%; border-collapse:collapse; font-size:.85rem; }
    .subs-table th { text-align:left; font-size:.68rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); padding:.55rem .7rem; border-bottom:2px solid var(--border); white-space:nowrap; background:var(--bg); position:sticky; top:0; }
    .subs-table td { padding:.55rem .7rem; border-bottom:1px solid var(--border); vertical-align:top; }
    .subs-table tr:last-child td { border-bottom:none; }
    .subs-table tbody tr:hover td { background:var(--bg); }
    .subs-table tr.subhdr td { background:#dededf; color:#1a1a1a; font-size:1.15rem; font-weight:800; padding:.6rem .8rem; border-top:2px solid #cfcfd2; }
    .subs-table tr.subhdr:hover td { background:#dededf; }
    .spill { display:inline-block; padding:3px 12px; border-radius:13px; font-size:.78rem; font-weight:700; white-space:nowrap; }
    select.spill { border:1px solid rgba(0,0,0,.15); cursor:pointer; padding:3px 6px; }
    .pill-review { background:#ffe599; color:#7f6000; }
    .pill-approved { background:#b6d7a8; color:#274e13; }
    .pill-active { background:#38761d; color:#fff; }
    .pill-rejected { background:#e06666; color:#fff; }
    .pill-black { background:#111; color:#fff; }
    .pill-default { background:#e6e6e6; color:#555; }
    .subs-table a { color:#1d4ed8; text-decoration:none; white-space:nowrap; }
    .subs-table .co { font-weight:600; }
    .subs-table .notes { color:var(--muted); max-width:260px; }
    .note-clip { display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; cursor:pointer; }
    .note-clip.open { -webkit-line-clamp:unset; line-clamp:unset; overflow:visible; }
    .thumbs { display:flex; gap:.3rem; margin-top:.3rem; flex-wrap:wrap; }
    .thumb { position:relative; display:inline-block; }
    .thumbs img { width:46px; height:46px; object-fit:cover; border-radius:6px; border:1px solid var(--border); display:block; }
    .thx { position:absolute; top:-6px; right:-6px; width:17px; height:17px; line-height:15px; text-align:center; font-size:.7rem; background:#cc2222; color:#fff; border-radius:50%; cursor:pointer; border:1.5px solid var(--surface); }
    #modalPhotos .thumbs, #modalPhotos { gap:.4rem; }
    #modalPhotos img { width:60px; height:60px; }
    .addphotos { display:inline-flex; align-items:center; gap:.4rem; padding:.55rem 1rem; border:1.5px dashed var(--border); border-radius:9px; cursor:pointer; font-size:.92rem; font-weight:600; background:var(--bg); }
    .addphotos:hover { border-color:#111; }

    /* ── Phone: stack each contractor into a readable card ── */
    @media (max-width: 760px) {
      .subs-toolbar { flex-wrap:wrap; }
      .subs-toolbar input[type="search"] { flex:1 1 100%; }
      .tbl-wrap { overflow-x:visible; }
      .subs-table { border:none; }
      .subs-table thead { display:none; }
      .subs-table, .subs-table tbody { display:block; width:100%; }
      .subs-table tr.subhdr { display:block; margin:1.1rem 0 .5rem; }
      .subs-table tr.subhdr td { display:block; padding:.4rem .2rem; }
      .subs-table tr:not(.subhdr) { display:block; border:1px solid var(--border); border-radius:13px; padding:.8rem .95rem; margin:0 0 .8rem; background:var(--surface); box-shadow:0 1px 4px rgba(0,0,0,.04); }
      .subs-table tr:not(.subhdr) td { display:block; border:none; padding:.14rem 0; font-size:.95rem; }
      .subs-table .drag-h { display:none; }
      .subs-table .co { font-size:1.15rem; font-weight:800; margin-bottom:.2rem; }
      .subs-table td[data-label]:not(:empty)::before { content:attr(data-label) ": "; font-weight:700; color:var(--muted); font-size:.76rem; text-transform:uppercase; letter-spacing:.03em; }
      .subs-table .notes { white-space:normal; }
      .subs-table .note-clip { -webkit-line-clamp:unset; max-height:none; }
      .subs-table .spill { font-size:1rem; padding:.4rem .6rem; }
      .subs-table .row-actions { display:flex; flex-wrap:wrap; align-items:center; gap:.7rem; margin-top:.7rem; padding-top:.6rem; border-top:1px dashed var(--border); }
      .subs-table .moveSel { max-width:60%; font-size:.85rem; }
      .subs-table .row-actions button, .subs-table .row-actions label.upl { font-size:1.25rem; padding:.45rem .7rem; }
      .thumbs img { width:64px; height:64px; }
      .modal-card { width:96vw; max-width:96vw; max-height:92vh; overflow-y:auto; }
    }
    .row-actions { white-space:nowrap; }
    .row-actions button, .row-actions label.upl { font-size:.85rem; padding:.2rem .4rem; border:1px solid var(--border); background:var(--surface); border-radius:6px; cursor:pointer; line-height:1; }
    .moveSel { font-size:.74rem; padding:.2rem .3rem; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; max-width:130px; }
    .drag-h { cursor:grab; color:var(--muted); text-align:center; user-select:none; font-size:1.05rem; width:24px; }
    .drag-h:active { cursor:grabbing; }
    .subs-table tr.drop-hi > td { background:#dbeafe !important; box-shadow:inset 0 2px 0 #4f8ef7; }
    /* read-only super view: hide all the editing controls */
    .super-view .admin-actions { display:none; }
    .super-view .subs-table th:first-child, .super-view .subs-table td.drag-h { display:none; }
    .super-view .subs-table th:last-child, .super-view .subs-table td.row-actions { display:none; }
    .super-view select.spill { pointer-events:none; -webkit-appearance:none; appearance:none; padding:3px 12px; }
    .row-actions .del { color:var(--danger); border-color:rgba(204,34,34,.3); }
    .modal-bk { position:fixed; inset:0; background:rgba(0,0,0,.5); display:none; align-items:flex-start; justify-content:center; z-index:50; padding:2rem 1rem; overflow:auto; }
    .modal-bk.show { display:flex; }
    .modal-card { background:var(--surface); border-radius:14px; padding:1.3rem; width:100%; max-width:520px; }
    .modal-card h2 { font-size:1.15rem; margin:0 0 1rem; }
    .mg { margin-bottom:.7rem; } .mg label { display:block; font-size:.8rem; font-weight:600; margin-bottom:.25rem; }
    .mg input, .mg textarea, .mg select { width:100%; padding:.5rem .6rem; border:1px solid var(--border); border-radius:8px; background:var(--bg); font-size:.92rem; }
    .mg2 { display:grid; grid-template-columns:1fr 1fr; gap:.7rem; }
    .trade-chips { display:flex; flex-wrap:wrap; gap:.4rem; }
    .trade-chip { padding:.32rem .7rem; border:1px solid var(--border); border-radius:16px; font-size:.82rem; cursor:pointer; user-select:none; background:var(--bg); white-space:nowrap; }
    .trade-chip.on { background:#111; color:#fff; border-color:#111; }
    .sortbtn { font:inherit; font-size:.82rem; padding:.32rem .8rem; border:1px solid var(--border); border-radius:8px; text-decoration:none; color:var(--text); background:var(--surface); cursor:pointer; }
    .sortbtn.on { background:#111; color:#fff; border-color:#111; }
    .vetsel { font-size:.82rem; padding:.3rem .5rem; border:1px solid var(--border); border-radius:8px; background:var(--surface); }
    .seg { display:flex; gap:.5rem; }
    .segbtn { flex:1; font:inherit; font-size:.95rem; font-weight:700; padding:.6rem; border:2px solid var(--border); border-radius:10px; background:var(--bg); color:var(--text); cursor:pointer; }
    .segbtn.on { background:#111; color:#fff; border-color:#111; }
    .subs-table .refby { color:var(--muted); font-size:.8rem; max-width:160px; }
  </style>
</head>
<body class="<%= (isSuper && !(typeof canEdit !== 'undefined' && canEdit)) ? 'super-view' : '' %>">
<%- include('_nav', { active: 'subs' }) %>

<div class="container">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.6rem">
    <h1>Subcontractors <span style="color:var(--muted);font-weight:400;font-size:1rem">(<%= subs.length %>)</span></h1>
    <div class="admin-actions" style="display:flex;gap:.5rem;flex-wrap:wrap">
      <button class="btn btn-primary" onclick="openAdd()">+ Add</button>
      <form method="POST" action="/subs/import" style="margin:0" onsubmit="this.querySelector('button').textContent='Importing…'">
        <button type="submit" class="btn btn-ghost" title="Pull any new companies from the GC & Sub Database Google Sheet">↻ Import from Sheet</button>
      </form>
    </div>
  </div>

  <% if (typeof imported !== 'undefined' && imported !== undefined) { %>
    <div class="card" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a;font-weight:600;margin-bottom:1rem">✓ Imported <%= imported %> new subcontractor(s) from the sheet.</div>
  <% } %>
  <% if (typeof added !== 'undefined' && added) { %>
    <div class="card" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a;font-weight:600;margin-bottom:1rem">✓ Subcontractor added.</div>
  <% } %>

  <div class="subs-toolbar">
    <input type="search" id="subSearch" placeholder="Search name, trade, phone…" oninput="filterSubs()">
    <select id="typeFilter" onchange="filterSubs()"><option value="">All trades</option></select>
    <% if (typeof recentCount !== 'undefined' && recentCount > 0) { %>
      <label class="recent-toggle"><input type="checkbox" id="recentOnly" onchange="filterSubs()"> 🆕 Recently added (<%= recentCount %>)</label>
      <form method="POST" action="/subs/clear-recent" style="margin:0" onsubmit="return confirm('Clear the “Recently added” tag from all <%= recentCount %>? (They stay in the list — this just removes the tag.)')">
        <button type="submit" class="btn btn-ghost btn-sm">Clear tag</button>
      </form>
    <% } %>
  </div>

  <%
    function catOf(s) { return s.category || (/general\s*contractor|^\s*gc\b/i.test(s.type || '') ? 'gc' : 'sub'); }
    function pillClass(st) { st = (st || '').toLowerCase();
      if (/black/.test(st)) return 'pill-black';
      if (/reject|declin/.test(st)) return 'pill-rejected';
      if (/active/.test(st)) return 'pill-active';
      if (/approv/.test(st)) return 'pill-approved';
      if (/review|vetting|pending/.test(st)) return 'pill-review';
      return 'pill-default'; }
    const STATUS_OPTS = ['Under Review', 'Approved', 'Active', 'Rejected', 'Blacklisted'];
    const LOCATION_OPTS = ['LA County', 'Orange County', 'Riverside County', 'San Diego County', 'Ventura County', 'San Bernardino County'];
    const sections = [
      { title: 'Outside GCs', key: 'gc', list: subs.filter(s => catOf(s) === 'gc') },
      { title: 'Subcontractors', key: 'sub', list: subs.filter(s => catOf(s) !== 'gc') },
    ];
    // Distinct buckets you can move a sub into (preserving sheet order)
    const moveTargets = []; const _seenT = {};
    subs.forEach(s => { const cat = catOf(s), grp = s.group_label || '', k = cat + '||' + grp; if (!_seenT[k]) { _seenT[k] = 1; moveTargets.push({ cat, grp }); } });
  %>

  <% if (!subs.length) { %>
    <div class="card" style="color:var(--muted)">No subcontractors yet. Click <strong>Import from Sheet</strong> or <strong>+ Add</strong>.</div>
  <% } %>

  <% sections.forEach(sec => { %>
    <div class="sub-section" data-section>
      <div class="sec-title sec-<%= sec.key %>"><%= sec.title %> <span class="cnt">(<%= sec.list.length %>)</span></div>
      <% if (sec.list.length) { %>
      <div style="display:flex;align-items:center;gap:.5rem;margin:.1rem 0 .7rem;flex-wrap:wrap">
        <span style="font-size:.82rem;color:var(--muted)">Vetting:</span>
        <% var vetOpts = [...new Set(sec.list.map(s => s.status).filter(Boolean))].sort(); %>
        <select id="vetFilter_<%= sec.key %>" class="vetsel" onchange="filterSubs()">
          <option value="">All</option>
          <% vetOpts.forEach(v => { %><option value="<%= v %>"><%= v %></option><% }) %>
        </select>
        <span style="font-size:.82rem;color:var(--muted);margin-left:.7rem">Group by:</span>
        <span id="sortbtns_<%= sec.key %>">
          <button type="button" class="sortbtn on" data-sort="status" onclick="setGroupBy('<%= sec.key %>','status')">Status</button>
          <button type="button" class="sortbtn" data-sort="trade" onclick="setGroupBy('<%= sec.key %>','trade')">Trade</button>
        </span>
      </div>
      <% } %>
      <% if (!sec.list.length) { %>
        <div style="color:var(--muted);font-size:.85rem">None.</div>
      <% } else { %>
      <div class="tbl-wrap">
        <table class="subs-table">
          <thead><tr>
            <th></th><th>Company</th><th>Location</th><th>Type</th><th>Status</th><th>Contact</th><th>Email</th><th>Phone</th><th>Ref. By</th><th>Notes</th><th></th>
          </tr></thead>
          <tbody id="tbody_<%= sec.key %>">
            <%
              const byTrade = false;   // initial render is by status; the Group-by toggle re-groups client-side (no reload)
              const keyOf = x => byTrade ? ((x.type || '').split(',')[0].trim() || 'Other') : (x.group_label || '');
              const groups = []; const gmap = {};
              sec.list.forEach(x => { const g = keyOf(x); if (!(g in gmap)) { gmap[g] = []; groups.push(g); } gmap[g].push(x); });
              if (byTrade) groups.sort((a, b) => a.localeCompare(b));
            %>
            <% groups.forEach(g => { %>
              <% if (g) { %><tr class="subhdr" data-cat="<%= sec.key %>" data-grp="<%= g %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)"><td colspan="11"><%= g %></td></tr><% } %>
              <% gmap[g].forEach(s => { var ph = photosBySub[s.id] || []; var flagged = /reject|black/.test((s.status||'').toLowerCase()); %>
              <tr class="<%= flagged ? 'flagged-row' : '' %>" data-cat="<%= catOf(s) %>" data-grp="<%= s.group_label||'' %>" data-status="<%= (s.status||'').toLowerCase() %>" data-trade="<%= (s.type||'').split(',')[0].trim() %>" data-recent="<%= s.recent_add ? '1' : '' %>" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)" data-search="<%= [s.company,s.owner,s.type,s.phone,s.email,s.location].filter(Boolean).join(' ').toLowerCase() %>" data-type="<%= (s.type||'').toLowerCase() %>">
                <td class="drag-h" draggable="true" ondragstart="onDragStart(event,'<%= s.id %>')" title="Drag to move">⠿</td>
                <td class="co"><% if (flagged && s.reject_reason) { %><span class="row-reason" onclick="this.classList.toggle('off')" title="Click to hide / show this reason">⛔ <%= (s.status||'').toUpperCase() %>: <%= s.reject_reason %></span><% } %><% if (s.recent_add) { %><span class="newdot" title="Recently added — verify">🆕</span> <% } %><%= s.company || '—' %>
                  <% if (ph.length) { %><div class="thumbs"><% ph.forEach(pid => { %><span class="thumb"><a href="/sub-photo/<%= pid %>" target="_blank"><img src="/sub-photo/<%= pid %>"></a><span class="thx" onclick="delPhoto(<%= pid %>, this)" title="Remove photo">✕</span></span><% }) %></div><% } %>
                </td>
                <td data-label="Location"><% if (flagged && s.location) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.location %></span><% } else { %><%= s.location || '' %><% } %></td>
                <td data-label="Trade"><%= s.type || '' %></td>
                <td data-label="Status">
                  <select class="spill <%= pillClass(s.status) %>" data-id="<%= s.id %>" onchange="changeStatus(this)">
                    <option value="">—</option>
                    <% STATUS_OPTS.forEach(o => { %><option value="<%= o %>" <%= s.status===o?'selected':'' %>><%= o %></option><% }) %>
                    <% if (s.status && STATUS_OPTS.indexOf(s.status) < 0) { %><option value="<%= s.status %>" selected><%= s.status %></option><% } %>
                  </select>
                </td>
                <td data-label="Contact"><% if (flagged && s.owner) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.owner %></span><% } else { %><%= s.owner || '' %><% } %></td>
                <td data-label="Email"><% if (s.email) { %><% if (flagged) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.email %></span><% } else { %><a href="mailto:<%= s.email %>"><%= s.email %></a><% } %><% } %></td>
                <td data-label="Phone"><% if (s.phone) { %><% if (flagged) { %><span class="blurred" onclick="this.classList.toggle('show')"><%= s.phone %></span><% } else { %><a href="tel:<%= s.phone.replace(/[^0-9+]/g,'') %>"><%= s.phone %></a><% } %><% } %></td>
                <td class="refby" data-label="Ref. by"><%= s.referenced_by || '' %></td>
                <td class="notes" data-label="Notes"><% if (flagged && s.reject_reason) { %><div class="reject-reason">⛔ <%= s.status %>: <%= s.reject_reason %></div><% } %><% if (s.notes) { %><div class="note-clip" onclick="this.classList.toggle('open')" title="Click to expand / collapse"><%= s.notes %></div><% } %></td>
                <td class="row-actions">
                  <select class="moveSel" data-id="<%= s.id %>" onchange="changeMove(this)" title="Move to another section / group">
                    <option value="">Move…</option>
                    <optgroup label="Outside GCs">
                      <% moveTargets.filter(t => t.cat === 'gc').forEach(t => { %><option value="gc||<%= t.grp %>"><%= t.grp || '(no group)' %></option><% }) %>
                    </optgroup>
                    <optgroup label="Subcontractors">
                      <% moveTargets.filter(t => t.cat !== 'gc').forEach(t => { %><option value="sub||<%= t.grp %>"><%= t.grp || '(no group)' %></option><% }) %>
                    </optgroup>
                  </select>
                  <button onclick='openEdit(<%- JSON.stringify(s) %>, <%- JSON.stringify(photosBySub[s.id] || []) %>)' title="Edit">✏</button>
                  <form method="POST" action="/subs/<%= s.id %>/photo" enctype="multipart/form-data" style="margin:0;display:inline">
                    <label class="upl" title="Add photos (pick several at once — work, vehicle, job site)">📷<input type="file" name="photos" accept="image/*" multiple style="display:none" onchange="this.form.submit()"></label>
                  </form>
                  <form method="POST" action="/subs/<%= s.id %>/delete" style="margin:0;display:inline" onsubmit="return confirm('Delete this subcontractor?')">
                    <button type="submit" class="del" title="Delete">🗑</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  <% }) %>
</div>

<!-- Add / Edit modal -->
<div class="modal-bk" id="subModal">
  <div class="modal-card">
    <h2 id="modalTitle">Add Subcontractor</h2>
    <form id="subForm" method="POST" action="/subs" enctype="multipart/form-data">
      <input type="hidden" id="editId" value="">
      <div class="mg"><label>Adding to which list?</label>
        <div class="seg" id="catSeg">
          <button type="button" class="segbtn" data-cat="gc" onclick="setCat('gc')">🏗️ Outside GC</button>
          <button type="button" class="segbtn on" data-cat="sub" onclick="setCat('sub')">🔧 Subcontractor</button>
        </div>
        <input type="hidden" name="category" id="f_category" value="sub">
      </div>
      <div class="mg"><label>Company</label><input name="company" id="f_company" placeholder="e.g. Pyramid Drywall"></div>
      <div class="mg"><label>Contact / Owner</label><input name="owner" id="f_owner"></div>
      <div class="mg"><label>Trade / Type <span style="font-weight:400;color:var(--muted)">— tap all that apply</span></label>
        <div id="tradeChips" class="trade-chips"></div>
        <div style="display:flex;gap:.4rem;margin-top:.45rem">
          <input id="tradeOther" placeholder="Add another trade…" style="flex:1;padding:.45rem .6rem;border:1px solid var(--border);border-radius:8px;background:var(--bg);font-size:.88rem" onkeydown="if(event.key==='Enter'){event.preventDefault();addTradeOther();}">
          <button type="button" class="btn btn-ghost btn-sm" onclick="addTradeOther()">Add</button>
        </div>
        <input type="hidden" name="type" id="f_type">
      </div>
      <div class="mg2">
        <div class="mg"><label>Phone</label><input name="phone" id="f_phone"></div>
        <div class="mg"><label>Email</label><input name="email" id="f_email"></div>
      </div>
      <div class="mg"><label>Status</label>
        <select name="status" id="f_status">
          <option value="">—</option>
          <% STATUS_OPTS.forEach(o => { %><option value="<%= o %>"><%= o %></option><% }) %>
        </select>
      </div>
      <div class="mg"><label>Location <span style="font-weight:400;color:var(--muted)">— tap all that apply</span></label>
        <div id="locChips" class="trade-chips"></div>
        <input type="hidden" name="location" id="f_location">
      </div>
      <div class="mg"><label>Referenced by <span style="font-weight:400;color:var(--muted)">— how you found them</span></label><input name="referenced_by" id="f_referenced_by" placeholder="e.g. Referral from Bobby · Google · past project"></div>
      <div class="mg"><label>Notes</label><textarea name="notes" id="f_notes" rows="2"></textarea></div>
      <div class="mg" id="photosField" style="display:none">
        <label>Photos <span id="photosHint" style="font-weight:400;color:var(--muted)">— work, vehicle, job site.</span></label>
        <div id="modalPhotos" class="thumbs" style="margin-bottom:.55rem"></div>
        <label class="addphotos">📷 Add photos<input type="file" name="photos" id="modalPhotoInput" accept="image/*" multiple style="display:none" onchange="onPhotoInput()"></label>
        <span id="photoUploading" style="display:none;font-size:.82rem;color:var(--muted);margin-left:.6rem">Uploading…</span>
      </div>
      <input type="hidden" name="group_label" id="f_group">
      <div style="display:flex;gap:.6rem;align-items:center;margin-top:.4rem">
        <button type="button" id="delBtn" class="btn" style="display:none;color:#cc2222;border:1px solid #cc2222;background:none" onclick="delSubFromModal()">🗑 Delete</button>
        <div style="margin-left:auto;display:flex;gap:.6rem">
        <button type="button" class="btn btn-ghost" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="saveBtn">Save</button>
        </div>
      </div>
    </form>
  </div>
</div>
<datalist id="tradeList">
  <option>General Contractor</option><option>Electrician</option><option>Plumber</option>
  <option>Drywall</option><option>Framing</option><option>Painter</option><option>Handyman</option>
  <option>HVAC</option><option>Flooring</option><option>Roofing</option><option>Concrete</option>
  <option>Demolition</option><option>Junk Removal</option><option>Landscaping</option><option>Tile</option>
</datalist>

<script>
(function () {
  const set = new Set();
  document.querySelectorAll('tr[data-type]').forEach(r => r.dataset.type.split(',').forEach(t => { t = t.trim(); if (t) set.add(t); }));
  const sel = document.getElementById('typeFilter');
  [...set].sort().forEach(t => { const o = document.createElement('option'); o.value = t; o.textContent = t.replace(/\b\w/g, m => m.toUpperCase()); sel.appendChild(o); });
})();
function filterSubs() {
  const q = document.getElementById('subSearch').value.toLowerCase().trim();
  const tf = document.getElementById('typeFilter').value;
  const vg = document.getElementById('vetFilter_gc'), vs = document.getElementById('vetFilter_sub');
  const vet = { gc: vg ? vg.value.toLowerCase() : '', sub: vs ? vs.value.toLowerCase() : '' };
  const ro = document.getElementById('recentOnly'); const recentOnly = !!(ro && ro.checked);
  document.querySelectorAll('tr[data-search]').forEach(r => {
    const okQ = !q || r.dataset.search.includes(q);
    const okT = !tf || r.dataset.type.split(',').map(x => x.trim()).includes(tf);
    const v = vet[r.dataset.cat] || '';
    const okV = !v || (r.dataset.status || '') === v;
    const okR = !recentOnly || r.dataset.recent === '1';
    r.style.display = (okQ && okT && okV && okR) ? '' : 'none';
  });
  // Hide sub-section headers that have no visible rows beneath them
  document.querySelectorAll('.subs-table tbody').forEach(tb => {
    const trs = [...tb.children];
    trs.forEach((tr, i) => {
      if (!tr.classList.contains('subhdr')) return;
      let any = false;
      for (let j = i + 1; j < trs.length; j++) { if (trs[j].classList.contains('subhdr')) break; if (trs[j].style.display !== 'none') { any = true; break; } }
      tr.style.display = any ? '' : 'none';
    });
  });
  // Hide a whole section if it has no visible rows
  document.querySelectorAll('.sub-section').forEach(sec => {
    const vis = [...sec.querySelectorAll('tr[data-search]')].some(r => r.style.display !== 'none');
    sec.style.display = vis ? '' : 'none';
  });
}

// ── Group-by toggle: re-group rows in the browser, no page reload (so no scroll-to-top) ──
const ORIG_STATUS_ORDER = {};   // {gc:[grp,…], sub:[…]} — the original sheet order of status groups
function captureStatusOrder() {
  ['gc','sub'].forEach(key => {
    const tb = document.getElementById('tbody_' + key);
    if (!tb) return;
    const order = [];
    [...tb.children].forEach(tr => {
      if (tr.classList.contains('subhdr')) { const g = tr.getAttribute('data-grp') || ''; if (g && order.indexOf(g) < 0) order.push(g); }
    });
    ORIG_STATUS_ORDER[key] = order;
  });
}
function makeSubhdr(key, grp, display) {
  const tr = document.createElement('tr');
  tr.className = 'subhdr';
  tr.setAttribute('data-cat', key);
  tr.setAttribute('data-grp', grp);
  tr.setAttribute('ondragover', 'onDragOver(event)');
  tr.setAttribute('ondragleave', 'onDragLeave(event)');
  tr.setAttribute('ondrop', 'onDrop(event)');
  const td = document.createElement('td');
  td.colSpan = 11;
  td.textContent = (display == null) ? grp : display;
  tr.appendChild(td);
  return tr;
}
function setGroupBy(key, mode) {
  const tb = document.getElementById('tbody_' + key);
  if (!tb) return;
  const rows = [...tb.querySelectorAll('tr[data-search]')];
  [...tb.querySelectorAll('tr.subhdr')].forEach(tr => tr.remove());
  const gmap = {}, display = {}, order = [];
  rows.forEach(tr => {
    let g, disp;
    if (mode === 'trade') { disp = (tr.getAttribute('data-trade') || '').trim() || 'Other'; g = disp.toLowerCase(); }
    else { g = tr.getAttribute('data-grp') || ''; disp = g; }
    if (!(g in gmap)) { gmap[g] = []; display[g] = disp; order.push(g); }
    gmap[g].push(tr);
  });
  let groups;
  if (mode === 'trade') {
    groups = order.slice().sort((a, b) => display[a].localeCompare(display[b]));
  } else {
    const orig = ORIG_STATUS_ORDER[key] || [];
    groups = orig.filter(g => g in gmap).concat(order.filter(g => orig.indexOf(g) < 0));
  }
  tb.innerHTML = '';
  groups.forEach(g => {
    if (g) tb.appendChild(makeSubhdr(key, g, display[g]));
    gmap[g].forEach(tr => tb.appendChild(tr));
  });
  const box = document.getElementById('sortbtns_' + key);
  if (box) box.querySelectorAll('.sortbtn').forEach(b => b.classList.toggle('on', b.dataset.sort === mode));
  filterSubs();
}
captureStatusOrder();

// ── Multi-select trades ──
const TRADES = ['General Contractor','Electrician','Plumber','Drywall','Framing','Painter','Handyman','HVAC','Flooring','Roofing','Concrete','Demolition','Junk Removal','Landscaping','Tile','Solar','Stucco','Insulation','Fire Sprinklers','Decking','Finishes','Tree Removal'];
let selectedTrades = [];
function renderTradeChips() {
  const all = [...new Set([...TRADES, ...selectedTrades])];
  document.getElementById('tradeChips').innerHTML = all.map(t =>
    `<span class="trade-chip${selectedTrades.includes(t) ? ' on' : ''}" onclick="toggleTrade(this.dataset.t)" data-t="${t.replace(/"/g,'&quot;')}">${t}</span>`).join('');
  document.getElementById('f_type').value = selectedTrades.join(', ');
}
function toggleTrade(t) {
  const i = selectedTrades.indexOf(t);
  if (i >= 0) selectedTrades.splice(i, 1); else selectedTrades.push(t);
  renderTradeChips();
  // Picking the "General Contractor" trade nudges the entry into the GC list
  if (i < 0 && /general\s*contractor/i.test(t)) setCat('gc');
}
function addTradeOther() {
  const inp = document.getElementById('tradeOther');
  const v = inp.value.trim();
  if (v && !selectedTrades.some(t => t.toLowerCase() === v.toLowerCase())) selectedTrades.push(v);
  inp.value = '';
  renderTradeChips();
}
function setTradesFromString(str) {
  selectedTrades = String(str || '').split(/[,;]+/).map(x => x.trim()).filter(Boolean);
  renderTradeChips();
}
// ── Multi-select location (counties) ──
const COUNTIES = ['LA County','Orange County','Riverside County','San Diego County','Ventura County','San Bernardino County'];
let selectedLocs = [];
function renderLocChips() {
  const all = [...new Set([...COUNTIES, ...selectedLocs])];
  document.getElementById('locChips').innerHTML = all.map(t =>
    `<span class="trade-chip${selectedLocs.includes(t) ? ' on' : ''}" onclick="toggleLoc(this.dataset.t)" data-t="${t.replace(/"/g,'&quot;')}">${t}</span>`).join('');
  document.getElementById('f_location').value = selectedLocs.join(', ');
}
function toggleLoc(t) {
  const i = selectedLocs.indexOf(t);
  if (i >= 0) selectedLocs.splice(i, 1); else selectedLocs.push(t);
  renderLocChips();
}
function setLocsFromString(str) {
  selectedLocs = String(str || '').split(/[,;]+/).map(x => x.trim()).filter(Boolean);
  renderLocChips();
}
// Set a <select> value, injecting the value as an option if it isn't already listed
function fillSelect(id, val) {
  const sel = document.getElementById(id);
  Array.from(sel.querySelectorAll('option[data-custom]')).forEach(o => o.remove());
  if (val && !Array.from(sel.options).some(o => o.value === val)) {
    const o = document.createElement('option'); o.value = val; o.textContent = val; o.setAttribute('data-custom', ''); sel.appendChild(o);
  }
  sel.value = val || '';
}
function setCat(c) {
  c = (c === 'gc') ? 'gc' : 'sub';
  document.getElementById('f_category').value = c;
  document.querySelectorAll('#catSeg .segbtn').forEach(b => b.classList.toggle('on', b.dataset.cat === c));
}
function openAdd() {
  document.getElementById('modalTitle').textContent = 'Add Contractor';
  document.getElementById('editId').value = '';
  ['company','owner','phone','email','status','notes','group','referenced_by'].forEach(k => document.getElementById('f_' + k).value = '');
  setLocsFromString('');
  setTradesFromString('');
  setCat('sub');   // default new entries to Subcontractor — tap the toggle for GC
  document.getElementById('f_status').value = 'Under Review';   // new contractors start Under Review
  document.getElementById('delBtn').style.display = 'none';   // no delete when adding
  document.getElementById('photosField').style.display = '';   // can attach photos while adding
  document.getElementById('photosHint').textContent = '— work, vehicle, job site. They upload when you tap Save.';
  document.getElementById('modalPhotos').innerHTML = '';
  document.getElementById('modalPhotoInput').value = '';
  document.getElementById('subModal').classList.add('show');
}
function openEdit(s, photos) {
  document.getElementById('modalTitle').textContent = 'Edit Subcontractor';
  document.getElementById('editId').value = s.id;
  document.getElementById('f_company').value = s.company || '';
  document.getElementById('f_owner').value = s.owner || '';
  setTradesFromString(s.type);
  document.getElementById('f_phone').value = s.phone || '';
  document.getElementById('f_email').value = s.email || '';
  setLocsFromString(s.location || '');
  document.getElementById('f_status').value = s.status || '';
  setCat((s.category === 'gc' || s.category === 'sub') ? s.category : (/general\s*contractor|^\s*gc\b/i.test(s.type || '') ? 'gc' : 'sub'));
  document.getElementById('f_notes').value = s.notes || '';
  document.getElementById('f_referenced_by').value = s.referenced_by || '';
  document.getElementById('f_group').value = s.group_label || '';
  document.getElementById('delBtn').style.display = '';   // allow deleting when editing
  document.getElementById('photosField').style.display = '';
  document.getElementById('photosHint').textContent = '— work, vehicle, job site. Add several at once, or come back and add more anytime.';
  renderModalPhotos(photos || []);
  document.getElementById('modalPhotoInput').value = '';
  document.getElementById('subModal').classList.add('show');
}
// In edit mode photos upload immediately; in add mode they ride along with the form on Save.
function onPhotoInput() {
  if (document.getElementById('editId').value) uploadModalPhotos();
  else previewAddPhotos();
}
function previewAddPhotos() {
  const input = document.getElementById('modalPhotoInput');
  const box = document.getElementById('modalPhotos');
  box.innerHTML = '';
  Array.from(input.files || []).forEach(f => {
    const span = document.createElement('span'); span.className = 'thumb';
    const img = document.createElement('img'); img.src = URL.createObjectURL(f);
    span.appendChild(img);
    box.appendChild(span);
  });
}
function photoThumbHtml(pid) {
  return `<span class="thumb"><a href="/sub-photo/${pid}" target="_blank"><img src="/sub-photo/${pid}"></a><span class="thx" onclick="delPhoto(${pid}, this)" title="Remove photo">✕</span></span>`;
}
function renderModalPhotos(photos) {
  const box = document.getElementById('modalPhotos');
  box.innerHTML = (photos && photos.length)
    ? photos.map(photoThumbHtml).join('')
    : '<span class="noph" style="color:var(--muted);font-size:.82rem">No photos yet — add some below.</span>';
}
async function uploadModalPhotos() {
  const input = document.getElementById('modalPhotoInput');
  const id = document.getElementById('editId').value;
  if (!input.files.length || !id) return;
  document.getElementById('photoUploading').style.display = 'inline';
  const fd = new FormData();
  Array.from(input.files).forEach(f => fd.append('photos', f));
  try {
    const r = await fetch('/subs/' + id + '/photo', { method: 'POST', headers: { 'X-Requested-With': 'fetch' }, body: fd });
    const d = await r.json();
    document.getElementById('photoUploading').style.display = 'none';
    input.value = '';
    if (!d.ok) { alert('Could not upload — please try again.'); return; }
    const box = document.getElementById('modalPhotos');
    const ph = box.querySelector('.noph'); if (ph) box.innerHTML = '';   // clear the "no photos" note
    d.ids.forEach(pid => box.insertAdjacentHTML('beforeend', photoThumbHtml(pid)));
  } catch (e) {
    document.getElementById('photoUploading').style.display = 'none';
    alert('Could not upload — please try again.');
  }
}
function delSubFromModal() {
  const id = document.getElementById('editId').value;
  if (!id) return;
  if (!confirm('Delete this contractor permanently? This also removes their photos. This cannot be undone.')) return;
  const f = document.createElement('form');
  f.method = 'POST'; f.action = '/subs/' + id + '/delete';
  document.body.appendChild(f); f.submit();
}
async function delPhoto(id, el) {
  if (!confirm('Remove this photo?')) return;
  try {
    const r = await fetch('/sub-photo/' + id + '/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
    const d = await r.json();
    if (!d.ok) { alert('Could not remove photo.'); return; }
    if (el && el.closest('.thumb')) el.closest('.thumb').remove();   // remove in place (row + modal)
    else location.reload();
  } catch (e) { alert('Could not remove photo.'); }
}
function pillClassJS(st) { st = (st || '').toLowerCase();
  if (/black/.test(st)) return 'pill-black';
  if (/reject|declin/.test(st)) return 'pill-rejected';
  if (/active/.test(st)) return 'pill-active';
  if (/approv/.test(st)) return 'pill-approved';
  if (/review|vetting|pending/.test(st)) return 'pill-review';
  return 'pill-default'; }
// ── Drag & drop to move between buckets / sections ──
let dragId = null;
function onDragStart(e, id) { dragId = id; e.dataTransfer.effectAllowed = 'move'; try { e.dataTransfer.setData('text/plain', id); } catch (x) {} }
function onDragOver(e) { if (!dragId) return; e.preventDefault(); e.currentTarget.classList.add('drop-hi'); }
function onDragLeave(e) { e.currentTarget.classList.remove('drop-hi'); }
async function onDrop(e) {
  e.preventDefault();
  const t = e.currentTarget; t.classList.remove('drop-hi');
  const cat = t.dataset.cat, grp = t.dataset.grp || '';
  const id = dragId; dragId = null;
  if (!id || cat == null) return;
  const body = new URLSearchParams({ category: cat, group_label: grp });
  try {
    const r = await fetch('/subs/' + id + '/move', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    if (r.ok) location.reload(); else throw 0;
  } catch (err) { alert('Could not move — try again'); }
}
async function changeMove(sel) {
  if (!sel.value) return;
  const [cat, grp] = sel.value.split('||');
  const body = new URLSearchParams({ category: cat, group_label: grp });
  try {
    const r = await fetch('/subs/' + sel.dataset.id + '/move', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    if (r.ok) location.reload(); else throw 0;
  } catch (e) { alert('Could not move — try again'); sel.value = ''; }
}
async function changeStatus(sel) {
  const v = sel.value;
  const flag = /reject|black/i.test(v);
  let reason = '';
  if (flag) {
    reason = prompt((/black/i.test(v) ? 'Blacklist' : 'Reject') + ' this contractor — reason? (Shows on the card; the contact info gets blurred.)', '');
    if (reason === null) { location.reload(); return; }   // cancelled → restore previous status
  }
  sel.className = 'spill ' + pillClassJS(v);   // recolor instantly
  const body = new URLSearchParams({ status: v });
  if (flag) body.set('reason', reason || '');
  try {
    const r = await fetch('/subs/' + sel.dataset.id + '/status', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    const data = await r.json();
    if (!r.ok || !data.ok) throw 0;
    location.reload();   // refresh to move section + apply or clear the blur/reason
  } catch (e) { alert('Could not save status — try again'); }
}
function closeModal() { document.getElementById('subModal').classList.remove('show'); }
document.getElementById('subForm').addEventListener('submit', async function (e) {
  const id = document.getElementById('editId').value;
  if (!id) return;
  e.preventDefault();
  const body = new URLSearchParams();
  ['company','owner','type','phone','email','location','status','notes','category','referenced_by'].forEach(k => body.set(k, document.getElementById('f_' + k).value));
  document.getElementById('saveBtn').textContent = 'Saving…';
  const r = await fetch('/subs/' + id, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
  if (r.ok) location.reload(); else { alert('Could not save'); document.getElementById('saveBtn').textContent = 'Save'; }
});
document.getElementById('subModal').addEventListener('click', e => { if (e.target.id === 'subModal') closeModal(); });
</script>
</body>
</html>

const EMAIL_SUBJECT = 'ADU BID REQUEST BUILDOLY';
const AREA_LIST = <%- JSON.stringify(typeof LOCATION_OPTS !== 'undefined' ? LOCATION_OPTS : []) %>;

// ── Trade coverage panel ──
// Minimal per-sub data for counting: trades, service areas, status, category.
const COV_DATA = <%- JSON.stringify(subs.map(function (s) { return { t: s.type || '', l: s.location || '', st: s.status || '', cat: s.category || '', n: s.company || '' }; })).replace(/</g, '\\u003c') %>;
let covInit = false;
function covToggle() {
  const p = document.getElementById('covPanel');
  if (p.classList.toggle('show')) covRender();
}
const COV_MIN = 4;   // recruiting target: at least this many subs per trade in every coverage zone
let covSel = '';     // clicked zone tile → highlight its matrix column
function covRender() {
  const tradeList = TRADES.filter(function (t) { return t !== 'General Contractor'; });
  const globalTrade = {}, areaTot = {}, areaTrade = {}, noAreaTrade = {};
  tradeList.forEach(function (t) { globalTrade[t] = 0; noAreaTrade[t] = 0; });
  AREA_LIST.forEach(function (a) { areaTot[a] = 0; areaTrade[a] = {}; });
  let noArea = 0;
  COV_DATA.forEach(function (s) {
    if (!/^\s*active\s*$/i.test(s.st || '')) return;                              // coverage = Active subs only
    const isGc = s.cat === 'gc' || (!s.cat && /general\s*contractor|^\s*gc\b/i.test(s.t));
    if (isGc) return;                                                              // outside GCs aren't trade coverage
    const locs = String(s.l || '').split(',').map(function (x) { return x.trim().toLowerCase(); }).filter(Boolean);
    const ts = String(s.t).split(',').map(function (x) { return x.trim().toLowerCase(); }).filter(Boolean);
    tradeList.forEach(function (t) {
      if (!ts.includes(t.toLowerCase())) return;
      globalTrade[t]++;
      if (!locs.length) noAreaTrade[t]++;
    });
    if (!locs.length) { noArea++; return; }
    AREA_LIST.forEach(function (a) {
      if (!locs.includes(a.toLowerCase())) return;
      areaTot[a]++;
      tradeList.forEach(function (t) { if (ts.includes(t.toLowerCase())) areaTrade[a][t] = (areaTrade[a][t] || 0) + 1; });
    });
  });
  // Zone tiles: per-area headcount + how many trades there are under the minimum.
  // Trades-under-target only looks at trades we actually recruit (≥1 usable sub somewhere).
  const activeTrades = tradeList.filter(function (t) { return globalTrade[t] > 0; });
  document.getElementById('covAreas').innerHTML = AREA_LIST.map(function (a) {
    const tot = areaTot[a];
    const under = activeTrades.filter(function (t) { return (areaTrade[a][t] || 0) < COV_MIN; }).length;
    const cls = tot < COV_MIN ? 'cov-tile-bad' : (under ? 'cov-tile-mid' : 'cov-tile-good');
    const sel = covSel === a ? ' sel' : '';
    const status = tot < COV_MIN ? '🚨 need ' + (COV_MIN - tot) + ' more (min ' + COV_MIN + ')' : (under ? under + ' trade' + (under === 1 ? '' : 's') + ' under ' + COV_MIN : '✓ all trades at ' + COV_MIN + '+');
    return '<div class="cov-tile ' + cls + sel + '" onclick="covPick(this.dataset.a)" data-a="' + a.replace(/"/g, '&quot;') + '" title="Subs covering ' + a + ' — click to highlight its column"><div class="ct-n">' + tot + '</div><div class="ct-a">' + a + '</div><div class="ct-s">' + status + '</div></div>';
  }).join('') + (noArea ? '<div class="cov-tile cov-tile-na" title="These subs count toward NO zone until you set their service areas — open them and pick counties"><div class="ct-n">' + noArea + '</div><div class="ct-a">No area set</div><div class="ct-s">⚠ not counted anywhere</div></div>' : '');
  // The matrix: trade rows × zone columns, worst-covered trades first
  const gapsOf = function (t) { return AREA_LIST.filter(function (a) { return (areaTrade[a][t] || 0) < COV_MIN; }).length; };
  const order = activeTrades.slice().sort(function (a, b) { return gapsOf(b) - gapsOf(a) || a.localeCompare(b); });
  const anyNoArea = order.some(function (t) { return noAreaTrade[t] > 0; });
  let html = '<thead><tr><th class="cm-t">Trade</th>' + AREA_LIST.map(function (a) {
    return '<th class="' + (covSel === a ? 'cm-selh' : '') + '">' + a.replace(' County', '') + '</th>';

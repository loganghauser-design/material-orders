<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<%- include('_nav', { active: 'settings' }) %>

<div class="container">
  <div class="page-header"><h1>Settings</h1></div>

  <style>
    .linkrow { display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; padding:1rem 0; border-top:1px solid var(--border); }
    .linkrow:first-of-type { border-top:none; padding-top:.2rem; }
    .linkname { font-weight:700; font-size:1rem; }
    .linkdesc { color:var(--muted); font-size:.84rem; margin:.18rem 0 .35rem; line-height:1.45; max-width:440px; }
    .linkurl { font-family:ui-monospace,Menlo,Consolas,monospace; font-size:.82rem; color:var(--accent); word-break:break-all; }
    .linkbtns { display:flex; gap:.5rem; flex:none; }
  </style>

  <div class="card" id="links">
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.4rem">🔗 Shareable Links</h2>
    <p style="color:var(--muted);font-size:.875rem;margin-bottom:1rem">
      Public links you — or any employee — can hand out. No login needed. Tap <strong>Copy</strong> to grab one.
    </p>

    <div class="linkrow">
      <div>
        <div class="linkname">🏠 Warranty &amp; Service</div>
        <div class="linkdesc">Give to <strong>homeowners / clients</strong> to report a warranty issue or reach you in an emergency.</div>
        <div class="linkurl" data-path="/warranty"></div>
      </div>
      <div class="linkbtns">
        <a class="btn btn-ghost btn-sm" href="/warranty" target="_blank">Open</a>
        <button type="button" class="btn btn-primary btn-sm" onclick="copyLink('/warranty', this)">Copy</button>
      </div>
    </div>

    <div class="linkrow">
      <div>
        <div class="linkname">🧰 Contractor Submission</div>
        <div class="linkdesc">Send to <strong>GCs / subcontractors</strong> to apply — their info lands in Subs → Under Vetting.</div>
        <div class="linkurl" data-path="/apply"></div>
      </div>
      <div class="linkbtns">
        <a class="btn btn-ghost btn-sm" href="/apply" target="_blank">Open</a>
        <button type="button" class="btn btn-primary btn-sm" onclick="copyLink('/apply', this)">Copy</button>
      </div>
    </div>

    <div class="linkrow">
      <div>
        <div class="linkname">🔐 Staff App <span style="color:var(--muted);font-weight:400">— internal</span></div>
        <div class="linkdesc">For <strong>employees &amp; superintendents</strong> to log in. Don't share this one with clients.</div>
        <div class="linkurl" data-path="/login"></div>
      </div>
      <div class="linkbtns">
        <a class="btn btn-ghost btn-sm" href="/login" target="_blank">Open</a>
        <button type="button" class="btn btn-primary btn-sm" onclick="copyLink('/login', this)">Copy</button>
      </div>
    </div>
  </div>

  <div class="card" style="margin-top:1.5rem">
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.4rem">Default Email Attachment</h2>
    <p style="color:var(--muted);font-size:.875rem;margin-bottom:1.5rem">
      This file (e.g. your wire-transfer details PDF) automatically attaches to <strong>every</strong> milestone payment email you send.
    </p>

    <% if (attachmentName) { %>
      <div class="current-attachment">
        <div>
          <div style="font-weight:600">📎 <%= attachmentName %></div>
          <div style="font-size:.8rem;color:var(--muted)">Currently attached to all milestone emails<% if (updatedAt) { %> · uploaded <%= new Date(updatedAt).toLocaleDateString() %><% } %></div>
        </div>
        <form method="POST" action="/settings/attachment/delete" onsubmit="return confirm('Remove the default attachment?')">
          <button type="submit" class="btn btn-danger btn-sm">Remove</button>
        </form>
      </div>
    <% } else { %>
      <div class="error-msg" style="background:rgba(217,119,6,.08);border-color:rgba(217,119,6,.3);color:#b45309">
        No default attachment set. Milestone emails will send without one unless you add a file per-send.
      </div>
    <% } %>

    <form method="POST" action="/settings/attachment" enctype="multipart/form-data" style="margin-top:1.5rem">
      <div class="form-group">
        <label><%= attachmentName ? 'Replace with a new file' : 'Upload a file' %></label>
        <input type="file" name="attachment" required>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><%= attachmentName ? 'Replace file' : 'Upload file' %></button>
      </div>
    </form>
  </div>

  <div class="card" style="margin-top:1.5rem" id="supers">
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.4rem">👷 Superintendents</h2>
    <p style="color:var(--muted);font-size:.875rem;margin-bottom:1rem">
      Add each super's phone number. When a super is assigned to a project, their name &amp; number are
      automatically included as the <strong>on-site delivery contact</strong> on every RFQ / delivery / outbound email for that project.
    </p>
    <% if (typeof savedSupers !== 'undefined' && savedSupers) { %>
      <div class="error-msg" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a">✓ Phone numbers saved.</div>
    <% } %>
    <form method="POST" action="/settings/supers">
      <% (supers || []).forEach(s => { %>
        <div class="form-group" style="display:flex;align-items:center;gap:.8rem;flex-wrap:wrap;margin-bottom:.7rem">
          <div style="min-width:200px"><strong><%= s.name %></strong><br><span style="color:var(--muted);font-size:.8rem"><%= s.email %></span></div>
          <input type="tel" name="phone_<%= s.email %>" value="<%= s.phone %>" placeholder="(555) 123-4567" style="flex:1;min-width:180px;max-width:280px">
        </div>
      <% }) %>
      <div class="form-actions"><button type="submit" class="btn btn-primary">Save phone numbers</button></div>
    </form>
  </div>

  <div class="card" style="margin-top:1.5rem" id="warranty">
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.4rem">🏠 Warranty</h2>
    <p style="color:var(--muted);font-size:.875rem;margin-bottom:1rem">
      The number clients see when they tap <strong>“Emergency”</strong> on the warranty page. (The shareable warranty link is up under <a href="#links">🔗 Shareable Links</a>.)
    </p>
    <% if (typeof savedEmergency !== 'undefined' && savedEmergency) { %>
      <div class="error-msg" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a">✓ Emergency number saved.</div>
    <% } %>
    <form method="POST" action="/settings/emergency-phone">
      <div class="form-group">
        <label>Emergency phone <span style="color:var(--muted);font-weight:400">— shown to clients who tap “Emergency” to call or text</span></label>
        <input type="tel" name="emergency_phone" value="<%= emergencyPhone || '' %>" placeholder="(555) 123-4567" style="max-width:280px">
      </div>
      <div class="form-actions"><button type="submit" class="btn btn-primary">Save emergency number</button></div>
    </form>

    <hr style="border:none;border-top:1px solid var(--border);margin:1.4rem 0">

    <h3 style="font-size:1rem;font-weight:700;margin-bottom:.3rem">📄 Manufacturer warranty document</h3>
    <p style="color:var(--muted);font-size:.85rem;margin-bottom:.9rem">
      Shown to clients who select a manufacturer-warranty item (Water Heater / AC / Appliances) on the warranty form and tap <strong>“No”</strong> when asked if they've contacted the manufacturer.
    </p>
    <% if (typeof savedDoc !== 'undefined' && savedDoc) { %>
      <div class="error-msg" style="background:rgba(76,175,125,.1);border-color:rgba(76,175,125,.4);color:#16a34a">✓ Document saved.</div>
    <% } %>
    <% if (typeof warrantyDocName !== 'undefined' && warrantyDocName) { %>
      <div class="current-attachment" style="margin-bottom:1rem">
        <div>
          <div style="font-weight:600">📄 <%= warrantyDocName %></div>
          <div style="font-size:.8rem;color:var(--muted)"><a href="/warranty-doc" target="_blank">View current document →</a></div>
        </div>
        <form method="POST" action="/settings/warranty-doc/delete" onsubmit="return confirm('Remove the warranty document?')">
          <button type="submit" class="btn btn-danger btn-sm">Remove</button>
        </form>
      </div>
    <% } %>
    <form method="POST" action="/settings/warranty-doc" enctype="multipart/form-data">
      <div class="form-group">
        <label><%= (typeof warrantyDocName !== 'undefined' && warrantyDocName) ? 'Replace the document' : 'Upload a PDF' %></label>
        <input type="file" name="warranty_doc" accept="application/pdf,image/*" required>
      </div>
      <div class="form-actions"><button type="submit" class="btn btn-primary"><%= (typeof warrantyDocName !== 'undefined' && warrantyDocName) ? 'Replace document' : 'Upload document' %></button></div>
    </form>
  </div>

  <div class="card" style="margin-top:1.5rem">
    <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.4rem">Suppliers</h2>
    <p style="color:var(--muted);font-size:.875rem">
      Supplier contacts have their own page now → <a href="/suppliers">Manage Suppliers</a>.
    </p>
  </div>
</div>
<script>
  document.querySelectorAll('.linkurl').forEach(function(el){ el.textContent = location.origin + el.dataset.path; });
  function copyLink(path, btn){
    navigator.clipboard.writeText(location.origin + path).then(function(){
      var t = btn.textContent; btn.textContent = '✓ Copied'; setTimeout(function(){ btn.textContent = t; }, 1500);
    });
  }
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Permits — Buildoly Office</title>
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .ptbl-wrap { overflow-x:auto; border:1px solid var(--border); border-radius:10px; background:var(--surface); }
    table.ptbl { border-collapse:collapse; font-size:.78rem; white-space:nowrap; }
    .ptbl th { background:var(--bg); color:var(--muted); font-size:.63rem; text-transform:uppercase; letter-spacing:.03em; padding:.5rem .55rem; border-bottom:2px solid var(--border); position:sticky; top:0; text-align:left; z-index:2; }
    .ptbl td { padding:2px; border-bottom:1px solid var(--border); border-right:1px solid var(--border); }
    .ptbl tr.grp td { background:#15161a; color:#fff; font-weight:800; font-size:.85rem; padding:.5rem .75rem; }
    .pname { min-width:210px; position:sticky; left:0; background:var(--surface); z-index:1; }
    th.pname { z-index:3; }
    .pname input { border:none; background:transparent; font-weight:600; width:100%; font-size:.8rem; color:var(--text); padding:.3rem .5rem; }
    input.ptext, input.pnum { border:none; background:transparent; font-size:.78rem; padding:.32rem .4rem; color:var(--text); }
    input.pnum { width:54px; text-align:center; }
    select.pstat { border:none; border-radius:5px; font-size:.73rem; font-weight:700; padding:.34rem .4rem; cursor:pointer; color:#fff; width:100%; min-width:100px; -webkit-appearance:none; appearance:none; text-align:center; text-align-last:center; }
    select.pstat.empty { color:var(--muted); background:transparent !important; font-weight:400; }
    select.pstat option { color:#111; background:#fff; font-weight:600; }
    .prange { display:flex; gap:1px; }
    .prange input { border:none; background:transparent; font-size:.66rem; width:90px; color:var(--text); padding:.2rem; }
    .pdel { color:#cc2222; cursor:pointer; background:none; border:none; font-size:.9rem; padding:.25rem .4rem; }
  </style>
</head>
<body>
<%- include('_nav', { active: 'permits' }) %>

<div class="container" style="max-width:100%;padding:1.2rem 1.1rem 3rem">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:.4rem">
    <h1 style="margin:0">Permits</h1>
    <form method="POST" action="/permits/new" style="margin:0"><button class="btn btn-primary btn-sm">+ New permit</button></form>
  </div>
  <p style="color:var(--muted);font-size:.85rem;margin-bottom:1rem">Permit tracking. Click any cell to edit — it saves automatically.</p>

  <div class="ptbl-wrap">
    <table class="ptbl">
      <thead><tr>
        <th class="pname">Permit</th>
        <% COLS.forEach(c => { %><th><%= c.title %></th><% }) %>
        <th></th>
      </tr></thead>
      <tbody>
        <% GROUPS.forEach(g => { var rows = permits.filter(p => (p.grp || 'Active Permits') === g); %>
          <% if (rows.length) { %>
            <tr class="grp"><td colspan="<%= COLS.length + 2 %>"><%= g %> · <%= rows.length %></td></tr>
            <% rows.forEach(p => { %>
              <tr data-id="<%= p.id %>">
                <td class="pname"><input class="ptext" value="<%= p.name || '' %>" data-col="name" onchange="saveCell(this)"></td>
                <% COLS.forEach(c => { %>
                  <td>
                    <% if (c.type === 'status') { var v = p[c.key] || ''; var hex = ''; c.opts.forEach(o => { if (o[0] === v) hex = o[1]; }); %>
                      <select class="pstat <%= v ? '' : 'empty' %>" data-col="<%= c.key %>" style="<%= v ? 'background:' + hex : '' %>" onchange="saveStatus(this)">
                        <option value="">—</option>
                        <% c.opts.forEach(o => { %><option value="<%= o[0] %>" data-hex="<%= o[1] %>" <%= v === o[0] ? 'selected' : '' %>><%= o[0] %></option><% }) %>
                      </select>
                    <% } else if (c.type === 'text') { %>
                      <input class="ptext" value="<%= p[c.key] || '' %>" data-col="<%= c.key %>" onchange="saveCell(this)" style="width:<%= c.w || 110 %>px">
                    <% } else if (c.type === 'number') { %>
                      <input class="pnum" type="number" value="<%= p[c.key] != null ? p[c.key] : '' %>" data-col="<%= c.key %>" onchange="saveCell(this)">
                    <% } else if (c.type === 'range') { %>
                      <div class="prange">
                        <input type="date" data-col="<%= c.start %>" value="<%= p[c.start] || '' %>" onchange="saveCell(this)" title="Start">
                        <input type="date" data-col="<%= c.end %>" value="<%= p[c.end] || '' %>" onchange="saveCell(this)" title="End">
                      </div>
                    <% } %>
                  </td>
                <% }) %>
                <td><button class="pdel" title="Delete permit" onclick="delPermit(<%= p.id %>)">🗑</button></td>
              </tr>
            <% }) %>
          <% } %>
        <% }) %>
        <% if (!permits.length) { %><tr><td colspan="<%= COLS.length + 2 %>" style="padding:1rem;color:var(--muted)">No permits yet. Click “+ New permit” to add one.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
async function post(url, body){ const r = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) }); return r.json(); }
async function saveCell(el){ const tr = el.closest('tr'); const d = await post('/permits/' + tr.dataset.id + '/cell', { col: el.dataset.col, value: el.value }); if (d.ok) flash(el); }
async function saveStatus(sel){
  const tr = sel.closest('tr'); const opt = sel.options[sel.selectedIndex]; const hex = (opt && opt.dataset.hex) || '';
  sel.style.background = sel.value ? hex : ''; sel.classList.toggle('empty', !sel.value);
  await post('/permits/' + tr.dataset.id + '/cell', { col: sel.dataset.col, value: sel.value });
}
async function delPermit(id){ if (!confirm('Delete this permit?')) return; const d = await post('/permits/' + id + '/delete', {}); if (d.ok) { var r = document.querySelector('tr[data-id="' + id + '"]'); if (r) r.remove(); } }
function flash(el){ var c = el.tagName === 'INPUT' ? el : el; c.style.transition = 'background .1s'; c.style.background = '#d7f7e0'; setTimeout(function(){ c.style.background = 'transparent'; }, 400); }
</script>
</body>
</html>
